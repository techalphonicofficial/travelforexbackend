<%
  const money = value => Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const typeLabel = value => {
    const match = (voucherTypes || []).find(item => item.value === value);
    return match ? match.label : String(value || '').replace(/_/g, ' ');
  };
  const statusStyle = status => {
    if (status === 'posted') return 'background:#dcfce7;color:#166534;';
    if (status === 'draft') return 'background:#eef2ff;color:#3730a3;';
    if (status === 'cancelled') return 'background:#fee2e2;color:#991b1b;';
    return 'background:#f1f5f9;color:#334155;';
  };
  const entry = voucher.journalEntry || null;
  const lines = entry && entry.lines ? entry.lines : [];
  const totalDebit = lines.reduce((sum, line) => sum + Number(line.debit || 0), 0);
  const totalCredit = lines.reduce((sum, line) => sum + Number(line.credit || 0), 0);
%>

<style>
  .acc-nav{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.6rem;}
  .acc-nav a{display:inline-flex;align-items:center;gap:.4rem;padding:.42rem 1rem;border-radius:10px;font-size:.82rem;font-weight:600;text-decoration:none;background:#fff;color:#4f46e5;border:1.5px solid rgba(79,70,229,.2);box-shadow:0 2px 8px rgba(79,70,229,.07);transition:all .15s;}
  .acc-nav a:hover,.acc-nav a.active{background:#4f46e5;color:#fff;border-color:#4f46e5;box-shadow:0 4px 14px rgba(79,70,229,.3);}
  .acc-page-hdr{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.4rem;}
  .acc-page-title{font-size:1.3rem;font-weight:800;color:#1e1b4b;display:flex;align-items:center;gap:.5rem;}
  .acc-page-title i{color:#4f46e5;}
  .acc-panel{background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(79,70,229,.07);overflow:hidden;margin-bottom:1rem;}
  .vd-head{padding:1.2rem 1.3rem;border-bottom:1px solid #eef2ff;display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
  .vd-no{font-size:1.4rem;font-weight:900;color:#1e1b4b;}
  .vd-muted{font-size:.78rem;color:#64748b;margin-top:.2rem;}
  .vd-badge{display:inline-flex;align-items:center;gap:.35rem;border-radius:999px;padding:.2rem .65rem;font-size:.73rem;font-weight:800;text-transform:capitalize;}
  .vd-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1px;background:#eef2ff;}
  .vd-cell{background:#fff;padding:1rem;}
  .vd-label{font-size:.72rem;font-weight:800;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:.35rem;}
  .vd-value{font-size:.92rem;font-weight:800;color:#111827;word-break:break-word;}
  .vd-table{width:100%;border-collapse:collapse;}
  .vd-table thead tr{background:linear-gradient(90deg,#f0f0fa,#e8e8f5);}
  .vd-table th{padding:.75rem 1rem;font-size:.73rem;font-weight:800;text-transform:uppercase;letter-spacing:.05em;color:#5555aa;}
  .vd-table td{padding:.75rem 1rem;border-bottom:1px solid #f4f4fb;font-size:.86rem;color:#334155;}
  .vd-dr{color:#059669;font-weight:800;}
  .vd-cr{color:#dc2626;font-weight:800;}
  @media (max-width: 900px){.vd-grid{grid-template-columns:repeat(2,minmax(0,1fr));}}
  @media (max-width: 560px){.vd-grid{grid-template-columns:1fr;}}
</style>

<div class="acc-nav">
  <a href="/accounting/dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
  <a href="/accounting/vouchers" class="active"><i class="bi bi-receipt-cutoff"></i> Vouchers</a>
  <a href="/accounting/ledger"><i class="bi bi-journal-text"></i> General Ledger</a>
  <a href="/accounting/accounts"><i class="bi bi-list-columns-reverse"></i> Chart of Accounts</a>
  <a href="/accounting/trial-balance"><i class="bi bi-scale"></i> Trial Balance</a>
  <a href="/accounting/pnl"><i class="bi bi-graph-up-arrow"></i> P&amp;L Statement</a>
  <a href="/accounting/vouchers/new"><i class="bi bi-pencil-square"></i> New Voucher</a>
</div>

<div class="acc-page-hdr">
  <div class="acc-page-title"><i class="bi bi-receipt"></i> Voucher Detail</div>
  <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
    <a href="/accounting/vouchers" class="btn btn-light border"><i class="bi bi-arrow-left"></i> Back</a>
    <button type="button" class="btn btn-outline-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
  </div>
</div>

<div class="acc-panel">
  <div class="vd-head">
    <div>
      <div class="vd-no"><%= voucher.voucher_no %></div>
      <div class="vd-muted"><%= typeLabel(voucher.voucher_type) %> · FY <%= voucher.financial_year %></div>
    </div>
    <div style="display:flex;align-items:flex-start;gap:.5rem;flex-wrap:wrap;">
      <span class="vd-badge" style="<%= statusStyle(voucher.status) %>"><%= voucher.status %></span>
      <span class="vd-badge" style="background:#eef2ff;color:#3730a3;"><%= new Date(voucher.voucher_date).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></span>
    </div>
  </div>

  <div class="vd-grid">
    <div class="vd-cell">
      <div class="vd-label">Amount</div>
      <div class="vd-value">INR <%= money(voucher.total_amount) %></div>
    </div>
    <div class="vd-cell">
      <div class="vd-label">Reference Type</div>
      <div class="vd-value"><%= voucher.reference_type || '-' %></div>
    </div>
    <div class="vd-cell">
      <div class="vd-label">Reference ID</div>
      <div class="vd-value"><%= voucher.reference_id || '-' %></div>
    </div>
    <div class="vd-cell">
      <div class="vd-label">Party</div>
      <div class="vd-value"><%= voucher.party_type || '-' %><% if(voucher.party_id) { %> / <%= voucher.party_id %><% } %></div>
    </div>
  </div>

  <div style="padding:1rem 1.3rem;">
    <div class="vd-label">Narration</div>
    <div style="font-size:.92rem;color:#334155;font-weight:600;"><%= voucher.narration || '-' %></div>
  </div>
</div>

<div class="acc-panel">
  <div style="padding:1rem 1.3rem;border-bottom:1px solid #eef2ff;display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
    <div style="font-weight:900;color:#1e1b4b;"><i class="bi bi-journal-text me-1"></i> Journal Lines</div>
    <% if(entry) { %>
      <div style="font-size:.78rem;color:#64748b;font-weight:700;">Journal <%= String(entry.id).slice(0, 8).toUpperCase() %></div>
    <% } %>
  </div>
  <div style="overflow-x:auto;">
    <table class="vd-table">
      <thead>
        <tr>
          <th>Account</th>
          <th>Memo</th>
          <th class="text-end">Debit</th>
          <th class="text-end">Credit</th>
        </tr>
      </thead>
      <tbody>
        <% if(lines.length) { %>
          <% lines.forEach(line => { %>
            <tr>
              <td>
                <div style="font-weight:800;color:#111827;"><%= line.account ? `${line.account.code} · ${line.account.name}` : line.account_id %></div>
              </td>
              <td><%= line.memo || '-' %></td>
              <td class="text-end vd-dr"><%= Number(line.debit || 0) > 0 ? 'INR ' + money(line.debit) : '-' %></td>
              <td class="text-end vd-cr"><%= Number(line.credit || 0) > 0 ? 'INR ' + money(line.credit) : '-' %></td>
            </tr>
          <% }) %>
          <tr>
            <td colspan="2" style="font-weight:900;color:#1e1b4b;">Total</td>
            <td class="text-end vd-dr">INR <%= money(totalDebit) %></td>
            <td class="text-end vd-cr">INR <%= money(totalCredit) %></td>
          </tr>
        <% } else { %>
          <tr>
            <td colspan="4" style="text-align:center;padding:2.5rem;color:#8888bb;">No journal lines linked to this voucher.</td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
