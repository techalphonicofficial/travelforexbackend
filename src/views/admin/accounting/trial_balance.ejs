<style>
  .acc-nav{display:flex;gap:.6rem;flex-wrap:wrap;margin-bottom:1.6rem;}
  .acc-nav a{display:inline-flex;align-items:center;gap:.4rem;padding:.42rem 1rem;border-radius:10px;font-size:.82rem;font-weight:600;text-decoration:none;background:#fff;color:#4f46e5;border:1.5px solid rgba(79,70,229,.2);box-shadow:0 2px 8px rgba(79,70,229,.07);transition:all .15s;}
  .acc-nav a:hover,.acc-nav a.active{background:#4f46e5;color:#fff;border-color:#4f46e5;}
  .acc-page-hdr{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.4rem;}
  .acc-page-title{font-size:1.3rem;font-weight:800;color:#1e1b4b;display:flex;align-items:center;gap:.5rem;}
  .acc-page-title i{color:#4f46e5;}
  .acc-panel{background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(79,70,229,.07);overflow:hidden;}
  .tb-table{width:100%;border-collapse:collapse;}
  .tb-table thead tr{background:linear-gradient(90deg,#f0f0fa,#e8e8f5);}
  .tb-table thead th{padding:.75rem 1.1rem;font-size:.73rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:#5555aa;border:0;}
  .tb-table tbody tr{border-bottom:1px solid #f4f4fb;transition:background .12s;}
  .tb-table tbody tr:hover{background:#fafafe;}
  .tb-table tbody td{padding:.72rem 1.1rem;font-size:.84rem;color:#333;vertical-align:middle;}
  .tb-table tfoot tr{background:linear-gradient(90deg,#1e1b4b,#312e81);color:#fff;}
  .tb-table tfoot td{padding:.85rem 1.1rem;font-size:.9rem;font-weight:700;}
  .tb-dr{color:#059669;font-weight:700;}
  .tb-cr{color:#dc2626;font-weight:700;}
  .tb-zero{color:#ccc;}
  .tb-code{font-family:monospace;font-size:.79rem;font-weight:700;color:#4f46e5;background:#eef2ff;padding:2px 7px;border-radius:5px;}
  .tb-type-badge{font-size:.68rem;font-weight:700;padding:1px 8px;border-radius:20px;text-transform:uppercase;}
  .bal-chip{display:inline-flex;align-items:center;gap:.4rem;padding:.4rem 1rem;border-radius:10px;font-size:.85rem;font-weight:700;}
</style>

<div class="acc-nav">
  <a href="/accounting/dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
  <a href="/accounting/vouchers"><i class="bi bi-receipt-cutoff"></i> Vouchers</a>
  <a href="/accounting/ledger"><i class="bi bi-journal-text"></i> General Ledger</a>
  <a href="/accounting/accounts"><i class="bi bi-list-columns-reverse"></i> Chart of Accounts</a>
  <a href="/accounting/trial-balance" class="active"><i class="bi bi-scale"></i> Trial Balance</a>
  <a href="/accounting/pnl"><i class="bi bi-graph-up-arrow"></i> P&amp;L Statement</a>
  <a href="/accounting/vouchers/new"><i class="bi bi-pencil-square"></i> New Voucher</a>
</div>

<div class="acc-page-hdr">
  <div class="acc-page-title"><i class="bi bi-scale"></i> Trial Balance</div>
  <div style="display:flex;align-items:center;gap:.7rem;flex-wrap:wrap;">
    <% if(isBalanced) { %>
      <span class="bal-chip" style="background:#ecfdf5;color:#059669;"><i class="bi bi-check-circle-fill"></i> Balanced ✓</span>
    <% } else { %>
      <span class="bal-chip" style="background:#fef2f2;color:#dc2626;"><i class="bi bi-exclamation-triangle-fill"></i> Out of Balance!</span>
    <% } %>
    <span style="font-size:.8rem;color:#8888bb;">As of <%= new Date().toLocaleDateString('en-IN',{day:'2-digit',month:'long',year:'numeric'}) %></span>
  </div>
</div>

<div class="acc-panel">
  <table class="tb-table">
    <thead>
      <tr>
        <th>Code</th>
        <th>Account Name</th>
        <th>Type</th>
        <th class="text-end">Total Debit (₹)</th>
        <th class="text-end" style="padding-right:1.2rem;">Total Credit (₹)</th>
      </tr>
    </thead>
    <tbody>
      <%
        const typeColors = {
          asset:'#4f46e5', liability:'#ef4444', equity:'#8b5cf6', revenue:'#10b981', expense:'#f59e0b'
        };
      %>
      <% rows.forEach(row => { %>
      <tr>
        <td><span class="tb-code"><%= row.code %></span></td>
        <td style="font-weight:600;color:#1e1b4b;"><%= row.name %></td>
        <td>
          <span class="tb-type-badge" style="background:rgba(79,70,229,.08);color:<%= typeColors[row.type]||'#4f46e5' %>;">
            <%= row.type %>
          </span>
        </td>
        <td class="text-end">
          <% const dr = parseFloat(row.total_debit); %>
          <span class="<%= dr>0?'tb-dr':'tb-zero' %>">
            <%= dr>0 ? '₹'+dr.toLocaleString('en-IN',{minimumFractionDigits:2}) : '—' %>
          </span>
        </td>
        <td class="text-end" style="padding-right:1.2rem;">
          <% const cr = parseFloat(row.total_credit); %>
          <span class="<%= cr>0?'tb-cr':'tb-zero' %>">
            <%= cr>0 ? '₹'+cr.toLocaleString('en-IN',{minimumFractionDigits:2}) : '—' %>
          </span>
        </td>
      </tr>
      <% }) %>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3" style="font-weight:700;font-size:.88rem;">TOTALS</td>
        <td class="text-end" style="font-size:.95rem;">₹<%= Number(totalDebit).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
        <td class="text-end" style="padding-right:1.2rem;font-size:.95rem;">₹<%= Number(totalCredit).toLocaleString('en-IN',{minimumFractionDigits:2}) %></td>
      </tr>
    </tfoot>
  </table>
</div>

<div style="font-size:.75rem;color:#8888bb;margin-top:.6rem;text-align:right;">
  <i class="bi bi-info-circle"></i>
  In double-entry accounting, total debits must always equal total credits.
</div>
