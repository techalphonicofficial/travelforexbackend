<%
  const roundMoney = (value) => {
    const amount = Number(value || 0);
    return Number.isFinite(amount) ? Math.round(amount * 100) / 100 : 0;
  };
  const money = (value) => Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const clampPercent = (value) => Math.min(Math.max(roundMoney(value), 0), 100);
  const percentLabel = (value) => clampPercent(value).toLocaleString('en-IN', { maximumFractionDigits: 2 });
  const ruleReturnPercent = (rule = {}) => {
    if (rule.return_percentage !== undefined) return clampPercent(rule.return_percentage);
    if (rule.refundable_percentage !== undefined) return clampPercent(rule.refundable_percentage);
    const refundPercent = clampPercent(rule.refund_percentage);
    return refundPercent > 0 ? refundPercent : clampPercent(rule.cancellation_percentage);
  };
  const displayRequestAmounts = (request = {}) => {
    const booking = request.booking || {};
    const rule = request.cancellation_rule_snapshot || {};
    const hasRule = rule.return_percentage !== undefined
      || rule.refundable_percentage !== undefined
      || rule.refund_percentage !== undefined
      || rule.cancellation_percentage !== undefined;
    const pendingRule = request.status === 'pending' && hasRule;
    const paid = roundMoney(booking.paid_amount);
    const remaining = roundMoney(booking.remaining_amount);
    const returnPercent = ruleReturnPercent(rule);
    const refundAmount = pendingRule ? roundMoney(paid * returnPercent / 100) : roundMoney(request.requested_refund_amount);
    const cancelRemainingAmount = pendingRule ? remaining : roundMoney(request.requested_cancel_remaining_amount);
    const retainedAmount = pendingRule
      ? roundMoney(Math.max(paid - refundAmount, 0))
      : roundMoney((request.settlement_snapshot || {}).retained_amount);

    return {
      refundAmount,
      cancelRemainingAmount,
      retainedAmount,
      total: roundMoney(refundAmount + cancelRemainingAmount),
      returnPercent,
      retainedPercent: clampPercent(100 - returnPercent),
      hasRule
    };
  };
  const dateLabel = (value) => {
    if (!value) return '';
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? '' : date.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
  };
  const statusStyle = {
    pending: 'background:#fef3c7;color:#92400e;',
    approved: 'background:#dcfce7;color:#166534;',
    rejected: 'background:#fee2e2;color:#991b1b;'
  };
%>

<style>
  .rr-page { padding: 6px 0 32px; }
  .rr-title { font-size: 1.8rem; font-weight: 900; color:#07123a; margin:0; }
  .rr-sub { color:#556987; margin-top:4px; }
  .rr-tabs { display:flex; gap:8px; flex-wrap:wrap; margin:18px 0; }
  .rr-tab { border:1px solid #d8e1f2; background:#fff; color:#334155; border-radius:8px; padding:8px 12px; font-weight:800; font-size:.86rem; text-decoration:none; }
  .rr-tab.active { border-color:#4f46e5; color:#4338ca; background:#eef2ff; }
  .rr-filter { display:grid; grid-template-columns:1fr 160px 130px auto; gap:10px; background:#fff; border:1px solid #d8e1f2; border-radius:8px; padding:14px; margin-bottom:16px; }
  .rr-input { border:1px solid #d8e1f2; border-radius:8px; min-height:42px; padding:0 12px; color:#0f172a; background:#fff; }
  .rr-btn { border:1px solid transparent; border-radius:8px; min-height:38px; padding:0 12px; font-weight:800; cursor:pointer; display:inline-flex; align-items:center; justify-content:center; gap:6px; text-decoration:none; }
  .rr-btn-primary { background:#4f46e5; color:#fff; }
  .rr-btn-soft { background:#eef2ff; color:#4338ca; border-color:#c7d2fe; }
  .rr-btn-approve { background:#dcfce7; color:#166534; border-color:#86efac; }
  .rr-btn-reject { background:#fee2e2; color:#991b1b; border-color:#fecaca; }
  .rr-card { background:#fff; border:1px solid #d8e1f2; border-radius:8px; overflow:hidden; }
  .rr-table { width:100%; border-collapse:collapse; }
  .rr-table th { background:#f8fafc; color:#334155; font-size:.75rem; letter-spacing:.04em; text-transform:uppercase; padding:12px; text-align:left; border-bottom:1px solid #d8e1f2; }
  .rr-table td { padding:14px 12px; border-bottom:1px solid #eef2f7; vertical-align:top; color:#0f172a; }
  .rr-main { font-weight:900; color:#07123a; }
  .rr-muted { color:#60708a; font-size:.84rem; margin-top:3px; }
  .rr-badge { display:inline-flex; align-items:center; border-radius:999px; padding:5px 10px; font-size:.76rem; font-weight:900; }
  .rr-actions { display:grid; gap:8px; min-width:220px; }
  .rr-action-form { display:grid; grid-template-columns:1fr auto; gap:6px; }
  .rr-alert { border-radius:8px; padding:10px 12px; margin-bottom:12px; font-weight:800; }
  .rr-alert-success { background:#dcfce7; color:#166534; }
  .rr-alert-error { background:#fee2e2; color:#991b1b; }
  .rr-empty { padding:28px; text-align:center; color:#64748b; }
  .rr-pagination { display:flex; justify-content:flex-end; gap:8px; margin-top:14px; }
  @media (max-width: 900px) {
    .rr-filter { grid-template-columns:1fr; }
    .rr-table { min-width:980px; }
    .rr-card { overflow-x:auto; }
  }
</style>

<div class="rr-page">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
    <div>
      <h1 class="rr-title">Package Cancel Requests</h1>
      <div class="rr-sub">Customer package cancellation / return requests awaiting admin action.</div>
    </div>
    <a class="rr-btn rr-btn-soft" href="/admin/bookings/package-bookings"><i class="bi bi-suitcase-lg"></i> Package Bookings</a>
  </div>

  <% if (successMessage) { %>
    <div class="rr-alert rr-alert-success"><%= successMessage %></div>
  <% } %>
  <% if (errorMessage) { %>
    <div class="rr-alert rr-alert-error"><%= errorMessage %></div>
  <% } %>

  <div class="rr-tabs">
    <% statuses.forEach(item => { %>
      <a class="rr-tab <%= statusFilter === item ? 'active' : '' %>" href="/admin/bookings/return-requests?status=<%= item %>&limit=<%= limit %>">
        <%= item.charAt(0).toUpperCase() + item.slice(1) %> <%= statusCounts[item] || 0 %>
      </a>
    <% }) %>
  </div>

  <form class="rr-filter" method="GET" action="/admin/bookings/return-requests">
    <input class="rr-input" type="text" name="search" value="<%= searchQuery %>" placeholder="Search booking ref, customer, phone, email or reason">
    <select class="rr-input" name="status">
      <% statuses.forEach(item => { %>
        <option value="<%= item %>" <%= statusFilter === item ? 'selected' : '' %>><%= item.charAt(0).toUpperCase() + item.slice(1) %></option>
      <% }) %>
    </select>
    <select class="rr-input" name="limit">
      <% limitOptions.forEach(item => { %>
        <option value="<%= item %>" <%= Number(limit) === Number(item) ? 'selected' : '' %>><%= item %> / page</option>
      <% }) %>
    </select>
    <button class="rr-btn rr-btn-primary" type="submit"><i class="bi bi-search"></i> Search</button>
  </form>

  <div class="rr-card">
    <% if (requests.length > 0) { %>
      <table class="rr-table">
        <thead>
          <tr>
            <th>Request</th>
            <th>Customer</th>
            <th>Booking</th>
            <th>Requested Amount</th>
            <th>Reason / Rule</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% requests.forEach(request => {
            const booking = request.booking || {};
            const rule = request.cancellation_rule_snapshot || {};
            const requestAmounts = displayRequestAmounts(request);
          %>
            <tr>
              <td>
                <div class="rr-main"><%= request.booking_reference || booking.booking_reference || 'Request' %></div>
                <div class="rr-muted">Created <%= dateLabel(request.created_at) %></div>
                <% if (request.departure_date) { %>
                  <div class="rr-muted">Departure <%= dateLabel(request.departure_date) %></div>
                <% } %>
              </td>
              <td>
                <div class="rr-main"><%= request.customer_name || 'Guest customer' %></div>
                <div class="rr-muted"><%= request.customer_email || 'No email' %></div>
                <div class="rr-muted"><%= request.customer_phone || 'No phone' %></div>
              </td>
              <td>
                <div class="rr-main"><%= booking.package_name || 'Package booking' %></div>
                <div class="rr-muted">Total INR <%= money(booking.package_total) %></div>
                <div class="rr-muted">Paid INR <%= money(booking.paid_amount) %> / Remaining INR <%= money(booking.remaining_amount) %></div>
              </td>
              <td>
                <div class="rr-main">INR <%= money(requestAmounts.total) %></div>
                <div class="rr-muted">Refund INR <%= money(requestAmounts.refundAmount) %></div>
                <div class="rr-muted">Retained INR <%= money(requestAmounts.retainedAmount) %></div>
                <div class="rr-muted">Cancel remaining INR <%= money(requestAmounts.cancelRemainingAmount) %></div>
              </td>
              <td>
                <div class="rr-main"><%= request.reason || 'No reason added' %></div>
                <% if (requestAmounts.hasRule) { %>
                  <div class="rr-muted">Rule: <%= percentLabel(requestAmounts.returnPercent) %>% refund / <%= percentLabel(requestAmounts.retainedPercent) %>% retained</div>
                <% } %>
              </td>
              <td>
                <span class="rr-badge" style="<%= statusStyle[request.status] || 'background:#eef2ff;color:#4338ca;' %>"><%= request.status %></span>
                <% if (request.approved_at) { %><div class="rr-muted">Approved <%= dateLabel(request.approved_at) %></div><% } %>
                <% if (request.rejected_at) { %><div class="rr-muted">Rejected <%= dateLabel(request.rejected_at) %></div><% } %>
              </td>
              <td>
                <div class="rr-actions">
                  <a class="rr-btn rr-btn-soft" href="/admin/bookings/package-bookings?search=<%= encodeURIComponent(request.booking_reference || booking.booking_reference || '') %>">
                    <i class="bi bi-eye"></i> View Booking
                  </a>
                  <% if (request.status === 'pending' && canProcessPackageRefund) { %>
                    <form class="rr-action-form" method="POST" action="/admin/bookings/return-requests/<%= request.id %>/approve" onsubmit="return confirm('Approve and settle this cancel request?');">
                      <input class="rr-input" type="text" name="refund_reference" placeholder="Refund ref">
                      <button class="rr-btn rr-btn-approve" type="submit"><i class="bi bi-check-circle"></i> Approve</button>
                    </form>
                    <form class="rr-action-form" method="POST" action="/admin/bookings/return-requests/<%= request.id %>/reject" onsubmit="return confirm('Reject this cancel request?');">
                      <input class="rr-input" type="text" name="admin_notes" placeholder="Reject note">
                      <button class="rr-btn rr-btn-reject" type="submit"><i class="bi bi-x-circle"></i> Reject</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="rr-empty">
        <div class="rr-main">No package cancel requests found</div>
        <div class="rr-muted">New customer cancellation requests will appear here.</div>
      </div>
    <% } %>
  </div>

  <div class="rr-pagination">
    <% if (currentPage > 1) { %>
      <a class="rr-btn rr-btn-soft" href="?page=<%= currentPage - 1 %>&limit=<%= limit %>&status=<%= statusFilter %>&search=<%= encodeURIComponent(searchQuery) %>">Previous</a>
    <% } %>
    <span class="rr-btn rr-btn-soft">Page <%= currentPage %> of <%= totalPages %></span>
    <% if (currentPage < totalPages) { %>
      <a class="rr-btn rr-btn-soft" href="?page=<%= currentPage + 1 %>&limit=<%= limit %>&status=<%= statusFilter %>&search=<%= encodeURIComponent(searchQuery) %>">Next</a>
    <% } %>
  </div>
</div>
