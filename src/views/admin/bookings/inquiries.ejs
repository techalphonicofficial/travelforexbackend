    color: #1e1b4b;
    box-shadow: 0 2px 8px rgba(79, 70, 229, 0.12);
  }

  .inquiry-create-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 10px;
    background: #4f46e5;
    color: #fff;
    padding: 0.68rem 1rem;
    font-size: 0.88rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 8px 20px rgba(79, 70, 229, 0.22);
  }

  .inquiry-create-btn:hover {
    background: #4338ca;
    color: #fff;
  }

  .inquiry-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.8rem;
  }

  .inquiry-stat {
    background: #fff;
    border: 1px solid #eef2ff;
    border-radius: 12px;
    padding: 0.95rem 1rem;
    box-shadow: 0 4px 16px rgba(79, 70, 229, 0.06);
  }

  .inquiry-stat-label {
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .inquiry-stat-value {
    color: #111827;
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1;
    margin-top: 0.4rem;
  }

  .inquiry-toolbar {
    background: #fff;
    border: 1px solid #eef2ff;
    border-radius: 12px;
    padding: 0.9rem;
    box-shadow: 0 4px 16px rgba(79, 70, 229, 0.06);
  }

  .inquiry-toolbar form {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin: 0;
  }

  .inquiry-search {
    position: relative;
    min-width: min(320px, 100%);
  }

  .inquiry-search i {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
  }

  .inquiry-search input {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.58rem 0.75rem 0.58rem 2.2rem;
    outline: none;
  }

  .inquiry-select {
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.58rem 0.75rem;
    background: #fff;
    color: #334155;
  }

  .inquiry-btn {
    border: 0;
    border-radius: 10px;
    background: #4f46e5;
    color: #fff;
    padding: 0.62rem 1rem;
    font-weight: 700;
  }

  .inquiry-table-wrap {
    background: #fff;
    border: 1px solid #eef2ff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(79, 70, 229, 0.07);
  }

  .inquiry-table {
    width: 100%;
    border-collapse: collapse;
  }

  .inquiry-table th {
    background: #f8fafc;
    color: #475569;
    font-size: 0.74rem;
