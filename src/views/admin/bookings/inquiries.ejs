<%- contentFor('body') %>

<%
const statuses = ['new', 'contacted', 'quoted', 'converted', 'cancelled'];
const statusStyle = {
  new: 'background:#e0f2fe;color:#0369a1;',
  contacted: 'background:#eef2ff;color:#4f46e5;',
  quoted: 'background:#fef3c7;color:#92400e;',
  converted: 'background:#dcfce7;color:#166534;',
  cancelled: 'background:#fee2e2;color:#991b1b;'
};
const totalPagesSafe = Math.max(1, totalPages || 1);
const selectedLimit = limit || 10;
const startItem = totalInquiries ? ((currentPage - 1) * selectedLimit) + 1 : 0;
const endItem = Math.min(currentPage * selectedLimit, totalInquiries || 0);
const pageItems = [];
for (let pageNo = 1; pageNo <= totalPagesSafe; pageNo++) {
  if (pageNo === 1 || pageNo === totalPagesSafe || Math.abs(pageNo - currentPage) <= 1) {
    pageItems.push(pageNo);
  } else if (pageItems[pageItems.length - 1] !== '...') {
    pageItems.push('...');
  }
}
const pageUrl = (pageNo) => `/admin/bookings/inquiries?page=${pageNo}&limit=${selectedLimit}&search=${encodeURIComponent(searchQuery || '')}&status=${encodeURIComponent(statusFilter || '')}`;
const getRoomCount = (inquiry) => {
  if (inquiry && inquiry.raw_payload && inquiry.raw_payload.room_count) return parseInt(inquiry.raw_payload.room_count, 10) || 0;
  const rooms = Array.isArray(inquiry.rooms) ? inquiry.rooms : [];
  return rooms.reduce((sum, room) => sum + (parseInt(room.room_count, 10) || 1), 0);
};
%>

<style>
  .inquiry-shell {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .inquiry-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .inquiry-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #111827;
    margin: 0;
  }

  .inquiry-muted {
    color: #64748b;
    font-size: 0.88rem;
    margin: 0.15rem 0 0;
  }

  .booking-tabs {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #eef2ff;
    padding: 0.28rem;
    border-radius: 10px;
  }

  .booking-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.48rem 0.85rem;
    color: #4f46e5;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.86rem;
    font-weight: 700;
  }

  .booking-tab.active {
