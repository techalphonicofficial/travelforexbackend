    const pkg = quote.package || {};
    const amounts = quote.amounts || {};
    const hotels = Array.isArray(quote.hotels) ? quote.hotels : [];
    const route = Array.isArray(quote.route) && quote.route.length ? quote.route.join(' to ') : 'No route added';
    const inclusions = Array.isArray(quote.inclusions) ? quote.inclusions : [];
    const exclusions = Array.isArray(quote.exclusions) ? quote.exclusions : [];
    const preview = document.getElementById('packagePreview');
    const hotelsHtml = hotels.length ? `
        <details class="preview-disclosure">
            <summary><span><i class="fas fa-hotel text-primary mr-2"></i>Hotels included</span><span class="badge badge-light">${hotels.length}</span></summary>
            <div class="preview-disclosure-body">
                <div class="hotel-preview-list compact">
                    ${hotels.map(hotel => `
