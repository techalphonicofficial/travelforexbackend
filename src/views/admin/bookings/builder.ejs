async function updateDayDestination(dayId, destId) {
    try {
        const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/id/${dayId}/destination`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ destination_id: destId })
        });
        const data = await res.json();
        if(data.success) {
            // Update local state
            const dayIdx = currentTrip.days.findIndex(d => d.id === dayId);
            if (dayIdx !== -1) currentTrip.days[dayIdx].destination_id = destId;
        } else {
            console.error("Failed to update destination");
        }
    } catch (e) {
        console.error("Error updating destination", e);
    }
}

async function updateDayDesc(dayId, text) {
    try {
        const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/id/${dayId}/description`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: text })
        });
        const data = await res.json();
        if(!data.success) {
            console.error("Failed to update description");
        }
    } catch (e) {
        console.error("Error updating description", e);
    }
}

async function removeActivity(dayNumber, activityId) {
    const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/${dayNumber}/activities/${activityId}`, {
        method: 'DELETE'
    });
    const data = await res.json();
    if(data.success) { currentTrip = data.data; renderItinerary(); }
}

function recalculateManualTotal() {
    const inputs = document.querySelectorAll('.manual-dest-price');
    let base_price = 0;
    let taxBreakdownObj = {};
    let total_tax = 0;
    const companyState = 'Delhi'; // Fallback state
    const autoPricedInputs = inputs.length > 0 && Array.from(inputs).every(input => input.dataset.autoPriced === '1');
    const tripTotal = parseFloat(currentTrip?.total_price || 0);
    const tripBase = parseFloat(currentTrip?.base_price || 0);
    const tripTax = parseFloat(currentTrip?.total_tax || 0);

    inputs.forEach(input => {
        const amount = parseFloat(input.value) || 0;
        base_price += amount;
        
        const destId = input.getAttribute('data-dest-id');
        const destObj = window.selectedDestinations.find(d => d.id == destId);
        
        if (destObj && amount > 0) {
            const rule = destObj.tax_rule || 'domestic';
            let taxAmt = 0;
            if (destObj.gst_amount > 0) {
                taxAmt = destObj.gst_amount;
            } else if (destObj.gst_rate > 0) {
                taxAmt = (amount * destObj.gst_rate) / 100;
            }

            if (rule === 'domestic') {
                if (taxAmt > 0) {
                    // Mock intra vs inter state
                    if (destObj.state && destObj.state.toLowerCase() === companyState.toLowerCase()) {
                        const half = taxAmt / 2;
                        const sgstKey = `SGST (${destObj.name})`;
                        const cgstKey = `CGST (${destObj.name})`;
                        taxBreakdownObj[sgstKey] = (taxBreakdownObj[sgstKey] || 0) + half;
                        taxBreakdownObj[cgstKey] = (taxBreakdownObj[cgstKey] || 0) + half;
                    } else {
                        const igstKey = `IGST (${destObj.name})`;
                        taxBreakdownObj[igstKey] = (taxBreakdownObj[igstKey] || 0) + taxAmt;
                    }
                    total_tax += taxAmt;
                }
            } else if (rule === 'international_outbound') {
                // Apply GST if configured (TCS removed)
                if (taxAmt > 0) {
                    const gstKey = `IGST (${destObj.name})`;
                    taxBreakdownObj[gstKey] = (taxBreakdownObj[gstKey] || 0) + taxAmt;
                    total_tax += taxAmt;
                }
            }
        }
    });
    
    // Update display (if no inputs exist, fallback to currentTrip.total_price)
    if (inputs.length === 0) {
        base_price = parseFloat(currentTrip.total_price || 0);
        // Note: Without inputs, we can't easily calculate accurate tax live on UI, we rely on backend
    }
    
    let grand_total = base_price + total_tax;
    window.useTripAmountFallback = false;

    if (autoPricedInputs && tripTotal > 0) {
        base_price = tripBase || Math.max(tripTotal - tripTax, 0);
        total_tax = tripTax || Math.max(tripTotal - base_price, 0);
        grand_total = tripTotal;
        taxBreakdownObj = currentTrip?.tax_breakdown || {};
        window.useTripAmountFallback = true;
    }
    
    // Render tax breakdown HTML
    const taxContainer = document.getElementById('liveTaxBreakdownContainer');
    if (taxContainer && Object.keys(taxBreakdownObj).length > 0) {
        let taxHtml = '<hr><h6 class="text-muted mb-2" style="font-size: 0.85rem;">Taxes & Levies:</h6><ul class="list-unstyled mb-0" style="font-size: 0.85rem; color:#d97706;">';
        for (const [key, amt] of Object.entries(taxBreakdownObj)) {
            const displayAmount = Number(amt || 0);
            taxHtml += `<li class="d-flex justify-content-between mb-1"><span>${key}</span> <span>₹${displayAmount.toLocaleString('en-IN', {minimumFractionDigits: 2})}</span></li>`;
        }
        taxHtml += '</ul><hr>';
        taxContainer.innerHTML = taxHtml;
    } else if (taxContainer) {
        taxContainer.innerHTML = '';
    }
    
    document.getElementById('livePrice').innerText = '₹' + grand_total.toLocaleString('en-IN', {minimumFractionDigits: 2});
    document.getElementById('btnConfirmBooking').disabled = grand_total <= 0;
    
    // Store in global var for checkout
    window.finalManualPrice = grand_total;
    window.manualDestBreakdown = Array.from(inputs).map(inp => ({
        destId: inp.getAttribute('data-dest-id'),
        amount: parseFloat(inp.value) || 0
    }));
}

document.getElementById('btnConfirmBooking').addEventListener('click', confirmBooking);

async function confirmBooking() {
    try {
        const btn = document.getElementById('btnConfirmBooking');
        const selections = getBookingSelections();
        if (!selections.customerId) {
            alert('Please select a customer.');
            return;
        }
        if (!selections.packageId) {
            alert('Please select a package.');
            return;
        }
        if (!currentPackageQuote) {
            await fetchPackageQuote(false);
        }
        if (!currentPackageQuote) {
            alert('Please fetch package details before confirming.');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Confirming...';

        const payload = {
            customer_id: selections.customerId,
            package_id: selections.packageId,
            adults: selections.adults,
            payment_mode: selections.paymentMode,
            inquiry_id: selections.inquiryId,
            passengers: Array.from(document.querySelectorAll('.passenger-form')).map((form, index) => ({
                full_name: form.querySelector('.p-full-name').value.trim(),
                age: form.querySelector('.p-age').value.trim(),
                gender: form.querySelector('.p-gender').value,
                dob: form.querySelector('.p-dob').value,
                passport_no: form.querySelector('.p-passport').value.trim(),
                passport_expiry: form.querySelector('.p-expiry').value,
                is_lead: index === 0
            }))
        };
        const res = await fetch('/admin/bookings/api/package-bookings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if(data.success) {
            document.getElementById('tripStatus').innerHTML = '<span class="text-success font-weight-bold">Confirmed</span>';
            const msg = data.packageBookingReference
                ? `Package Booking ${data.packageBookingReference} Created! Redirecting...`
                : 'Booking Created! Redirecting...';
            document.getElementById('checkoutMessage').innerHTML = `<span class="text-success"><i class="fas fa-check"></i> ${msg}</span>`;
            setTimeout(() => { window.location.href = data.redirectUrl || '/admin/bookings/package-bookings'; }, 1500);
        } else {
            alert(data.message);
            setConfirmButtonState();
            btn.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Confirm Booking';
        }
    } catch(err) {
        alert("Error during checkout");
        setConfirmButtonState();
        document.getElementById('btnConfirmBooking').innerHTML = '<i class="fas fa-check-circle mr-2"></i> Confirm Booking';
    }
}
</script>
