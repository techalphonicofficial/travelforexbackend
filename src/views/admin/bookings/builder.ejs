                <div class="package-preview-item">
                    <span>Hotels Included</span>
                    <strong>${Number(amounts.hotel_count || 0)}</strong>
                </div>
                <div class="package-preview-item">
                    <span>Payment Mode</span>
                    <strong>${quote.partial_booking?.enabled ? `Partial ${Number(quote.partial_booking.percentage || 0)}% now` : 'Full Payment'}</strong>
                </div>
            </div>
            ${hotelsHtml}
            ${pkg.description ? `<details class="preview-disclosure"><summary><span>Package overview</span></summary><div class="preview-disclosure-body preview-copy pt-3">${escapeHtml(String(pkg.description))}</div></details>` : ''}
            ${inclusions.length ? `<details class="preview-disclosure"><summary><span>Inclusions</span><span class="badge badge-light">${inclusions.length}</span></summary><div class="preview-disclosure-body preview-copy pt-3">${inclusions.map(escapeHtml).join('<br>')}</div></details>` : ''}
            ${exclusions.length ? `<details class="preview-disclosure"><summary><span>Exclusions</span><span class="badge badge-light">${exclusions.length}</span></summary><div class="preview-disclosure-body preview-copy pt-3">${exclusions.map(escapeHtml).join('<br>')}</div></details>` : ''}
