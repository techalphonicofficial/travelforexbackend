<%- contentFor('body') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

body {
    background-color: #f8fafc;
    font-family: 'Inter', sans-serif;
}

.builder-step { display: none; }
.builder-step.active { display: block; animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
@keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }

.glass-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
    border: 1px solid rgba(226, 232, 240, 0.8);
    margin-bottom: 2rem;
}

.card-header-custom {
    background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
    color: white;
    border-radius: 20px 20px 0 0 !important;
    padding: 1.5rem 2.5rem !important;
    border-bottom: none;
    box-shadow: 0 4px 15px -3px rgba(79, 70, 229, 0.3);
}

.card-header-custom h3 {
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: -0.5px;
}

.form-label {
    font-weight: 600;
    color: #475569;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
}

.form-control, .select2-container--default .select2-selection--multiple, .select2-container--default .select2-selection--single {
    border-radius: 12px;
    padding: 0.75rem 1rem;
    border: 1.5px solid #e2e8f0;
    background: #f8fafc;
    font-size: 0.95rem;
    color: #1e293b;
    transition: all 0.2s;
    height: auto !important;
    min-height: 48px;
}

.form-control:focus, .select2-container--focus .select2-selection--multiple {
    border-color: #3b82f6 !important;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
    background: #ffffff;
}

.select2-container--default .select2-selection--multiple .select2-selection__choice {
    background-color: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1d4ed8;
    border-radius: 6px;
    padding: 4px 8px;
    font-weight: 500;
    font-size: 0.85rem;
    margin-top: 6px;
}

.select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
    color: #2563eb;
    margin-right: 5px;
}

.btn-primary-custom {
    background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
    color: white;
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
}

.btn-primary-custom:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
    color: white;
}

.summary-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
    border: 1px solid #e2e8f0;
    position: sticky;
    top: 2rem;
}

.summary-title {
    font-weight: 800;
    color: #1e293b;
    font-size: 1.25rem;
    margin-bottom: 1.5rem;
    border-bottom: 2px solid #f1f5f9;
    padding-bottom: 1rem;
}

.price-display {
    font-size: 2.5rem;
    font-weight: 800;
    color: #10b981;
    letter-spacing: -1px;
    margin: 1rem 0;
}
.travel-date-card {
    background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
    border: 1px solid #dbe4f0;
    border-radius: 16px;
    padding: 1rem 1rem 0;
    margin-bottom: 1.5rem;
}
.travel-date-card .form-label, .pricing-editor .form-label {
    color: #334155;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: .035em;
    text-transform: uppercase;
}
.pricing-editor {
    background: #f8fafc;
    border: 1px solid #dbe4f0;
    border-radius: 16px;
    padding: 1rem;
    margin-top: 1rem;
}
.pricing-editor .form-control {
    min-height: 48px;
    border-radius: 10px;
    border-color: #cbd5e1;
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
}
.pricing-editor .input-group-text {
    border-radius: 10px 0 0 10px;
    border-color: #cbd5e1;
    background: #fff;
    color: #64748b;
    font-weight: 800;
}
.gst-control { display: grid; grid-template-columns: minmax(0, 1fr) 105px; gap: .75rem; align-items: end; }
.gst-toggle {
    min-height: 48px;
    display: flex;
    align-items: center;
    gap: .65rem;
    padding: 0 .8rem;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background: #fff;
    font-weight: 700;
    color: #334155;
}
.amount-total-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .85rem 1rem;
    margin-top: 1rem;
    border-radius: 12px;
    background: #ecfdf5;
    color: #065f46;
}
.amount-total-strip strong { font-size: 1.15rem; }

.day-card { 
    border-left: 4px solid #4f46e5; 
    margin-bottom: 1.5rem; 
    border-radius: 16px; 
    box-shadow: 0 4px 15px rgba(0,0,0,0.03); 
    border-top: 1px solid #f1f5f9; 
    border-right: 1px solid #f1f5f9; 
    border-bottom: 1px solid #f1f5f9; 
    background: #ffffff;
}

.hotel-selection, .activity-selection { 
    border: 2px dashed #cbd5e1; 
    padding: 1.5rem; 
    border-radius: 12px; 
    background: #f8fafc; 
    margin-top: 10px; 
    cursor: pointer; 
    text-align: center; 
    transition: all 0.2s; 
    color: #64748b;
    font-weight: 500;
}

.hotel-selection:hover, .activity-selection:hover { 
    background: #eff6ff; 
    border-color: #93c5fd; 
    color: #2563eb;
    transform: translateY(-2px); 
}

.manual-dest-price {
    font-weight: 600;
    color: #1e293b;
    padding: 0.4rem 0.75rem;
    border-radius: 0 8px 8px 0;
}

.input-group-text {
    background-color: #f1f5f9;
    border-color: #e2e8f0;
    border-radius: 8px 0 0 8px;
    font-weight: 600;
    color: #64748b;
}

/* Cities Itinerary Editor */
.city-block {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
}
.city-block-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px dashed #cbd5e1;
}
.city-block-header .city-name-input {
    font-size: 1rem;
    font-weight: 700;
    border: none;
    background: transparent;
    box-shadow: none;
    padding: 0;
    flex: 1;
    color: #1e293b;
}
.city-block-header .city-country-input {
    font-size: 0.82rem;
    border: none;
    background: transparent;
    box-shadow: none;
    padding: 0;
    max-width: 150px;
    color: #64748b;
}
.city-day-block {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 0.7rem 0.85rem;
    margin-bottom: 0.6rem;
}
.city-day-label {
    font-size: 0.82rem;
    font-weight: 700;
    color: #4f46e5;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.activity-row {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.4rem;
}
.activity-row input {
    flex: 1;
    border-radius: 8px;
    border: 1px solid #e2e8f0;
    padding: 0.3rem 0.6rem;
    font-size: 0.85rem;
    color: #1e293b;
    background: #fff;
}
.activity-row input:focus {
    border-color: #4f46e5;
    outline: none;
    box-shadow: 0 0 0 2px rgba(79,70,229,0.12);
}
.btn-icon-remove {
    border: none;
    background: none;
    cursor: pointer;
    padding: 0.2rem 0.3rem;
    color: #94a3b8;
    font-size: 0.8rem;
    transition: color 0.15s;
    border-radius: 6px;
    line-height: 1;
}
.btn-icon-remove:hover { color: #ef4444; background: #fef2f2; }
.cities-panel {
    background: #fff;
    border-radius: 16px;
    border: 1px solid #e2e8f0;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
}
.cities-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.2rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #f1f5f9;
}
.cities-panel-header h5 {
    font-weight: 800;
    color: #1e293b;
    margin: 0;
    font-size: 1.05rem;
}
.package-preview {
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 16px;
    padding: 1.25rem;
    margin-top: 1rem;
}
.package-preview.empty {
    color: #64748b;
    text-align: center;
    font-weight: 600;
}
.package-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.85rem;
}
.package-preview-item {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.85rem;
}
.package-preview-item span,
.summary-line span {
    display: block;
    font-size: 0.72rem;
    color: #64748b;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}
.package-preview-item strong {
    display: block;
    color: #0f172a;
    font-size: 0.98rem;
    margin-top: 0.2rem;
}
.summary-line {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    padding: 0.45rem 0;
    border-bottom: 1px solid #f1f5f9;
}
.summary-line span {
    display: inline;
}
.summary-line strong {
    color: #0f172a;
    text-align: right;
}
.summary-muted-box {
    border: 1px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 12px;
    padding: 0.9rem;
    color: #475569;
    font-size: 0.9rem;
}
.payment-mode-control {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
}
.payment-mode-control input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
}
.payment-mode-control label {
    border: 1.5px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 12px;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    font-weight: 800;
    color: #475569;
    cursor: pointer;
    transition: all 0.2s ease;
}
.payment-mode-control input:checked + label {
    background: #eef2ff;
    border-color: #4f46e5;
    color: #3730a3;
    box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.08);
}
.hotel-preview-list {
    display: grid;
    gap: 0.65rem;
    margin-top: 1rem;
}
.hotel-preview-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: center;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.8rem 0.9rem;
}
.hotel-preview-row strong {
    color: #0f172a;
}
.hotel-preview-row small {
    display: block;
    color: #64748b;
    margin-top: 0.15rem;
}
/* Refined booking workspace */
:root {
    --booking-ink: #172033;
    --booking-muted: #667085;
    --booking-border: #e4e7ec;
    --booking-surface: #ffffff;
    --booking-soft: #f8fafc;
    --booking-primary: #4f46e5;
    --booking-primary-dark: #3730a3;
    --booking-success: #079455;
}
body { background: #f5f7fb; color: var(--booking-ink); font-size: 13px; }
.booking-shell { max-width: 1580px; margin: 0 auto; }
.booking-page-heading { font-size: 1.45rem; font-weight: 780; letter-spacing: -.035em; color: var(--booking-ink); }
.booking-page-heading-icon {
    width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center;
    margin-right: .65rem; border-radius: 12px; background: #eef2ff; color: var(--booking-primary); font-size: 1rem;
}
.booking-page-copy { margin: .3rem 0 0 3.45rem; color: var(--booking-muted); font-size: .78rem; }
.glass-card, .summary-card { border: 1px solid var(--booking-border); border-radius: 16px; box-shadow: 0 8px 28px rgba(16, 24, 40, .06); }
.card-header-custom {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    background: var(--booking-surface); color: var(--booking-ink); border-radius: 16px 16px 0 0 !important;
    padding: 1.25rem 1.5rem !important; border-bottom: 1px solid var(--booking-border); box-shadow: none;
}
.card-header-custom h3 { font-size: .95rem; letter-spacing: -.02em; }
.card-header-custom .header-icon {
    width: 38px; height: 38px; display: inline-flex; align-items: center; justify-content: center;
    border-radius: 10px; color: var(--booking-primary); background: #eef2ff;
}
.card-header-custom .header-copy { color: var(--booking-muted); font-size: .8rem; margin-top: .15rem; }
.form-label { color: #475467; font-size: .76rem; font-weight: 700; letter-spacing: .045em; }
.form-control, .select2-container--default .select2-selection--multiple, .select2-container--default .select2-selection--single {
    border: 1px solid #d0d5dd; border-radius: 10px; background: #fff; min-height: 48px; box-shadow: 0 1px 2px rgba(16, 24, 40, .03);
    font-size: 13px;
}
.form-control:focus, .select2-container--focus .select2-selection--multiple {
    border-color: #818cf8 !important; box-shadow: 0 0 0 3px rgba(99, 102, 241, .12) !important;
}
.travel-date-card { background: #fbfcfe; border-color: var(--booking-border); border-radius: 12px; padding: 1.1rem 1.1rem .15rem; }
.schedule-icon {
    width: 38px; height: 38px; flex: 0 0 38px; display: inline-flex; align-items: center; justify-content: center;
    color: var(--booking-primary); background: #eef2ff; border-radius: 10px;
}
.payment-mode-control label { border-radius: 10px; background: #fff; min-height: 48px; font-size: .9rem; }
.payment-mode-control input:checked + label { background: #eef2ff; border-color: #6366f1; color: var(--booking-primary-dark); box-shadow: 0 0 0 3px rgba(99, 102, 241, .1); }
.package-preview { border-radius: 14px; border-color: var(--booking-border); background: #f8fafc; }
.package-preview-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.package-preview-item { border: 1px solid var(--booking-border); border-radius: 10px; box-shadow: none; padding: .75rem; }
.package-preview-item span { font-size: .65rem; }
.package-preview-item strong { font-size: .78rem; line-height: 1.4; }
.preview-disclosure { margin-top: .8rem; border: 1px solid var(--booking-border); border-radius: 10px; background: #fff; overflow: hidden; }
.preview-disclosure summary {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .85rem 1rem;
    color: #344054; font-size: .84rem; font-weight: 750; cursor: pointer; list-style: none;
}
.preview-disclosure summary::-webkit-details-marker { display: none; }
.preview-disclosure summary::after { content: '\f078'; font-family: 'Font Awesome 5 Free'; font-weight: 900; color: #667085; font-size: .7rem; transition: transform .2s; }
.preview-disclosure[open] summary::after { transform: rotate(180deg); }
.preview-disclosure-body { padding: 0 .85rem .85rem; border-top: 1px solid #f0f2f5; }
.preview-copy { color: #667085; font-size: .82rem; line-height: 1.6; }
.hotel-preview-list.compact { margin-top: .75rem; }
.hotel-preview-list.compact .hotel-preview-row { padding: .7rem .75rem; border-radius: 9px; }
.hotel-preview-list.compact .hotel-preview-row strong { font-size: .83rem; }
.hotel-preview-list.compact .hotel-preview-row small { font-size: .76rem; }
.summary-card { top: 1rem; padding: 1.25rem; }
.summary-header { display: flex; align-items: center; justify-content: space-between; gap: .75rem; padding-bottom: 1rem; border-bottom: 1px solid var(--booking-border); }
.summary-title { border: 0; padding: 0; margin: 0; font-size: .95rem; letter-spacing: -.02em; }
.summary-status { border-radius: 999px !important; padding: .45rem .7rem !important; font-size: .72rem; }
.summary-meta { display: grid; grid-template-columns: 1fr 1fr; gap: .65rem; margin-top: 1rem; }
.summary-meta-item { min-width: 0; padding: .75rem; border-radius: 10px; background: #f8fafc; border: 1px solid #eef2f6; }
.summary-meta-item.wide { grid-column: 1 / -1; }
.summary-meta-label { display: block; margin-bottom: .3rem; color: var(--booking-muted); font-size: .68rem; font-weight: 750; text-transform: uppercase; letter-spacing: .06em; }
.summary-meta-value { display: block; color: var(--booking-ink); font-size: .85rem; font-weight: 700; line-height: 1.35; overflow-wrap: anywhere; }
.summary-total {
    margin-top: 1rem; padding: 1rem; border-radius: 12px; color: #fff;
    background: linear-gradient(135deg, #111827 0%, #27324a 100%);
}
.summary-total-label { color: #cbd5e1; font-size: .7rem; font-weight: 750; letter-spacing: .08em; text-transform: uppercase; }
.price-display { margin: .35rem 0 0; color: #6ee7b7; font-size: 1.65rem; letter-spacing: -.045em; }
.pricing-editor { margin-top: .8rem; border-radius: 12px; background: #fff; border-color: var(--booking-border); }
.gst-toggle { border-color: #d0d5dd; border-radius: 9px; }
.amount-total-strip { padding: .75rem .85rem; border: 1px solid #a7f3d0; border-radius: 9px; }
.summary-muted-box { margin-top: .8rem; border-color: var(--booking-border); border-radius: 10px; background: #fafbfc; }
.btn-primary-custom { border-radius: 10px; background: var(--booking-primary); box-shadow: 0 2px 6px rgba(79, 70, 229, .22); font-weight: 700; }
.btn-primary-custom:hover { background: #4338ca; transform: translateY(-1px); box-shadow: 0 5px 12px rgba(79, 70, 229, .24); }
.btn-primary-custom:disabled { background: #c7c9d1; box-shadow: none; cursor: not-allowed; transform: none; }
@media (max-width: 1199.98px) {
    .summary-card { position: static; margin-top: 1.25rem; }
    .package-preview-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 767.98px) {
    .booking-page-heading { font-size: 1.35rem; }
    .booking-page-copy { margin-left: 0; }
    .card-header-custom { padding: 1rem !important; }
    .card-body.p-md-5 { padding: 1rem !important; }
    .package-preview-grid, .summary-meta { grid-template-columns: 1fr; }
    .summary-meta-item.wide { grid-column: auto; }
    .gst-control { grid-template-columns: 1fr 100px; }
}
</style>

<div class="content-header">
    <div class="container-fluid booking-shell">
        <div class="row mb-3 mt-2 align-items-center">
            <div class="col-12">
                <h1 class="booking-page-heading m-0"><span class="booking-page-heading-icon"><i class="fas fa-suitcase-rolling"></i></span>Create Package Booking</h1>
                <p class="booking-page-copy">Build a confirmed package booking with travel dates, passengers and payment details.</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid booking-shell">
        <div class="row align-items-start">
            <!-- Left Column: Builder -->
            <div class="col-xl-8 col-lg-7">
                
                <!-- STEP 1: INITIALIZE TRIP -->
                <div id="step-1" class="glass-card builder-step active p-0 overflow-hidden">
                    <div class="card-header card-header-custom">
                        <div class="d-flex align-items-center">
                            <span class="header-icon mr-3"><i class="fas fa-box-open"></i></span>
                            <div><h3 class="card-title mb-0">Package details</h3><div class="header-copy">Customer, schedule and package selection</div></div>
                        </div>
                        <span class="badge badge-light px-3 py-2" style="border-radius:999px;color:#475467;">Step 1 of 1</span>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <%
                        let nameVal = '';
                        let emailVal = '';
                        let phoneVal = '';
                        let startVal = '';
                        let endVal = '';
                        let selectedDestIds = [];

                        if (typeof booking !== 'undefined' && booking) {
                            if (booking.customer && booking.customer.user) {
                                nameVal = booking.customer.user.name || '';
                                emailVal = booking.customer.user.email || '';
                            }
                            if (booking.customer) {
                                phoneVal = booking.customer.phone || '';
                            }
                            if (booking.custom_trip) {
                                if (booking.custom_trip.start_date) {
                                    startVal = new Date(booking.custom_trip.start_date).toISOString().substring(0,10);
                                }
                                if (booking.custom_trip.end_date) {
                                    endVal = new Date(booking.custom_trip.end_date).toISOString().substring(0,10);
                                }
                                if (booking.custom_trip.destination_id) {
                                    selectedDestIds.push(booking.custom_trip.destination_id);
                                }
                                if (booking.custom_trip.days) {
                                    booking.custom_trip.days.forEach(day => {
                                        if (day.destination_id && !selectedDestIds.includes(day.destination_id)) {
                                            selectedDestIds.push(day.destination_id);
                                        }
                                    });
                                }
                            }
                        } else if (typeof inquiry !== 'undefined' && inquiry) {
                            nameVal = inquiry.customer_name || '';
                            emailVal = inquiry.customer_email || '';
                            phoneVal = inquiry.customer_phone || '';
                            
                            if (inquiry.departure_date) {
                                const pDate = Date.parse(inquiry.departure_date);
                                if (!isNaN(pDate)) {
                                    const sDate = new Date(pDate);
                                    startVal = sDate.toISOString().substring(0,10);
                                    
                                    let days = 7;
                                    if (inquiry.duration) {
                                        const match = inquiry.duration.match(/(\d+)/);
                                        if (match) days = parseInt(match[1], 10);
                                    }
                                    const eDate = new Date(sDate);
                                    eDate.setDate(sDate.getDate() + days);
                                    endVal = eDate.toISOString().substring(0,10);
                                }
                            }

                            if (inquiry.cities) {
                                inquiry.cities.forEach(c => {
                                    if (c.id) selectedDestIds.push(c.id);
                                });
                            }
                        }
                            const customerRows = Array.isArray(customers) ? customers : [];
                            let selectedCustomerId = '';
                            if (typeof inquiry !== 'undefined' && inquiry && inquiry.customer_email) {
                                const inquiryEmail = String(inquiry.customer_email || '').toLowerCase();
                                const matchedCustomer = customerRows.find(c => c.user && String(c.user.email || '').toLowerCase() === inquiryEmail);
                                selectedCustomerId = matchedCustomer ? matchedCustomer.id : '';
                            }
                            let adultVal = 1;
                            if (typeof inquiry !== 'undefined' && inquiry && inquiry.total_travellers) {
                                const parsedAdults = parseInt(inquiry.total_travellers, 10);
                                if (!isNaN(parsedAdults) && parsedAdults > 0) adultVal = parsedAdults;
                            }
                            let packageDepartureVal = '';
                            if (typeof inquiry !== 'undefined' && inquiry && inquiry.departure_date) {
                                const departure = new Date(inquiry.departure_date);
                                if (!isNaN(departure.getTime())) packageDepartureVal = departure.toISOString().substring(0, 10);
                            }
                        %>
                        <form id="initTripForm">
                            <% if (typeof inquiry !== 'undefined' && inquiry) { %>
                                <input type="hidden" id="inquiryId" value="<%= inquiry.id %>">
                            <% } %>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group mb-4">
                                        <label class="form-label">Customer</label>
                                        <select id="customerId" class="form-control select2" data-placeholder="Select customer..." required>
                                            <option value="">Select customer...</option>
                                            <% customerRows.forEach(c => { 
                                                const cu = c.user || {};
                                                const customerPhone = c.phone || cu.phone_number || '';
                                            %>
                                                <option value="<%= c.id %>"
                                                        <%= String(selectedCustomerId) === String(c.id) ? 'selected' : '' %>
                                                        data-name="<%= cu.name || '' %>"
                                                        data-email="<%= cu.email || '' %>"
                                                        data-phone="<%= customerPhone %>">
                                                    <%= cu.name || 'Customer' %><%= cu.email ? ` - ${cu.email}` : '' %><%= customerPhone ? ` - ${customerPhone}` : '' %>
                                                </option>
                                            <% }) %>
                                        </select>
                                        <small class="text-muted mt-2 d-block"><i class="fas fa-user-plus mr-1"></i>If the customer is not listed, add them from User Management first.</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group mb-4">
                                        <label class="form-label">Adults</label>
                                        <input type="number" id="adultCount" class="form-control" min="1" step="1" value="<%= adultVal %>" required>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group mb-4">
                                        <label class="form-label">Payment</label>
                                        <div class="payment-mode-control">
                                            <input type="radio" id="paymentModePartial" name="paymentMode" value="partial" checked>
                                            <label for="paymentModePartial">Partial</label>
                                            <input type="radio" id="paymentModeFull" name="paymentMode" value="full">
                                            <label for="paymentModeFull">Full</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="travel-date-card">
                                <div class="d-flex align-items-center mb-3">
                                    <span class="schedule-icon mr-2"><i class="fas fa-calendar-alt"></i></span>
                                    <div><strong class="d-block">Travel Schedule</strong><small class="text-muted">Confirm stay period and actual departure date.</small></div>
                                </div>
                                <div class="row">
                                    <div class="col-md-4"><div class="form-group mb-3">
                                        <label class="form-label" for="bookingFromDate">From Date *</label>
                                        <input type="date" id="bookingFromDate" class="form-control" value="<%= packageDepartureVal %>" required>
                                    </div></div>
                                    <div class="col-md-4"><div class="form-group mb-3">
                                        <label class="form-label" for="bookingToDate">To Date *</label>
                                        <input type="date" id="bookingToDate" class="form-control" required>
                                    </div></div>
                                    <div class="col-md-4"><div class="form-group mb-3">
                                        <label class="form-label" for="bookingDepartureDate">Departure Date *</label>
                                        <input type="date" id="bookingDepartureDate" class="form-control" value="<%= packageDepartureVal %>" required>
                                    </div></div>
                                </div>
                                <small id="travelDateError" class="text-danger d-block mb-3"></small>
                            </div>
                            <div class="form-group mb-4">
                                <label class="form-label">Package</label>
                                <select id="packageId" class="form-control select2" data-placeholder="Select package..." required>
                                    <option value="">Select package...</option>
                                    <% packages.forEach(p => { %>
                                        <option value="<%= p.id %>">
                                            <%= p.name %><%= p.duration_days ? ` - ${p.duration_days}D` : '' %><%= p.price ? ` - INR ${Number(p.price).toLocaleString('en-IN')}` : '' %>
                                        </option>
                                    <% }) %>
                                </select>
                                <small class="text-muted mt-2 d-block"><i class="fas fa-info-circle mr-1"></i>Package details are fetched for preview only. Confirming will create a package booking.</small>
                            </div>

                            <div id="packagePreview" class="package-preview empty">
                                Select a package to view route, duration, GST and partial booking amounts.
                            </div>

                            <!-- PASSENGER DETAILS SECTION -->
                            <div class="mt-4">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="m-0 font-weight-bold"><i class="fas fa-users text-primary mr-2"></i>Passenger Details</h6>
                                    <small class="text-muted">Lead passenger auto-filled from customer if empty</small>
                                </div>
                                <div id="passengersContainer"></div>
                            </div>

                            <div class="mt-4 text-right">
                                <button type="submit" id="btnInitTrip" class="btn-primary-custom w-100">
                                    <i class="fas fa-rotate mr-2"></i> Fetch Package Details
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- STEP 2: BUILD ITINERARY -->
                <div id="step-2" class="builder-step">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="m-0">Day-by-Day Itinerary</h4>
                        <span class="badge badge-info px-3 py-2" id="tripDurationBadge"></span>
                    </div>

                    <!-- CITIES & ITINERARY EDITOR PANEL -->
                    <div class="cities-panel" id="citiesPanelWrapper">
                        <div class="cities-panel-header">
                            <h5><i class="bi bi-geo-alt-fill me-2" style="color:#4f46e5;"></i>Cities &amp; Itinerary</h5>
                            <div class="d-flex gap-2 align-items-center">
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="addBuilderCity()" style="border-radius:8px;">
                                    <i class="bi bi-plus-circle me-1"></i>Add City
                                </button>
                                <button type="button" class="btn btn-sm btn-success" id="btnSaveCities" onclick="saveBuilderCities()" style="border-radius:8px;">
                                    <i class="bi bi-floppy me-1"></i>Save Itinerary
                                </button>
                            </div>
                        </div>
                        <div id="builderCitiesContainer"></div>
                        <div id="citiesSaveMsg" class="mt-2" style="font-size:0.85rem;"></div>
                    </div>

                    <div id="itineraryContainer">
                        <!-- Days will be rendered here dynamically -->
                    </div>
                </div>

            </div>

            <!-- Right Column: Live Price & Confirm -->
            <div class="col-xl-4 col-lg-5">
                <div class="summary-card">
                    <div class="summary-header">
                        <h4 class="summary-title"><i class="fas fa-receipt text-primary mr-2"></i>Booking Summary</h4>
                        <span id="tripStatus" class="badge badge-warning summary-status">Select Package</span>
                    </div>
                    <div class="summary-meta">
                        <div class="summary-meta-item wide">
                            <span class="summary-meta-label">Customer</span>
                            <span id="summaryCustomer" class="summary-meta-value">Not selected</span>
                        </div>
                        <div class="summary-meta-item wide">
                            <span class="summary-meta-label">Package</span>
                            <span id="summaryPackage" class="summary-meta-value">Not selected</span>
                        </div>
                        <div class="summary-meta-item">
                            <span class="summary-meta-label">Travellers</span>
                            <span id="summaryAdults" class="summary-meta-value">1 Adult</span>
                        </div>
                        <div class="summary-meta-item">
                            <span class="summary-meta-label">Duration</span>
                            <span id="summaryDurationBadge" class="summary-meta-value">0 Days</span>
                        </div>
                        <div class="summary-meta-item wide">
                            <span class="summary-meta-label">Travel dates</span>
                            <span id="summaryTravelDates" class="summary-meta-value">Not selected</span>
                        </div>
                    </div>
                    <div class="summary-total">
                        <span class="summary-total-label">Total booking value</span>
                        <h2 id="livePrice" class="price-display">INR 0.00</h2>
                    </div>

                    <div class="pricing-editor">
                        <div class="form-group mb-3">
                            <label for="manualBookingAmount" class="form-label">Base Booking Amount</label>
                            <div class="input-group">
                                <div class="input-group-prepend"><span class="input-group-text">INR</span></div>
                                <input type="number" class="form-control" id="manualBookingAmount" min="0.01" step="0.01" placeholder="Agreed base amount" disabled>
                            </div>
                        </div>
                        <div class="form-group mb-3">
                            <label for="manualHotelAmount" class="form-label">Hotel Amount</label>
                            <div class="input-group">
                                <div class="input-group-prepend"><span class="input-group-text">INR</span></div>
                                <input type="number" class="form-control" id="manualHotelAmount" min="0" step="0.01" placeholder="Total hotel cost" disabled>
                            </div>
                        </div>
                        <div class="gst-control">
                            <div>
                                <label class="form-label d-block">Tax</label>
                                <label class="gst-toggle mb-0" for="applyBookingGst"><input type="checkbox" id="applyBookingGst" disabled><span>Apply GST</span></label>
                            </div>
                            <div>
                                <label class="form-label" for="bookingGstPercent">GST %</label>
                                <input type="number" class="form-control" id="bookingGstPercent" min="0" max="100" step="0.01" value="0" disabled>
                            </div>
                        </div>
                        <div class="form-group mt-3 mb-0">
                            <label for="manualPaidAmount" class="form-label">Amount Received Now</label>
                            <div class="input-group">
                                <div class="input-group-prepend"><span class="input-group-text">INR</span></div>
                                <input type="number" class="form-control" id="manualPaidAmount" min="0" step="0.01" placeholder="Actual amount received" disabled>
                            </div>
                        </div>
                        <div class="amount-total-strip"><span>Total after GST</span><strong id="pricingEditorTotal">INR 0.00</strong></div>
                        <small id="manualAmountError" class="text-danger d-block mt-2"></small>
                    </div>

                    <div id="destBreakdownContainer" class="summary-muted-box">
                        Select a package to calculate booking amounts.
                    </div>

                    <button id="btnConfirmBooking" class="btn-primary-custom w-100 mt-4" disabled>
                        <i class="fas fa-check-circle mr-2"></i> Confirm Booking
                    </button>
                    <div id="checkoutMessage" class="mt-2 text-center text-sm"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modals -->
<!-- Hotel Modal -->
<div class="modal fade" id="hotelModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Hotel</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="hotelListContainer">
                <p class="text-center text-muted">Loading hotels...</p>
            </div>
        </div>
    </div>
</div>

<!-- Activity Modal -->
<div class="modal fade" id="activityModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Activity</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body" id="activityListContainer">
                <p class="text-center text-muted">Loading activities...</p>
            </div>
        </div>
    </div>
</div>

<script>
const bookingData = <%- typeof booking !== 'undefined' && booking ? JSON.stringify(booking) : 'null' %>;
const inquiryData = <%- typeof inquiry !== 'undefined' && inquiry ? JSON.stringify({id: inquiry.id, cities: inquiry.cities || []}) : 'null' %>;
let currentTrip = bookingData ? bookingData.custom_trip : null;
let currentDayContext = null;
let currentPackageQuote = null;

function formatMoney(amount) {
    const value = Number(amount || 0);
    return 'INR ' + value.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function escapeHtml(value) {
    return String(value || '').replace(/[&<>"']/g, ch => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    }[ch]));
}

// ============================================================
// CITIES & ITINERARY EDITOR (same as inquiry-edit)
// ============================================================
let builderCities = [];

// Initialize cities from inquiry data
if (inquiryData && Array.isArray(inquiryData.cities)) {
    builderCities = JSON.parse(JSON.stringify(inquiryData.cities));
}

function renderBuilderCities() {
    const container = document.getElementById('builderCitiesContainer');
    if (!container) return;
    if (builderCities.length === 0) {
        container.innerHTML = '<p class="text-muted small mb-0">No cities added yet. Click "Add City" to start building your itinerary.</p>';
        return;
    }
    container.innerHTML = builderCities.map((city, ci) => `
        <div class="city-block" id="bcity-${ci}">
            <div class="city-block-header">
                <i class="bi bi-geo-alt-fill" style="color:#4f46e5;font-size:1.1rem;"></i>
                <input type="text" class="city-name-input form-control" placeholder="City name"
                    value="${bEsc(city.name || '')}" onchange="updateBuilderCityField(${ci},'name',this.value)">
                <input type="text" class="city-country-input form-control" placeholder="Country"
                    value="${bEsc(city.country || '')}" onchange="updateBuilderCityField(${ci},'country',this.value)">
                <button type="button" class="btn-icon-remove ms-auto" onclick="removeBuilderCity(${ci})" title="Remove city">
                    <i class="bi bi-x-circle-fill" style="font-size:1.1rem;"></i>
                </button>
            </div>

            <div style="font-size:0.72rem;color:#4f46e5;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px;">Day-wise Itinerary:</div>

            ${(city.activities || []).map((day, di) => renderBuilderDayBlock(ci, di, day)).join('')}

            <button type="button" class="btn btn-sm btn-outline-success mt-1" style="border-radius:8px;font-size:0.82rem;" onclick="addBuilderDay(${ci})">
                <i class="bi bi-plus me-1"></i>Add Day
            </button>
        </div>
    `).join('');
}

function renderBuilderDayBlock(ci, di, day) {
    const acts = Array.isArray(day.activities) ? day.activities : [];
    return `
        <div class="city-day-block">
            <div class="city-day-label">
                <span>Day ${day.dayNumber || (di + 1)}</span>
                <button type="button" class="btn-icon-remove" onclick="removeBuilderDay(${ci},${di})">
                    <i class="bi bi-trash" style="font-size:0.85rem;"></i>
                </button>
            </div>
            <div id="bacts-${ci}-${di}">
                ${acts.map((act, ai) => renderBuilderActivityRow(ci, di, ai, act)).join('')}
            </div>
            <button type="button" class="btn btn-sm btn-link p-0 text-success" style="font-size:0.82rem;" onclick="addBuilderActivity(${ci},${di})">
                <i class="bi bi-plus-circle me-1"></i>Add Activity
            </button>
        </div>
    `;
}

function renderBuilderActivityRow(ci, di, ai, act) {
    return `
        <div class="activity-row">
            <input type="text" style="max-width:90px;" placeholder="09:00 AM"
                value="${bEsc(act.time || '')}" onchange="updateBuilderActivity(${ci},${di},${ai},'time',this.value)">
            <input type="text" placeholder="Activity description"
                value="${bEsc(act.description || '')}" onchange="updateBuilderActivity(${ci},${di},${ai},'description',this.value)">
            <input type="text" style="max-width:120px;" placeholder="Location"
                value="${bEsc(act.location || '')}" onchange="updateBuilderActivity(${ci},${di},${ai},'location',this.value)">
            <button type="button" class="btn-icon-remove" onclick="removeBuilderActivity(${ci},${di},${ai})">
                <i class="bi bi-x-lg" style="font-size:0.8rem;"></i>
            </button>
        </div>
    `;
}

function bEsc(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function updateBuilderCityField(ci, field, value) { builderCities[ci][field] = value; }
function updateBuilderActivity(ci, di, ai, field, value) {
    builderCities[ci].activities[di].activities[ai][field] = value;
}

function addBuilderCity() {
    builderCities.push({ name: '', country: '', activities: [{ dayNumber: 1, activities: [] }] });
    renderBuilderCities();
}

function removeBuilderCity(ci) {
    builderCities.splice(ci, 1);
    renderBuilderCities();
}

function addBuilderDay(ci) {
    if (!builderCities[ci].activities) builderCities[ci].activities = [];
    const next = builderCities[ci].activities.length + 1;
    builderCities[ci].activities.push({ dayNumber: next, activities: [] });
    renderBuilderCities();
}

function removeBuilderDay(ci, di) {
    builderCities[ci].activities.splice(di, 1);
    builderCities[ci].activities.forEach((d, i) => d.dayNumber = i + 1);
    renderBuilderCities();
}

function addBuilderActivity(ci, di) {
    if (!builderCities[ci].activities[di].activities) builderCities[ci].activities[di].activities = [];
    builderCities[ci].activities[di].activities.push({ time: '', description: '', location: '' });
    renderBuilderCities();
}

function removeBuilderActivity(ci, di, ai) {
    builderCities[ci].activities[di].activities.splice(ai, 1);
    renderBuilderCities();
}

async function saveBuilderCities() {
    const btn = document.getElementById('btnSaveCities');
    const msg = document.getElementById('citiesSaveMsg');
    if (!inquiryData) {
        msg.innerHTML = '<span class="text-warning">No inquiry linked — cities saved locally only.</span>';
        return;
    }
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Saving...';
    try {
        const res = await fetch(`/admin/bookings/inquiries/${inquiryData.id}/cities`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ cities: builderCities })
        });
        const data = await res.json();
        if (data.success) {
            msg.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Itinerary saved!</span>';
        } else {
            msg.innerHTML = '<span class="text-danger">Failed to save. Please try again.</span>';
        }
    } catch(e) {
        msg.innerHTML = '<span class="text-danger">Network error. Please try again.</span>';
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-floppy me-1"></i>Save Itinerary';
        setTimeout(() => { msg.innerHTML = ''; }, 3000);
    }
}

// Render cities panel on page load
document.addEventListener('DOMContentLoaded', () => { renderBuilderCities(); });
// ============================================================

function getBookingSelections() {
    const paymentModeInput = document.querySelector('input[name="paymentMode"]:checked');
    return {
        customerId: document.getElementById('customerId') ? document.getElementById('customerId').value : '',
        packageId: document.getElementById('packageId') ? document.getElementById('packageId').value : '',
        adults: Math.max(parseInt(document.getElementById('adultCount') ? document.getElementById('adultCount').value : '1', 10) || 1, 1),
        paymentMode: paymentModeInput ? paymentModeInput.value : 'partial',
        fromDate: document.getElementById('bookingFromDate')?.value || '',
        toDate: document.getElementById('bookingToDate')?.value || '',
        departureDate: document.getElementById('bookingDepartureDate')?.value || '',
        inquiryId: document.getElementById('inquiryId') ? document.getElementById('inquiryId').value : null
    };
}

function updateCustomerSummary() {
    const select = document.getElementById('customerId');
    const summary = document.getElementById('summaryCustomer');
    if (!select || !summary) return;

    const opt = select.options[select.selectedIndex];
    summary.textContent = opt && opt.value ? (opt.getAttribute('data-name') || opt.textContent.trim()) : 'Not selected';
    setConfirmButtonState();
}

function setConfirmButtonState() {
    const btn = document.getElementById('btnConfirmBooking');
    if (!btn) return;
    const selections = getBookingSelections();
    const baseAmount = Number(document.getElementById('manualBookingAmount')?.value || 0);
    const hotelAmount = Number(document.getElementById('manualHotelAmount')?.value || 0);
    const applyGst = Boolean(document.getElementById('applyBookingGst')?.checked);
    const gstPercent = applyGst ? Number(document.getElementById('bookingGstPercent')?.value || 0) : 0;
    const subtotal = baseAmount + hotelAmount;
    const bookingAmount = subtotal + (subtotal * gstPercent / 100);
    const paidAmount = Number(document.getElementById('manualPaidAmount')?.value || 0);
    const validDates = Boolean(selections.fromDate && selections.toDate && selections.departureDate && selections.toDate >= selections.fromDate && selections.departureDate <= selections.toDate);
    const validAmounts = Number.isFinite(baseAmount) && baseAmount > 0 && Number.isFinite(hotelAmount) && hotelAmount >= 0 && Number.isFinite(gstPercent) && gstPercent >= 0 && gstPercent <= 100 && Number.isFinite(paidAmount) && paidAmount >= 0 && paidAmount <= bookingAmount;
    const canConfirm = Boolean(selections.customerId && selections.packageId && currentPackageQuote && validDates && validAmounts);
    btn.disabled = !canConfirm;
}

function formatTravellerCount(value) {
    const count = Math.max(Number(value || 1), 1);
    return `${count} ${count === 1 ? 'Adult' : 'Adults'}`;
}

function formatDisplayDate(value) {
    if (!value) return '';
    const date = new Date(`${value}T00:00:00`);
    return Number.isNaN(date.getTime()) ? value : date.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
}

function refreshManualAmountSummary() {
    if (!currentPackageQuote) return;
    const bookingInput = document.getElementById('manualBookingAmount');
    const hotelInput = document.getElementById('manualHotelAmount');
    const paidInput = document.getElementById('manualPaidAmount');
    const applyGstInput = document.getElementById('applyBookingGst');
    const gstInput = document.getElementById('bookingGstPercent');
    const error = document.getElementById('manualAmountError');
    const base = Number(bookingInput?.value || 0);
    const hotel = Number(hotelInput?.value || 0);
    const gstPercent = applyGstInput?.checked ? Number(gstInput?.value || 0) : 0;
    const subtotal = base + hotel;
    const gstAmount = subtotal * gstPercent / 100;
    const total = subtotal + gstAmount;
    const paid = Number(paidInput?.value || 0);
    const valid = Number.isFinite(base) && base > 0 && Number.isFinite(hotel) && hotel >= 0 && Number.isFinite(gstPercent) && gstPercent >= 0 && gstPercent <= 100 && Number.isFinite(paid) && paid >= 0 && paid <= total;

    if (error) {
        error.textContent = paid > total ? 'Received amount cannot be greater than final booking amount.' : (!valid ? 'Enter valid booking and received amounts.' : '');
    }
    document.getElementById('livePrice').textContent = formatMoney(valid ? total : 0);
    document.getElementById('pricingEditorTotal').textContent = formatMoney(valid ? total : 0);
    if (gstInput) gstInput.disabled = !applyGstInput?.checked || bookingInput.disabled;
    const finalAmount = document.getElementById('summaryFinalAmount');
    const summaryHotel = document.getElementById('summaryHotelAmount');
    const summaryGst = document.getElementById('summaryGstAmount');
    const payNow = document.getElementById('summaryPayNow');
    const leftAmount = document.getElementById('summaryLeftAmount');
    if (finalAmount) finalAmount.textContent = formatMoney(valid ? total : 0);
    if (summaryHotel) summaryHotel.textContent = formatMoney(valid ? hotel : 0);
    if (summaryGst) summaryGst.textContent = formatMoney(valid ? gstAmount : 0);
    if (payNow) payNow.textContent = formatMoney(valid ? paid : 0);
    if (leftAmount) leftAmount.textContent = formatMoney(valid ? Math.max(total - paid, 0) : 0);
    setConfirmButtonState();
}

function updateTravelDateSummary() {
    const selections = getBookingSelections();
    const summary = document.getElementById('summaryTravelDates');
    if (summary) {
        summary.innerHTML = selections.fromDate && selections.toDate
            ? `${escapeHtml(formatDisplayDate(selections.fromDate))} &ndash; ${escapeHtml(formatDisplayDate(selections.toDate))}<br><small class="text-muted">Departure: ${escapeHtml(formatDisplayDate(selections.departureDate) || 'Not selected')}</small>`
            : 'Not selected';
    }
    const toInput = document.getElementById('bookingToDate');
    const departureInput = document.getElementById('bookingDepartureDate');
    const error = document.getElementById('travelDateError');
    if (toInput) toInput.min = selections.fromDate || '';
    if (departureInput) {
        departureInput.removeAttribute('min');
        departureInput.max = selections.toDate || '';
    }
    if (error) {
        error.textContent = selections.fromDate && selections.toDate && selections.toDate < selections.fromDate
            ? 'To date cannot be before from date.'
            : (selections.departureDate && selections.toDate && selections.departureDate > selections.toDate
                ? 'Departure date cannot be after the trip end date.'
                : '');
    }
    setConfirmButtonState();
}

function resetPackageQuote(message) {
    currentPackageQuote = null;
    const preview = document.getElementById('packagePreview');
    if (preview) {
        preview.className = 'package-preview empty';
        preview.innerHTML = message || 'Select a package to view route, duration, GST and partial booking amounts.';
    }
    document.getElementById('summaryPackage').textContent = 'Not selected';
    document.getElementById('summaryDurationBadge').textContent = '0 Days';
    document.getElementById('summaryAdults').textContent = formatTravellerCount(getBookingSelections().adults);
    document.getElementById('livePrice').textContent = formatMoney(0);
    const bookingAmountInput = document.getElementById('manualBookingAmount');
    const hotelAmountInput = document.getElementById('manualHotelAmount');
    const paidAmountInput = document.getElementById('manualPaidAmount');
    const applyGstInput = document.getElementById('applyBookingGst');
    const gstInput = document.getElementById('bookingGstPercent');
    if (bookingAmountInput) { bookingAmountInput.value = ''; bookingAmountInput.disabled = true; }
    if (hotelAmountInput) { hotelAmountInput.value = ''; hotelAmountInput.disabled = true; }
    if (paidAmountInput) { paidAmountInput.value = ''; paidAmountInput.disabled = true; }
    if (applyGstInput) { applyGstInput.checked = false; applyGstInput.disabled = true; }
    if (gstInput) { gstInput.value = '0'; gstInput.disabled = true; }
    document.getElementById('pricingEditorTotal').textContent = formatMoney(0);
    if (document.getElementById('manualAmountError')) document.getElementById('manualAmountError').textContent = '';
    document.getElementById('destBreakdownContainer').innerHTML = 'Select a package to calculate booking amounts.';
    document.getElementById('tripStatus').textContent = 'Select Package';
    setConfirmButtonState();
}

