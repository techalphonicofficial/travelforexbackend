function getBookingSelections() {
    const paymentModeInput = document.querySelector('input[name="paymentMode"]:checked');
    return {
        customerId: document.getElementById('customerId') ? document.getElementById('customerId').value : '',
        packageId: document.getElementById('packageId') ? document.getElementById('packageId').value : '',
        adults: Math.max(parseInt(document.getElementById('adultCount') ? document.getElementById('adultCount').value : '1', 10) || 1, 1),
        paymentMode: paymentModeInput ? paymentModeInput.value : 'partial',
        inquiryId: document.getElementById('inquiryId') ? document.getElementById('inquiryId').value : null
    };
}

function updateCustomerSummary() {
    const select = document.getElementById('customerId');
    const summary = document.getElementById('summaryCustomer');
    if (!select || !summary) return;

    const opt = select.options[select.selectedIndex];
    summary.textContent = opt && opt.value ? (opt.getAttribute('data-name') || opt.textContent.trim()) : 'Not selected';
    setConfirmButtonState();
}

function setConfirmButtonState() {
    const btn = document.getElementById('btnConfirmBooking');
    if (!btn) return;
    const selections = getBookingSelections();
    const canConfirm = Boolean(selections.customerId && selections.packageId && currentPackageQuote && Number(currentPackageQuote.amounts?.package_total || 0) > 0);
    btn.disabled = !canConfirm;
}

function resetPackageQuote(message) {
    currentPackageQuote = null;
    const preview = document.getElementById('packagePreview');
    if (preview) {
        preview.className = 'package-preview empty';
        preview.innerHTML = message || 'Select a package to view route, duration, GST and partial booking amounts.';
    }
    document.getElementById('summaryPackage').textContent = 'Not selected';
    document.getElementById('summaryDurationBadge').textContent = '0 Days';
    document.getElementById('summaryAdults').textContent = getBookingSelections().adults;
    document.getElementById('livePrice').textContent = formatMoney(0);
    document.getElementById('destBreakdownContainer').innerHTML = 'Select a package to calculate booking amounts.';
    document.getElementById('tripStatus').textContent = 'Select Package';
    setConfirmButtonState();
}

function renderPackageQuote(quote) {
    currentPackageQuote = quote;
    const pkg = quote.package || {};
    const amounts = quote.amounts || {};
    const hotels = Array.isArray(quote.hotels) ? quote.hotels : [];
    const route = Array.isArray(quote.route) && quote.route.length ? quote.route.join(' to ') : 'No route added';
    const inclusions = Array.isArray(quote.inclusions) ? quote.inclusions.slice(0, 4) : [];
    const exclusions = Array.isArray(quote.exclusions) ? quote.exclusions.slice(0, 3) : [];
    const preview = document.getElementById('packagePreview');
    const hotelsHtml = hotels.length ? `
        <div class="hotel-preview-list">
            ${hotels.map(hotel => `
                <div class="hotel-preview-row">
                    <div>
                        <strong>${escapeHtml(hotel.name || 'Hotel')}</strong>
                        <small>${escapeHtml(hotel.destination_name || 'Stay')} - ${Number(hotel.rooms || 1)} room(s), ${Number(hotel.nights || 1)} night(s)</small>
                    </div>
                    <strong>${formatMoney(hotel.estimated_amount)}</strong>
                </div>
            `).join('')}
        </div>
    ` : '';

    if (preview) {
        preview.className = 'package-preview';
        preview.innerHTML = `
            <div class="package-preview-grid">
                <div class="package-preview-item">
                    <span>Package</span>
                    <strong>${escapeHtml(pkg.name || 'Package')}</strong>
                </div>
                <div class="package-preview-item">
                    <span>Route</span>
                    <strong>${escapeHtml(route)}</strong>
                </div>
                <div class="package-preview-item">
                    <span>Duration</span>
                    <strong>${Number(pkg.duration_days || 0)} Days</strong>
                </div>
                <div class="package-preview-item">
                    <span>Base / Adult</span>
                    <strong>${formatMoney(amounts.base_per_adult)}</strong>
                </div>
                <div class="package-preview-item">
                    <span>GST</span>
                    <strong>${Number(amounts.tax_percent || 0)}% - ${formatMoney(amounts.tax_amount)}</strong>
                </div>
                <div class="package-preview-item">
                    <span>Hotels Included</span>
                    <strong>${Number(amounts.hotel_count || 0)} - ${formatMoney(amounts.hotel_estimated_amount)}</strong>
                </div>
                <div class="package-preview-item">
                    <span>Payment Mode</span>
                    <strong>${quote.partial_booking?.enabled ? `Partial ${Number(quote.partial_booking.percentage || 0)}% now` : 'Full Payment'}</strong>
                </div>
            </div>
            ${hotelsHtml}
            ${pkg.description ? `<div class="mt-3 text-muted">${escapeHtml(String(pkg.description).slice(0, 260))}</div>` : ''}
            ${inclusions.length ? `<div class="mt-3"><strong>Inclusions:</strong> ${inclusions.map(escapeHtml).join(', ')}</div>` : ''}
            ${exclusions.length ? `<div class="mt-2 text-muted"><strong>Exclusions:</strong> ${exclusions.map(escapeHtml).join(', ')}</div>` : ''}
        `;
    }

    document.getElementById('summaryPackage').textContent = pkg.name || 'Package';
    document.getElementById('summaryDurationBadge').textContent = `${Number(pkg.duration_days || 0)} Days`;
    document.getElementById('summaryAdults').textContent = amounts.adults || getBookingSelections().adults;
    document.getElementById('livePrice').textContent = formatMoney(amounts.package_total);
    document.getElementById('tripStatus').textContent = 'Ready';
    document.getElementById('destBreakdownContainer').innerHTML = `
        <div class="summary-line"><span>Base</span><strong>${formatMoney(amounts.package_base_amount)}</strong></div>
        <div class="summary-line"><span>Hotel Cost Included</span><strong>${formatMoney(amounts.hotel_estimated_amount)}</strong></div>
        ${Number(amounts.discount_amount || 0) > 0 ? `<div class="summary-line"><span>Discount</span><strong>- ${formatMoney(amounts.discount_amount)}</strong></div>` : ''}
        <div class="summary-line"><span>${escapeHtml(amounts.tax_type || 'GST')} ${Number(amounts.tax_percent || 0)}%</span><strong>${formatMoney(amounts.tax_amount)}</strong></div>
        <div class="summary-line"><span>Pay Now</span><strong>${formatMoney(amounts.payable_now)}</strong></div>
        <div class="summary-line"><span>Left Amount</span><strong>${formatMoney(amounts.remaining_amount)}</strong></div>
    `;
    setConfirmButtonState();
}

async function fetchPackageQuote(silent = false) {
    const selections = getBookingSelections();
    if (!selections.packageId) {
        resetPackageQuote();
        return;
    }

    const btn = document.getElementById('btnInitTrip');
    if (btn && !silent) {
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Fetching...';
    }

    try {
        const params = new URLSearchParams({
            adults: String(selections.adults),
            payment_mode: selections.paymentMode
        });
        const res = await fetch(`/admin/bookings/api/packages/${encodeURIComponent(selections.packageId)}/quote?${params.toString()}`);
        const data = await res.json();
        if (!data.success) {
            resetPackageQuote(data.message || 'Unable to fetch package details.');
            if (!silent) alert(data.message || 'Unable to fetch package details.');
            return;
        }
        renderPackageQuote(data.data);
    } catch (err) {
        resetPackageQuote('Error fetching package details.');
        if (!silent) alert('Error fetching package details.');
    } finally {
        if (btn && !silent) {
            btn.disabled = false;
            btn.innerHTML = '<i class="fas fa-rotate mr-2"></i> Fetch Package Details';
        }
    }
}

function initPackageBookingForm() {
    const form = document.getElementById('initTripForm');
    if (!form) return;

    updateCustomerSummary();
    document.getElementById('summaryAdults').textContent = getBookingSelections().adults;

    const customerSelect = document.getElementById('customerId');
    const packageSelect = document.getElementById('packageId');
    const adultInput = document.getElementById('adultCount');
    const paymentModeInputs = document.querySelectorAll('input[name="paymentMode"]');

    if (customerSelect) customerSelect.addEventListener('change', updateCustomerSummary);
    if (packageSelect) packageSelect.addEventListener('change', () => fetchPackageQuote(true));
    paymentModeInputs.forEach(input => input.addEventListener('change', () => {
        if (getBookingSelections().packageId) fetchPackageQuote(true);
    }));
    if (adultInput) {
        adultInput.addEventListener('input', () => {
            if (Number(adultInput.value || 0) < 1) adultInput.value = 1;
            document.getElementById('summaryAdults').textContent = getBookingSelections().adults;
            renderPassengerForms();
            if (getBookingSelections().packageId) fetchPackageQuote(true);
        });
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        await fetchPackageQuote(false);
    });

    if (getBookingSelections().packageId) {
        fetchPackageQuote(true);
    } else {
        resetPackageQuote();
    }
    
    renderPassengerForms();
}

