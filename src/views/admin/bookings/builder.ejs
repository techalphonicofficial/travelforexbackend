function renderItinerary() {
    if (!currentTrip) return;
    syncSelectedDestinationsFromTrip();
    document.getElementById('livePrice').innerText = '₹' + parseFloat(currentTrip.total_price).toFixed(2);
    document.getElementById('tripDurationBadge').innerText = currentTrip.days.length + ' Days';
    if(document.getElementById('summaryDurationBadge')) {
        document.getElementById('summaryDurationBadge').innerText = currentTrip.days.length + ' Days';
    }
    
    // Calculate destination-wise breakdown
    const destBreakdown = {};
    if (currentTrip.days) {
        currentTrip.days.forEach(day => {
            const destId = day.destination_id;
            if (destId) {
                if (!destBreakdown[destId]) destBreakdown[destId] = 0;
                
                // Add hotel price
                if (day.hotel && day.hotel.price_per_night) {
                    destBreakdown[destId] += parseFloat(day.hotel.price_per_night);
                }
                
                // Add activity prices
                if (day.activities && day.activities.length > 0) {
                    day.activities.forEach(ta => {
                        if (ta.activity && ta.activity.price) {
                            destBreakdown[destId] += parseFloat(ta.activity.price);
                        }
                        if (ta.price) {
                            destBreakdown[destId] += parseFloat(ta.price); // for custom activities
                        }
                    });
                }
            }
        });
    }

    let breakdownHtml = '';
    if (window.selectedDestinations && window.selectedDestinations.length > 0) {
        breakdownHtml = '<hr><h6 class="text-muted mb-2" style="font-size: 0.85rem;">Manual / Custom Price (Base):</h6><ul class="list-unstyled mb-0" style="font-size: 0.9rem;">';
        const hasCalculatedAmounts = Object.values(destBreakdown).some(amount => Number(amount || 0) > 0);
        const fallbackBase = parseFloat(currentTrip.base_price || 0);
        const fallbackCount = window.selectedDestinations.length || 1;
        let fallbackRemaining = fallbackBase;

        window.selectedDestinations.forEach((destObj, destIndex) => {
            let amount = destBreakdown[destObj.id] || 0;
            let autoPriced = false;
            if (!hasCalculatedAmounts && fallbackBase > 0) {
                amount = destIndex === fallbackCount - 1
                    ? fallbackRemaining
                    : Math.round((fallbackBase / fallbackCount) * 100) / 100;
                fallbackRemaining = Math.max(Math.round((fallbackRemaining - amount) * 100) / 100, 0);
                autoPriced = true;
            }
            breakdownHtml += `
                <li class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-truncate" style="max-width: 120px;" title="${destObj.name}">${destObj.name}</span> 
                    <div class="input-group input-group-sm" style="width: 100px;">
                        <div class="input-group-prepend"><span class="input-group-text">₹</span></div>
                        <input type="number" class="form-control text-right manual-dest-price" data-dest-id="${destObj.id}" data-auto-priced="${autoPriced ? '1' : '0'}" value="${amount}" oninput="this.dataset.autoPriced='0'; recalculateManualTotal()">
                    </div>
                </li>`;
        });
        breakdownHtml += '</ul>';
        // Container for live tax breakdown
        breakdownHtml += '<div id="liveTaxBreakdownContainer" class="mt-3"></div>';
    }
    
    // Inject breakdown html into the summary box
    const summaryBox = document.getElementById('livePrice').parentElement;
    let breakdownContainer = document.getElementById('destBreakdownContainer');
    if (!breakdownContainer) {
        breakdownContainer = document.createElement('div');
        breakdownContainer.id = 'destBreakdownContainer';
        summaryBox.appendChild(breakdownContainer);
    }
    breakdownContainer.innerHTML = breakdownHtml;

    // Call once to set initial state of confirm button based on the inputs
    recalculateManualTotal();

    let html = '';
    currentTrip.days.forEach(day => {
        html += `
        <div class="card day-card">
            <div class="card-body">
                <h5 class="font-weight-bold text-indigo mb-3">Day ${day.day_number}</h5>
                
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="text-muted"><i class="fas fa-map-marker-alt"></i> Destination</label>
                        <select class="form-control form-control-sm custom-day-dest" onchange="updateDayDestination(${day.id}, this.value)">
                            <option value="">Select Destination...</option>
                            ${(window.selectedDestinations || []).map(d => 
                                `<option value="${d.id}" ${day.destination_id == d.id ? 'selected' : ''}>${d.name}</option>`
                            ).join('')}
                        </select>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="text-muted"><i class="fas fa-file-alt"></i> Itinerary Description</label>
                        <textarea class="form-control form-control-sm" rows="1" placeholder="Enter what happens on Day ${day.day_number}..." onblur="updateDayDesc(${day.id}, this.value)">${day.description || ''}</textarea>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="text-muted"><i class="fas fa-bed"></i> Hotel</h6>
                        ${ day.hotel ? `
                            <div class="p-3 border rounded bg-light mb-2">
                                <strong>${day.hotel.name}</strong><br>
                                <span class="text-success small">₹${day.hotel.price_per_night}/night</span>
                                <button class="btn btn-xs btn-outline-primary float-right mt-1" onclick="openHotelModal(${day.day_number})">Change</button>
                            </div>
                        ` : `
                            <div class="hotel-selection" onclick="openHotelModal(${day.day_number})">
                                <i class="fas fa-plus-circle text-primary"></i><br>
                                <small>Select Hotel</small>
                            </div>
                        `}
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-muted"><i class="fas fa-hiking"></i> Activities</h6>
                        ${ day.activities && day.activities.length > 0 ? 
                            day.activities.map(a => `
                                <div class="p-2 border rounded bg-light mb-2 d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>${a.activity ? a.activity.name : (a.title || 'Custom Activity')}</strong><br>
                                        <span class="text-success small">${a.activity ? '₹' + a.activity.price : (a.description || '')}</span>
                                    </div>
                                    <button class="btn btn-xs btn-danger" onclick="removeActivity(${day.day_number}, ${a.activity_id || a.id})"><i class="fas fa-trash"></i></button>
                                </div>
                            `).join('')
                            : ''
                        }
                        <div class="activity-selection mt-2" onclick="openActivityModal(${day.day_number})">
                            <i class="fas fa-plus-circle text-primary"></i><br>
                            <small>Add Activity</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>`;
    });
    document.getElementById('itineraryContainer').innerHTML = html;
}

function syncSelectedDestinationsFromTrip() {
    const select = document.getElementById('destinationIds');
    if (!select || !currentTrip || !Array.isArray(currentTrip.days)) return;

    const selectedIds = new Set((window.selectedDestinations || []).map(item => String(item.id)));
    const tripDestinationIds = [...new Set(currentTrip.days
        .map(day => day.destination_id || currentTrip.destination_id)
        .filter(Boolean)
        .map(String))];

    if (selectedIds.size > 0 || tripDestinationIds.length === 0) return;

    window.selectedDestinations = tripDestinationIds.map(id => {
        const opt = select.querySelector(`option[value="${id}"]`);
        if (!opt) return null;
        opt.selected = true;
        return {
            id,
            name: opt.getAttribute('data-name') || opt.textContent.trim(),
            tax_rule: opt.getAttribute('data-tax-rule'),
            gst_rate: parseFloat(opt.getAttribute('data-gst')) || 0,
            gst_amount: parseFloat(opt.getAttribute('data-gst-amount')) || 0,
            tcs_rate: 0,
            state: opt.getAttribute('data-state')
        };
    }).filter(Boolean);
}

async function openHotelModal(dayNumber) {
    currentDayContext = dayNumber;
    const dayObj = currentTrip.days.find(d => d.day_number === dayNumber);
    if (!dayObj || !dayObj.destination_id) {
        alert("Please select a Destination for this day first!");
        return;
    }
    $('#hotelModal').modal('show');
    const destId = dayObj.destination_id;
    const res = await fetch(`/admin/bookings/api/destinations/${destId}/hotels`);
    const data = await res.json();
    let html = '<div class="list-group">';
    data.data.forEach(h => {
        html += `<div class="list-group-item d-flex justify-content-between align-items-center">
            <div><strong>${h.name}</strong><br><span class="text-success">₹${h.price_per_night}/night</span></div>
            <button class="btn btn-sm btn-primary" onclick="selectHotel(${h.id})">Select</button>
        </div>`;
    });
    html += '</div>';
    document.getElementById('hotelListContainer').innerHTML = html;
}

async function selectHotel(hotelId) {
    $('#hotelModal').modal('hide');
    const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/${currentDayContext}/hotel`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ hotel_id: hotelId })
    });
    const data = await res.json();
    if(data.success) { currentTrip = data.data; renderItinerary(); }
}

async function openActivityModal(dayNumber) {
    currentDayContext = dayNumber;
    const dayObj = currentTrip.days.find(d => d.day_number === dayNumber);
    if (!dayObj || !dayObj.destination_id) {
        alert("Please select a Destination for this day first!");
        return;
    }
    $('#activityModal').modal('show');
    const destId = dayObj.destination_id;
    const res = await fetch(`/admin/bookings/api/destinations/${destId}/activities`);
    const data = await res.json();
    let html = '<div class="list-group">';
    data.data.forEach(a => {
        html += `<div class="list-group-item d-flex justify-content-between align-items-center">
            <div><strong>${a.name}</strong><br><span class="text-success">₹${a.price}</span></div>
            <button class="btn btn-sm btn-success" onclick="selectActivity(${a.id})">Add</button>
        </div>`;
    });
    html += '</div>';
    document.getElementById('activityListContainer').innerHTML = html;
}

async function selectActivity(activityId) {
    $('#activityModal').modal('hide');
    const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/${currentDayContext}/activities`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ activity_id: activityId })
    });
    const data = await res.json();
    if(data.success) { currentTrip = data.data; renderItinerary(); }
}

async function updateDayDestination(dayId, destId) {
    try {
        const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/id/${dayId}/destination`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ destination_id: destId })
        });
        const data = await res.json();
        if(data.success) {
            // Update local state
            const dayIdx = currentTrip.days.findIndex(d => d.id === dayId);
            if (dayIdx !== -1) currentTrip.days[dayIdx].destination_id = destId;
        } else {
            console.error("Failed to update destination");
        }
    } catch (e) {
        console.error("Error updating destination", e);
    }
}

async function updateDayDesc(dayId, text) {
    try {
        const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/id/${dayId}/description`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ description: text })
        });
        const data = await res.json();
        if(!data.success) {
            console.error("Failed to update description");
        }
    } catch (e) {
        console.error("Error updating description", e);
    }
}

async function removeActivity(dayNumber, activityId) {
    const res = await fetch(`/admin/bookings/api/build/${currentTrip.id}/days/${dayNumber}/activities/${activityId}`, {
        method: 'DELETE'
    });
    const data = await res.json();
    if(data.success) { currentTrip = data.data; renderItinerary(); }
}

function recalculateManualTotal() {
    const inputs = document.querySelectorAll('.manual-dest-price');
    let base_price = 0;
    let taxBreakdownObj = {};
    let total_tax = 0;
    const companyState = 'Delhi'; // Fallback state
    const autoPricedInputs = inputs.length > 0 && Array.from(inputs).every(input => input.dataset.autoPriced === '1');
    const tripTotal = parseFloat(currentTrip?.total_price || 0);
    const tripBase = parseFloat(currentTrip?.base_price || 0);
    const tripTax = parseFloat(currentTrip?.total_tax || 0);

    inputs.forEach(input => {
        const amount = parseFloat(input.value) || 0;
        base_price += amount;
        
        const destId = input.getAttribute('data-dest-id');
        const destObj = window.selectedDestinations.find(d => d.id == destId);
        
        if (destObj && amount > 0) {
            const rule = destObj.tax_rule || 'domestic';
            let taxAmt = 0;
            if (destObj.gst_amount > 0) {
                taxAmt = destObj.gst_amount;
            } else if (destObj.gst_rate > 0) {
                taxAmt = (amount * destObj.gst_rate) / 100;
            }

            if (rule === 'domestic') {
                if (taxAmt > 0) {
                    // Mock intra vs inter state
                    if (destObj.state && destObj.state.toLowerCase() === companyState.toLowerCase()) {
                        const half = taxAmt / 2;
                        const sgstKey = `SGST (${destObj.name})`;
                        const cgstKey = `CGST (${destObj.name})`;
                        taxBreakdownObj[sgstKey] = (taxBreakdownObj[sgstKey] || 0) + half;
                        taxBreakdownObj[cgstKey] = (taxBreakdownObj[cgstKey] || 0) + half;
                    } else {
                        const igstKey = `IGST (${destObj.name})`;
                        taxBreakdownObj[igstKey] = (taxBreakdownObj[igstKey] || 0) + taxAmt;
                    }
                    total_tax += taxAmt;
                }
            } else if (rule === 'international_outbound') {
                // Apply GST if configured (TCS removed)
                if (taxAmt > 0) {
                    const gstKey = `IGST (${destObj.name})`;
                    taxBreakdownObj[gstKey] = (taxBreakdownObj[gstKey] || 0) + taxAmt;
                    total_tax += taxAmt;
                }
            }
        }
    });
    
    // Update display (if no inputs exist, fallback to currentTrip.total_price)
    if (inputs.length === 0) {
        base_price = parseFloat(currentTrip.total_price || 0);
        // Note: Without inputs, we can't easily calculate accurate tax live on UI, we rely on backend
    }
    
    let grand_total = base_price + total_tax;
    window.useTripAmountFallback = false;

    if (autoPricedInputs && tripTotal > 0) {
        base_price = tripBase || Math.max(tripTotal - tripTax, 0);
        total_tax = tripTax || Math.max(tripTotal - base_price, 0);
        grand_total = tripTotal;
        taxBreakdownObj = currentTrip?.tax_breakdown || {};
        window.useTripAmountFallback = true;
    }
    
    // Render tax breakdown HTML
    const taxContainer = document.getElementById('liveTaxBreakdownContainer');
    if (taxContainer && Object.keys(taxBreakdownObj).length > 0) {
        let taxHtml = '<hr><h6 class="text-muted mb-2" style="font-size: 0.85rem;">Taxes & Levies:</h6><ul class="list-unstyled mb-0" style="font-size: 0.85rem; color:#d97706;">';
        for (const [key, amt] of Object.entries(taxBreakdownObj)) {
            const displayAmount = Number(amt || 0);
            taxHtml += `<li class="d-flex justify-content-between mb-1"><span>${key}</span> <span>₹${displayAmount.toLocaleString('en-IN', {minimumFractionDigits: 2})}</span></li>`;
        }
        taxHtml += '</ul><hr>';
        taxContainer.innerHTML = taxHtml;
    } else if (taxContainer) {
        taxContainer.innerHTML = '';
    }
    
    document.getElementById('livePrice').innerText = '₹' + grand_total.toLocaleString('en-IN', {minimumFractionDigits: 2});
    document.getElementById('btnConfirmBooking').disabled = grand_total <= 0;
    
    // Store in global var for checkout
    window.finalManualPrice = grand_total;
    window.manualDestBreakdown = Array.from(inputs).map(inp => ({
        destId: inp.getAttribute('data-dest-id'),
        amount: parseFloat(inp.value) || 0
    }));
}

document.getElementById('btnConfirmBooking').addEventListener('click', confirmBooking);

async function confirmBooking() {
    try {
        const btn = document.getElementById('btnConfirmBooking');
        const selections = getBookingSelections();
        if (!selections.customerId) {
            alert('Please select a customer.');
            return;
        }
        if (!selections.packageId) {
            alert('Please select a package.');
            return;
        }
        if (!currentPackageQuote) {
            await fetchPackageQuote(false);
        }
        if (!currentPackageQuote) {
            alert('Please fetch package details before confirming.');
            return;
        }
        if (!selections.fromDate || !selections.toDate || !selections.departureDate) {
            alert('Please select from date, to date and departure date.');
            return;
        }
        if (selections.toDate < selections.fromDate || selections.departureDate > selections.toDate) {
            alert(selections.toDate < selections.fromDate ? 'To date cannot be before from date.' : 'Departure date cannot be after the trip end date.');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Confirming...';

        const payload = {
            customer_id: selections.customerId,
            package_id: selections.packageId,
            adults: selections.adults,
            payment_mode: selections.paymentMode,
            base_amount: Number(document.getElementById('manualBookingAmount').value),
            hotel_amount: Number(document.getElementById('manualHotelAmount').value),
            apply_gst: Boolean(document.getElementById('applyBookingGst').checked),
            gst_percent: Number(document.getElementById('bookingGstPercent').value || 0),
            paid_amount: Number(document.getElementById('manualPaidAmount').value),
            from_date: selections.fromDate,
            to_date: selections.toDate,
            departure_date: selections.departureDate,
            inquiry_id: selections.inquiryId,
            passengers: Array.from(document.querySelectorAll('.passenger-form')).map((form, index) => ({
                full_name: form.querySelector('.p-full-name').value.trim(),
                age: form.querySelector('.p-age').value.trim(),
                gender: form.querySelector('.p-gender').value,
                dob: form.querySelector('.p-dob').value,
                passport_no: form.querySelector('.p-passport').value.trim(),
                passport_expiry: form.querySelector('.p-expiry').value,
                is_lead: index === 0
            }))
        };
        const res = await fetch('/admin/bookings/api/package-bookings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        if(data.success) {
            document.getElementById('tripStatus').innerHTML = '<span class="text-success font-weight-bold">Confirmed</span>';
            const msg = data.packageBookingReference
                ? `Package Booking ${data.packageBookingReference} Created! Redirecting...`
                : 'Booking Created! Redirecting...';
            document.getElementById('checkoutMessage').innerHTML = `<span class="text-success"><i class="fas fa-check"></i> ${msg}</span>`;
            setTimeout(() => { window.location.href = data.redirectUrl || '/admin/bookings/package-bookings'; }, 1500);
        } else {
            alert(data.message);
            setConfirmButtonState();
            btn.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Confirm Booking';
        }
    } catch(err) {
        alert("Error during checkout");
        setConfirmButtonState();
        document.getElementById('btnConfirmBooking').innerHTML = '<i class="fas fa-check-circle mr-2"></i> Confirm Booking';
    }
}
</script>
