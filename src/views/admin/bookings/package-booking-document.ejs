<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title><%= booking.booking_reference %> - Package Booking</title>
  <style>
    *{box-sizing:border-box}body{margin:0;background:#f5f7fb;color:#172033;font:13px/1.5 Arial,sans-serif}.doc{max-width:980px;margin:24px auto;background:#fff;border:1px solid #dfe3ea;padding:28px}.head{display:flex;justify-content:space-between;gap:20px;padding-bottom:18px;border-bottom:2px solid #172033}.title{font-size:23px;font-weight:800}.muted{color:#667085}.ref{font-size:15px;font-weight:800;text-align:right}.grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:18px}.card{border:1px solid #dfe3ea;border-radius:8px;padding:14px}.wide{grid-column:1/-1}.card h2{font-size:13px;margin:0 0 10px;text-transform:uppercase;letter-spacing:.05em}.row{display:flex;justify-content:space-between;gap:15px;padding:6px 0;border-bottom:1px solid #eef0f3}.row:last-child{border:0}.row span{color:#667085}.row strong{text-align:right}table{width:100%;border-collapse:collapse}th{background:#f7f8fa;color:#667085;font-size:10px;text-transform:uppercase;text-align:left}th,td{padding:8px;border:1px solid #e5e7eb;vertical-align:top}.total{font-size:16px;color:#067647}.foot{margin-top:20px;padding-top:12px;border-top:1px solid #dfe3ea;color:#667085;font-size:10px}@media print{body{background:#fff}.doc{margin:0;border:0;max-width:none;padding:10mm}.card{break-inside:avoid}}@media(max-width:650px){.doc{margin:0;padding:16px}.grid{grid-template-columns:1fr}.wide{grid-column:auto}.head{flex-direction:column}.ref{text-align:left}}
  </style>
</head>
<body>
<%
  const raw = booking.raw_payload || {};
  const passengers = Array.isArray(booking.passengers) ? booking.passengers : [];
  const hotels = Array.isArray(raw.hotels) ? raw.hotels : [];
  const route = Array.isArray(raw.route) ? raw.route : [];
  const money = value => `INR ${Number(value || 0).toLocaleString('en-IN',{minimumFractionDigits:2,maximumFractionDigits:2})}`;
  const dateText = value => value ? new Date(`${String(value).substring(0,10)}T00:00:00`).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : 'N/A';
%>
<main class="doc">
  <header class="head"><div><div class="title">Package Booking Summary</div><div class="muted"><%= booking.package_name || 'Package' %></div></div><div class="ref"><%= booking.booking_reference %><div class="muted">Generated <%= generatedAt.toLocaleString('en-IN') %></div></div></header>
  <div class="grid">
    <section class="card"><h2>Customer & travel</h2><div class="row"><span>Customer</span><strong><%= booking.customer_name || 'N/A' %></strong></div><div class="row"><span>Email</span><strong><%= booking.customer_email || 'N/A' %></strong></div><div class="row"><span>Phone</span><strong><%= booking.customer_phone || 'N/A' %></strong></div><div class="row"><span>From</span><strong><%= dateText(booking.from_date || raw.from_date) %></strong></div><div class="row"><span>To</span><strong><%= dateText(booking.to_date || raw.to_date) %></strong></div><div class="row"><span>Departure</span><strong><%= dateText(booking.departure_date || raw.departure_date) %></strong></div><% if(route.length){ %><div class="row"><span>Route</span><strong><%= route.join(' → ') %></strong></div><% } %></section>
    <section class="card"><h2>Payment</h2><div class="row"><span>Base package amount</span><strong><%= money(Number(booking.package_base_amount || 0) - Number(booking.hotel_amount || 0)) %></strong></div><div class="row"><span>Hotel amount</span><strong><%= money(booking.hotel_amount) %></strong></div><div class="row"><span>GST (<%= Number(booking.tax_percent || 0) %>%)</span><strong><%= money(booking.tax_amount) %></strong></div><div class="row"><span>Total</span><strong class="total"><%= money(booking.package_total) %></strong></div><div class="row"><span>Received</span><strong><%= money(booking.paid_amount) %></strong></div><div class="row"><span>Remaining</span><strong><%= money(booking.remaining_amount) %></strong></div><div class="row"><span>Status</span><strong><%= String(booking.payment_status || 'pending').replace(/_/g,' ') %></strong></div></section>
    <section class="card wide"><h2>Passengers (<%= passengers.length %>)</h2><% if(passengers.length){ %><table><thead><tr><th>Name</th><th>Age</th><th>Gender</th><th>DOB</th><th>Passport</th><th>Expiry</th></tr></thead><tbody><% passengers.forEach(p=>{ %><tr><td><%= p.full_name %><%= p.is_lead?' (Lead)':'' %></td><td><%= p.age||'—' %></td><td><%= p.gender||'—' %></td><td><%= dateText(p.dob) %></td><td><%= p.passport_no||'—' %></td><td><%= dateText(p.passport_expiry) %></td></tr><% }) %></tbody></table><% }else{ %><span class="muted">No passenger details.</span><% } %></section>
    <section class="card wide"><h2>Hotels (<%= hotels.length %>)</h2><% if(hotels.length){ %><table><thead><tr><th>Hotel</th><th>Destination</th><th>Rooms</th><th>Nights</th></tr></thead><tbody><% hotels.forEach(h=>{ %><tr><td><%= h.name||'Hotel' %></td><td><%= h.destination_name||'—' %></td><td><%= h.rooms||1 %></td><td><%= h.nights||1 %></td></tr><% }) %></tbody></table><% }else{ %><span class="muted">No hotel details.</span><% } %></section>
  </div>
  <footer class="foot">This document was generated from the package booking administration system.</footer>
</main>
</body>
</html>
