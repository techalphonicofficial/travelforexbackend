  .pb-row-actions{display:flex;align-items:flex-start;gap:.4rem;flex-wrap:wrap;min-width:150px;}
  .pb-action-view{background:#eff6ff;color:#2563eb;border-color:#bfdbfe;}
  .pb-action-download{background:#f8fafc;color:#334155;border-color:#cbd5e1;}
