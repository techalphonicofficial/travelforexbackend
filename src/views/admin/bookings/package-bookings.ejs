  .pb-summary-muted{font-size:.78rem;color:#64748b;line-height:1.45;margin-top:.18rem;}
  .pb-summary-table{width:100%;border-collapse:collapse;border:1px solid #e0e7ff;border-radius:8px;overflow:hidden;}
  .pb-summary-table th{background:#f8fafc;color:#475569;text-transform:uppercase;font-size:.72rem;letter-spacing:.03em;padding:.7rem;border-bottom:1px solid #e0e7ff;}
  .pb-summary-table td{padding:.7rem;border-bottom:1px solid #f1f5f9;font-size:.84rem;color:#334155;vertical-align:top;}
