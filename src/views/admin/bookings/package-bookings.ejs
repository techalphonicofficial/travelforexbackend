<div class="pb-shell">
  <div class="pb-header">
    <div>
      <h1 class="pb-title">Package Bookings</h1>
      <p class="pb-muted">Payment-verified package bookings with customer, vendor split, tax, and accounting status.</p>
    </div>
    <div class="pb-tabs">
      <a href="/admin/bookings/package-bookings" class="pb-tab active"><i class="bi bi-receipt-cutoff"></i> Package Bookings</a>
      <a href="/admin/bookings/return-requests" class="pb-tab"><i class="bi bi-arrow-counterclockwise"></i> Cancel Requests</a>
      <a href="/" class="pb-tab"><i class="bi bi-speedometer2"></i> Dashboard</a>

      <a href="/admin/bookings/hotel-bookings" class="pb-tab"><i class="bi bi-building"></i> Hotel Bookings</a>
    </div>
    <div>
      <a href="/admin/bookings/create" class="pb-btn" style="display:inline-flex;align-items:center;gap:0.4rem;text-decoration:none;white-space:nowrap;">
        <i class="bi bi-plus-lg"></i> Create Booking
      </a>
    </div>
  </div>

  <div class="pb-stats">
    <div class="pb-stat">
      <div class="pb-stat-label">Total Showing</div>
      <div class="pb-stat-value"><%= totalBookings || 0 %></div>
      <div class="pb-stat-sub">Current filtered bookings</div>
    </div>
    <div class="pb-stat">
      <div class="pb-stat-label">Package Total</div>
      <div class="pb-stat-value">INR <%= money(totalsSafe.packageTotal) %></div>
      <div class="pb-stat-sub">Booking value including tax</div>
    </div>
    <div class="pb-stat">
      <div class="pb-stat-label">Collected</div>
      <div class="pb-stat-value pb-positive">INR <%= money(totalsSafe.paidTotal) %></div>
      <div class="pb-stat-sub">Paid now / verified amount</div>
    </div>
    <div class="pb-stat">
      <div class="pb-stat-label">Remaining</div>
      <div class="pb-stat-value pb-warn">INR <%= money(totalsSafe.remainingTotal) %></div>
      <div class="pb-stat-sub">Balance receivable</div>
    </div>
    <div class="pb-stat">
      <div class="pb-stat-label">Vendor Payable</div>
      <div class="pb-stat-value">INR <%= money(totalsSafe.vendorTotal) %></div>
      <div class="pb-stat-sub">Hotel/package cost split</div>
    </div>
    <div class="pb-stat">
      <div class="pb-stat-label">Platform + Tax</div>
      <div class="pb-stat-value">INR <%= money(Number(totalsSafe.platformTotal || 0) + Number(totalsSafe.taxTotal || 0)) %></div>
      <div class="pb-stat-sub">Revenue INR <%= money(totalsSafe.platformTotal) %> / tax INR <%= money(totalsSafe.taxTotal) %></div>
    </div>
  </div>

  <div class="pb-toolbar">
    <form method="GET" action="/admin/bookings/package-bookings">
      <div class="pb-search">
        <i class="bi bi-search"></i>
        <input type="text" name="search" value="<%= searchQuery || '' %>" placeholder="Search booking ref, customer, vendor, coupon, package, payment id">
      </div>
      <select class="pb-select" name="status">
        <option value="">All Payment Statuses</option>
        <% statuses.forEach(statusName => { %>
          <option value="<%= statusName %>" <%= statusFilter === statusName ? 'selected' : '' %>><%= label(statusName) %></option>
        <% }) %>
      </select>
      <select class="pb-select" name="limit">
        <% limitOptions.forEach(option => { %>
          <option value="<%= option %>" <%= selectedLimit === option ? 'selected' : '' %>><%= option %> / page</option>
        <% }) %>
      </select>
      <button class="pb-btn" type="submit">Filter</button>
      <% if (searchQuery || statusFilter) { %>
        <a href="/admin/bookings/package-bookings" class="pb-action pb-clear">Clear</a>
      <% } %>
    </form>
  </div>

  <div class="pb-table-wrap">
    <table class="pb-table">
      <thead>
        <tr>
          <th>Booking</th>
          <th>Customer</th>
          <th>Package</th>
          <th>Collected</th>
          <th>Split</th>
          <th>Payment</th>
          <th>Accounting</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (bookings && bookings.length) { %>
          <% bookings.forEach(booking => { %>
            <%
              const raw = booking.raw_payload || {};
              const route = Array.isArray(raw.route) ? raw.route.join(' to ') : '';
              const hotels = Array.isArray(raw.hotels) ? raw.hotels : [];
              const hotelPaymentTotal = hotels.reduce((sum, hotel) => sum + Number(hotel.estimated_amount || 0), 0);
              const createdAt = booking.created_at ? new Date(booking.created_at) : null;
              const verifiedAt = booking.payment_verified_at ? new Date(booking.payment_verified_at) : null;
              const modalKey = String(booking.id || booking.booking_reference || '').replace(/[^a-zA-Z0-9_-]/g, '');
              const paidAmount = Number(booking.paid_amount || 0);
              const remainingAmount = Number(booking.remaining_amount || 0);
              const couponSnapshot = booking.coupon_snapshot || {};
              const rawCoupon = raw.coupon || raw.applied_coupon || {};
              const couponCode = booking.coupon_code || couponSnapshot.code || couponSnapshot.coupon_code || rawCoupon.code || rawCoupon.coupon_code || '';
              const couponDiscount = Number(booking.coupon_discount_amount || couponSnapshot.discount_amount || rawCoupon.discount_amount || rawCoupon.amount || 0);
              const hotelAmount = Number(booking.hotel_amount || 0);
              const baseAfterCoupon = Number(booking.package_base_amount || booking.package_price || 0) - hotelAmount;
              const baseBeforeCoupon = Number(couponSnapshot.booking_amount || (baseAfterCoupon + couponDiscount));
              const canAccount = booking.accounting_status === 'recorded';
              const canPayRemaining = canAccount && remainingAmount > 0;
              const departureInputValue = dateInputValue(findDepartureDate(raw));
              const returnClosed = raw.return_status === 'closed' || ['refunded', 'cancelled'].includes(String(booking.payment_status || '').toLowerCase());
              const canRefund = canProcessRefundAction && canAccount && !returnClosed && (paidAmount > 0 || remainingAmount > 0);
              const refundDisabledTitle = !canProcessRefundAction
                ? 'Only admin or manager can process package refunds'
                : (!canAccount ? 'Accounting must be recorded first' : (returnClosed ? 'Package return is already closed' : 'Nothing available to refund'));
            %>
            <tr>
              <td>
                <div class="pb-main"><%= booking.booking_reference %></div>
                <div class="pb-sub">Package ID: <%= booking.package_id || 'N/A' %></div>
                <% if (booking.page_url) { %>
                  <div class="pb-actions">
                    <a href="<%= booking.page_url %>" class="pb-action" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i> Source Page</a>
                  </div>
                <% } %>
              </td>
              <td>
                <div class="pb-main"><%= booking.customer_name || 'Guest Customer' %></div>
                <div class="pb-sub"><%= booking.customer_email || 'No email' %></div>
                <div class="pb-sub"><%= booking.customer_phone || 'No phone' %></div>
              </td>
              <td>
                <div class="pb-main"><%= booking.package_name || (booking.package && booking.package.name) || 'Package' %></div>
                <div class="pb-sub"><%= booking.package_slug || (booking.package && booking.package.slug) || 'No slug' %></div>
                <% if (route) { %>
                  <div class="pb-sub"><i class="bi bi-signpost-2"></i> <%= route %></div>
                <% } %>
                <% if (departureInputValue) { %>
                  <div class="pb-sub"><i class="bi bi-calendar-event"></i> Departure <%= new Date(departureInputValue).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                <% } %>
                <div class="pb-sub"><%= hotels.length || raw.hotel_count || 0 %> hotel<%= (hotels.length || raw.hotel_count || 0) === 1 ? '' : 's' %></div>
                <% if (booking.vendor) { %>
                  <div class="pb-sub">Vendor: <%= booking.vendor.name || booking.vendor.email || booking.vendor_id %></div>
                <% } else if (booking.vendor_id) { %>
                  <div class="pb-sub">Vendor ID: <%= booking.vendor_id %></div>
                <% } %>
              </td>
              <td>
                <div class="pb-mini-grid">
                  <div class="pb-money">Total INR <%= money(booking.package_total) %></div>
                  <div class="pb-sub">Paid INR <%= money(booking.paid_amount) %></div>
                  <div class="pb-sub">Remaining INR <%= money(booking.remaining_amount) %></div>
                  <% if (couponDiscount > 0 || couponCode) { %>
                    <div>
                      <span class="pb-pill pb-coupon-pill">
                        <i class="bi bi-ticket-perforated"></i>
                        <%= couponCode || 'Coupon Applied' %><% if (couponDiscount > 0) { %>: -INR <%= money(couponDiscount) %><% } %>
                      </span>
                    </div>
                  <% } %>
                  <% if (booking.partial_booking_enabled) { %>
                    <div><span class="pb-pill" style="background:#eef2ff;color:#4f46e5;"><%= Number(booking.partial_booking_percentage || 0) %>% paid now</span></div>
                  <% } %>
                </div>
              </td>
              <td>
                <div class="pb-mini-grid">
                  <div class="pb-money">Vendor INR <%= money(booking.vendor_amount) %></div>
                  <div class="pb-sub">Platform INR <%= money(booking.platform_amount) %></div>
                  <div class="pb-sub"><%= booking.tax_type || 'Tax' %> <%= Number(booking.tax_percent || 0) %>%: INR <%= money(booking.tax_amount) %></div>
                </div>
              </td>
              <td>
                <span class="pb-pill" style="<%= statusStyle[booking.payment_status] || statusStyle.pending %>"><%= label(booking.payment_status) %></span>
                <div class="pb-sub">Order: <%= booking.razorpay_order_id || 'N/A' %></div>
                <div class="pb-sub">Payment: <%= booking.razorpay_payment_id || 'N/A' %></div>
                <% if (booking.payment_verified_at) { %>
                  <div class="pb-sub">Verified <%= new Date(booking.payment_verified_at).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                <% } %>
              </td>
              <td>
                <span class="pb-pill" style="<%= accountingStyle[booking.accounting_status] || accountingStyle.pending %>"><%= label(booking.accounting_status) %></span>
                <div class="pb-sub">Entry: <%= booking.accounting_entry_id || 'Not posted' %></div>
              </td>
              <td>
                <% if (createdAt) { %>
                  <div class="pb-main"><%= createdAt.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
                  <div class="pb-sub"><%= createdAt.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></div>
                <% } else { %>
                  <div class="pb-sub">No date</div>
                <% } %>
              </td>
              <td>
                <div class="pb-row-actions">
                  <a href="/admin/bookings/package-bookings/<%= booking.id %>" class="pb-action pb-action-view"><i class="bi bi-eye"></i> View</a>
                  <a href="/admin/bookings/package-bookings/<%= booking.id %>/edit" class="pb-action pb-action-edit"><i class="bi bi-pencil-square"></i> Edit</a>
                  <a href="/admin/bookings/package-bookings/<%= booking.id %>/download" class="pb-action pb-action-download"><i class="bi bi-download"></i> Download</a>
                  <% if (canPayRemaining) { %>
                    <button type="button" class="pb-action pb-action-pay" data-bs-toggle="modal" data-bs-target="#payRemainingModal<%= modalKey %>">
                      <i class="bi bi-cash-coin"></i> Pay Remaining
                    </button>
                  <% } else { %>
                    <button type="button" class="pb-action pb-action-disabled" disabled title="<%= canAccount ? 'No remaining amount' : 'Accounting must be recorded first' %>">
                      <i class="bi bi-cash-coin"></i> Pay Remaining
                    </button>
                  <% } %>
                  <% if (canRefund) { %>
                    <button type="button" class="pb-action pb-action-refund" data-bs-toggle="modal" data-bs-target="#refundModal<%= modalKey %>">
                      <i class="bi bi-arrow-counterclockwise"></i> Return / Refund
                    </button>
                  <% } else { %>
                    <button type="button" class="pb-action pb-action-disabled" disabled title="<%= refundDisabledTitle %>">
                      <i class="bi bi-arrow-counterclockwise"></i> Return / Refund
                    </button>
                  <% } %>
                </div>

                <div class="modal fade" id="bookingSummaryModal<%= modalKey %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Booking Summary</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="pb-summary" id="bookingSummaryContent<%= modalKey %>">
                          <div class="pb-summary-head">
                            <div>
                              <h2 class="pb-summary-title"><%= booking.booking_reference %></h2>
                              <div class="pb-summary-muted">Package ID <%= booking.package_id || 'N/A' %> | <%= booking.package_slug || 'No slug' %></div>
                            </div>
                            <div>
                              <span class="pb-pill" style="<%= statusStyle[booking.payment_status] || statusStyle.pending %>"><%= label(booking.payment_status) %></span>
                              <span class="pb-pill ms-1" style="<%= accountingStyle[booking.accounting_status] || accountingStyle.pending %>"><%= label(booking.accounting_status) %></span>
                            </div>
                          </div>

                          <div class="pb-summary-grid">
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Customer</div>
                              <div class="pb-summary-value"><%= booking.customer_name || 'Guest Customer' %></div>
                              <div class="pb-summary-muted"><%= booking.customer_email || 'No email' %></div>
                              <div class="pb-summary-muted"><%= booking.customer_phone || 'No phone' %></div>
                            </div>
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Package</div>
                              <div class="pb-summary-value"><%= booking.package_name || (booking.package && booking.package.name) || 'Package' %></div>
                              <div class="pb-summary-muted">Duration: <%= booking.duration || raw.duration || 'N/A' %></div>
                              <div class="pb-summary-muted">Route: <%= route || 'Route not added' %></div>
                              <div class="pb-summary-muted"><%= hotels.length || raw.hotel_count || 0 %> hotel<%= (hotels.length || raw.hotel_count || 0) === 1 ? '' : 's' %></div>
                            </div>
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Created</div>
                              <div class="pb-summary-value"><%= createdAt ? createdAt.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'No date' %></div>
                              <div class="pb-summary-muted"><%= createdAt ? createdAt.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) : '' %></div>
                              <% if (booking.page_url) { %>
                                <div class="pb-summary-muted">Source: <a href="<%= booking.page_url %>" target="_blank" rel="noopener">Open package page</a></div>
                              <% } else { %>
                                <div class="pb-summary-muted">Source: N/A</div>
                              <% } %>
                            </div>
                          </div>

                          <div class="pb-summary-grid">
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Collected</div>
                              <div class="pb-summary-value">INR <%= money(booking.package_total) %></div>
                              <% if (couponDiscount > 0 || couponCode) { %>
                                <div class="pb-summary-muted">Original base INR <%= money(baseBeforeCoupon) %></div>
                                <div class="pb-summary-muted">Coupon <%= couponCode || 'Applied' %><% if (couponDiscount > 0) { %>: -INR <%= money(couponDiscount) %><% } %></div>
                              <% } %>
                              <div class="pb-summary-muted">Base INR <%= money(baseAfterCoupon || booking.package_base_amount || booking.package_price) %></div>
                              <div class="pb-summary-muted">Paid INR <%= money(booking.paid_amount) %></div>
                              <div class="pb-summary-muted">Remaining INR <%= money(booking.remaining_amount) %></div>
                              <div class="pb-summary-muted"><%= Number(booking.partial_booking_percentage || 0) %>% paid now</div>
                            </div>
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Split</div>
                              <div class="pb-summary-value">Vendor INR <%= money(booking.vendor_amount) %></div>
                              <div class="pb-summary-muted">Platform INR <%= money(booking.platform_amount) %></div>
                              <div class="pb-summary-muted"><%= booking.tax_type || 'Tax' %> <%= Number(booking.tax_percent || 0) %>%: INR <%= money(booking.tax_amount) %></div>
                              <div class="pb-summary-muted">Hotel payment total INR <%= money(hotelPaymentTotal) %></div>
                              <% if (booking.vendor_split_basis) { %>
                                <div class="pb-summary-muted">Basis: <%= label(booking.vendor_split_basis) %></div>
                              <% } %>
                            </div>
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Payment</div>
                              <div class="pb-summary-value"><%= label(booking.payment_status) %></div>
                              <div class="pb-summary-muted">Order: <%= booking.razorpay_order_id || 'N/A' %></div>
                              <div class="pb-summary-muted">Payment: <%= booking.razorpay_payment_id || 'N/A' %></div>
                              <div class="pb-summary-muted">Verified: <%= verifiedAt ? verifiedAt.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %></div>
                            </div>
                            <div class="pb-summary-card">
                              <div class="pb-summary-label">Accounting</div>
                              <div class="pb-summary-value"><%= label(booking.accounting_status) %></div>
                              <div class="pb-summary-muted">Entry: <%= booking.accounting_entry_id || 'Not posted' %></div>
                              <div class="pb-summary-muted">Vendor: <%= booking.vendor ? (booking.vendor.name || booking.vendor.email || booking.vendor_id) : (booking.vendor_id || 'N/A') %></div>
                            </div>
                          </div>

                          <div class="pb-summary-card pb-summary-card-wide">
                            <div class="pb-summary-label mb-2">Hotel Payments</div>
                            <table class="pb-summary-table">
                              <thead>
                                <tr>
                                  <th>Hotel</th>
                                  <th>Destination</th>
                                  <th>Stay</th>
                                  <th>Rating</th>
                                  <th>Rate</th>
                                  <th>Amount</th>
                                  <th>Notes</th>
                                </tr>
                              </thead>
                              <tbody>
                                <% if (hotels.length) { %>
                                  <% hotels.forEach((hotel, hotelIndex) => { %>
                                    <tr>
                                      <td><strong><%= hotel.name || ('Hotel #' + (hotel.hotel_id || hotelIndex + 1)) %></strong><div class="pb-summary-muted">Hotel ID: <%= hotel.hotel_id || 'N/A' %></div></td>
                                      <td><%= hotel.destination || 'N/A' %></td>
                                      <td><%= hotel.rooms || 1 %> room<%= Number(hotel.rooms || 1) === 1 ? '' : 's' %><div class="pb-summary-muted"><%= hotel.nights || 0 %> night<%= Number(hotel.nights || 0) === 1 ? '' : 's' %></div></td>
                                      <td><%= hotel.star_rating || 'N/A' %> star<div class="pb-summary-muted">Guest <%= hotel.guest_rating || 'N/A' %></div></td>
                                      <td>INR <%= money(hotel.price_per_night) %></td>
                                      <td><strong>INR <%= money(hotel.estimated_amount) %></strong></td>
                                      <td><%= hotel.notes || 'N/A' %></td>
                                    </tr>
                                  <% }) %>
                                <% } else { %>
                                  <tr><td colspan="7" class="text-center text-muted py-4">No hotel-wise payment added.</td></tr>
                                <% } %>
                              </tbody>
                              <% if (hotels.length) { %>
                                <tfoot>
                                  <tr>
                                    <td colspan="5">Hotel Payment Total</td>
                                    <td>INR <%= money(hotelPaymentTotal) %></td>
                                    <td></td>
                                  </tr>
                                </tfoot>
                              <% } %>
                            </table>
                          </div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                        <a href="/admin/bookings/package-bookings/<%= booking.id %>/download" class="btn btn-primary"><i class="bi bi-download"></i> Download Booking</a>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="modal fade" id="payRemainingModal<%= modalKey %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form class="pb-admin-action-form" method="POST" action="/admin/bookings/package-bookings/<%= booking.id %>/pay-remaining">
                        <div class="modal-header">
                          <h5 class="modal-title">Pay Remaining</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                          <div class="pb-main mb-1"><%= booking.booking_reference %></div>
                          <div class="pb-sub mb-3">Remaining INR <%= money(remainingAmount) %></div>
                          <div class="pb-modal-grid">
                            <div>
                              <label class="pb-modal-label">Amount</label>
                              <input class="pb-modal-input" type="number" name="amount" min="1" max="<%= remainingAmount %>" step="0.01" value="<%= remainingAmount %>" required>
                              <div class="pb-modal-help">Cannot exceed current remaining amount.</div>
                            </div>
                            <div>
                              <label class="pb-modal-label">Payment Reference</label>
                              <input class="pb-modal-input" type="text" name="reference" placeholder="Manual / gateway reference">
                            </div>
                            <div>
                              <label class="pb-modal-label">Razorpay Order ID</label>
                              <input class="pb-modal-input" type="text" name="razorpay_order_id" placeholder="order_xxx">
                            </div>
                            <div>
                              <label class="pb-modal-label">Razorpay Payment ID</label>
                              <input class="pb-modal-input" type="text" name="razorpay_payment_id" placeholder="pay_xxx">
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-success"><i class="bi bi-check2-circle"></i> Record Payment</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

                <% if (canRefund) { %>
                <div class="modal fade" id="refundModal<%= modalKey %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form class="pb-admin-action-form" method="POST" action="/admin/bookings/package-bookings/<%= booking.id %>/refund">
                        <input type="hidden" name="apply_cancellation_rule" value="1">
                        <div class="modal-header">
                          <h5 class="modal-title">Return / Refund</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                          <div class="pb-main mb-1"><%= booking.booking_reference %></div>
                          <div class="pb-sub mb-3">Paid INR <%= money(paidAmount) %> · Remaining INR <%= money(remainingAmount) %></div>
                          <div class="pb-modal-grid">
                            <div>
                              <label class="pb-modal-label">Departure Date</label>
                              <input class="pb-modal-input" type="date" name="departure_date" value="<%= departureInputValue %>" required>
                              <div class="pb-modal-help">Used to apply the active cancellation rule.</div>
                            </div>
                            <div>
                              <label class="pb-modal-label">Paid Amount</label>
                              <input class="pb-modal-input" type="text" value="INR <%= money(paidAmount) %>" readonly>
                              <div class="pb-modal-help">Refund is calculated by rule and credited to the customer account.</div>
                            </div>
                            <div>
                              <label class="pb-modal-label">Cancel Remaining</label>
                              <input class="pb-modal-input" type="number" name="cancel_remaining_amount" min="0" max="<%= remainingAmount %>" step="0.01" value="<%= remainingAmount %>">
                              <div class="pb-modal-help">Unpaid receivable to cancel.</div>
                            </div>
                            <div>
                              <label class="pb-modal-label">Refund Reference</label>
                              <input class="pb-modal-input" type="text" name="refund_reference" placeholder="rfnd_manual_001">
                            </div>
                            <div>
                              <label class="pb-modal-label">Razorpay Refund ID</label>
                              <input class="pb-modal-input" type="text" name="razorpay_refund_id" placeholder="rfnd_xxx">
                            </div>
                          </div>
                          <div class="mt-3">
                            <label class="pb-modal-label">Reason</label>
                            <input class="pb-modal-input" type="text" name="reason" placeholder="Customer requested cancellation">
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn btn-warning"><i class="bi bi-arrow-counterclockwise"></i> Record Return</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>
                <% } %>

                <!-- Edit Booking Modal -->
                <div class="modal fade" id="editBookingModal<%= modalKey %>" tabindex="-1" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                      <form method="POST" action="/admin/bookings/package-bookings/<%= booking.id %>/edit">
                        <div class="modal-header">
                          <h5 class="modal-title"><i class="bi bi-pencil-square" style="color:#7c3aed;"></i> Edit Booking</h5>
                          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                          <div class="pb-main mb-1"><%= booking.booking_reference %></div>
                          <div class="pb-sub mb-3"><%= booking.package_name || booking.package_slug || 'N/A' %></div>
                          <div class="pb-modal-grid">
                            <div>
                              <label class="pb-modal-label">Payment Status</label>
                              <select class="pb-modal-input" name="payment_status">
                                <% statuses.forEach(s => { %>
                                  <option value="<%= s %>" <%= booking.payment_status === s ? 'selected' : '' %>><%= label(s) %></option>
                                <% }) %>
                              </select>
                            </div>
                            <div>
                              <label class="pb-modal-label">Accounting Status</label>
                              <select class="pb-modal-input" name="accounting_status">
                                <% ['pending', 'recorded', 'posted', 'failed'].forEach(s => { %>
                                  <option value="<%= s %>" <%= booking.accounting_status === s ? 'selected' : '' %>><%= label(s) %></option>
                                <% }) %>
                              </select>
                            </div>
                            <div>
                              <label class="pb-modal-label">Customer Name</label>
                              <input class="pb-modal-input" type="text" name="customer_name" value="<%= booking.customer_name || '' %>">
                            </div>
                            <div>
                              <label class="pb-modal-label">Customer Email</label>
                              <input class="pb-modal-input" type="email" name="customer_email" value="<%= booking.customer_email || '' %>">
                            </div>
                            <div>
                              <label class="pb-modal-label">Customer Phone</label>
                              <input class="pb-modal-input" type="text" name="customer_phone" value="<%= booking.customer_phone || '' %>">
                            </div>
                          </div>
                        </div>
                        <div class="modal-footer">
                          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                          <button type="submit" class="btn" style="background:#7c3aed;color:#fff;"><i class="bi bi-check2-circle"></i> Save Changes</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="9">
              <div class="pb-empty">
                <i class="bi bi-inbox"></i>
                <div class="mt-2 fw-bold">No package bookings found.</div>
                <div class="mt-1">When a package payment is verified, it will appear here with the accounting split.</div>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (totalBookings > 0) { %>
    <div class="pagination-row">
      <div class="text-muted small">Showing <%= startItem %>-<%= endItem %> of <%= totalBookings %></div>
      <div class="d-flex gap-1">
        <% if (currentPage > 1) { %>
          <a href="<%= pageUrl(currentPage - 1) %>" title="Previous"><i class="bi bi-chevron-left"></i></a>
        <% } else { %>
          <span class="disabled"><i class="bi bi-chevron-left"></i></span>
        <% } %>
        <% pageItems.forEach(item => { %>
          <% if (item === '...') { %>
            <span class="disabled">...</span>
          <% } else if (item === currentPage) { %>
            <span class="active"><%= item %></span>
          <% } else { %>
            <a href="<%= pageUrl(item) %>"><%= item %></a>
          <% } %>
        <% }) %>
        <% if (currentPage < totalPagesSafe) { %>
          <a href="<%= pageUrl(currentPage + 1) %>" title="Next"><i class="bi bi-chevron-right"></i></a>
        <% } else { %>
          <span class="disabled"><i class="bi bi-chevron-right"></i></span>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<script>
  document.querySelectorAll('.pb-admin-action-form').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn ? submitBtn.innerHTML : '';
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Saving';
      }

      const formData = new FormData(form);
      const payload = {};
      formData.forEach((value, key) => {
        if (value === '') return;
        payload[key] = value;
      });

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        const result = await response.json();
        if (!response.ok || !result.success) {
          throw new Error(result.message || 'Unable to update booking');
        }
        window.location.reload();
      } catch (error) {
        alert(error.message || 'Unable to update booking');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      }
    });
  });
</script>
