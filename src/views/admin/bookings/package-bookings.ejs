  .pb-action-edit{background:#faf5ff;color:#7c3aed;border-color:#d8b4fe;}
  .pb-action-disabled{background:#f8fafc;color:#94a3b8;border-color:#e2e8f0;cursor:not-allowed;}
  .pb-action[disabled]{opacity:.7;}
  .pb-modal-label{font-size:.78rem;font-weight:800;color:#475569;margin-bottom:.25rem;}
  .pb-modal-input{border:1px solid #dbe3ef;border-radius:8px;padding:.62rem .75rem;width:100%;outline:none;}
  .pb-modal-help{font-size:.75rem;color:#64748b;margin-top:.25rem;}
  .pb-modal-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.75rem;}
  .pb-summary{display:grid;gap:1rem;}
  .pb-summary-head{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;border:1px solid #e0e7ff;background:#f8fafc;border-radius:8px;padding:1rem;}
  .pb-summary-title{font-size:1.05rem;font-weight:900;color:#111827;margin:0;}
  .pb-summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:.75rem;}
  .pb-summary-card{border:1px solid #e0e7ff;border-radius:8px;background:#fff;padding:.85rem;}
  .pb-summary-card-wide{grid-column:1/-1;}
  .pb-summary-label{font-size:.72rem;font-weight:900;text-transform:uppercase;color:#64748b;letter-spacing:.03em;}
