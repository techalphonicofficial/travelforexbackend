<%- contentFor('body') %>

<%
const statuses = paymentStatuses || ['pending', 'payment_initiated', 'paid', 'payment_verified', 'failed', 'cancelled'];
const canProcessRefundAction = Boolean(locals.canProcessPackageRefund);
const statusStyle = {
  pending: 'background:#f1f5f9;color:#475569;',
  payment_initiated: 'background:#fef3c7;color:#92400e;',
  paid: 'background:#dcfce7;color:#166534;',
  payment_verified: 'background:#dcfce7;color:#166534;',
  partial_paid: 'background:#e0f2fe;color:#0369a1;',
  partially_refunded: 'background:#ffedd5;color:#9a3412;',
  partially_cancelled: 'background:#fef3c7;color:#92400e;',
  refunded: 'background:#fee2e2;color:#991b1b;',
  failed: 'background:#fee2e2;color:#991b1b;',
  cancelled: 'background:#fee2e2;color:#991b1b;'
};
const accountingStyle = {
  pending: 'background:#fef3c7;color:#92400e;',
  recorded: 'background:#fef3c7;color:#92400e;',
  posted: 'background:#dcfce7;color:#166534;',
  failed: 'background:#fee2e2;color:#991b1b;'
};
const selectedLimit = limit || 10;
const totalPagesSafe = Math.max(1, totalPages || 1);
const startItem = totalBookings ? ((currentPage - 1) * selectedLimit) + 1 : 0;
const endItem = Math.min(currentPage * selectedLimit, totalBookings || 0);
const pageItems = [];
for (let pageNo = 1; pageNo <= totalPagesSafe; pageNo++) {
  if (pageNo === 1 || pageNo === totalPagesSafe || Math.abs(pageNo - currentPage) <= 1) {
    pageItems.push(pageNo);
  } else if (pageItems[pageItems.length - 1] !== '...') {
    pageItems.push('...');
  }
}
const pageUrl = (pageNo) => `/admin/bookings/package-bookings?page=${pageNo}&limit=${selectedLimit}&search=${encodeURIComponent(searchQuery || '')}&status=${encodeURIComponent(statusFilter || '')}`;
const money = (value) => Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const label = (value) => String(value || 'pending').replace(/_/g, ' ');
const totalsSafe = totals || {};
const dateInputValue = (value) => {
  if (!value) return '';
  if (typeof value === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(value.trim())) return value.trim();
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '';
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${date.getFullYear()}-${month}-${day}`;
};
const findDepartureDate = (raw = {}) => {
  const keys = ['departure_date', 'departureDate', 'travel_date', 'travelDate', 'start_date', 'startDate', 'trip_start_date', 'tripStartDate', 'journey_date', 'journeyDate', 'package_start_date', 'packageStartDate', 'selected_date', 'selectedDate'];
  const sources = [raw, raw.trip, raw.travel, raw.booking, raw.package_date, raw.packageDate, raw.custom_fields, raw.customFields].filter(Boolean);
  for (const source of sources) {
    for (const key of keys) {
      if (source[key]) return source[key];
    }
  }
  return '';
};
%>

