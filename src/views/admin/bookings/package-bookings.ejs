  .pagination-row a,.pagination-row span{display:inline-flex;align-items:center;justify-content:center;min-width:34px;height:34px;border-radius:7px;text-decoration:none;color:#4f46e5;font-weight:700;border:1px solid #e2e8f0;background:#fff;}
