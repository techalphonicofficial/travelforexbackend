<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vendor Login - Picktrails</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <%
        const vendorAuthThemeColours = typeof theme_colours === 'object' && theme_colours ? theme_colours : {};
        const vendorAuthThemeValue = (key, fallback) => /^#[0-9a-fA-F]{6}$/.test(String(vendorAuthThemeColours[key] || ''))
            ? String(vendorAuthThemeColours[key]).toLowerCase()
            : fallback;
        const vendorAuthThemeRgb = color => [
            parseInt(color.slice(1, 3), 16),
            parseInt(color.slice(3, 5), 16),
            parseInt(color.slice(5, 7), 16)
        ].join(', ');
        const vendorAuthBrandPrimary = vendorAuthThemeValue('theme_brand_primary', '#026eb5');
        const vendorAuthBrandPrimaryHover = vendorAuthThemeValue('theme_brand_primary_hover', '#005f9f');
        const vendorAuthBrandPrimaryLight = vendorAuthThemeValue('theme_brand_primary_light', '#c5e5fb');
        const vendorAuthBrandPrimaryBorder = vendorAuthThemeValue('theme_brand_primary_border', '#7abfee');
        const vendorAuthBrandSecondary = vendorAuthThemeValue('theme_brand_secondary', '#fdce2e');
        const vendorAuthBrandSecondaryHover = vendorAuthThemeValue('theme_brand_secondary_hover', '#f6b800');
        const vendorAuthAccent = vendorAuthThemeValue('theme_color_accent', '#00b894');
        const vendorAuthAccentHover = vendorAuthThemeValue('theme_color_accent_hover', '#00a382');
    %>
    <style>
        :root {
            --brand-primary: <%= vendorAuthBrandPrimary %>;
            --brand-primary-hover: <%= vendorAuthBrandPrimaryHover %>;
            --brand-primary-light: <%= vendorAuthBrandPrimaryLight %>;
            --brand-primary-border: <%= vendorAuthBrandPrimaryBorder %>;
            --brand-secondary: <%= vendorAuthBrandSecondary %>;
            --brand-secondary-hover: <%= vendorAuthBrandSecondaryHover %>;
            --color-primary: var(--brand-primary);
            --color-primary-hover: var(--brand-primary-hover);
            --color-primary-light: var(--brand-primary-light);
            --color-secondary: var(--brand-secondary);
            --color-secondary-hover: var(--brand-secondary-hover);
            --bs-primary: var(--color-primary);
            --bs-secondary: var(--color-secondary);
            --bs-link-color: var(--color-primary);
            --bs-link-hover-color: var(--color-primary-hover);
            --bs-primary-rgb: <%= vendorAuthThemeRgb(vendorAuthBrandPrimary) %>;
            --bs-secondary-rgb: <%= vendorAuthThemeRgb(vendorAuthBrandSecondary) %>;
            --color-accent: <%= vendorAuthAccent %>;
            --color-accent-hover: <%= vendorAuthAccentHover %>;
            --primary: var(--color-primary);
            --primary-hover: var(--color-primary-hover);
            --primary-light: var(--color-primary-light);
            --secondary: var(--color-secondary);
            --secondary-hover: var(--color-secondary-hover);
            --accent: var(--color-accent);
            --accent-hover: var(--color-accent-hover);
            --bg-dark: #0f172a;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Outfit', sans-serif; }
        body {
            background-color: var(--bg-dark);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image: 
                radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.2) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(236, 72, 153, 0.2) 0px, transparent 50%);
        }
        .login-card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(15px);
            padding: 3rem;
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            width: 100%;
            max-width: 450px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .logo {
            text-align: center;
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 2rem;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .form-group { margin-bottom: 1.5rem; }
        label { display: block; color: #94a3b8; margin-bottom: 0.5rem; font-size: 0.9rem; }
        input {
            width: 100%;
            padding: 0.8rem 1.2rem;
            background: rgba(15, 23, 42, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s;
        }
        input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
        }
        .btn {
            width: 100%;
            padding: 1rem;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            border: none;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: transform 0.3s, opacity 0.3s;
            margin-top: 1rem;
        }
        .btn:hover { transform: translateY(-2px); opacity: 0.9; }
        .error {
            background: rgba(248, 113, 113, 0.1);
            color: #f87171;
            padding: 0.8rem;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
            text-align: center;
            border: 1px solid rgba(248, 113, 113, 0.2);
        }
        .notice {
            background: rgba(16, 185, 129, 0.12);
            color: #86efac;
            padding: 0.8rem;
            border-radius: 10px;
            font-size: 0.85rem;
            margin-bottom: 1.5rem;
            text-align: center;
            border: 1px solid rgba(16, 185, 129, 0.22);
        }
        .footer-text {
            text-align: center;
            margin-top: 2rem;
            color: #64748b;
            font-size: 0.9rem;
        }
        .footer-text a { color: var(--primary); text-decoration: none; font-weight: 500; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">Vendors Login</div>
        <h2 style="color: white; margin-bottom: 1.5rem; text-align: center;">Welcome Back</h2>
        
        <% if (locals.error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        <% if (locals.message) { %>
            <div class="notice"><%= message %></div>
        <% } %>

        <form action="/vendor/login" method="POST">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" placeholder="vendor@example.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn">Login to Dashboard</button>
        </form>

        <div class="footer-text">
            Don't have a vendor account? <a href="/vendor/register">Register here</a>
        </div>
    </div>
</body>
</html>
