<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'Vendor Register - Picktrails' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --ink: #111827;
            --muted: #64748b;
            --line: #dbe4f0;
            --panel: #ffffff;
            --field: #f8fafc;
            --navy: #111a2e;
            --teal: #14b8a6;
            --violet: #6554f0;
            --coral: #f97362;
            --danger: #dc2626;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
        }

        body {
            min-height: 100vh;
            background:
                linear-gradient(135deg, rgba(20, 184, 166, 0.16), transparent 34%),
                linear-gradient(225deg, rgba(249, 115, 98, 0.12), transparent 38%),
                #eef3f8;
            color: var(--ink);
            padding: 32px;
        }

        .register-shell {
            width: min(1180px, 100%);
            margin: 0 auto;
            display: grid;
            grid-template-columns: 340px minmax(0, 1fr);
            background: var(--panel);
            border: 1px solid rgba(17, 24, 39, 0.08);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 28px 80px rgba(15, 23, 42, 0.16);
        }

        .brand-panel {
            background: linear-gradient(160deg, #111a2e 0%, #17213a 56%, #222044 100%);
            color: white;
            padding: 34px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 100%;
        }

        .brand-mark {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: 0;
        }

        .brand-mark i {
            width: 42px;
            height: 42px;
            display: grid;
            place-items: center;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--teal), var(--violet));
            box-shadow: 0 14px 32px rgba(20, 184, 166, 0.28);
        }

        .brand-copy {
            margin: 46px 0;
        }

        .brand-copy h1 {
            font-size: clamp(2rem, 4vw, 3.15rem);
            line-height: 1.02;
            letter-spacing: 0;
            margin-bottom: 18px;
        }

        .brand-copy p {
            color: #b7c3d5;
            line-height: 1.7;
            font-size: 1rem;
        }

        .trust-list {
            display: grid;
            gap: 14px;
            color: #dbeafe;
            font-size: 0.94rem;
        }

        .trust-list span {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .trust-list i {
            color: var(--teal);
        }

        .login-link {
            margin-top: 34px;
            color: #b7c3d5;
            font-size: 0.95rem;
        }

        .login-link a {
            color: white;
            font-weight: 700;
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.45);
        }

        .form-panel {
            padding: 34px;
            background: #fbfdff;
        }

        .form-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
            padding-bottom: 22px;
            border-bottom: 1px solid var(--line);
            margin-bottom: 24px;
        }

        .form-header h2 {
            font-size: 1.8rem;
            letter-spacing: 0;
            margin-bottom: 8px;
        }

        .form-header p {
            color: var(--muted);
            line-height: 1.55;
        }

        .status-pill {
            flex: 0 0 auto;
            border: 1px solid rgba(20, 184, 166, 0.22);
            color: #04756b;
            background: rgba(20, 184, 166, 0.09);
            padding: 9px 12px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.84rem;
        }

        .error {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: #fff1f2;
            color: #991b1b;
            border: 1px solid #fecdd3;
            padding: 13px 14px;
            border-radius: 12px;
            margin-bottom: 22px;
            line-height: 1.45;
        }

        .register-form {
            display: grid;
            gap: 26px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            font-weight: 800;
            margin-bottom: 14px;
            color: #0f172a;
        }

        .section-title i {
            width: 32px;
            height: 32px;
            display: grid;
            place-items: center;
            border-radius: 9px;
            background: #e8f8f5;
            color: #0f9488;
        }

        .field-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        .field {
            display: grid;
            gap: 7px;
        }

        .field.full {
            grid-column: 1 / -1;
        }

        label {
            color: #334155;
            font-size: 0.9rem;
            font-weight: 700;
        }

        .req {
            color: var(--danger);
        }

        input,
        select,
        textarea {
            width: 100%;
            border: 1px solid var(--line);
            background: var(--field);
            color: #0f172a;
            border-radius: 12px;
            padding: 12px 13px;
            font-size: 0.96rem;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
        }

        textarea {
            min-height: 88px;
            resize: vertical;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--violet);
            background: white;
            box-shadow: 0 0 0 4px rgba(101, 84, 240, 0.12);
        }

        .terms-row {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            background: #f1f7f8;
            border: 1px solid #d7eaeb;
            padding: 14px;
            border-radius: 12px;
            color: #334155;
            line-height: 1.5;
        }

        .terms-row input {
            width: 18px;
            height: 18px;
            margin-top: 2px;
            accent-color: var(--teal);
            flex: 0 0 auto;
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 14px;
            padding-top: 4px;
        }

        .ghost-link {
            color: #475569;
            text-decoration: none;
            font-weight: 700;
        }

        .submit-btn {
            border: 0;
            color: white;
            background: linear-gradient(135deg, var(--violet), var(--teal));
            border-radius: 12px;
            padding: 13px 22px;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            box-shadow: 0 14px 28px rgba(101, 84, 240, 0.24);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .submit-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 34px rgba(20, 184, 166, 0.22);
        }

        @media (max-width: 920px) {
            body {
                padding: 18px;
            }

            .register-shell {
                grid-template-columns: 1fr;
            }

            .brand-panel {
                min-height: auto;
            }

            .brand-copy {
                margin: 30px 0;
            }
        }

        @media (max-width: 640px) {
            body {
                padding: 0;
                background: #fbfdff;
            }

            .register-shell {
                border-radius: 0;
                border: 0;
                box-shadow: none;
            }

            .brand-panel,
            .form-panel {
                padding: 24px 18px;
            }

            .form-header {
                display: grid;
            }

            .field-grid {
                grid-template-columns: 1fr;
            }

            .form-actions {
                display: grid;
                grid-template-columns: 1fr;
            }

            .ghost-link,
            .submit-btn {
                text-align: center;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <%
        const formData = locals.form || {};
        const val = (key) => formData[key] || '';
        const selected = (key, value) => val(key) === value ? 'selected' : '';
        const termsChecked = formData.terms_accepted ? 'checked' : '';
    %>
    <main class="register-shell">
        <aside class="brand-panel">
            <div>
                <div class="brand-mark">
                    <i class="fa-solid fa-route"></i>
                    <span>Vendor</span>
                </div>
                <div class="brand-copy">
                    <h1>Join the travel partner dashboard</h1>
                    <p>Create packages, manage payouts, and keep your travel products ready for review from one vendor workspace.</p>
                </div>
                <div class="trust-list">
                    <span><i class="fa-solid fa-check"></i> Business profile captured</span>
                    <span><i class="fa-solid fa-check"></i> Bank details ready for payouts</span>
                    <span><i class="fa-solid fa-check"></i> Package dashboard access after signup</span>
                </div>
            </div>
            <div class="login-link">
                Already registered? <a href="/vendor/login">Login here</a>
            </div>
        </aside>

        <section class="form-panel">
            <div class="form-header">
                <div>
                    <h2>Vendor Registration</h2>
                    <p>Fill the required details so your vendor account and payout profile are complete.</p>
                </div>
                <div class="status-pill"><i class="fa-solid fa-shield-halved"></i> Secure signup</div>
            </div>

            <% if (locals.error) { %>
                <div class="error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error %></span>
                </div>
            <% } %>

            <form class="register-form" action="/vendor/register" method="POST">
                <section>
                    <div class="section-title"><i class="fa-solid fa-user-tie"></i> Account Details</div>
                    <div class="field-grid">
                        <div class="field">
                            <label>Owner / Contact Name <span class="req">*</span></label>
                            <input type="text" name="owner_name" value="<%= val('owner_name') %>" placeholder="Piyush Kumar" autocomplete="name" required>
                        </div>
                        <div class="field">
                            <label>Email Address <span class="req">*</span></label>
                            <input type="email" name="email" value="<%= val('email') %>" placeholder="vendor@example.com" autocomplete="email" required>
                        </div>
                        <div class="field">
                            <label>Phone Number <span class="req">*</span></label>
                            <input type="tel" name="phone" value="<%= val('phone') %>" placeholder="+91 98765 43210" autocomplete="tel" required>
                        </div>
                        <div class="field">
                            <label>Years in Business</label>
                            <input type="number" min="0" name="years_in_business" value="<%= val('years_in_business') %>" placeholder="5">
                        </div>
                        <div class="field">
                            <label>Password <span class="req">*</span></label>
                            <input type="password" name="password" placeholder="Minimum 8 characters" autocomplete="new-password" required>
                        </div>
                        <div class="field">
                            <label>Confirm Password <span class="req">*</span></label>
                            <input type="password" name="confirm_password" placeholder="Re-enter password" autocomplete="new-password" required>
                        </div>
                    </div>
                </section>

                <section>
                    <div class="section-title"><i class="fa-solid fa-building"></i> Business Details</div>
                    <div class="field-grid">
                        <div class="field">
                            <label>Business Name <span class="req">*</span></label>
                            <input type="text" name="business_name" value="<%= val('business_name') %>" placeholder="Your travel company" required>
                        </div>
                        <div class="field">
                            <label>Legal Name</label>
                            <input type="text" name="legal_name" value="<%= val('legal_name') %>" placeholder="Registered legal entity">
                        </div>
                        <div class="field">
                            <label>Business Type <span class="req">*</span></label>
                            <select name="business_type" required>
                                <option value="">Select type</option>
                                <option value="Travel Agency" <%= selected('business_type', 'Travel Agency') %>>Travel Agency</option>
                                <option value="Hotel Partner" <%= selected('business_type', 'Hotel Partner') %>>Hotel Partner</option>
                                <option value="Activity Partner" <%= selected('business_type', 'Activity Partner') %>>Activity Partner</option>
                                <option value="Transport Partner" <%= selected('business_type', 'Transport Partner') %>>Transport Partner</option>
                                <option value="DMC" <%= selected('business_type', 'DMC') %>>DMC</option>
                                <option value="Other" <%= selected('business_type', 'Other') %>>Other</option>
                            </select>
                        </div>
                        <div class="field">
                            <label>Website</label>
                            <input type="url" name="website" value="<%= val('website') %>" placeholder="https://example.com">
                        </div>
                        <div class="field">
                            <label>PAN Number <span class="req">*</span></label>
                            <input type="text" name="pan_number" value="<%= val('pan_number') %>" placeholder="ABCDE1234F" required>
                        </div>
                        <div class="field">
                            <label>GST Number</label>
                            <input type="text" name="gst_number" value="<%= val('gst_number') %>" placeholder="22AAAAA0000A1Z5">
                        </div>
                    </div>
                </section>

                <section>
                    <div class="section-title"><i class="fa-solid fa-location-dot"></i> Address & Coverage</div>
                    <div class="field-grid">
                        <div class="field full">
                            <label>Address Line 1 <span class="req">*</span></label>
                            <input type="text" name="address_line1" value="<%= val('address_line1') %>" placeholder="Office / building / street" autocomplete="address-line1" required>
                        </div>
                        <div class="field full">
                            <label>Address Line 2</label>
                            <input type="text" name="address_line2" value="<%= val('address_line2') %>" placeholder="Area / landmark" autocomplete="address-line2">
                        </div>
                        <div class="field">
                            <label>City <span class="req">*</span></label>
                            <input type="text" name="city" value="<%= val('city') %>" placeholder="New Delhi" autocomplete="address-level2" required>
                        </div>
                        <div class="field">
                            <label>State <span class="req">*</span></label>
                            <input type="text" name="state" value="<%= val('state') %>" placeholder="Delhi" autocomplete="address-level1" required>
                        </div>
                        <div class="field">
                            <label>Country <span class="req">*</span></label>
                            <input type="text" name="country" value="<%= val('country') || 'India' %>" autocomplete="country-name" required>
                        </div>
                        <div class="field">
                            <label>Pincode <span class="req">*</span></label>
                            <input type="text" name="pincode" value="<%= val('pincode') %>" placeholder="110001" autocomplete="postal-code" required>
                        </div>
                        <div class="field full">
                            <label>Service Regions</label>
                            <textarea name="service_regions" placeholder="Bali, Dubai, Thailand"><%= val('service_regions') %></textarea>
                        </div>
                    </div>
                </section>

                <section>
                    <div class="section-title"><i class="fa-solid fa-building-columns"></i> Operations & Bank</div>
                    <div class="field-grid">
                        <div class="field">
                            <label>Emergency Contact Name <span class="req">*</span></label>
                            <input type="text" name="emergency_contact_name" value="<%= val('emergency_contact_name') %>" placeholder="Operations manager" required>
                        </div>
                        <div class="field">
                            <label>Emergency Contact Phone <span class="req">*</span></label>
                            <input type="tel" name="emergency_contact_phone" value="<%= val('emergency_contact_phone') %>" placeholder="+91 98765 43210" required>
                        </div>
                        <div class="field">
                            <label>Account Holder Name <span class="req">*</span></label>
                            <input type="text" name="bank_account_name" value="<%= val('bank_account_name') %>" placeholder="Account holder" required>
                        </div>
                        <div class="field">
                            <label>Bank Name <span class="req">*</span></label>
                            <input type="text" name="bank_name" value="<%= val('bank_name') %>" placeholder="Bank name" required>
                        </div>
                        <div class="field">
                            <label>Account Number <span class="req">*</span></label>
                            <input type="text" name="bank_account_number" value="<%= val('bank_account_number') %>" placeholder="000000000000" inputmode="numeric" required>
                        </div>
                        <div class="field">
                            <label>IFSC / SWIFT Code <span class="req">*</span></label>
                            <input type="text" name="bank_ifsc" value="<%= val('bank_ifsc') %>" placeholder="HDFC0001234" required>
                        </div>
                    </div>
                </section>

                <label class="terms-row">
                    <input type="checkbox" name="terms_accepted" value="1" <%= termsChecked %> required>
                    <span>I confirm these vendor, business, and bank details are accurate and I agree to the  vendor terms.</span>
                </label>

                <div class="form-actions">
                    <a class="ghost-link" href="/vendor/login">Back to login</a>
                    <button class="submit-btn" type="submit">
                        <i class="fa-solid fa-arrow-right-to-bracket"></i> Create Vendor Account
                    </button>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
