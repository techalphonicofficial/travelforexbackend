<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2rem;
    }
    .stat-icon-box {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        margin-bottom: 1rem;
    }
    .vendor-booking-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 0.85rem 0;
        border-bottom: 1px solid var(--glass-border);
    }
    .vendor-booking-row:last-child { border-bottom: 0; }
    .vendor-booking-ref {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--nav-text);
    }
    .vendor-booking-sub {
        font-size: 0.72rem;
        color: var(--nav-muted);
        margin-top: 0.18rem;
    }
    .vendor-booking-amount {
        text-align: right;
        font-size: 0.85rem;
        font-weight: 800;
        color: #10b981;
        white-space: nowrap;
    }
</style>

<%
    const money = (value) => Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
    const recentVendorBookings = typeof recentBookings !== 'undefined' && Array.isArray(recentBookings) ? recentBookings : [];
%>

<div class="stats-grid">
    <div class="glass-card">
        <div class="stat-icon-box" style="background: rgba(79, 70, 229, 0.1); color: var(--primary);">
            <i class="fas fa-box-archive"></i>
        </div>
        <p style="color: var(--nav-muted); font-size: 0.85rem; font-weight: 500;">Total Packages</p>
        <h2 style="font-size: 1.8rem; margin-top: 0.4rem; color: var(--nav-text);"><%= stats.totalPackages %></h2>
    </div>

    <div class="glass-card">
        <div class="stat-icon-box" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
            <i class="fas fa-check-circle"></i>
        </div>
        <p style="color: var(--nav-muted); font-size: 0.85rem; font-weight: 500;">Active Packages</p>
        <h2 style="font-size: 1.8rem; margin-top: 0.4rem; color: var(--nav-text);"><%= stats.activePackages %></h2>
    </div>

    <div class="glass-card">
        <div class="stat-icon-box" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
            <i class="fas fa-wallet"></i>
        </div>
        <p style="color: var(--nav-muted); font-size: 0.85rem; font-weight: 500;">Wallet Balance</p>
        <h2 style="font-size: 1.8rem; margin-top: 0.4rem; color: var(--nav-text);"><%= stats.currency %> <%= stats.walletBalance %></h2>
    </div>

    <div class="glass-card">
        <div class="stat-icon-box" style="background: rgba(236, 72, 153, 0.1); color: #ec4899;">
            <i class="fas fa-users"></i>
        </div>
        <p style="color: var(--nav-muted); font-size: 0.85rem; font-weight: 500;">Total Bookings</p>
        <h2 style="font-size: 1.8rem; margin-top: 0.4rem; color: var(--nav-text);"><%= stats.totalBookings || 0 %></h2>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
    <div class="glass-card" style="min-height: 350px;">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.1rem;">Recent Performance</h3>
        <canvas id="performanceChart"></canvas>
    </div>

    <div class="glass-card">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.1rem;">Package Bookings</h3>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.8rem;margin-bottom:1rem;">
            <div style="background:rgba(16,185,129,0.08);border:1px solid rgba(16,185,129,0.14);border-radius:12px;padding:0.8rem;">
                <p style="font-size:0.7rem;color:var(--nav-muted);font-weight:700;margin:0 0 0.35rem;">Booking Value</p>
                <p style="font-size:1.05rem;color:#10b981;font-weight:800;margin:0;">₹<%= money(stats.totalBookingValue) %></p>
            </div>
            <div style="background:rgba(79,70,229,0.08);border:1px solid rgba(79,70,229,0.14);border-radius:12px;padding:0.8rem;">
                <p style="font-size:0.7rem;color:var(--nav-muted);font-weight:700;margin:0 0 0.35rem;">Vendor Share</p>
                <p style="font-size:1.05rem;color:var(--primary);font-weight:800;margin:0;">₹<%= money(stats.vendorPayableValue) %></p>
            </div>
        </div>
        <% if (recentVendorBookings.length > 0) { %>
            <% recentVendorBookings.forEach(booking => { %>
                <div class="vendor-booking-row">
                    <div>
                        <div class="vendor-booking-ref"><%= booking.booking_reference %></div>
                        <div class="vendor-booking-sub"><%= booking.package_name || 'Package booking' %></div>
                        <div class="vendor-booking-sub"><%= booking.customer_name || 'Guest customer' %> · <%= new Date(booking.created_at).toLocaleDateString('en-IN') %></div>
                    </div>
                    <div class="vendor-booking-amount">
                        ₹<%= money(booking.vendor_amount) %>
                        <div class="vendor-booking-sub"><%= booking.payment_status %></div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align:center;padding:2rem;">
                <i class="fas fa-suitcase-rolling" style="font-size:2rem;color:var(--nav-muted);opacity:0.3;display:block;margin-bottom:10px;"></i>
                <p style="color:var(--nav-muted);font-size:0.85rem;">No package bookings yet</p>
            </div>
        <% } %>
    </div>

    <div class="glass-card">
        <h3 style="margin-bottom: 1.5rem; font-size: 1.1rem;">Recent Transactions</h3>
        <div style="display: flex; flex-direction: column; gap: 0.8rem;">
            <% if (recentTransactions.length > 0) { %>
                <% recentTransactions.forEach(tx => { %>
                    <div style="display: flex; align-items: center; justify-content: space-between; padding-bottom: 0.8rem; border-bottom: 1px solid var(--glass-border);">
                        <div style="display: flex; align-items: center; gap: 12px;">
                            <div style="background: <%= tx.type === 'credit' ? 'rgba(16, 185, 129, 0.1)' : 'rgba(239, 68, 68, 0.1)' %>; width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem;">
                                <i class="fas <%= tx.type === 'credit' ? 'fa-arrow-down' : 'fa-arrow-up' %>" style="color: <%= tx.type === 'credit' ? '#10b981' : '#ef4444' %>;"></i>
                            </div>
                            <div>
                                <p style="font-size: 0.8rem; font-weight: 600; color: var(--nav-text);"><%= tx.description %></p>
                                <p style="font-size: 0.7rem; color: var(--nav-muted);"><%= new Date(tx.created_at).toLocaleDateString() %></p>
                            </div>
                        </div>
                        <p style="font-size: 0.85rem; font-weight: 700; color: <%= tx.type === 'credit' ? '#10b981' : '#ef4444' %>;">
                            <%= tx.type === 'credit' ? '+' : '-' %> ₹<%= tx.amount %>
                        </p>
                    </div>
                <% }) %>
            <% } else { %>
                <div style="text-align: center; padding: 2rem;">
                    <i class="fas fa-receipt" style="font-size: 2rem; color: var(--nav-muted); opacity: 0.3; display: block; margin-bottom: 10px;"></i>
                    <p style="color: var(--nav-muted); font-size: 0.85rem;">No recent transactions</p>
                </div>
            <% } %>
        </div>
        <a href="/vendor/wallet" style="display: block; text-align: center; margin-top: 1.5rem; color: var(--primary); text-decoration: none; font-size: 0.8rem; font-weight: 600;">View All Transactions</a>
    </div>
</div>

<% const extraScripts = `
<script>
    const ctx = document.getElementById('performanceChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Bookings',
                data: [12, 19, 15, 25, 22, 30],
                borderColor: '#4f46e5',
                backgroundColor: 'rgba(79, 70, 229, 0.05)',
                tension: 0.4,
                fill: true,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#4f46e5'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { color: '#8888bb', font: { size: 10 } } },
                x: { grid: { display: false }, ticks: { color: '#8888bb', font: { size: 10 } } }
            }
        }
    });
</script>
` %>
