<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary: #4f46e5;
            --primary-dark: #3730a3;
            --secondary: #818cf8;
            --accent: #f59e0b;
            --bg-light: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #fff;
            color: var(--text-main);
            overflow-x: hidden;
        }

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Outfit', sans-serif;
            font-weight: 700;
        }

        .navbar {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 1rem 0;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--primary) !important;
            font-family: 'Outfit', sans-serif;
        }

        /* Generic Section Spacing */
        section {
            padding: 5rem 0;
        }

        /* Footer */
        footer {
            background: #0f172a;
            color: #fff;
            padding: 4rem 0 2rem;
        }

        .footer-logo {
            font-size: 1.5rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            display: block;
            color: #fff;
            text-decoration: none;
        }

        /* Utilities */
        .text-indigo { color: var(--primary); }
        .bg-indigo-light { background-color: #eef2ff; }
        .glass-card {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 8px 32px rgba(0,0,0,0.05);
        }

        /* Animations */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .reveal { animation: fadeInUp 0.8s ease-out forwards; }
    </style>
</head>
<body>

    <!-- Simple Navbar -->
    <nav class="navbar sticky-top navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">PICK<span>&</span>TRAIL</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link px-3 fw-semibold text-main" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link px-3 fw-semibold text-main" href="/page/about-us">About</a></li>
                    <li class="nav-item"><a class="nav-link px-3 fw-semibold text-main" href="/page/blog">Blog</a></li>
                    <li class="nav-item ms-lg-3"><a class="btn btn-primary rounded-pill px-4" href="/auth/login">Login</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <%- body %>
    </main>

    <footer>
        <div class="container text-center">
            <a href="#" class="footer-logo">PICK&TRAIL</a>
            <p class="text-muted small mb-4">Crafting unforgettable journeys around the world.</p>
            <div class="d-flex justify-content-center gap-4 mb-4">
                <a href="#" class="text-white opacity-50"><i class="bi bi-facebook"></i></a>
                <a href="#" class="text-white opacity-50"><i class="bi bi-instagram"></i></a>
                <a href="#" class="text-white opacity-50"><i class="bi bi-twitter-x"></i></a>
            </div>
            <hr class="opacity-10 my-4">
            <p class="small opacity-50">&copy; 2026 PickAndTrail. All rights reserved.</p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
