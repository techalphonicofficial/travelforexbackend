<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <!-- Google Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;600;800&display=swap"
        rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <%
        const layoutThemeColours = typeof theme_colours === 'object' && theme_colours ? theme_colours : {};
        const layoutThemeCssVariables = typeof theme_css_variables === 'object' && theme_css_variables ? theme_css_variables : {};
        const layoutThemeValue = (key, fallback) => /^#[0-9a-fA-F]{6}$/.test(String(layoutThemeColours[key] || ''))
            ? String(layoutThemeColours[key]).toLowerCase()
            : fallback;
        const layoutThemeRgb = color => [
            parseInt(color.slice(1, 3), 16),
            parseInt(color.slice(3, 5), 16),
            parseInt(color.slice(5, 7), 16)
        ].join(', ');
        const layoutBrandPrimary = layoutThemeValue('theme_brand_primary', '#026eb5');
        const layoutBrandPrimaryHover = layoutThemeValue('theme_brand_primary_hover', '#005f9f');
        const layoutBrandPrimaryLight = layoutThemeValue('theme_brand_primary_light', '#c5e5fb');
        const layoutBrandPrimaryBorder = layoutThemeValue('theme_brand_primary_border', '#7abfee');
        const layoutBrandSecondary = layoutThemeValue('theme_brand_secondary', '#fdce2e');
        const layoutBrandSecondaryHover = layoutThemeValue('theme_brand_secondary_hover', '#f6b800');
        const layoutAccent = layoutThemeValue('theme_color_accent', '#00b894');
        const layoutAccentHover = layoutThemeValue('theme_color_accent_hover', '#00a382');
        const layoutBrandPrimaryRgb = layoutThemeRgb(layoutBrandPrimary);
        const layoutBrandSecondaryRgb = layoutThemeRgb(layoutBrandSecondary);
    %>
    <style>
        :root {
            --brand-primary: <%= layoutBrandPrimary %>;
            --brand-primary-hover: <%= layoutBrandPrimaryHover %>;
            --brand-primary-light: <%= layoutBrandPrimaryLight %>;
            --brand-primary-border: <%= layoutBrandPrimaryBorder %>;
            --brand-secondary: <%= layoutBrandSecondary %>;
            --brand-secondary-hover: <%= layoutBrandSecondaryHover %>;
            --color-primary: var(--brand-primary);
            --color-primary-hover: var(--brand-primary-hover);
            --color-primary-light: var(--brand-primary-light);
            --color-secondary: var(--brand-secondary);
            --color-secondary-hover: var(--brand-secondary-hover);
            --bs-primary: var(--color-primary);
            --bs-secondary: var(--color-secondary);
            --bs-link-color: var(--color-primary);
            --bs-link-hover-color: var(--color-primary-hover);
            --bs-primary-rgb: <%= layoutBrandPrimaryRgb %>;
            --bs-secondary-rgb: <%= layoutBrandSecondaryRgb %>;
            --color-accent: <%= layoutAccent %>;
            --color-accent-hover: <%= layoutAccentHover %>;
            --primary: var(--color-primary);
            --primary-hover: var(--color-primary-hover);
            --primary-light: var(--color-primary-light);
            --secondary: var(--color-secondary);
            --secondary-hover: var(--color-secondary-hover);
            --accent: var(--color-accent);
            --accent-hover: var(--color-accent-hover);
            <% Object.entries(layoutThemeCssVariables).forEach(([key, value]) => { %>
            <%= key %>: <%= value %>;
            <% }) %>
            --icon-strip-bg: #e8e8f4;
            --nav-panel-bg: #f0f0fa;
            --nav-text: #2d2d6e;
            --nav-muted: #8888bb;
            --nav-active-bg: var(--color-primary-light);
            --nav-hover-bg: color-mix(in srgb, var(--color-primary-light) 70%, white);
            --icon-strip-w: 62px;
            --nav-panel-w: 220px;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #f4f5fb;
            overflow-x: hidden;
        }

        h1,
        h2,
        h3,
        h4,
        h5,
        h6 {
            font-family: 'Outfit', sans-serif;
        }

        /* ── Layout ── */
        .layout-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ── Icon Strip ── */
        .icon-strip {
            width: var(--icon-strip-w);
            background: var(--icon-strip-bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1rem 0;
            gap: 0.4rem;
            flex-shrink: 0;
            z-index: 1001;
            border-right: 1px solid rgba(79, 70, 229, 0.1);
        }

        .icon-strip .strip-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: var(--nav-muted);
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }

        .icon-strip .strip-icon:hover {
            background: var(--nav-active-bg);
            color: var(--primary);
        }

        .icon-strip .strip-icon.active {
            background: var(--primary);
            color: #fff;
        }

        .icon-strip .strip-divider {
            width: 28px;
            height: 1px;
            background: rgba(79, 70, 229, 0.15);
            margin: 0.3rem 0;
        }

        .icon-strip .strip-toggle {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: none;
            border: none;
            color: var(--nav-muted);
            font-size: 1.15rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .icon-strip .strip-toggle:hover {
            background: var(--nav-active-bg);
            color: var(--primary);
        }


        /* ── Nav Panel ── */
        .nav-panel {
            width: var(--nav-panel-w);
            background: var(--nav-panel-bg);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            z-index: 1000;
            border-right: 1px solid rgba(79, 70, 229, 0.08);
            overflow-y: auto;
        }

        .nav-panel-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 1rem 0.9rem;
            border-bottom: 1px solid rgba(79, 70, 229, 0.1);
        }

        .nav-company {
            display: flex;
            align-items: center;
            gap: 0.55rem;
        }

        .nav-company-logo {
            width: 30px;
            height: 30px;
            background: var(--primary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 0.9rem;
        }

        .nav-company-name {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--nav-text);
        }

        .nav-panel-toggle {
            color: var(--nav-muted);
            border: none;
            background: none;
            font-size: 0.9rem;
            cursor: pointer;
        }

        /* Nav items */
        .nav-menu {
            padding: 0.6rem 0;
            flex-grow: 1;
        }

        .nav-link-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.55rem 0.9rem;
            color: var(--nav-text);
            text-decoration: none;
            border-radius: 8px;
            margin: 0.08rem 0.45rem;
            font-size: 0.88rem;
            font-weight: 500;
            transition: background 0.18s, color 0.18s;
            cursor: pointer;
        }

        .nav-link-item .nav-label-row {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .nav-link-item i.nav-icon {
            font-size: 1rem;
            color: var(--nav-muted);
            width: 18px;
            text-align: center;
            transition: color 0.18s;
        }

        .nav-link-item:hover {
            background: var(--nav-hover-bg);
            color: var(--primary);
        }

        .nav-link-item:hover i.nav-icon {
            color: var(--primary);
        }

        .nav-link-item.active {
            background: var(--nav-active-bg);
            color: var(--primary);
            font-weight: 600;
        }

        .nav-link-item.active i.nav-icon {
            color: var(--primary);
        }

        .nav-link-item .chevron {
            font-size: 0.7rem;
            color: var(--nav-muted);
            transition: transform 0.2s;
        }

        .nav-link-item[aria-expanded="true"] .chevron {
            transform: rotate(180deg);
        }

        .nav-sub {
            list-style: none;
            padding: 0.2rem 0 0.2rem 2.3rem;
        }

        .nav-sub .nav-link-item {
            font-size: 0.83rem;
            color: var(--nav-muted);
            margin: 0 0.45rem 0 0;
        }

        .nav-sub .nav-link-item:hover,
        .nav-sub .nav-link-item.active {
            color: var(--primary);
            background: var(--nav-active-bg);
        }

        .nav-panel-footer {
            padding: 0.7rem 0.9rem;
            border-top: 1px solid rgba(79, 70, 229, 0.1);
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            padding: 0.45rem 0.55rem;
            border-radius: 10px;
            background: rgba(79, 70, 229, 0.08);
        }

        .user-chip img {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
        }

        .user-chip-info {
            overflow: hidden;
            flex-grow: 1;
        }

        .user-chip-name {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--nav-text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-chip-role {
            font-size: 0.68rem;
            color: var(--nav-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-chip-logout {
            color: #e53e3e;
            font-size: 0.95rem;
            text-decoration: none;
            flex-shrink: 0;
        }

        .user-chip-logout:hover {
            color: #c53030;
        }

        /* ── Main Content ── */
        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            min-width: 0;
        }

        .topbar {
            height: 62px;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            border-bottom: 1px solid #ebebf5;
            box-shadow: 0 1px 4px rgba(79, 70, 229, 0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e1e4a;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .topbar-btn {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f0f0fa;
            color: var(--nav-text);
            border: none;
            cursor: pointer;
            font-size: 0.95rem;
            transition: background 0.2s;
        }

        .topbar-btn:hover {
            background: var(--nav-active-bg);
            color: var(--primary);
        }

        .page-content {
            padding: 2rem;
            flex-grow: 1;
        }

        /* ── Helpers ── */
        .card {
            border: 0;
            box-shadow: 0 4px 16px rgba(79, 70, 229, 0.07);
            border-radius: 1rem;
        }

        .table-responsive {
            border-radius: 1rem;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.06);
        }

        .btn-primary {
            background: var(--primary);
            border-color: var(--primary);
        }

        .btn-primary:hover {
            background: var(--color-primary-hover);
            border-color: var(--color-primary-hover);
        }

        /* ══════════════════════════════════════════════
           SHARED PREMIUM TRAVEL UI STYLES
        ══════════════════════════════════════════════ */
        .tf-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            margin-bottom: 1.5rem
        }

        .tf-page-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1e1e4a;
            margin: 0
        }

        .tf-page-sub {
            font-size: 0.83rem;
            color: #8888bb;
            margin: 0
        }

        /* stat cards */
        .tf-stat-card {
            border-radius: 16px;
            padding: 1.1rem 1.3rem;
            display: flex;
            align-items: center;
            gap: 0.9rem;
            border: 0;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s
        }

        .tf-stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 28px rgba(0, 0, 0, 0.13)
        }

        .tf-stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            flex-shrink: 0;
            background: rgba(255, 255, 255, .22)
        }

        .tf-stat-num {
            font-size: 1.8rem;
            font-weight: 800;
            line-height: 1
        }

        .tf-stat-lbl {
            font-size: 0.77rem;
            opacity: .85
        }

        /* toolbar */
        .tf-toolbar {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: .5rem;
            margin-bottom: 1rem
        }

        .tf-search {
            position: relative
        }

        .tf-search input {
            padding: .45rem .8rem .45rem 2.1rem;
            border-radius: 10px;
            border: 1.5px solid #e5e7f0;
            background: #fafafa;
            font-size: .87rem;
            width: 230px;
            transition: border .2s, box-shadow .2s
        }

        .tf-search input:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .1);
            outline: none
        }

        .tf-search .tf-si {
            position: absolute;
            left: .65rem;
            top: 50%;
            transform: translateY(-50%);
            color: #8888bb;
            font-size: .9rem;
            pointer-events: none
        }

        .view-btn {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1.5px solid #e5e7f0;
            background: #fff;
            color: #8888bb;
            cursor: pointer;
            transition: all .15s;
            font-size: .95rem
        }

        .view-btn.active,
        .view-btn:hover {
            background: #4f46e5;
            border-color: #4f46e5;
            color: #fff
        }

        .tf-select {
            border-radius: 10px;
            border: 1.5px solid #e5e7f0;
            background: #fafafa;
            font-size: .85rem;
            padding: .42rem .8rem;
            color: #333;
            cursor: pointer;
            transition: border .2s
        }

        .tf-select:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .1);
            outline: none
        }

        /* table */
        .tf-table-wrap {
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 4px 24px rgba(79, 70, 229, .07)
        }

        .tf-table {
            width: 100%;
            border-collapse: collapse
        }

        .tf-table thead tr {
            background: linear-gradient(90deg, #f0f0fa, #e8e8f5)
        }

        .tf-table thead th {
            padding: .8rem 1rem;
            font-size: .75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #5555aa;
            border: 0
        }

        .tf-table tbody tr {
            border-bottom: 1px solid #f4f4fb;
            transition: background .15s
        }

        .tf-table tbody tr:last-child {
            border-bottom: 0
        }

        .tf-table tbody tr:hover {
            background: #fafafe
        }

        .tf-table tbody td {
            padding: .8rem 1rem;
            font-size: .875rem;
            color: #333;
            vertical-align: middle
        }

        /* cards */
        .tf-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
            gap: 1rem
        }

        .tf-card {
            background: #fff;
            border-radius: 16px;
            padding: 1.3rem;
            box-shadow: 0 4px 16px rgba(79, 70, 229, .07);
            border: 1.5px solid transparent;
            transition: all .2s;
            display: flex;
            flex-direction: column;
            gap: .55rem
        }

        .tf-card:hover {
            border-color: #4f46e5;
            box-shadow: 0 8px 28px rgba(79, 70, 229, .14);
            transform: translateY(-2px)
        }

        .tf-card-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem
        }

        .tf-card-name {
            font-weight: 700;
            font-size: .95rem;
            color: #1e1e4a
        }

        .tf-card-meta {
            font-size: .77rem;
            color: #8888bb
        }

        .tf-card-actions {
            display: flex;
            gap: .4rem;
            margin-top: .3rem
        }

        /* action buttons */
        .btn-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: .83rem;
            border: 1.5px solid transparent;
            cursor: pointer;
            transition: all .15s;
            background: none
        }

        .btn-icon-edit {
            border-color: #c7d2fe;
            background: #eef2ff;
            color: #4f46e5
        }

        .btn-icon-edit:hover {
            background: #4f46e5;
            color: #fff;
            border-color: #4f46e5
        }

        .btn-icon-del {
            border-color: #fecaca;
            background: #fef2f2;
            color: #ef4444
        }

        .btn-icon-del:hover {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444
        }

        .btn-icon-view {
            border-color: #bae6fd;
            background: #f0f9ff;
            color: #0ea5e9
        }

        .btn-icon-view:hover {
            background: #0ea5e9;
            color: #fff;
            border-color: #0ea5e9
        }

        /* badge */
        .tf-badge {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            padding: 3px 11px;
            border-radius: 20px;
            font-size: .77rem;
            font-weight: 600
        }

        /* pagination */
        .tf-pagination {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: .5rem;
            padding: .9rem 1.1rem;
            background: #fff;
            border-top: 1px solid #f0f0fa
        }

        .tf-page-info {
            font-size: .81rem;
            color: #8888bb
        }

        .tf-pages {
            display: flex;
            gap: .28rem
        }

        .tf-pages button {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1.5px solid #e5e7f0;
            background: #fff;
            color: #4444aa;
            font-size: .82rem;
            font-weight: 600;
            cursor: pointer;
            transition: all .15s
        }

        .tf-pages button.active {
            background: #4f46e5;
            border-color: #4f46e5;
            color: #fff;
            box-shadow: 0 3px 10px rgba(79, 70, 229, .3)
        }

        .tf-pages button:hover:not(.active):not(:disabled) {
            background: #f0f0fa;
            border-color: #c7d2fe
        }

        .tf-pages button:disabled {
            opacity: .4;
            cursor: not-allowed
        }

        /* modal */
        .tf-modal .modal-content {
            border: 0;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, .18)
        }

        .tf-modal .modal-header {
            border-radius: 20px 20px 0 0;
            border: 0;
            padding: 1.2rem 1.4rem
        }

        .tf-modal .modal-body {
            padding: 1.4rem
        }

        .tf-modal .modal-footer {
            border: 0;
            padding: .9rem 1.4rem 1.2rem
        }

        .tf-modal .form-control,
        .tf-modal .form-select {
            border-radius: 10px;
            border: 1.5px solid #e5e7f0;
            font-size: .87rem;
            padding: .55rem .85rem;
            transition: border .2s, box-shadow .2s
        }

        .tf-modal .form-control:focus,
        .tf-modal .form-select:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .1)
        }

        .tf-modal .form-label {
            font-size: .82rem;
            font-weight: 600;
            color: #4444aa;
            margin-bottom: .28rem
        }

        /* add button */
        .btn-add-primary {
            background: linear-gradient(135deg, #4f46e5, #818cf8);
            color: #fff;
            border: 0;
            border-radius: 12px;
            padding: .52rem 1.15rem;
            font-weight: 600;
            font-size: .87rem;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            box-shadow: 0 4px 14px rgba(79, 70, 229, .35);
            transition: transform .15s, box-shadow .15s;
            cursor: pointer
        }

        .btn-add-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 7px 20px rgba(79, 70, 229, .4);
            color: #fff
        }

        /* empty state */
        .tf-empty {
            text-align: center;
            padding: 3rem 1rem
        }

        .tf-empty-icon {
            font-size: 3rem;
            opacity: .18;
            color: #4f46e5;
            margin-bottom: .7rem
        }

        .tf-empty p {
            color: #8888bb;
            font-size: .88rem;
            margin: 0
        }

        /* status pills */
        .pill-active {
            background: rgba(16, 185, 129, .12);
            color: #059669
        }

        .pill-inactive {
            background: rgba(148, 163, 184, .18);
            color: #64748b
        }

        .pill-soldout {
            background: rgba(239, 68, 68, .12);
            color: #dc2626
        }

        /* row avatar */
        .row-avatar {
            width: 34px;
            height: 34px;
