<body>
    <div class="layout-wrapper">
        <%
            const visibleNavItems = (typeof navItems !== 'undefined' ? navItems : [])
                .filter(item => typeof canAccessItem === 'function' ? canAccessItem(item) : true);
            const itemActive = item => item && typeof item.active === 'function' ? item.active(title || '') : false;
            const itemChildren = item => (item.children || [])
                .filter(child => typeof canAccessItem === 'function' ? canAccessItem(child) : true);
            const parentHref = item => {
                const children = itemChildren(item);
                return item.href && item.href !== '#' ? item.href : (children[0] ? children[0].href : '#');
            };
            const renderIconItems = visibleNavItems.filter(item => item.stripIcon || item.icon);
        %>

        <div class="icon-strip">
            <button class="strip-toggle" id="stripToggleBtn" title="Toggle sidebar">
                <i class="bi bi-layout-sidebar"></i>
            </button>
            <div class="strip-divider"></div>
            <% renderIconItems.forEach((item, index) => { %>
                <% if (index > 0 && ['access_control', 'travel', 'crm', 'pages', 'reports'].includes(item.key)) { %>
                    <div class="strip-divider"></div>
                <% } %>
                <a href="<%= parentHref(item) %>" class="strip-icon <%= itemActive(item) ? 'active' : '' %>" title="<%= item.label %>">
                    <i class="bi <%= item.stripIcon || item.icon %>"></i>
                </a>
            <% }) %>
            <div class="strip-divider"></div>
        </div>

        <aside class="nav-panel">
            <div class="nav-panel-header">
                <div class="nav-company">
                    <div style="background-color:#1e293b; padding:8px 12px; border-radius:6px; display:flex; justify-content:center; align-items:center;">
                        <% if (company_logo_url) { %>
                            <img src="<%= company_logo_url %>" alt="Company Logo" style="max-height:30px; max-width: 100%;">
                        <% } else { %>
                            <span style="color:white; font-weight:bold; font-size:16px;"><%= typeof company_name !== 'undefined' && company_name ? company_name : 'PickTrails' %></span>
                        <% } %>
                    </div>
                </div>
                <button class="nav-panel-toggle"><i class="bi bi-chevron-left"></i></button>
            </div>

            <nav class="nav-menu">
                <ul class="list-unstyled">
                    <% visibleNavItems.forEach(item => { const children = itemChildren(item); const active = itemActive(item); %>
                        <% if (children.length) { %>
                            <li>
                                <a class="nav-link-item <%= active ? 'active' : '' %>" data-bs-toggle="collapse" href="#nav_<%= item.key %>" aria-expanded="<%= active ? 'true' : 'false' %>">
                                    <span class="nav-label-row"><i class="bi <%= item.icon %> nav-icon"></i> <%= item.label %></span>
                                    <i class="bi bi-chevron-down chevron"></i>
                                </a>
                                <div class="collapse <%= active ? 'show' : '' %>" id="nav_<%= item.key %>">
                                    <ul class="nav-sub list-unstyled">
                                        <% children.forEach(child => { %>
                                            <li>
                                                <a href="<%= child.href %>" class="nav-link-item <%= itemActive(child) ? 'active' : '' %>">
                                                    <i class="bi <%= child.icon %> nav-icon"></i>
                                                    <% if (child.key === 'follow_ups') { %>
                                                        <span style="display: flex; align-items: center; gap: 0.4rem;">
                                                            <%= child.label %>
                                                            <% if (typeof pendingFollowUpCount !== 'undefined' && pendingFollowUpCount > 0) { %>
                                                                <span class="badge bg-danger rounded-pill" style="font-size: 0.7rem; padding: 0.25em 0.6em;"><%= pendingFollowUpCount %></span>
                                                            <% } %>
                                                        </span>
                                                    <% } else { %>
                                                        <%= child.label %>
                                                    <% } %>
                                                </a>
                                            </li>
                                        <% }) %>
                                    </ul>
                                </div>
                            </li>
                        <% } else { %>
                            <li>
                                <a href="<%= item.href %>" class="nav-link-item <%= active ? 'active' : '' %>">
                                    <span class="nav-label-row"><i class="bi <%= item.icon %> nav-icon"></i> <%= item.label %></span>
                                </a>
                            </li>
                        <% } %>
                    <% }) %>
