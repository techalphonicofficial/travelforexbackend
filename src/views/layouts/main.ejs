            <div class="nav-panel-footer">
                <div class="user-chip">
                    <img src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(user ? user.name : 'G') %>&background=4f46e5&color=fff"
                        alt="User">
                    <div class="user-chip-info">
                        <div class="user-chip-name">
                            <%= user ? user.name : 'Guest' %>
                        </div>
                        <div class="user-chip-role">
                            <%= user ? user.role_name : 'No Role' %>
                        </div>
                    </div>
                    <a href="/auth/logout" class="user-chip-logout" title="Logout"><i
                            class="bi bi-box-arrow-right"></i></a>
                </div>
            </div>
        </aside>

        <% } %>

        <!-- ③ Main Content -->
        <main class="main-content">
            <header class="topbar">
                <span class="topbar-title">
                    <%= title %>
                </span>
                <div class="topbar-actions">
                    <div class="dropdown">
                        <button class="topbar-btn position-relative" title="Notifications" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell"></i>
                            <% if (typeof unreadNotificationCount !== 'undefined' && unreadNotificationCount > 0) { %>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">
                                    <%= unreadNotificationCount > 99 ? '99+' : unreadNotificationCount %>
                                </span>
                            <% } %>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end p-0 shadow-lg" style="width: 320px; border: none; border-radius: 12px; overflow: hidden;">
                            <li class="bg-light p-3 border-bottom d-flex justify-content-between align-items-center">
                                <h6 class="m-0 fw-bold">Notifications</h6>
                            </li>
                            <div style="max-height: 350px; overflow-y: auto;">
                                <% if (typeof recentNotifications !== 'undefined' && recentNotifications.length > 0) { %>
                                    <% recentNotifications.forEach(notif => { %>
                                        <li>
                                            <a class="dropdown-item p-3 border-bottom text-wrap" href="#">
                                                <div class="d-flex w-100 justify-content-between">
                                                    <h6 class="mb-1 fw-semibold" style="font-size: 0.85rem;"><%= notif.title %></h6>
                                                </div>
                                                <p class="mb-1 text-muted" style="font-size: 0.8rem;"><%= notif.message %></p>
                                            </a>
                                        </li>
                                    <% }) %>
                                <% } else { %>
                                    <li><div class="dropdown-item p-3 text-center text-muted" style="font-size: 0.85rem;">No new notifications</div></li>
                                <% } %>
                            </div>
                        </ul>
                    </div>
                    <button class="topbar-btn" title="Search"><i class="bi bi-search"></i></button>
                </div>
            </header>
            <div class="page-content">
                <%- body %>
            </div>
        </main>
    </div>

    <!-- Floating restore button (visible only when icon strip is hidden) -->
    <button id="stripRestoreBtn" title="Show sidebar" style="
        display:none; position:fixed; left:0; top:50%; transform:translateY(-50%);
        width:20px; height:48px; background:var(--primary); color:#fff;
        border:none; border-radius:0 8px 8px 0; cursor:pointer;
        font-size:0.75rem; z-index:2000; box-shadow:2px 0 8px rgba(79,70,229,0.3);
        transition: opacity 0.2s;
    "><i class="bi bi-chevron-right"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const T = 'width 0.25s ease, opacity 0.25s ease';

        // ── Nav panel toggle (chevron < in header)
        const navToggleBtn = document.querySelector('.nav-panel-toggle');
        const navPanel = document.querySelector('.nav-panel');
        let navHidden = false;
        navToggleBtn.addEventListener('click', () => {
            navHidden = !navHidden;
            navPanel.style.transition = T;
            navPanel.style.width = navHidden ? '0' : 'var(--nav-panel-w)';
            navPanel.style.overflow = navHidden ? 'hidden' : '';
            navPanel.style.opacity = navHidden ? '0' : '1';
            navToggleBtn.innerHTML = navHidden
                ? '<i class="bi bi-chevron-right"></i>'
                : '<i class="bi bi-chevron-left"></i>';
        });

        // ── Icon strip toggle (≡ button at top of strip)
        const stripToggleBtn = document.getElementById('stripToggleBtn');
        const stripRestoreBtn = document.getElementById('stripRestoreBtn');
        const iconStrip = document.querySelector('.icon-strip');
        let stripHidden = false;

        function setStripState(hide) {
            stripHidden = hide;
            iconStrip.style.transition = T;
            iconStrip.style.width = hide ? '0' : 'var(--icon-strip-w)';
            iconStrip.style.overflow = hide ? 'hidden' : '';
            iconStrip.style.opacity = hide ? '0' : '1';
            stripRestoreBtn.style.display = hide ? 'flex' : 'none';
            stripRestoreBtn.style.alignItems = 'center';
            stripRestoreBtn.style.justifyContent = 'center';
        }

        stripToggleBtn.addEventListener('click', () => setStripState(true));
        stripRestoreBtn.addEventListener('click', () => setStripState(false));
    </script>
</body>

</html>
