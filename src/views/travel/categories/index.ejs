function openEdit(id){ 
  const r = ALL.find(x => String(x.id) === String(id));
  if(!r) return;
  document.getElementById('modalTitle').textContent='Edit Category'; 
  document.getElementById('fId').value=r.id; 
  document.getElementById('fName').value=r.name; 
  document.getElementById('fSlug').value=r.slug||'';
  document.getElementById('fDesc').value=r.description||'';
  document.getElementById('fTagColor').value=r.tag_color||'gray';
  document.getElementById('fShowInMenu').checked=!!r.show_in_menu;
  document.getElementById('fShowInSidebar').checked=!!r.show_in_sidebar;
  document.getElementById('fShowInHome').checked = !!r.show_in_home;
  // document.getElementById('fIsCustomizable').checked = !!r.is_customizable;
  document.getElementById('fIsTourType').checked = !!r.is_tour_type;

  // Set file/image preview
  document.getElementById('fImageFile').value='';
  document.getElementById('fRemoveImage').value='false';
  if (r.feature_image) {
    document.getElementById('imagePreview').src = r.feature_image;
    document.getElementById('imagePreviewContainer').classList.remove('d-none');
  } else {
    document.getElementById('imagePreview').src = '';
    document.getElementById('imagePreviewContainer').classList.add('d-none');
  }
  document.getElementById('fImageAlt').value = r.feature_image_alt || '';

  // Set SEO fields
  document.getElementById('fMetaTitle').value = r.meta_title || '';
  document.getElementById('fMetaDesc').value = r.meta_description || '';
  document.getElementById('fMetaKeyword').value = r.meta_keyword || '';
  document.getElementById('fSchema').value = r.schema || '';

  // Collapse accordion if open
  const collapseEl = document.getElementById('seoFields');
  if (collapseEl && collapseEl.classList.contains('show')) {
    bootstrap.Collapse.getInstance(collapseEl).hide();
  }
}

async function save(){
  const id=document.getElementById('fId').value;
  const name=document.getElementById('fName').value.trim();
  const slug=document.getElementById('fSlug').value.trim();
  const description=document.getElementById('fDesc').value.trim();
  const tag_color=document.getElementById('fTagColor').value;
  const show_in_menu=!!document.getElementById('fShowInMenu').checked;
  const show_in_sidebar=!!document.getElementById('fShowInSidebar').checked;
  const show_in_home = !!document.getElementById('fShowInHome').checked;
  const is_customizable = false; // removed from form
  const is_tour_type = !!document.getElementById('fIsTourType').checked;
  
  if(!name) return alert('Name is required');

  const formData = new FormData();
  formData.append('name', name);
  formData.append('slug', slug);
  formData.append('description', description);
  formData.append('tag_color', tag_color);
  formData.append('show_in_menu', show_in_menu);
  formData.append('show_in_sidebar', show_in_sidebar);
  formData.append('show_in_home', show_in_home);
  formData.append('is_customizable', is_customizable);
  formData.append('is_tour_type', is_tour_type);

  // File & Alt text
  const fileInput = document.getElementById('fImageFile');
  if (fileInput.files.length > 0) {
    formData.append('feature_image_file', fileInput.files[0]);
  }
  formData.append('feature_image_alt', document.getElementById('fImageAlt').value.trim());
  formData.append('remove_feature_image', document.getElementById('fRemoveImage').value);

  // SEO fields
  formData.append('meta_title', document.getElementById('fMetaTitle').value.trim());
  formData.append('meta_description', document.getElementById('fMetaDesc').value.trim());
  formData.append('meta_keyword', document.getElementById('fMetaKeyword').value.trim());
  formData.append('schema', document.getElementById('fSchema').value.trim());

  const saveBtn = document.querySelector('.btn-add-primary');
  const originalHtml = saveBtn.innerHTML;
  
  try {
    saveBtn.disabled = true;
    saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
    
    const res = await fetch(id ? `/api/v1/categories/${id}` : '/api/v1/categories', {
      method: id ? 'PUT' : 'POST',
      body: formData
    });
    
    const j = await res.json();
    if(j.success) {
      location.reload();
    } else {
      alert(j.message || 'Error saving category');
      saveBtn.disabled = false;
      saveBtn.innerHTML = originalHtml;
    }
  } catch(e) {
    alert('Network error occurred');
    saveBtn.disabled = false;
    saveBtn.innerHTML = originalHtml;
  }
}
function confirmDel(id,name){delId=id;document.getElementById('delMsg').textContent=`"${name}" will be permanently removed.`;new bootstrap.Modal(document.getElementById('delModal')).show();}
document.getElementById('delBtn').addEventListener('click',executeSingleDelete);
async function executeSingleDelete(){
  const res=await fetch(`/api/v1/categories/${delId}`,{method:'DELETE'}); const j=await res.json();
  if(j.success) location.reload(); else alert(j.message);
}

// BULK DELETE API HOOKS
function toggleSelectAll() {
  const mainCheckbox = document.getElementById('selectAllCheckbox');
  const rowCheckboxes = document.querySelectorAll('.row-checkbox');
  const checked = mainCheckbox.checked;

  rowCheckboxes.forEach(cb => {
    cb.checked = checked;
    const tr = cb.closest('tr');
    if(checked) {
      tr.classList.add('row-selected');
      selectedIds.add(cb.value);
    } else {
      tr.classList.remove('row-selected');
      selectedIds.delete(cb.value);
    }
  });

  updateBulkActionBar();
}

function toggleRowSelection(cb) {
  const tr = cb.closest('tr');
  if(cb.checked) {
    tr.classList.add('row-selected');
    selectedIds.add(cb.value);
  } else {
    tr.classList.remove('row-selected');
    selectedIds.delete(cb.value);
    document.getElementById('selectAllCheckbox').checked = false;
  }
  updateBulkActionBar();
}

function evaluateSelectionState() {
   const rowCheckboxes = document.querySelectorAll('.row-checkbox');
   if(!rowCheckboxes.length) {
     document.getElementById('selectAllCheckbox').checked = false;
     return;
   }

   let allChecked = true;
   rowCheckboxes.forEach(cb => {
      if(!cb.checked) allChecked = false;
   });
   document.getElementById('selectAllCheckbox').checked = allChecked;
}

function updateBulkActionBar() {
  const bar = document.getElementById('bulkActionsBar');
  const msg = document.getElementById('selectedCountMsg');
  if(selectedIds.size > 0) {
    bar.style.display = 'flex';
    msg.textContent = `${selectedIds.size} records selected`;
  } else {
    bar.style.display = 'none';
    document.getElementById('selectAllCheckbox').checked = false;
  }
}

function confirmBulkDelete() {
  document.getElementById('delMsg').textContent = `Are you sure you want to permanently delete the ${selectedIds.size} selected category records?`;
  document.getElementById('delBtn').onclick = executeBulkDelete;
  new bootstrap.Modal(document.getElementById('delModal')).show();
}

async function executeBulkDelete() {
  const ids = Array.from(selectedIds);
  const res = await fetch(`/api/v1/categories/bulk-delete`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids })
  });
  const j = await res.json();
  if(j.success) location.reload(); else alert(j.message);
}

async function moveRow(localIndex, direction) {
  const globalIndex = (page - 1) * PS + localIndex;
  const targetIndex = globalIndex + direction;
  
  if (targetIndex < 0 || targetIndex >= filtered.length) return;
  
  // Swap sort_order in our local data
  // Since they are already sorted by sort_order, we just need to swap the values
  const currentItem = filtered[globalIndex];
  const targetItem = filtered[targetIndex];
  
  // If sort_order is the same (e.g. all 0), we assign them values based on index first
  const itemsToUpdate = filtered.map((item, idx) => ({
    id: item.id,
    sort_order: idx
  }));
  
  // Swap the orders
  const temp = itemsToUpdate[globalIndex].sort_order;
  itemsToUpdate[globalIndex].sort_order = itemsToUpdate[targetIndex].sort_order;
  itemsToUpdate[targetIndex].sort_order = temp;
  
  // Send only the relevant items to API
  const payload = [
    { id: itemsToUpdate[globalIndex].id, sort_order: itemsToUpdate[globalIndex].sort_order },
    { id: itemsToUpdate[targetIndex].id, sort_order: itemsToUpdate[targetIndex].sort_order }
  ];

  try {
    const res = await fetch('/api/v1/categories/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order: payload })
    });
    const data = await res.json();
    if (data.success) location.reload();
    else alert(data.message);
  } catch (err) {
    alert('Failed to reorder');
  }
}

render();
</script>
