<style>
  .design-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.03);
    margin-bottom: 2rem;
  }
  .table-minimal {
    border-collapse: separate;
    border-spacing: 0 0.5rem;
  }
  .table-minimal thead th {
    border-bottom: 0;
    color: #111827;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: capitalize;
    padding-bottom: 0.5rem;
  }
  .table-minimal tbody tr {
    background-color: transparent;
  }
  .table-minimal tbody td {
    border: none;
    padding: 0.75rem 0.5rem;
    color: #4b5563;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .btn-create {
    background-color: #8b5cf6;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .btn-create:hover { background-color: #7c3aed; color: #fff; }
  
  .filter-input {
    background-color: #f9fafb;
    border: 1px solid #f3f4f6;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #4b5563;
  }
  .filter-input:focus {
    background-color: #fff;
    border-color: #d1d5db;
    box-shadow: none;
  }
  .btn-group-toggle .btn {
    border: 1px solid #e5e7eb;
    background-color: #fff;
    color: #4b5563;
    font-size: 0.82rem;
    padding: 0.35rem 0.75rem;
    font-weight: 500;
  }
  .btn-group-toggle .btn.active {
    background-color: #f3f4f6;
    color: #111827;
    box-shadow: none;
  }

  /* bulk select custom styles */
  .custom-checkbox {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid #d1d5db;
    appearance: none;
    outline: none;
    cursor: pointer;
    position: relative;
    background-color: #fff;
    transition: all 0.2s;
    margin: 0;
    vertical-align: middle;
  }
  .custom-checkbox:checked {
    background-color: #22c55e;
    border-color: #22c55e;
  }
  .custom-checkbox:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .table-minimal tbody tr td:first-child {
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .table-minimal tbody tr.row-selected td:first-child {
    border-left-color: #22c55e;
  }
  .table-minimal tbody tr.row-selected td {
    background-color: #f8fafc;
  }
  .bulk-delete-bar {
    display: none;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.8rem 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
</style>

<div class="design-card">
  <!-- HEADER ROW -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h3 class="fw-bold mb-1" style="color: #111827;">Destination Categories</h3>
      <p class="text-muted mb-0" style="font-size: 0.85rem;">Tag types for destinations (Beach, Mountain, Heritage…)</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="btn-group btn-group-toggle shadow-sm" role="group">
        <button type="button" class="btn active d-flex align-items-center gap-2" id="vList" onclick="setView('list')">
          <i class="bi bi-list-ul"></i> List
        </button>
        <button type="button" class="btn d-flex align-items-center gap-2" id="vCards" onclick="setView('cards')">
          <i class="bi bi-person-vcard"></i> Cards
        </button>
      </div>
      <button class="btn-create shadow-sm" data-bs-toggle="modal" data-bs-target="#modal" onclick="openCreate()">
        <i class="bi bi-plus-lg me-1"></i> Add Category
      </button>
    </div>
  </div>

  <hr style="border-color: #e5e7eb; margin: 1.25rem -1.5rem;">

  <!-- TOOLBAR ROW -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4 mt-2">
    <div class="d-flex gap-2">
      <div class="position-relative" style="width: 260px;">
        <i class="bi bi-search position-absolute text-muted" style="left: 12px; top: 50%; transform: translateY(-50%); font-size: 0.85rem;"></i>
        <input type="text" id="searchInput" class="form-control form-control-sm filter-input ps-5 py-2" placeholder="Search category..." oninput="applyFilters()">
      </div>
    </div>
    <div>
      <span class="text-muted fw-bold" id="countLabel" style="font-size: 0.85rem;"></span>
    </div>
  </div>

  <!-- BULK ACTIONS BAR -->
  <div id="bulkActionsBar" class="bulk-delete-bar align-items-center justify-content-between">
    <div>
      <button class="btn btn-danger btn-sm px-3 py-2 d-inline-flex align-items-center gap-2" style="background-color: #ef4444; border:none; border-radius:6px; font-weight:600;" onclick="confirmBulkDelete()">
        <i class="bi bi-trash3"></i> Delete selected
      </button>
    </div>
    <div>
      <span id="selectedCountMsg" class="fw-bold" style="color: #4b5563; font-size:0.9rem;">0 records selected</span>
    </div>
  </div>

  <!-- LIST VIEW -->
  <div id="listView">
    <div class="table-responsive" style="border: none; box-shadow: none; overflow: visible;">
      <table class="table table-minimal w-100">
        <thead>
          <tr>
            <th style="width:30px">
              <input type="checkbox" class="custom-checkbox" id="selectAllCheckbox" onchange="toggleSelectAll()">
            </th>
            <th style="width:40px">#</th>
            <th style="width:70px">Sort</th>
            <th>Category Name</th>
            <th>Description</th>
            <th>Menu</th>
            <th>Sidebar</th>
            <th>Home</th>
            <th style="width:80px;text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="listBody"></tbody>
      </table>
      <div id="listPag"></div>
    </div>
  </div>

<!-- CARDS VIEW -->
<div id="cardsView" style="display:none">
  <div class="tf-cards" id="cardsBody"></div>
  <div class="tf-pagination mt-3" style="border-radius:16px;background:#fff;box-shadow:0 4px 16px rgba(79,70,229,.07)" id="cardsPag"></div>
</div>

<!-- MODAL -->
<div class="modal fade tf-modal" id="modal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" style="max-width:460px">
    <div class="modal-content">
      <div class="modal-header" style="background:linear-gradient(135deg,#10b981,#34d399);color:#fff">
        <h5 class="modal-title fw-bold" id="modalTitle">Add Category</h5>
        <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="fId">
        <div class="mb-3">
          <label class="form-label">Category Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="fName" placeholder="e.g. Beach, Hill Station, Heritage">
        </div>
        <div class="mb-3">
          <label class="form-label">Description</label>
          <textarea class="form-control" id="fDesc" rows="3" placeholder="Short description…"></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label">Tag Style (Badge Color)</label>
          <select class="form-select" id="fTagColor">
            <option value="gray">None / Gray</option>
            <option value="red">Red (e.g. Trending)</option>
            <option value="pink">Pink (e.g. Romance)</option>
            <option value="orange">Orange (e.g. Budget)</option>
            <option value="purple">Purple (e.g. Popular)</option>
            <option value="blue">Blue</option>
            <option value="green">Green</option>
          </select>
        </div>
        <div class="d-flex gap-4 mb-3">
          <div class="form-check form-switch px-4">
            <input class="form-check-input" type="checkbox" id="fShowInMenu" role="switch">
            <label class="form-check-label ps-2 py-0" for="fShowInMenu">Show in Menu</label>
          </div>
          <div class="form-check form-switch px-4">
            <input class="form-check-input" type="checkbox" id="fShowInSidebar" role="switch">
            <label class="form-check-label ps-2 py-0" for="fShowInSidebar">Show in Sidebar</label>
          </div>
          <div class="form-check form-switch px-4">
     <input class="form-check-input" type="checkbox" id="fShowInHome" role="switch">
  <label class="form-check-label ps-2 py-0" for="fShowInHome">
    Show in Home
  </label>
</div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
        <button class="btn-add-primary" style="background:linear-gradient(135deg,#10b981,#34d399);box-shadow:0 4px 14px rgba(16,185,129,.35)" onclick="save()"><i class="bi bi-check2 me-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade tf-modal" id="delModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
    <div class="modal-content">
      <div class="modal-body text-center p-4">
        <div style="width:60px;height:60px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.7rem;color:#ef4444"><i class="bi bi-trash3"></i></div>
        <h5 class="fw-bold mb-1">Delete Category?</h5>
        <p class="text-muted" id="delMsg" style="font-size:.88rem"></p>
        <div class="d-flex gap-2 justify-content-center mt-3">
          <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-danger px-4 rounded-3 fw-semibold" id="delBtn">Yes, Delete</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const ALL = <%- JSON.stringify(categories) %>;
const CAT_COLORS = ['#10b981','#4f46e5','#f59e0b','#ec4899','#0ea5e9','#8b5cf6','#ef4444','#06b6d4'];
const CAT_ICONS  = ['bi-geo-alt-fill','bi-water','bi-tree-fill','bi-building','bi-snow','bi-sunset','bi-star-fill','bi-heart-fill'];
const TAG_STYLES = {
  red:    { bg: '#fee2e2', text: '#991b1b', label: 'Red' },
  pink:   { bg: '#fce7f3', text: '#9d174d', label: 'Pink' },
  orange: { bg: '#ffedd5', text: '#9a3412', label: 'Orange' },
  purple: { bg: '#f3e8ff', text: '#6b21a8', label: 'Purple' },
  blue:   { bg: '#dbeafe', text: '#1e40af', label: 'Blue' },
  green:  { bg: '#dcfce7', text: '#166534', label: 'Green' },
  gray:   { bg: '#f3f4f6', text: '#4b5563', label: 'Gray' }
};
const PS=12; let view='list',page=1,filtered=[...ALL],delId=null;
let selectedIds = new Set();

function applyFilters(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  filtered=ALL.filter(r=>r.name.toLowerCase().includes(q));
  page=1; render();
}
function render(){
  const tot=filtered.length,pages=Math.max(1,Math.ceil(tot/PS));
  page=Math.min(page,pages);
  const s=(page-1)*PS,slice=filtered.slice(s,s+PS);
  document.getElementById('countLabel').textContent=`${tot} result${tot!==1?'s':''}`;
  if(view==='cards') renderCards(slice,s,tot,pages);
  else               renderList(slice,s,tot,pages);
  evaluateSelectionState();
}
function renderCards(slice,s,tot,pages){
  const body=document.getElementById('cardsBody');
  if(!slice.length){body.innerHTML=`<div class="tf-empty" style="grid-column:1/-1"><div class="tf-empty-icon"><i class="bi bi-tags"></i></div><p>No categories found.</p></div>`;document.getElementById('cardsPag').innerHTML='';return;}
  body.innerHTML=slice.map((r,i)=>{
    const col=CAT_COLORS[(r.id||i)%CAT_COLORS.length];
    const ico=CAT_ICONS[(r.id||i)%CAT_ICONS.length];
    return `<div class="tf-card">
      <div class="tf-card-icon" style="background:${col}18;color:${col}"><i class="bi ${ico}"></i></div>
      <div class="tf-card-name">${r.name}</div>
      ${r.description?`<div class="tf-card-meta">${r.description}</div>`:''}
      <div class="tf-card-actions">
        <button class="btn-icon btn-icon-edit" style="flex:1;justify-content:center" onclick='openEdit(${JSON.stringify(r)})' data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil me-1"></i>Edit</button>
        <button class="btn-icon btn-icon-del" onclick="confirmDel('${r.id}','${r.name.replace(/'/g,"\\'")}')"><i class="bi bi-trash3"></i></button>
      </div>
    </div>`;
  }).join('');
  document.getElementById('cardsPag').innerHTML=pagHTML(page,pages,tot,s,slice.length);
}
function renderList(slice,s,tot,pages){
  const body=document.getElementById('listBody');
  if(!slice.length){body.innerHTML=`<tr><td colspan="5"><div class="text-center p-4 text-muted"><p>No categories found.</p></div></td></tr>`;document.getElementById('listPag').innerHTML='';return;}
  body.innerHTML=slice.map((r,i)=>{
    const col=CAT_COLORS[(r.id||i)%CAT_COLORS.length];
    const ico=CAT_ICONS[(r.id||i)%CAT_ICONS.length];
    const checked = selectedIds.has(r.id.toString()) ? 'checked' : '';
    const rowClass = checked ? 'row-selected' : '';
    return `<tr class="${rowClass}">
      <td><input type="checkbox" class="custom-checkbox row-checkbox" value="${r.id}" onchange="toggleRowSelection(this)" ${checked}></td>
      <td style="color:#6b7280;">${s+i+1}</td>
      <td>
        <div class="d-flex gap-1">
          <button class="btn btn-sm btn-light border p-0" style="width:24px;height:24px" onclick="moveRow(${i}, -1)" ${s+i===0?'disabled':''}><i class="bi bi-chevron-up" style="font-size:0.7rem"></i></button>
          <button class="btn btn-sm btn-light border p-0" style="width:24px;height:24px" onclick="moveRow(${i}, 1)" ${s+i===filtered.length-1?'disabled':''}><i class="bi bi-chevron-down" style="font-size:0.7rem"></i></button>
        </div>
      </td>
      <td><div style="display:flex;align-items:center;gap:.7rem">
        <div class="row-avatar" style="background:${col}18;color:${col}; width:28px; height:28px; font-size:0.8rem; border-radius:10px; display:flex; align-items:center; justify-content:center;"><i class="bi ${ico}"></i></div>
        <div style="line-height:1.2;">
          <span style="font-weight:600;color:#1e1e4a;display:block;">${r.name}</span>
          ${(() => {
            const t = TAG_STYLES[r.tag_color || 'gray'];
            if(r.tag_color && r.tag_color !== 'gray') return `<span style="background:${t.bg}; color:${t.text}; font-size:0.6rem; font-weight:700; padding:1px 6px; border-radius:12px; text-transform:uppercase; margin-top:3px; display:inline-block; letter-spacing:0.5px;">${r.name}</span>`;
            return '';
          })()}
        </div>
      </div></td>
      <td><span style="color:#4b5563;font-size:0.85rem">${r.description||'—'}</span></td>
      <td>${r.show_in_menu ? '<span class="badge" style="background-color:#d1fae5; color:#065f46; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>' : '<span class="badge" style="background-color:#f3f4f6; color:#6b7280; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-dash-circle me-1"></i>No</span>'}</td>
      <td>${r.show_in_sidebar ? '<span class="badge" style="background-color:#d1fae5; color:#065f46; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>' : '<span class="badge" style="background-color:#f3f4f6; color:#6b7280; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-dash-circle me-1"></i>No</span>'}</td>
     <td>
${r.show_in_home
  ? '<span class="badge" style="background-color:#d1fae5; color:#065f46; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-check-circle-fill me-1"></i>Yes</span>'
  : '<span class="badge" style="background-color:#f3f4f6; color:#6b7280; border-radius:12px; padding:0.35rem 0.6rem; font-size:0.75rem; font-weight:600;"><i class="bi bi-dash-circle me-1"></i>No</span>'
}
</td>
      <td style="text-align:right">
        <button class="btn btn-sm btn-light border me-1 rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="openEdit('${r.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil" style="font-size:0.8rem;color:#4b5563;"></i></button>
        <button class="btn btn-sm btn-light border rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="confirmDel('${r.id}','${r.name.replace(/'/g,"\\'")}')"><i class="bi bi-trash3" style="font-size:0.8rem;color:#ef4444;"></i></button>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('listPag').innerHTML=pagHTML(page,pages,tot,s,slice.length);
}
function pagHTML(p,pages,tot,s,len){
  const prev=`<button onclick="goPage(${p-1})" ${p<=1?'disabled':''}><i class="bi bi-chevron-left"></i></button>`;
  const next=`<button onclick="goPage(${p+1})" ${p>=pages?'disabled':''}><i class="bi bi-chevron-right"></i></button>`;
  let nums='';
  for(let i=1;i<=pages;i++){
    if(pages<=6||Math.abs(i-p)<=1||i===1||i===pages) nums+=`<button class="${i===p?'active':''}" onclick="goPage(${i})">${i}</button>`;
    else if(Math.abs(i-p)===2) nums+=`<button disabled style="border:0;background:none;color:#8888bb">…</button>`;
  }
  return `<div class="tf-page-info">Showing ${s+1}–${s+len} of ${tot}</div><div class="tf-pages">${prev}${nums}${next}</div>`;
}
function goPage(p){page=p;render();}
function setView(v){
  view=v;
  document.getElementById('cardsView').style.display=v==='cards'?'':'none';
  document.getElementById('listView').style.display=v==='list'?'':'none';
  document.getElementById('vCards').classList.toggle('active',v==='cards');
  document.getElementById('vList').classList.toggle('active',v==='list');
  render();
}
function openCreate() {
  document.getElementById('modalTitle').textContent='Add Category';
  document.getElementById('fId').value='';
  document.getElementById('fName').value='';
  document.getElementById('fDesc').value='';
  document.getElementById('fTagColor').value='gray';
  document.getElementById('fShowInMenu').checked=false;
  document.getElementById('fShowInSidebar').checked=false;
   document.getElementById('fShowInHome').checked=false;
}

function openEdit(id){ 
  const r = ALL.find(x => String(x.id) === String(id));
  if(!r) return;
  document.getElementById('modalTitle').textContent='Edit Category'; document.getElementById('fId').value=r.id; document.getElementById('fName').value=r.name; document.getElementById('fDesc').value=r.description||'';
  document.getElementById('fTagColor').value=r.tag_color||'gray';
  document.getElementById('fShowInMenu').checked=!!r.show_in_menu;
  document.getElementById('fShowInSidebar').checked=!!r.show_in_sidebar;
   document.getElementById('fShowInHome').checked = !!r.show_in_home;
}
async function save(){
  const id=document.getElementById('fId').value,name=document.getElementById('fName').value.trim(),description=document.getElementById('fDesc').value.trim();
  const tag_color=document.getElementById('fTagColor').value;
  const show_in_menu=!!document.getElementById('fShowInMenu').checked, show_in_sidebar=!!document.getElementById('fShowInSidebar').checked;
  if(!name) return alert('Name is required');
  const show_in_home = !!document.getElementById('fShowInHome').checked;
  const res=await fetch(id?`/api/v1/categories/${id}`:'/api/v1/categories',{method:id?'PUT':'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({name,description,tag_color,show_in_menu,show_in_sidebar,show_in_home})});
  const j=await res.json(); if(j.success) location.reload(); else alert(j.message||'Error');
}
function confirmDel(id,name){delId=id;document.getElementById('delMsg').textContent=`"${name}" will be permanently removed.`;new bootstrap.Modal(document.getElementById('delModal')).show();}
document.getElementById('delBtn').addEventListener('click',executeSingleDelete);
async function executeSingleDelete(){
  const res=await fetch(`/api/v1/categories/${delId}`,{method:'DELETE'}); const j=await res.json();
  if(j.success) location.reload(); else alert(j.message);
}

// BULK DELETE API HOOKS
function toggleSelectAll() {
  const mainCheckbox = document.getElementById('selectAllCheckbox');
  const rowCheckboxes = document.querySelectorAll('.row-checkbox');
  const checked = mainCheckbox.checked;

  rowCheckboxes.forEach(cb => {
    cb.checked = checked;
    const tr = cb.closest('tr');
    if(checked) {
      tr.classList.add('row-selected');
      selectedIds.add(cb.value);
    } else {
      tr.classList.remove('row-selected');
      selectedIds.delete(cb.value);
    }
  });

  updateBulkActionBar();
}

function toggleRowSelection(cb) {
  const tr = cb.closest('tr');
  if(cb.checked) {
    tr.classList.add('row-selected');
    selectedIds.add(cb.value);
  } else {
    tr.classList.remove('row-selected');
    selectedIds.delete(cb.value);
    document.getElementById('selectAllCheckbox').checked = false;
  }
  updateBulkActionBar();
}

function evaluateSelectionState() {
   const rowCheckboxes = document.querySelectorAll('.row-checkbox');
   if(!rowCheckboxes.length) {
     document.getElementById('selectAllCheckbox').checked = false;
     return;
   }

   let allChecked = true;
   rowCheckboxes.forEach(cb => {
      if(!cb.checked) allChecked = false;
   });
   document.getElementById('selectAllCheckbox').checked = allChecked;
}

function updateBulkActionBar() {
  const bar = document.getElementById('bulkActionsBar');
  const msg = document.getElementById('selectedCountMsg');
  if(selectedIds.size > 0) {
    bar.style.display = 'flex';
    msg.textContent = `${selectedIds.size} records selected`;
  } else {
    bar.style.display = 'none';
    document.getElementById('selectAllCheckbox').checked = false;
  }
}

function confirmBulkDelete() {
  document.getElementById('delMsg').textContent = `Are you sure you want to permanently delete the ${selectedIds.size} selected category records?`;
  document.getElementById('delBtn').onclick = executeBulkDelete;
  new bootstrap.Modal(document.getElementById('delModal')).show();
}

async function executeBulkDelete() {
  const ids = Array.from(selectedIds);
  const res = await fetch(`/api/v1/categories/bulk-delete`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids })
  });
  const j = await res.json();
  if(j.success) location.reload(); else alert(j.message);
}

async function moveRow(localIndex, direction) {
  const globalIndex = (page - 1) * PS + localIndex;
  const targetIndex = globalIndex + direction;
  
  if (targetIndex < 0 || targetIndex >= filtered.length) return;
  
  // Swap sort_order in our local data
  // Since they are already sorted by sort_order, we just need to swap the values
  const currentItem = filtered[globalIndex];
  const targetItem = filtered[targetIndex];
  
  // If sort_order is the same (e.g. all 0), we assign them values based on index first
  const itemsToUpdate = filtered.map((item, idx) => ({
    id: item.id,
    sort_order: idx
  }));
  
  // Swap the orders
  const temp = itemsToUpdate[globalIndex].sort_order;
  itemsToUpdate[globalIndex].sort_order = itemsToUpdate[targetIndex].sort_order;
  itemsToUpdate[targetIndex].sort_order = temp;
  
  // Send only the relevant items to API
  const payload = [
    { id: itemsToUpdate[globalIndex].id, sort_order: itemsToUpdate[globalIndex].sort_order },
    { id: itemsToUpdate[targetIndex].id, sort_order: itemsToUpdate[targetIndex].sort_order }
  ];

  try {
    const res = await fetch('/api/v1/categories/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order: payload })
    });
    const data = await res.json();
    if (data.success) location.reload();
    else alert(data.message);
  } catch (err) {
    alert('Failed to reorder');
  }
}

render();
</script>
