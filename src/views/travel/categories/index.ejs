<style>
  .categories-page {
    --cat-primary: #2563eb;
    --cat-primary-dark: #1d4ed8;
    --cat-border: #e5e7eb;
    --cat-text: #111827;
  }
  .design-card {
    background: #fff;
    border: 1px solid #eef2f7;
    border-radius: 10px;
    padding: 1.25rem;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    margin-bottom: 2rem;
  }
  .table-minimal {
    border-collapse: separate;
    border-spacing: 0;
  }
  .table-minimal thead th {
    background: #f8fafc;
    border-bottom: 1px solid #e5e7eb;
    color: #475569;
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0;
    text-transform: uppercase;
    padding: 0.8rem 0.7rem;
    white-space: nowrap;
  }
  .table-minimal tbody tr {
    background-color: #fff;
    transition: background-color .18s ease;
  }
  .table-minimal tbody tr:hover {
    background-color: #f8fafc;
  }
  .table-minimal tbody td {
    border-bottom: 1px solid #eef2f7;
    padding: 0.8rem 0.7rem;
    color: #4b5563;
    font-size: 0.85rem;
    font-weight: 500;
    vertical-align: middle;
  }
  .table-minimal thead th:first-child { border-top-left-radius: 8px; }
  .table-minimal thead th:last-child { border-top-right-radius: 8px; }
  .btn-create {
    background-color: var(--cat-primary);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .btn-create:hover { background-color: var(--cat-primary-dark); color: #fff; }

  .filter-input {
    background-color: #f9fafb;
    border: 1px solid #f3f4f6;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #4b5563;
  }
  .filter-input:focus {
    background-color: #fff;
    border-color: #d1d5db;
    box-shadow: none;
  }
  .btn-group-toggle .btn {
    border: 1px solid #e5e7eb;
    background-color: #fff;
    color: #4b5563;
    font-size: 0.82rem;
    padding: 0.35rem 0.75rem;
    font-weight: 500;
  }
  .btn-group-toggle .btn.active {
    background-color: #f3f4f6;
    color: #111827;
    box-shadow: none;
  }

  /* bulk select custom styles */
  .custom-checkbox {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid #d1d5db;
    appearance: none;
    outline: none;
    cursor: pointer;
    position: relative;
    background-color: #fff;
    transition: all 0.2s;
    margin: 0;
    vertical-align: middle;
  }
  .custom-checkbox:checked {
    background-color: #22c55e;
    border-color: #22c55e;
  }
  .custom-checkbox:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .table-minimal tbody tr td:first-child {
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .table-minimal tbody tr.row-selected td:first-child {
    border-left-color: #22c55e;
  }
  .table-minimal tbody tr.row-selected td {
    background-color: #f8fafc;
  }
  .bulk-delete-bar {
    display: none;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.8rem 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .category-shell {
    background: linear-gradient(180deg, #f8fafc 0%, #fff 42%);
    border-radius: 10px;
    padding: 1rem;
  }
  .category-table-wrap {
    border: 1px solid #eef2f7;
    border-radius: 10px;
    overflow-x: auto;
    overflow-y: visible;
  }
  .category-modal .modal-dialog {
    max-width: 720px;
  }
  .category-modal .modal-content {
    border: 0;
    border-radius: 14px;
    overflow: hidden;
  }
  .category-modal .modal-header {
    background: #fff !important;
    border-bottom: 1px solid #eef2f7;
    color: var(--cat-text) !important;
    padding: 1rem 1.35rem;
  }
  .category-modal .btn-close {
    filter: none;
  }
  .category-modal .modal-body {
    max-height: min(72vh, 720px);
    overflow-y: auto;
    padding: 1.25rem 1.35rem;
  }
  .category-modal .modal-footer {
    background: #fff;
    border-top: 1px solid #eef2f7;
    padding: 1rem 1.35rem;
  }
  .category-form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }
  .category-form-grid .full-span {
    grid-column: 1 / -1;
  }
  .category-switch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: .75rem;
    margin-bottom: 1rem;
  }
  .category-switch {
    align-items: center;
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    display: flex;
    gap: .65rem;
    min-height: 46px;
    padding: .6rem .75rem;
    padding-left: .75rem !important;
  }
  .category-switch .form-check-input {
    flex: 0 0 auto;
    margin: 0;
  }
  .category-switch .form-check-label {
    color: #334155;
    font-size: .86rem;
    font-weight: 600;
    line-height: 1.2;
    padding: 0 !important;
  }
  .category-seo-button {
    border-radius: 8px !important;
    min-height: 48px;
  }
  .category-status-badge {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    font-size: .73rem;
    font-weight: 700;
    gap: .28rem;
    justify-content: center;
    line-height: 1;
    min-width: 58px;
    padding: .38rem .58rem;
  }
  .category-status-badge.yes {
    background: #dcfce7;
    color: #166534;
  }
  .category-status-badge.no {
    background: #f1f5f9;
    color: #64748b;
  }
  .category-status-badge.tour {
    background: #dbeafe;
    color: #1e40af;
  }
  @media (max-width: 767px) {
    .design-card {
      padding: 1rem;
    }
    .category-form-grid {
      grid-template-columns: 1fr;
    }
    .category-modal .modal-dialog {
      margin: .75rem;
    }
    .category-modal .modal-body {
      max-height: 70vh;
    }
  }
</style>

<div class="design-card categories-page">
  <!-- HEADER ROW -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h3 class="fw-bold mb-1" style="color: #111827;">Destination Categories</h3>
      <p class="text-muted mb-0" style="font-size: 0.85rem;">Tag types for destinations (Beach, Mountain, Heritage…)</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="btn-group btn-group-toggle shadow-sm" role="group">
        <button type="button" class="btn active d-flex align-items-center gap-2" id="vList" onclick="setView('list')">
          <i class="bi bi-list-ul"></i> List
        </button>
        <button type="button" class="btn d-flex align-items-center gap-2" id="vCards" onclick="setView('cards')">
          <i class="bi bi-person-vcard"></i> Cards
        </button>
      </div>
      <button class="btn-create shadow-sm" data-bs-toggle="modal" data-bs-target="#modal" onclick="openCreate()">
        <i class="bi bi-plus-lg me-1"></i> Add Category
      </button>
    </div>
  </div>

  <hr style="border-color: #e5e7eb; margin: 1.25rem -1.5rem;">

  <!-- TOOLBAR ROW -->
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4 mt-2">
    <div class="d-flex gap-2">
      <div class="position-relative" style="width: 260px;">
        <i class="bi bi-search position-absolute text-muted" style="left: 12px; top: 50%; transform: translateY(-50%); font-size: 0.85rem;"></i>
        <input type="text" id="searchInput" class="form-control form-control-sm filter-input ps-5 py-2" placeholder="Search category..." oninput="applyFilters()">
      </div>
    </div>
    <div>
      <span class="text-muted fw-bold" id="countLabel" style="font-size: 0.85rem;"></span>
    </div>
  </div>

  <!-- BULK ACTIONS BAR -->
  <div id="bulkActionsBar" class="bulk-delete-bar align-items-center justify-content-between">
    <div>
      <button class="btn btn-danger btn-sm px-3 py-2 d-inline-flex align-items-center gap-2" style="background-color: #ef4444; border:none; border-radius:6px; font-weight:600;" onclick="confirmBulkDelete()">
        <i class="bi bi-trash3"></i> Delete selected
      </button>
    </div>
    <div>
      <span id="selectedCountMsg" class="fw-bold" style="color: #4b5563; font-size:0.9rem;">0 records selected</span>
    </div>
  </div>

  <!-- LIST VIEW -->
  <div id="listView" class="category-shell">
    <div class="category-table-wrap">
      <table class="table table-minimal w-100">
        <thead>
          <tr>
            <th style="width:30px">
              <input type="checkbox" class="custom-checkbox" id="selectAllCheckbox" onchange="toggleSelectAll()">
            </th>
            <th style="width:40px">#</th>
            <th style="width:70px">Sort</th>
            <th>Category Name</th>
            <th>Description</th>
            <th>Menu</th>
            <th>Sidebar</th>
            <th>Home</th>
            <th>Tour Type</th>
            <th style="width:80px;text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="listBody"></tbody>
      </table>
      <div id="listPag"></div>
    </div>
  </div>

<!-- CARDS VIEW -->
<div id="cardsView" class="category-shell" style="display:none">
  <div class="tf-cards" id="cardsBody"></div>
  <div class="tf-pagination mt-3" style="border-radius:16px;background:#fff;box-shadow:0 4px 16px rgba(79,70,229,.07)" id="cardsPag"></div>
</div>

<!-- MODAL -->
<div class="modal fade tf-modal category-modal" id="modal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="modalTitle">Add Category</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="fId">
        <div class="category-form-grid">
        <div>
          <label class="form-label">Category Name <span class="text-danger">*</span></label>
          <input type="text" class="form-control" id="fName" placeholder="e.g. Beach, Hill Station, Heritage">
        </div>
        <div>
          <label class="form-label">Slug</label>
          <input type="text" class="form-control" id="fSlug" placeholder="e.g. beach-tours (auto-generated if empty)">
        </div>
        <div class="full-span">
          <label class="form-label">Description</label>
          <textarea class="form-control" id="fDesc" rows="3" placeholder="Short description…"></textarea>
        </div>
        <div>
          <label class="form-label">Tag Style (Badge Color)</label>
          <select class="form-select" id="fTagColor">
            <option value="gray">None / Gray</option>
            <option value="red">Red (e.g. Trending)</option>
            <option value="pink">Pink (e.g. Romance)</option>
            <option value="orange">Orange (e.g. Budget)</option>
            <option value="purple">Purple (e.g. Popular)</option>
            <option value="blue">Blue</option>
            <option value="green">Green</option>
          </select>
        </div>
        <div>
          <label class="form-label">Feature Image</label>
          <input type="file" class="form-control" id="fImageFile" accept="image/*" onchange="previewImage(this)">
          <div id="imagePreviewContainer" class="mt-2 position-relative d-none" style="max-width: 150px;">
            <img id="imagePreview" src="" alt="Feature Image" class="img-thumbnail w-100" style="max-height: 100px; object-fit: cover;">
            <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 p-1" style="line-height:1;" onclick="clearImage()"><i class="bi bi-x-circle"></i></button>
          </div>
          <input type="hidden" id="fRemoveImage" value="false">
        </div>
        <div class="full-span">
          <label class="form-label">Feature Image Alt Text</label>
          <input type="text" class="form-control" id="fImageAlt" placeholder="Alt text for SEO">
        </div>
        </div>

        <div class="category-switch-grid mt-3">
          <div class="form-check form-switch category-switch">
            <input class="form-check-input" type="checkbox" id="fShowInMenu" role="switch">
            <label class="form-check-label" for="fShowInMenu">Show in Menu</label>
          </div>
          <div class="form-check form-switch category-switch">
            <input class="form-check-input" type="checkbox" id="fShowInSidebar" role="switch">
            <label class="form-check-label" for="fShowInSidebar">Show in Sidebar</label>
          </div>
          <div class="form-check form-switch category-switch">
            <input class="form-check-input" type="checkbox" id="fShowInHome" role="switch">
            <label class="form-check-label" for="fShowInHome">Show in Home</label>
          </div>
          <!-- <div class="form-check form-switch category-switch">
            <input class="form-check-input" type="checkbox" id="fIsCustomizable" role="switch">
            <label class="form-check-label" for="fIsCustomizable">Customizable</label>
          </div> -->
          <div class="form-check form-switch category-switch">
            <input class="form-check-input" type="checkbox" id="fIsTourType" role="switch">
            <label class="form-check-label" for="fIsTourType">Tour Type</label>
          </div>
        </div>

        <!-- SEO Collapse Section -->
        <div class="accordion mb-3" id="seoAccordion">
          <div class="accordion-item border rounded-3 overflow-hidden">
            <h2 class="accordion-header">
              <button class="accordion-button collapsed category-seo-button px-3 fw-semibold text-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#seoFields" style="box-shadow:none; background:none;">
                <i class="bi bi-search me-2"></i> SEO & Schema Settings
              </button>
            </h2>
            <div id="seoFields" class="accordion-collapse collapse" data-bs-parent="#seoAccordion">
              <div class="accordion-body px-3 py-3 bg-light">
                <div class="mb-3">
                  <label class="form-label text-dark">Meta Title</label>
                  <input type="text" class="form-control bg-white" id="fMetaTitle" placeholder="SEO Title">
                </div>
                <div class="mb-3">
                  <label class="form-label text-dark">Meta Description</label>
                  <textarea class="form-control bg-white" id="fMetaDesc" rows="2" placeholder="SEO Description..."></textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label text-dark">Meta Keyword</label>
                  <textarea class="form-control bg-white" id="fMetaKeyword" rows="2" placeholder="SEO Keywords..."></textarea>
                </div>
                <div class="mb-3">
                  <label class="form-label text-dark">Schema (JSON-LD)</label>
                  <textarea class="form-control bg-white" id="fSchema" rows="2" placeholder="JSON-LD Schema Markup..."></textarea>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
      <div class="modal-footer">
        <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
        <button class="btn-add-primary" style="background:linear-gradient(135deg,#10b981,#34d399);box-shadow:0 4px 14px rgba(16,185,129,.35)" onclick="save()"><i class="bi bi-check2 me-1"></i>Save</button>
      </div>
    </div>
  </div>
</div>

<!-- DELETE MODAL -->
<div class="modal fade tf-modal" id="delModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
    <div class="modal-content">
      <div class="modal-body text-center p-4">
        <div style="width:60px;height:60px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.7rem;color:#ef4444"><i class="bi bi-trash3"></i></div>
        <h5 class="fw-bold mb-1">Delete Category?</h5>
        <p class="text-muted" id="delMsg" style="font-size:.88rem"></p>
        <div class="d-flex gap-2 justify-content-center mt-3">
          <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button class="btn btn-danger px-4 rounded-3 fw-semibold" id="delBtn">Yes, Delete</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const ALL = <%- JSON.stringify(categories) %>;
const CAT_COLORS = ['#10b981','#4f46e5','#f59e0b','#ec4899','#0ea5e9','#8b5cf6','#ef4444','#06b6d4'];
const CAT_ICONS  = ['bi-geo-alt-fill','bi-water','bi-tree-fill','bi-building','bi-snow','bi-sunset','bi-star-fill','bi-heart-fill'];
const TAG_STYLES = {
  red:    { bg: '#fee2e2', text: '#991b1b', label: 'Red' },
  pink:   { bg: '#fce7f3', text: '#9d174d', label: 'Pink' },
  orange: { bg: '#ffedd5', text: '#9a3412', label: 'Orange' },
  purple: { bg: '#f3e8ff', text: '#6b21a8', label: 'Purple' },
  blue:   { bg: '#dbeafe', text: '#1e40af', label: 'Blue' },
  green:  { bg: '#dcfce7', text: '#166534', label: 'Green' },
  gray:   { bg: '#f3f4f6', text: '#4b5563', label: 'Gray' }
};
const PS=12; let view='list',page=1,filtered=[...ALL],delId=null;
let selectedIds = new Set();

function statusBadge(value, type = 'default') {
  if (value) {
    const icon = type === 'tour' ? 'bi-compass-fill' : 'bi-check-circle-fill';
    const className = type === 'tour' ? 'tour' : 'yes';
    return `<span class="category-status-badge ${className}"><i class="bi ${icon}"></i>Yes</span>`;
  }
  return '<span class="category-status-badge no"><i class="bi bi-dash-circle"></i>No</span>';
}

function getTagStyle(tagColor) {
  if (TAG_STYLES[tagColor]) return TAG_STYLES[tagColor];
  if (tagColor && /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(tagColor)) {
    return { bg: `${tagColor}18`, text: tagColor, label: tagColor };
  }
  return TAG_STYLES.gray;
}

function applyFilters(){
  const q=document.getElementById('searchInput').value.toLowerCase();
  filtered=ALL.filter(r=>r.name.toLowerCase().includes(q));
  page=1; render();
}
function render(){
  const tot=filtered.length,pages=Math.max(1,Math.ceil(tot/PS));
  page=Math.min(page,pages);
  const s=(page-1)*PS,slice=filtered.slice(s,s+PS);
  document.getElementById('countLabel').textContent=`${tot} result${tot!==1?'s':''}`;
  if(view==='cards') renderCards(slice,s,tot,pages);
  else               renderList(slice,s,tot,pages);
  evaluateSelectionState();
}
function renderCards(slice,s,tot,pages){
  const body=document.getElementById('cardsBody');
  if(!slice.length){body.innerHTML=`<div class="tf-empty" style="grid-column:1/-1"><div class="tf-empty-icon"><i class="bi bi-tags"></i></div><p>No categories found.</p></div>`;document.getElementById('cardsPag').innerHTML='';return;}
  body.innerHTML=slice.map((r,i)=>{
    const col=CAT_COLORS[(r.id||i)%CAT_COLORS.length];
    const ico=CAT_ICONS[(r.id||i)%CAT_ICONS.length];
    return `<div class="tf-card">
      <div class="tf-card-icon" style="background:${col}18;color:${col}"><i class="bi ${ico}"></i></div>
      <div class="tf-card-name">${r.name}</div>
      ${r.description?`<div class="tf-card-meta">${r.description}</div>`:''}
      <div class="tf-card-actions">
        <button class="btn-icon btn-icon-edit" style="flex:1;justify-content:center" onclick="openEdit('${r.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil me-1"></i>Edit</button>
        <button class="btn-icon btn-icon-del" onclick="confirmDel('${r.id}','${r.name.replace(/'/g,"\\'")}')"><i class="bi bi-trash3"></i></button>
      </div>
    </div>`;
  }).join('');
  document.getElementById('cardsPag').innerHTML=pagHTML(page,pages,tot,s,slice.length);
}
function renderList(slice,s,tot,pages){
  const body=document.getElementById('listBody');
  if(!slice.length){body.innerHTML=`<tr><td colspan="10"><div class="text-center p-4 text-muted"><p>No categories found.</p></div></td></tr>`;document.getElementById('listPag').innerHTML='';return;}
  body.innerHTML=slice.map((r,i)=>{
    const col=CAT_COLORS[(r.id||i)%CAT_COLORS.length];
    const ico=CAT_ICONS[(r.id||i)%CAT_ICONS.length];
    const checked = selectedIds.has(r.id.toString()) ? 'checked' : '';
    const rowClass = checked ? 'row-selected' : '';
    return `<tr class="${rowClass}">
      <td><input type="checkbox" class="custom-checkbox row-checkbox" value="${r.id}" onchange="toggleRowSelection(this)" ${checked}></td>
      <td style="color:#6b7280;">${s+i+1}</td>
      <td>
        <div class="d-flex gap-1">
          <button class="btn btn-sm btn-light border p-0" style="width:24px;height:24px" onclick="moveRow(${i}, -1)" ${s+i===0?'disabled':''}><i class="bi bi-chevron-up" style="font-size:0.7rem"></i></button>
          <button class="btn btn-sm btn-light border p-0" style="width:24px;height:24px" onclick="moveRow(${i}, 1)" ${s+i===filtered.length-1?'disabled':''}><i class="bi bi-chevron-down" style="font-size:0.7rem"></i></button>
        </div>
      </td>
      <td><div style="display:flex;align-items:center;gap:.7rem">
        <div class="row-avatar" style="background:${col}18;color:${col}; width:28px; height:28px; font-size:0.8rem; border-radius:10px; display:flex; align-items:center; justify-content:center;"><i class="bi ${ico}"></i></div>
        <div style="line-height:1.2;">
          <span style="font-weight:600;color:#1e1e4a;display:block;">${r.name}</span>
          ${(() => {
            const t = getTagStyle(r.tag_color || 'gray');
            if(r.tag_color && r.tag_color !== 'gray') return `<span style="background:${t.bg}; color:${t.text}; font-size:0.6rem; font-weight:700; padding:1px 6px; border-radius:12px; text-transform:uppercase; margin-top:3px; display:inline-block; letter-spacing:0.5px;">${r.name}</span>`;
            return '';
          })()}
        </div>
      </div></td>
      <td><span style="color:#4b5563;font-size:0.85rem">${r.description||'—'}</span></td>
      <td>${statusBadge(r.show_in_menu)}</td>
      <td>${statusBadge(r.show_in_sidebar)}</td>
      <td>${statusBadge(r.show_in_home)}</td>
      <td>${statusBadge(r.is_tour_type, 'tour')}</td>
      <td style="text-align:right">
        <button class="btn btn-sm btn-light border me-1 rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="openEdit('${r.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil" style="font-size:0.8rem;color:#4b5563;"></i></button>
        <button class="btn btn-sm btn-light border rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="confirmDel('${r.id}','${r.name.replace(/'/g,"\\'")}')"><i class="bi bi-trash3" style="font-size:0.8rem;color:#ef4444;"></i></button>
      </td>
    </tr>`;
  }).join('');
  document.getElementById('listPag').innerHTML=pagHTML(page,pages,tot,s,slice.length);
}
function pagHTML(p,pages,tot,s,len){
  const prev=`<button onclick="goPage(${p-1})" ${p<=1?'disabled':''}><i class="bi bi-chevron-left"></i></button>`;
  const next=`<button onclick="goPage(${p+1})" ${p>=pages?'disabled':''}><i class="bi bi-chevron-right"></i></button>`;
  let nums='';
  for(let i=1;i<=pages;i++){
    if(pages<=6||Math.abs(i-p)<=1||i===1||i===pages) nums+=`<button class="${i===p?'active':''}" onclick="goPage(${i})">${i}</button>`;
    else if(Math.abs(i-p)===2) nums+=`<button disabled style="border:0;background:none;color:#8888bb">…</button>`;
  }
  return `<div class="tf-page-info">Showing ${s+1}–${s+len} of ${tot}</div><div class="tf-pages">${prev}${nums}${next}</div>`;
}
function goPage(p){page=p;render();}
function setView(v){
  view=v;
  document.getElementById('cardsView').style.display=v==='cards'?'':'none';
  document.getElementById('listView').style.display=v==='list'?'':'none';
  document.getElementById('vCards').classList.toggle('active',v==='cards');
  document.getElementById('vList').classList.toggle('active',v==='list');
  render();
}
function previewImage(input) {
  if (input.files && input.files[0]) {
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('imagePreview').src = e.target.result;
      document.getElementById('imagePreviewContainer').classList.remove('d-none');
      document.getElementById('fRemoveImage').value = 'false';
    };
    reader.readAsDataURL(input.files[0]);
  }
}

function clearImage() {
  document.getElementById('fImageFile').value = '';
  document.getElementById('imagePreview').src = '';
  document.getElementById('imagePreviewContainer').classList.add('d-none');
  document.getElementById('fRemoveImage').value = 'true';
}

function openCreate() {
  document.getElementById('modalTitle').textContent='Add Category';
  document.getElementById('fId').value='';
  document.getElementById('fName').value='';
  document.getElementById('fSlug').value='';
  document.getElementById('fDesc').value='';
  document.getElementById('fTagColor').value='gray';
