<%- contentFor('body') %>
<%
    const hotelGallery = Array.isArray(gallery) ? gallery : [];
    const hotelAmenities = hotel && Array.isArray(hotel.amenities) ? hotel.amenities : [];
    const amenityOptions = [
        'Restaurant',
        'Wi-Fi',
        'Smoke Detector',
        'Laundry Service',
        'Room Service',
        'Air Conditioning',
        'Parking',
        'Swimming Pool',
        'Fitness Center',
        'Airport Transfer',
        'Breakfast',
        'Spa'
    ];
%>

<div class="content-header">
    <div class="container-fluid">
        <div class="row align-items-center mb-4 mt-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark" style="font-weight: 800;"><%= title %></h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="/travel/hotels" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form id="hotelForm" action="/travel/hotels/<%= hotel ? hotel.id : 'save' %>" method="POST" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Hotel Name</label>
                            <input type="text" name="name" class="form-control" value="<%= hotel ? hotel.name : '' %>" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>City</label>
                            <div class="position-relative" id="hotelCityPicker">
                                <input type="text" id="hotelCitySearch" class="form-control"
                                    value="<%= selectedCity ? `${selectedCity.name}${selectedCity.country ? ` — ${selectedCity.country.name}` : ''}` : '' %>"
                                    placeholder="Search city or country..." autocomplete="off">
                                <input type="hidden" name="city_id" id="hotelCityId" value="<%= selectedCity ? selectedCity.id : '' %>">
                                <div id="hotelCityResults" class="list-group position-absolute w-100 shadow"
                                    style="display:none;z-index:2050;top:calc(100% + 4px);max-height:280px;overflow-y:auto;background:#fff;border:1px solid #dbe3ef;border-radius:8px"></div>
                            </div>
                            <small class="form-text text-muted">Search by city or country. Scroll to load more cities.</small>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Source Type</label>
                            <select name="source_type" id="source_type" class="form-control">
                                <option value="manual" <%= hotel && hotel.source_type === 'manual' ? 'selected' : '' %>>Manual</option>
                                <option value="third_party" <%= hotel && hotel.source_type === 'third_party' ? 'selected' : '' %>>3rd Party Provider</option>
                            </select>
                        </div>
                        <div class="col-md-8 form-group" id="provider_name_group" style="display: none;">
                            <label>Provider Name</label>
                            <input type="text" name="provider_name" class="form-control" value="<%= hotel ? hotel.provider_name : '' %>" placeholder="e.g. MakeMyTrip, Agoda, Expedia...">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 form-group">
                            <label>Star Rating (1-5)</label>
                            <input type="number" name="star_rating" class="form-control" min="1" max="5" value="<%= hotel ? hotel.star_rating : 3 %>" required>
                        </div>
                        <div class="col-md-3 form-group">
                            <label>Guest Rating (0-5)</label>
                            <input type="number" step="0.1" name="guest_rating" class="form-control" min="0" max="5" value="<%= hotel ? hotel.guest_rating : 4.0 %>" required>
                        </div>
                        <div class="col-md-3 form-group">
                            <label>Total Rooms</label>
                            <input type="number" name="total_rooms" class="form-control" min="0" value="<%= hotel ? hotel.total_rooms : 0 %>" required>
                        </div>
                        <div class="col-md-3 form-group">
                            <label>Price Per Night (INR)</label>
                            <input type="number" step="0.01" name="price_per_night" class="form-control" value="<%= hotel ? hotel.price_per_night : '' %>" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 form-group">
                            <label>Discount (%)</label>
                            <input type="number" step="0.01" name="discount_percent" class="form-control" min="0" max="100" value="<%= hotel ? hotel.discount_percent : 0 %>">
                        </div>
                        <div class="col-md-3 form-group">
                            <label>Commission (%)</label>
                            <input type="number" step="0.01" name="commission_percent" class="form-control" min="0" max="100" value="<%= hotel ? hotel.commission_percent : 0 %>">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Amenities</label>
                        <div class="row">
                            <% amenityOptions.forEach(amenity => { %>
                                <div class="col-md-3 col-sm-6 mb-2">
                                    <label class="border rounded px-3 py-2 w-100 mb-0" style="background:#f8fafc; cursor:pointer;">
                                        <input type="checkbox" name="amenities" value="<%= amenity %>" <%= hotelAmenities.includes(amenity) ? 'checked' : '' %>>
                                        <%= amenity %>
                                    </label>
                                </div>
                            <% }) %>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="description" class="form-control" rows="4"><%= hotel ? hotel.description : '' %></textarea>
                    </div>

                    <div class="form-group">
                        <label class="font-weight-bold">Hotel Gallery</label>
                        <div class="text-muted small mb-2">Upload multiple images or paste multiple image/video URLs. The primary item is used as the hotel cover image.</div>

                        <% if (hotelGallery.length) { %>
                            <div class="d-flex flex-wrap align-items-center justify-content-between mb-2 p-2 border rounded" style="background:#fff7f7; gap:.75rem;">
                                <label class="mb-0 font-weight-bold" style="cursor:pointer;">
                                    <input type="checkbox" id="selectAllMedia">
                                    Select all media
                                </label>
                                <button type="button" id="markSelectedMediaBtn" class="btn btn-sm btn-danger" disabled>
                                    <i class="fas fa-trash mr-1"></i> Delete selected (<span id="selectedMediaCount">0</span>)
                                </button>
                            </div>
                            <div class="row mb-3">
                                <% hotelGallery.forEach(item => { %>
                                    <div class="col-md-3 mb-3">
                                        <div class="border rounded p-2 h-100" style="background:#f8fafc;">
                                            <div style="aspect-ratio: 16 / 10; background:#e5e7eb; border-radius:8px; overflow:hidden; display:flex; align-items:center; justify-content:center;">
                                                <% if (item.media_type === 'video') { %>
                                                    <video src="<%= item.url %>" style="width:100%; height:100%; object-fit:cover;" muted></video>
                                                <% } else { %>
                                                    <img src="<%= item.url %>" alt="<%= item.alt_text || hotel.name %>" style="width:100%; height:100%; object-fit:cover;">
                                                <% } %>
                                            </div>
                                            <div class="mt-2 d-flex justify-content-between align-items-center">
                                                <label class="mb-0 small">
                                                    <input type="radio" name="primary_media_id" value="<%= item.id %>" <%= item.is_primary ? 'checked' : '' %>>
                                                    Primary
                                                </label>
                                                <label class="mb-0 small text-danger">
                                                    <input type="checkbox" class="remove-media-checkbox" name="remove_media_ids" value="<%= item.id %>">
                                                    Remove
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label>Upload Gallery Media</label>
                                <input type="file" name="gallery_files" class="form-control" multiple accept="image/*,video/mp4,video/quicktime,video/webm">
                            </div>
                            <div class="col-md-6 form-group">
                                <label>Gallery URLs</label>
                                <textarea name="gallery_urls" class="form-control" rows="3" placeholder="Paste one URL per line"></textarea>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-success mt-3"><i class="fas fa-save mr-2"></i> Save Hotel</button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function toggleProviderField() {
        const sourceType = document.getElementById('source_type');
        const providerGroup = document.getElementById('provider_name_group');
        if (providerGroup) providerGroup.style.display = sourceType?.value === 'third_party' ? '' : 'none';
    }

    document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('source_type')?.addEventListener('change', toggleProviderField);
        toggleProviderField();

        const cityPicker = document.getElementById('hotelCityPicker');
        const citySearch = document.getElementById('hotelCitySearch');
        const cityId = document.getElementById('hotelCityId');
        const cityResults = document.getElementById('hotelCityResults');
        const hotelForm = document.getElementById('hotelForm');
        let cityPage = 0;
        let cityQuery = '';
        let cityHasMore = true;
        let cityLoading = false;
        let citySearchTimer = null;
        let cityRequestController = null;

        function showCityMessage(message) {
            cityResults.innerHTML = '';
            const item = document.createElement('div');
            item.className = 'list-group-item text-muted small py-3';
            item.textContent = message;
            cityResults.appendChild(item);
            cityResults.style.display = 'block';
        }

        function appendCity(city) {
            const country = city.country?.name || 'Country not set';
            const option = document.createElement('button');
            option.type = 'button';
            option.className = 'list-group-item list-group-item-action py-2 px-3 text-start fw-semibold';
            option.textContent = `${city.name} — ${country}`;
            option.addEventListener('click', function() {
                cityId.value = city.id;
                citySearch.value = `${city.name} — ${country}`;
                citySearch.setCustomValidity('');
                cityResults.style.display = 'none';
            });
            cityResults.appendChild(option);
        }

        async function loadCities(reset = false) {
            if (reset && cityRequestController) {
                cityRequestController.abort();
                cityLoading = false;
            }
            if (cityLoading || (!reset && !cityHasMore)) return;
            if (reset) {
                cityPage = 0;
                cityHasMore = true;
                cityResults.innerHTML = '';
            }

            cityLoading = true;
            const requestController = new AbortController();
            cityRequestController = requestController;
            const nextPage = cityPage + 1;
            if (nextPage === 1) showCityMessage('Loading cities...');

            try {
                const params = new URLSearchParams({ page: nextPage, limit: 20, search: cityQuery });
                const response = await fetch(`/travel/api/v1/cities/paginated?${params.toString()}`, {
                    signal: requestController.signal
                });
                const result = await response.json();
                if (!response.ok || !result.success) throw new Error(result.message || 'Unable to load cities');

                const rows = result.data?.rows || [];
                const total = Number(result.data?.count) || 0;
                if (nextPage === 1) cityResults.innerHTML = '';
                rows.forEach(appendCity);
                cityPage = nextPage;
                cityHasMore = cityPage * 20 < total;

                if (!rows.length && nextPage === 1) showCityMessage('No matching cities found.');
                else cityResults.style.display = 'block';
            } catch (error) {
                if (error.name === 'AbortError') return;
                showCityMessage(error.message || 'Unable to load cities.');
            } finally {
                if (cityRequestController === requestController) {
                    cityLoading = false;
                    cityRequestController = null;
                }
            }
        }

        citySearch?.addEventListener('focus', function() {
            cityQuery = citySearch.value.includes(' — ') ? '' : citySearch.value.trim();
            loadCities(true);
        });

        citySearch?.addEventListener('input', function() {
            cityId.value = '';
            citySearch.setCustomValidity('');
            cityQuery = citySearch.value.trim();
            clearTimeout(citySearchTimer);
            citySearchTimer = setTimeout(() => loadCities(true), 250);
        });

        cityResults?.addEventListener('scroll', function() {
            const nearBottom = cityResults.scrollTop + cityResults.clientHeight >= cityResults.scrollHeight - 40;
            if (nearBottom) loadCities(false);
        });

        document.addEventListener('click', function(event) {
            if (cityPicker && !cityPicker.contains(event.target)) cityResults.style.display = 'none';
        });

        hotelForm?.addEventListener('submit', function(event) {
            if (cityId.value) return;
            event.preventDefault();
            citySearch.setCustomValidity('Please select a city from the search results.');
            citySearch.reportValidity();
            citySearch.focus();
        });

        const selectAllMedia = document.getElementById('selectAllMedia');
        const mediaCheckboxes = Array.from(document.querySelectorAll('.remove-media-checkbox'));
        const selectedMediaCount = document.getElementById('selectedMediaCount');
        const markSelectedMediaBtn = document.getElementById('markSelectedMediaBtn');

        function updateMediaSelection() {
            if (!selectAllMedia) return;
            const checkedCount = mediaCheckboxes.filter(checkbox => checkbox.checked).length;
            selectAllMedia.checked = mediaCheckboxes.length > 0 && checkedCount === mediaCheckboxes.length;
            selectAllMedia.indeterminate = checkedCount > 0 && checkedCount < mediaCheckboxes.length;
            selectedMediaCount.textContent = checkedCount;
            markSelectedMediaBtn.disabled = checkedCount === 0;
        }

        if (selectAllMedia) {
            selectAllMedia.addEventListener('change', function() {
                mediaCheckboxes.forEach(checkbox => { checkbox.checked = this.checked; });
                updateMediaSelection();
            });
            mediaCheckboxes.forEach(checkbox => checkbox.addEventListener('change', updateMediaSelection));
            markSelectedMediaBtn.addEventListener('click', function() {
                const checkedCount = mediaCheckboxes.filter(checkbox => checkbox.checked).length;
                if (!checkedCount) return;
                if (confirm(`Delete ${checkedCount} selected media item${checkedCount === 1 ? '' : 's'}?`)) {
                    document.getElementById('hotelForm').requestSubmit();
                }
            });
            updateMediaSelection();
        }
    });
</script>
