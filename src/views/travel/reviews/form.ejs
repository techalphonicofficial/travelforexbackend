<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Bali Travel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    .tf-form-card {
      background: #fff;
      border-radius: 20px;
      border: 0;
      box-shadow: 0 10px 40px rgba(79, 70, 229, 0.08);
      margin-bottom: 2rem;
      overflow: hidden;
    }
    .tf-form-header {
      padding: 1.5rem;
      background: linear-gradient(to right, #f8faff, #ffffff);
      border-bottom: 1px solid #f0f0fa;
      font-weight: 700;
      color: #1e1e4a;
      display: flex;
      align-items: center;
      gap: .8rem;
      font-size: 1.1rem;
    }
    .tf-form-body {
      padding: 2rem;
    }
    .tf-page-header {
      background: white;
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 1.5rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 10px 40px rgba(79, 70, 229, 0.08);
    }
    .tf-page-title {
      font-size: 1.8rem;
      font-weight: 800;
      color: #1e1e4a;
      margin: 0;
    }
    .tf-back-btn {
      width: 40px;
      height: 40px;
      background: #f0f0fa;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #4f46e5;
      text-decoration: none;
      transition: all 0.2s;
    }
    .tf-back-btn:hover {
      background: #4f46e5;
      color: white;
    }
    .btn-save {
      background: linear-gradient(135deg, #4f46e5, #818cf8);
      border: none;
      padding: 0.6rem 2rem;
      border-radius: 12px;
      color: white;
      font-weight: 600;
      transition: all 0.2s;
    }
    .btn-save:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
    }
    .preview-placeholder {
      aspect-ratio: 9/16;
      background: #f8fafc;
      border: 2px dashed #e2e8f0;
      border-radius: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #94a3b8;
    }
    .video-preview-el {
      aspect-ratio: 9/16;
      width: 100%;
      border-radius: 20px;
      object-fit: cover;
      display: none;
    }
    .avatar-preview-el {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      object-fit: cover;
      display: none;
      border: 3px solid #fff;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body class="bg-light">

<div class="container-fluid" style="max-width: 1200px; margin: 0 auto; padding-top: 2rem;">
  <div class="tf-page-header">
    <div class="d-flex align-items-center gap-3">
      <a href="/travel/reviews" class="tf-back-btn"><i class="bi bi-chevron-left"></i></a>
      <div>
        <h1 class="tf-page-title"><%= title %></h1>
        <p class="tf-page-sub mb-0">Set up the reels-style journey video experience</p>
      </div>
    </div>
    <div class="d-flex gap-2">
      <a href="/travel/reviews" class="btn btn-light px-4 rounded-3 border">Cancel</a>
      <button class="btn-save" id="saveReviewBtn">
        <i class="bi bi-check2-circle me-1"></i> Save Review
      </button>
    </div>
  </div>

  <form id="reviewForm">
    <input type="hidden" name="id" value="<%= review ? review.id : '' %>">
    <div class="row g-4">
      <div class="col-md-8">
        <!-- Basic Info -->
        <div class="tf-form-card">
          <div class="tf-form-header"><i class="bi bi-info-circle text-primary"></i> Review Details</div>
          <div class="tf-form-body">
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label fw-bold">Review Title</label>
                <input type="text" class="form-control" name="title" value="<%= review ? review.title : '' %>" placeholder="e.g., James's Solo Japan Journey">
              </div>
              <div class="col-12">
                <label class="form-label fw-bold">Description</label>
                <textarea class="form-control" name="description" rows="3" placeholder="A short blurb about the journey..."><%= review ? review.description : '' %></textarea>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Location</label>
                <input type="text" class="form-control" name="location" value="<%= review ? review.location : '' %>" placeholder="e.g., Kyoto, Japan">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Likes Count (Initial)</label>
                <input type="number" class="form-control" name="likes_count" value="<%= review ? review.likes_count : '0' %>">
              </div>
              <div class="col-md-12">
                <label class="form-label fw-bold">Link to Package</label>
                <select class="form-select" name="package_id">
                  <option value="">-- No Specific Package --</option>
                  <% packages.forEach(p => { %>
                    <option value="<%= p.id %>" <%= review && review.package_id == p.id ? 'selected' : '' %>><%= p.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- User Info -->
        <div class="tf-form-card">
          <div class="tf-form-header"><i class="bi bi-person-circle text-success"></i> Reviewer Profile</div>
          <div class="tf-form-body">
            <div class="row g-3 align-items-center">
              <div class="col-auto">
                <div class="avatar-wrapper mb-2">
                  <img src="<%= review && review.user_avatar ? review.user_avatar : '' %>" class="avatar-preview-el" id="avatarPreview" style="<%= review && review.user_avatar ? 'display:block' : '' %>">
                  <div class="preview-placeholder" id="avatarPlaceholder" style="width:80px;height:80px;border-radius:50%; <%= review && review.user_avatar ? 'display:none' : '' %>">
                    <i class="bi bi-person fs-2"></i>
                  </div>
                </div>
              </div>
              <div class="col">
                <label class="form-label fw-bold">Avatar Image</label>
                <input type="file" class="form-control" name="avatar_file" accept="image/*" onchange="previewAvatar(this)">
                <input type="hidden" name="existing_avatar_url" value="<%= review ? review.user_avatar : '' %>">
              </div>
              <div class="col-12">
                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label fw-bold">Reviewer Name</label>
                    <input type="text" class="form-control" name="user_name" value="<%= review ? review.user_name : '' %>" placeholder="e.g., James">
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-bold">User Handle</label>
                    <input type="text" class="form-control" name="user_handle" value="<%= review ? review.user_handle : '' %>" placeholder="e.g., @james_globe">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4">
        <!-- Video Upload -->
        <div class="tf-form-card">
          <div class="tf-form-header"><i class="bi bi-camera-reels text-danger"></i> Video Upload</div>
          <div class="tf-form-body">
            <div class="video-preview-container mb-3">
              <video src="<%= review && review.video_url ? review.video_url : '' %>" class="video-preview-el" id="videoPreview" controls style="<%= review && review.video_url ? 'display:block' : '' %>"></video>
              <div class="preview-placeholder" id="videoPlaceholder" style="<%= review && review.video_url ? 'display:none' : '' %>">
                <i class="bi bi-play-btn fs-1 mb-2"></i>
                <span class="small fw-bold">NO VIDEO SELECTED</span>
              </div>
            </div>
            <label class="form-label fw-bold">Vertical Video (9:16)</label>
            <input type="file" class="form-control mb-2" name="video_file" accept="video/*" onchange="previewVideo(this)">
            <input type="hidden" name="existing_video_url" value="<%= review ? review.video_url : '' %>">
            
            <div class="form-check form-switch mt-4">
              <input class="form-check-input" type="checkbox" name="status" id="statusSwitch" <%= !review || review.status ? 'checked' : '' %>>
              <label class="form-check-label fw-bold" for="statusSwitch">Visibility: Active</label>
            </div>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<script>
  function previewVideo(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById('videoPreview');
        preview.src = e.target.result;
        preview.style.display = 'block';
        document.getElementById('videoPlaceholder').style.display = 'none';
      }
      reader.readAsDataURL(input.files[0]);
    }
  }

  function previewAvatar(input) {
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById('avatarPreview');
        preview.src = e.target.result;
        preview.style.display = 'block';
        document.getElementById('avatarPlaceholder').style.display = 'none';
      }
      reader.readAsDataURL(input.files[0]);
    }
  }

  document.getElementById('saveReviewBtn').addEventListener('click', async () => {
    const btn = document.getElementById('saveReviewBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Saving...';

    const formData = new FormData(document.getElementById('reviewForm'));
    
    try {
      const res = await fetch('/travel/reviews/save', {
        method: 'POST',
        body: formData
      });
      const data = await res.json();
      if (data.success) {
        window.location.href = '/travel/reviews';
      } else {
        alert('Error: ' + data.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Save Review';
      }
    } catch (err) {
      alert('Network error while saving');
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Save Review';
    }
  });
</script>

</body>
</html>
