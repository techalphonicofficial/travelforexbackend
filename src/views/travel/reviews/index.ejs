<div class="tf-page-header">
  <div>
    <h1 class="tf-page-title">Video Reviews</h1>
    <p class="tf-page-sub">Manage Reels-style customer journey videos</p>
  </div>
  <div class="d-flex gap-3">
    <div class="tf-view-toggle">
      <button id="viewGrid" class="active" onclick="toggleView('grid')"><i class="bi bi-grid-3x3-gap-fill"></i></button>
      <button id="viewList" onclick="toggleView('list')"><i class="bi bi-list-ul"></i></button>
    </div>
    <a href="/travel/reviews/create" class="btn-add-primary"><i class="bi bi-plus-lg"></i> Add New Review</a>
  </div>
</div>

<!-- FILTERS -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="input-group">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" class="form-control border-start-0 ps-0" id="searchReview" placeholder="Search by title or handle..."
        onkeyup="filterData()">
    </div>
  </div>
</div>

<div id="reviewContent"></div>
<div id="pagination" class="mt-4"></div>

<style>
  .review-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
    border: 1px solid #f0f0fa;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
  }
  .video-preview-wrapper {
    position: relative;
    aspect-ratio: 9/16;
    background: #000;
    overflow: hidden;
  }
  .video-preview-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
  }
  .card-overlay-top {
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    display: flex;
    justify-content: space-between;
    z-index: 2;
  }
  .card-overlay-bottom {
    position: absolute;
    bottom: 15px;
    left: 15px;
    right: 15px;
    z-index: 2;
    color: white;
  }
  .user-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(5px);
    padding: 4px 12px;
    border-radius: 20px;
    color: white;
    font-size: 0.8rem;
  }
  .user-badge img {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
  }
  .likes-badge {
    background: rgba(239, 68, 68, 0.9);
    color: white;
    padding: 2px 10px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .review-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .review-title {
    font-weight: 700;
    color: #1e1e4a;
    margin-bottom: 0.5rem;
    font-size: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .package-link-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #f0f7ff;
    color: #007bff;
    padding: 4px 10px;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-top: auto;
  }
</style>

<script>
  let ALL_DATA = <%- JSON.stringify(reviews) %>;
  let filtered = [...ALL_DATA];
  let currentView = 'grid';
  let currentPage = 1;
  const itemsPerPage = 8;

  function render() {
    const container = document.getElementById('reviewContent');
    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginated = filtered.slice(start, end);

    if (currentView === 'list') {
      container.innerHTML = `
      <div class="tf-table-card">
        <table class="table align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="ps-4">Reviewer</th>
              <th>Journey Title</th>
              <th>Linked Package</th>
              <th>Likes</th>
              <th>Status</th>
              <th class="text-end pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            ${paginated.map(r => `
              <tr>
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <img src="${r.user_avatar || '/img/default-avatar.png'}" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;">
                    <div>
                      <div class="fw-bold text-dark">${r.user_name}</div>
                      <div class="text-muted small">${r.user_handle}</div>
                    </div>
                  </div>
                </td>
                <td>
                  <div class="fw-600 text-dark">${r.title || 'Untitled'}</div>
                  <div class="text-muted small">${r.location || 'Unknown Location'}</div>
                </td>
                <td>
                  ${r.package ? `<span class="badge bg-soft-primary text-primary" style="padding: 5px 10px; border-radius: 8px; font-weight:600;"><i class="bi bi-box-seam me-1"></i> ${r.package.name}</span>` : '<span class="text-muted italic small">Not linked</span>'}
                </td>
                <td>
                  <span class="fw-bold text-danger"><i class="bi bi-heart-fill me-1"></i>${r.likes_count}</span>
                </td>
                <td>
                  ${r.status ? '<span class="tf-badge pill-active">Active</span>' : '<span class="tf-badge pill-inactive">Hidden</span>'}
                </td>
                <td class="text-end pe-4">
                  <div class="d-flex justify-content-end gap-2">
                    <a href="/travel/reviews/${r.id}/edit" class="btn-icon btn-icon-edit"><i class="bi bi-pencil"></i></a>
                    <button class="btn-icon btn-icon-del" onclick="deleteReview('${r.id}')"><i class="bi bi-trash3"></i></button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
    } else {
      container.innerHTML = `<div class="row g-4">${paginated.map(r => `
        <div class="col-md-3">
          <div class="review-card">
            <div class="video-preview-wrapper">
              <video src="${r.video_url}" muted onmouseover="this.play()" onmouseout="this.pause(); this.currentTime=0;"></video>
              <div class="card-overlay-top">
                <div class="likes-badge"><i class="bi bi-heart-fill me-1"></i>${r.likes_count}</div>
                ${r.status ? '<span class="badge bg-success" style="font-size:0.6rem">Live</span>' : '<span class="badge bg-secondary" style="font-size:0.6rem">Hidden</span>'}
              </div>
              <div class="card-overlay-bottom">
                <div class="user-badge">
                  <img src="${r.user_avatar || '/img/default-avatar.png'}">
                  <span>${r.user_handle}</span>
                </div>
              </div>
            </div>
            <div class="review-info">
              <div class="review-title">${r.title || 'Untitled Journey'}</div>
              <div class="text-muted small mb-3"><i class="bi bi-geo-alt me-1"></i>${r.location || 'Unknown'}</div>
              ${r.package ? `<div class="package-link-badge"><i class="bi bi-link-45deg"></i> ${r.package.name}</div>` : ''}
              
              <div class="mt-3 pt-3 border-top d-flex gap-2">
                <a href="/travel/reviews/${r.id}/edit" class="btn btn-sm btn-light border flex-grow-1 fw-bold rounded-3">Edit</a>
                <button onclick="deleteReview('${r.id}')" class="btn btn-sm btn-outline-danger border rounded-3"><i class="bi bi-trash3"></i></button>
              </div>
            </div>
          </div>
        </div>
      `).join('')}</div>`;
    }
    renderPagination();
  }

  function filterData() {
    const q = document.getElementById('searchReview').value.toLowerCase();
    filtered = ALL_DATA.filter(r => 
      (r.title && r.title.toLowerCase().includes(q)) || 
      (r.user_handle && r.user_handle.toLowerCase().includes(q)) ||
      (r.user_name && r.user_name.toLowerCase().includes(q))
    );
    currentPage = 1;
    render();
  }

  function toggleView(v) {
    currentView = v;
    document.getElementById('viewGrid').classList.toggle('active', v === 'grid');
    document.getElementById('viewList').classList.toggle('active', v === 'list');
    render();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filtered.length / itemsPerPage);
    let html = `<nav><ul class="pagination justify-content-center">`;
    for (let i = 1; i <= totalPages; i++) {
      html += `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="#" onclick="currentPage=${i}; render(); return false;">${i}</a></li>`;
    }
    html += `</ul></nav>`;
    document.getElementById('pagination').innerHTML = totalPages > 1 ? html : '';
  }

  async function deleteReview(id) {
    if (confirm('Delete this video review?')) {
      try {
        const res = await fetch(`/api/v1/reviews/${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) location.reload();
        else alert('Error: ' + data.message);
      } catch (err) { alert('Network Error'); }
    }
  }

  render();
</script>
