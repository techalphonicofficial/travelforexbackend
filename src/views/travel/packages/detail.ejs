<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- CSS assets assuming they are available in the project -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --primary: #4f46e5;
      --primary-dark: #4338ca;
      --secondary: #818cf8;
      --accent: #f59e0b;
      --success: #10b981;
      --danger: #ef4444;
      --bg-body: #f8faff;
      --card-bg: #ffffff;
      --text-main: #1e1e4a;
      --text-muted: #64748b;
      --border-color: #f0f0fa;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background-color: var(--bg-body);
      color: var(--text-main);
      overflow-x: hidden;
    }

    .tp-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    /* --- Hero Section --- */
    .hero-card {
      background: linear-gradient(135deg, #1e1e4a 0%, #312e81 100%);
      border-radius: 30px;
      padding: 3.5rem 3rem;
      position: relative;
      overflow: hidden;
      color: #fff;
      margin-bottom: 3rem;
      box-shadow: 0 20px 50px rgba(79, 70, 229, 0.15);
    }

    .hero-card::after {
      content: '';
      position: absolute;
      top: -100px;
      right: -100px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
      border-radius: 50%;
    }

    .pkg-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      padding: 0.6rem 1.2rem;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .pkg-title {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      letter-spacing: -1px;
      line-height: 1.1;
    }

    .pkg-meta {
      display: flex;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1.1rem;
      opacity: 0.9;
    }

    .meta-item i {
      font-size: 1.2rem;
      color: var(--accent);
    }

    /* --- Sidebar & Tracking --- */
    .sticky-nav {
      position: sticky;
      top: 2rem;
    }

    .nav-card {
      background: #fff;
      border-radius: 20px;
      padding: 1.5rem;
      border: 1px solid var(--border-color);
      box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .nav-title {
      font-weight: 800;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .dest-link {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 1rem;
      border-radius: 14px;
      color: var(--text-main);
      text-decoration: none;
      font-weight: 600;
      transition: all 0.2s;
      margin-bottom: 0.5rem;
      border: 1px solid transparent;
    }

    .dest-link:hover {
      background: #f1f5f9;
      color: var(--primary);
    }

    .dest-link.active {
      background: #eef2ff;
      color: var(--primary);
      border-color: #c7d2fe;
    }

    .dest-icon {
      width: 36px;
      height: 36px;
      background: #f1f5f9;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .dest-link.active .dest-icon {
      background: var(--primary);
      color: #fff;
    }

    /* --- Itinerary Sections --- */
    .itinerary-section {
      margin-bottom: 4rem;
    }

    .section-header {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 2rem;
    }

    .section-header h2 {
      font-weight: 800;
      font-size: 1.8rem;
      margin: 0;
    }

    .section-icon {
      width: 48px;
      height: 48px;
      background: #fff;
      border-radius: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.4rem;
      color: var(--primary);
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
    }

    /* --- Timeline --- */
    .timeline {
      position: relative;
      padding-left: 2.5rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 7.5px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--primary) 0%, #eef2ff 100%);
    }

    .day-card {
      background: #fff;
      border-radius: 20px;
      padding: 1.8rem;
      margin-bottom: 2rem;
      position: relative;
      border: 1px solid var(--border-color);
      box-shadow: 0 10px 30px rgba(0,0,0,0.02);
      transition: transform 0.3s ease;
    }

    .day-card:hover {
      transform: translateY(-5px);
    }

    .day-card::before {
      content: '';
      position: absolute;
      left: -2.5rem;
      top: 2rem;
      width: 17px;
      height: 17px;
      background: #fff;
      border: 4px solid var(--primary);
      border-radius: 50%;
      z-index: 2;
    }

    .day-number {
      font-weight: 800;
      color: var(--primary);
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      display: block;
      margin-bottom: 0.5rem;
    }

    .day-title {
      font-weight: 800;
      font-size: 1.4rem;
      margin-bottom: 1.5rem;
    }

    /* --- Activities --- */
    .activity-item {
      display: flex;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
      position: relative;
    }

    .activity-item:not(:last-child) {
      padding-bottom: 1.5rem;
    }

    .activity-time {
      min-width: 100px;
      text-align: right;
    }

    .time-badge {
      display: inline-block;
      padding: 0.4rem 0.8rem;
      border-radius: 10px;
      font-size: 0.75rem;
      font-weight: 700;
      background: #f1f5f9;
      color: var(--text-muted);
    }

    .time-badge.morning { background: #fffbeb; color: #b45309; }
    .time-badge.noon { background: #fef2f2; color: #b91c1c; }
    .time-badge.evening { background: #eef2ff; color: #4338ca; }

    .activity-content {
      flex: 1;
    }

    .activity-name {
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 0.3rem;
    }

    .activity-desc {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* --- Inclusions/Exclusions --- */
    .meta-card {
      background: #fff;
      border-radius: 20px;
      padding: 2rem;
      height: 100%;
      border: 1px solid var(--border-color);
      box-shadow: 0 10px 30px rgba(0,0,0,0.02);
    }

    .meta-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .meta-list-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .meta-list-item i {
      margin-top: 4px;
    }

    .text-success i { color: var(--success); }
    .text-danger i { color: var(--danger); }

    /* --- Footer Action --- */
    .footer-bar {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(20px);
      padding: 1.2rem;
      border-top: 1px solid var(--border-color);
      z-index: 100;
      display: flex;
      justify-content: center;
      gap: 1rem;
    }

    .btn-premium {
      background: var(--primary);
      color: #fff;
      border: none;
      padding: 0.8rem 2.5rem;
      border-radius: 14px;
      font-weight: 700;
      transition: all 0.2s;
    }

    .btn-premium:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
    }

    @media (max-width: 992px) {
      .pkg-title { font-size: 2.5rem; }
      .hero-card { padding: 2.5rem 2rem; }
    }
  </style>
</head>
<body>

  <div class="tp-container">
    
    <!-- Hero Section -->
    <div class="hero-card">
      <div class="pkg-badge">
        <i class="bi bi-stars"></i> Curated Experience
      </div>
      <h1 class="pkg-title"><%= pkg.name %></h1>
      <div class="pkg-meta">
        <div class="meta-item">
          <i class="bi bi-calendar3"></i>
          <span><%= pkg.duration_days %> Days Journey</span>
        </div>
        <div class="meta-item">
          <i class="bi bi-geo-alt"></i>
          <span><%= pkg.destinations.length %> Destinations</span>
        </div>
        <% if (pkg.price) { %>
        <div class="meta-item">
          <i class="bi bi-tag-fill"></i>
          <span>Starts from ₹<%= pkg.price.toLocaleString('en-IN') %></span>
        </div>
        <% } %>
      </div>
    </div>

    <div class="row g-5">
      <!-- Sidebar Navigation -->
      <div class="col-lg-4 d-none d-lg-block">
        <div class="sticky-nav">
          <div class="nav-card">
            <div class="nav-title">
              <i class="bi bi-map"></i> Major Stops
            </div>
            <% pkg.destinations.forEach((pd, idx) => { %>
              <a href="#dest-<%= pd.destination.id %>" class="dest-link">
                <div class="dest-icon"><%= idx + 1 %></div>
                <div>
                  <div class="small text-muted" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase;">Stop <%= idx + 1 %></div>
                  <div><%= pd.destination.name %></div>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="col-lg-8">
        
        <!-- Description -->
        <% if (pkg.description) { %>
        <div class="itinerary-section">
          <div class="section-header">
            <div class="section-icon"><i class="bi bi-chat-left-quote"></i></div>
            <h2>Overview</h2>
          </div>
          <div class="card border-0 shadow-sm rounded-4 p-4">
            <p class="lead mb-0" style="color: var(--text-muted); font-weight: 500; line-height: 1.8;">
              <%= pkg.description %>
            </p>
          </div>
        </div>
        <% } %>

        <!-- Itinerary -->
        <div class="itinerary-section">
          <div class="section-header">
            <div class="section-icon"><i class="bi bi-signpost-2"></i></div>
            <h2>Detailed Itinerary</h2>
          </div>

          <% pkg.destinations.forEach((pd, pIdx) => { %>
            <div id="dest-<%= pd.destination.id %>" class="mb-5">
              <div class="d-flex align-items-center gap-3 mb-4">
                <h3 class="fw-bold mb-0" style="font-size: 1.6rem;"><%= pd.destination.name %></h3>
                <span class="badge bg-light text-primary border px-3 py-2 rounded-pill"><%= pd.nights %> Nights</span>
              </div>

              <div class="timeline">
                <% pd.days.forEach((day, dIdx) => { %>
                  <div class="day-card">
                    <span class="day-number">Package Day</span>
                    <h4 class="day-title text-dark">Day <%= day.day_number %></h4>
                    
                    <div class="activities-wrapper">
                      <% if (day.activities && day.activities.length) { %>
                        <% day.activities.forEach(act => { %>
                          <div class="activity-item">
                            <div class="activity-time">
                              <span class="time-badge <%= (act.time_slot || '').toLowerCase().replace(/\s/g, '') %>">
                                <%= act.time_slot || 'Full Day' %>
                              </span>
                            </div>
                            <div class="activity-content">
                              <div class="activity-name"><%= act.title %></div>
                              <% if (act.description) { %>
                                <div class="activity-desc"><%= act.description %></div>
                              <% } %>
                            </div>
                          </div>
                        <% }) %>
                      <% } else { %>
                        <div class="text-muted small">Leisure time or travel to next destination.</div>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Inclusions & Exclusions -->
        <div class="row g-4 mb-5">
          <div class="col-md-6">
            <div class="meta-card">
              <h4 class="fw-bold mb-4 d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill text-success"></i> Inclusions
              </h4>
              <ul class="meta-list">
                <% if (pkg.inclusions && pkg.inclusions.length) { %>
                  <% pkg.inclusions.forEach(inc => { %>
                    <li class="meta-list-item">
                      <i class="bi bi-check2 text-success"></i>
                      <span><%= inc.text %></span>
                    </li>
                  <% }) %>
                <% } else { %>
                  <li class="text-muted small">No specific inclusions listed.</li>
                <% } %>
              </ul>
            </div>
          </div>
          <div class="col-md-6">
            <div class="meta-card">
              <h4 class="fw-bold mb-4 d-flex align-items-center gap-2">
                <i class="bi bi-dash-circle-fill text-danger"></i> Exclusions
              </h4>
              <ul class="meta-list">
                <% if (pkg.exclusions && pkg.exclusions.length) { %>
                  <% pkg.exclusions.forEach(exc => { %>
                    <li class="meta-list-item">
                      <i class="bi bi-x-lg text-danger" style="font-size: 0.8rem;"></i>
                      <span><%= exc.text %></span>
                    </li>
                  <% }) %>
                <% } else { %>
                  <li class="text-muted small">No specific exclusions listed.</li>
                <% } %>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Footer Navigation -->
  <div class="footer-bar">
    <a href="/travel/packages" class="btn btn-light border px-4 rounded-3 fw-bold">Back to List</a>
    <a href="/travel/packages/<%= pkg.id %>/edit" class="btn btn-premium d-flex align-items-center gap-2">
      <i class="bi bi-pencil-square"></i> Edit This Package
    </a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
