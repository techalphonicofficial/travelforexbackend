<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> - Bali Travel
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .tf-form-card {
            background: #fff;
            border-radius: 20px;
            border: 0;
            box-shadow: 0 10px 40px rgba(79, 70, 229, 0.08);
            /* margin-bottom: 2rem; */
            overflow: hidden;
        }

        .tf-form-header {
            padding: 1.5rem;
            background: linear-gradient(to right, #f8faff, #ffffff);
            border-bottom: 1px solid #f0f0fa;
            font-weight: 700;
            color: #1e1e4a;
            display: flex;
            align-items: center;
            gap: .8rem;
            font-size: 1.1rem;
        }

        .tf-form-body {
            padding: 2rem;
        }

        .tf-page-header {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 10px 40px rgba(79, 70, 229, 0.08);
        }

        .tf-page-title {
            font-size: 1.8rem;
            font-weight: 800;
            color: #1e1e4a;
            margin: 0;
        }

        .tf-page-sub {
            color: #6b6b8d;
            margin: 0;
            font-size: 0.9rem;
        }

        .tf-back-btn {
            width: 40px;
            height: 40px;
            background: #f0f0fa;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #4f46e5;
            text-decoration: none;
            transition: all 0.2s;
        }

        .tf-back-btn:hover {
            background: #4f46e5;
            color: white;
        }

        .btn-add-primary {
            background: linear-gradient(135deg, #4f46e5, #818cf8);
            border: none;
            padding: 0.6rem 1.8rem;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            transition: all 0.2s;
        }

        .btn-add-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
        }

        .tf-row-item {
            background: #ffffff;
            border: 1px solid #eef0f7;
            border-radius: 18px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            position: relative;
        }

        .tf-row-del {
            position: absolute;
            right: 1.2rem;
            top: 1.2rem;
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: #fff5f5;
            color: #ff4d4d;
            border: 1px solid #ffe3e3;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tf-row-del:hover {
            background: #ff4d4d;
            color: #fff;
        }

        .tf-add-row {
            background: #f8faff;
            color: #4f46e5;
            border: 2px dashed #c7d2fe;
            border-radius: 14px;
            padding: 0.8rem;
            width: 100%;
            font-weight: 700;
            transition: all 0.2s;
        }

        .tf-add-row:hover {
            background: #eff2ff;
            border-color: #4f46e5;
        }

        .day-tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            overflow-x: auto;
            padding-bottom: 8px;
        }

        .day-tab-btn {
            min-width: 70px;
            padding: 10px 15px;
            border-radius: 15px;
            border: 1px solid #e2e8f0;
            background: #fff;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }

        .day-tab-btn.active {
            background: #4f46e5;
            border-color: #4f46e5;
            color: #fff;
        }

        .day-tab-btn .d-num {
            font-weight: 800;
            font-size: 1.1rem;
        }

        .day-tab-btn .d-lbl {
            font-size: 0.7rem;
        }

        .tf-day-content {
            display: none;
        }

        .tf-day-content.active {
            display: block;
        }

        .tf-activity-unit {
            background: #f8fafc;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 10px;
            border: 1px solid #e2e8f0;
        }

        .tf-hotel-section {
            background: #fbfdfd;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 14px;
        }

        .tf-hotel-unit {
            background: #fff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 12px;
            margin-bottom: 10px;
        }

        .hotel-thumb {
            width: 56px;
            height: 56px;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            background: #f1f5f9;
            object-fit: cover;
            flex-shrink: 0;
        }

        .hotel-icon-thumb {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #0f766e;
            font-size: 1.35rem;
        }

        .hotel-meta-pill {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            border-radius: 20px;
            padding: 2px 8px;
            background: #ecfdf5;
            color: #0f766e;
            font-size: 0.72rem;
            font-weight: 700;
        }

        .hotel-empty {
            padding: 12px;
            border-radius: 10px;
            background: #fff;
            color: #64748b;
            font-size: 0.85rem;
            text-align: center;
            border: 1px dashed #cbd5e1;
        }

        .activity-badge {
            background: #e0e7ff;
            color: #4f46e5;
            padding: 2px 10px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .remove-activity {
            cursor: pointer;
            color: #ef4444;
        }

        .remove-activity:hover {
            color: #dc2626;
        }

        .toast-notification {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 9999;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .modal-activity {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 10000;
            justify-content: center;
            align-items: center;
        }

        .modal-activity.active {
            display: flex;
        }

        .modal-content-custom {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            width: 90%;
            max-width: 450px;
        }
        /* Gallery Styles */
        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .gallery-upload-card {
            border: 2px dashed #cbd5e1;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: not-allowed;
            aspect-ratio: 1;
            color: #94a3b8;
            background: #f8fafc;
        }
    </style>
</head>

<body class="bg-light">

    <div class="container-fluid" style="max-width: 1400px; margin: 0 auto;">
        <!-- Header -->
        <div class="tf-page-header">
            <div class="d-flex align-items-center gap-3">
                <a href="/travel/packages" class="tf-back-btn"><i class="bi bi-chevron-left"></i></a>
                <div>
                    <p class="tf-page-title">
                        <%= title %>
                    </p>
                    <p class="tf-page-sub">Multi-destination daily activity management</p>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="/travel/packages" class="btn btn-light px-4 rounded-3 border">Cancel</a>
                <button class="btn-add-primary px-5" id="savePackageBtn">
                    <i class="bi bi-check2-circle"></i> Save Package
                </button>
            </div>
        </div>

        <!-- Notification Toast -->
        <div id="notificationToast" class="toast-notification" style="display: none;">
            <div class="bg-white rounded-3 shadow-lg p-3 d-flex align-items-center gap-3 border-start border-4"
                id="toastMessage">
                <i class="bi bi-check-circle-fill text-success fs-4"></i>
                <span></span>
            </div>
        </div>

        <!-- Activity Modal (No prompt) -->
        <div id="activityModal" class="modal-activity">
            <div class="modal-content-custom">
                <h5 class="mb-3"><i class="bi bi-plus-circle me-2"></i> Add Activity</h5>
                <div class="mb-3">
                    <label class="form-label">Activity Name</label>
                    <input type="text" class="form-control" id="modalActivityName"
                        placeholder="e.g., Kintamani Volcano Tour">
                </div>
                <div class="mb-3">
                    <label class="form-label">Time Slot</label>
                    <select class="form-select" id="modalTimeSlot">
                        <option value="Full Day">Full Day</option>
                        <option value="Morning">Morning</option>
                        <option value="Noon">Noon</option>
                        <option value="Evening">Evening</option>
                        <option value="Morning to Noon">Morning to Noon</option>
                    </select>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Duration</label>
                        <input type="text" class="form-control" id="modalActivityDuration" placeholder="e.g. 2 Hours">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Departure City</label>
                        <input type="text" class="form-control" id="modalDepartureCity" placeholder="e.g. New Delhi">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <div class="btn-group btn-group-sm mb-1" role="group" aria-label="Description formatting">
                        <button type="button" class="btn btn-outline-secondary" onclick="formatActivityText('bold')"><b>B</b></button>
                        <button type="button" class="btn btn-outline-secondary" onclick="formatActivityText('italic')"><i>I</i></button>
                        <button type="button" class="btn btn-outline-secondary" onclick="formatActivityText('underline')"><u>U</u></button>
                        <button type="button" class="btn btn-outline-secondary" onclick="formatActivityText('insertUnorderedList')"><i class="bi bi-list-ul"></i></button>
                        <button type="button" class="btn btn-outline-secondary" onclick="formatActivityText('insertOrderedList')"><i class="bi bi-list-ol"></i></button>
                    </div>
                    <div class="form-control" id="modalDescription" contenteditable="true" style="min-height:110px; overflow:auto;"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Activity Image</label>
                    <div class="d-flex gap-2 align-items-center">
                        <div id="modalActivityImagePreview" style="width: 60px; height: 60px; border-radius: 8px; border: 1px solid #cbd5e1; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #f8fafc; flex-shrink: 0;">
                            <i class="bi bi-image text-muted opacity-50 fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <input type="file" id="modalActivityImageFile" accept="image/*" style="display: none;" onchange="uploadActivityImage(this)">
                            <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="modalActivityImageBtn" onclick="document.getElementById('modalActivityImageFile').click()">
                                <i class="bi bi-upload me-1"></i> Upload Image
                            </button>
                            <input type="hidden" id="modalActivityImage" value="">
                        </div>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-light" id="closeModalBtn">Cancel</button>
                    <button class="btn btn-primary" id="confirmActivityBtn">Add Activity</button>
                </div>
            </div>
        </div>

        <div id="hotelModal" class="modal-activity">
            <div class="modal-content-custom">
                <h5 class="mb-3"><i class="bi bi-building-add me-2"></i> Add Hotel</h5>
                <div class="mb-3">
                    <label class="form-label">Hotel</label>
                    <select class="form-select" id="modalHotelSelect"></select>
                    <div class="form-text" id="modalHotelHelp">Hotels from all destinations load in small chunks.</div>
                </div>
                <div class="mb-3">
                    <div class="d-flex gap-2 align-items-center p-2 rounded-3 border bg-light" id="modalHotelPreview">
                        <div class="hotel-thumb hotel-icon-thumb"><i class="bi bi-building"></i></div>
                        <div>
                            <div class="fw-bold">Select a hotel</div>
                            <div class="text-muted small">Price, rating, and room details will appear here.</div>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label">Nights</label>
                        <input type="number" class="form-control" id="modalHotelNights" min="1" value="1">
                    </div>
                    <div class="col-6">
                        <label class="form-label">Rooms</label>
                        <input type="number" class="form-control" id="modalHotelRooms" min="1" value="1">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea class="form-control" id="modalHotelNotes" rows="2" placeholder="Room type, meal plan, check-in note..."></textarea>
                </div>
                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-light" id="closeHotelModalBtn">Cancel</button>
                    <button class="btn btn-primary" id="confirmHotelBtn">Add Hotel</button>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-12">
                <!-- Basic Details -->
                <div class="tf-form-card">
                    <div class="tf-form-header"><i class="bi bi-info-circle text-primary"></i> Basic Details</div>
                    <div class="tf-form-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Package Name *</label>
                                <input type="text" class="form-control" id="packageName"
                                    placeholder="e.g., 6 Nights Bali Paradise">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Slug</label>
                                <input type="text" class="form-control" id="packageSlug" placeholder="6-nights-bali-paradise">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold d-block">Package Type *</label>
                                <div class="d-flex flex-wrap gap-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="packageTravelType" id="travelTypeDomestic" value="domestic" checked>
                                        <label class="form-check-label" for="travelTypeDomestic">Domestic</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="packageTravelType" id="travelTypeInternational" value="international">
                                        <label class="form-check-label" for="travelTypeInternational">International</label>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Departure City</label>
                                <input type="text" class="form-control" id="departureCity" placeholder="e.g. New Delhi">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Duration (Days) *</label>
                                <input type="number" class="form-control" id="duration" placeholder="6" min="1" readonly
                                    style="background:#f8f9fa">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Price (INR)</label>
                                <input type="number" class="form-control" id="price" placeholder="24999">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Discount %</label>
                                <input type="number" class="form-control" id="discountPercentage" placeholder="0" min="0" max="100" step="0.01" value="0">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Sort Order</label>
                                <input type="number" class="form-control" id="sortOrder" placeholder="Auto" min="0">
                                <small class="text-muted">Lower numbers appear first.</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tax Type</label>
                                <select class="form-select" id="taxType">
                                    <option value="" data-percent="0">Select Tax Type</option>
                                    <% (taxTypes || []).forEach(tax => { %>
                                        <option value="<%= tax.name %>" data-percent="<%= tax.percent %>"><%= tax.name %> (<%= tax.percent %>%)</option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Tax %</label>
                                <input type="number" class="form-control bg-light" id="taxPercent" value="0" readonly>
                            </div>
                            <div class="col-md-12 d-flex flex-wrap gap-4">
                                <div class="form-check form-switch pt-2 pb-2">
                                    <input class="form-check-input" type="checkbox" id="showInHomePage" role="switch">
                                    <label class="form-check-label fw-bold ps-2" for="showInHomePage">Show in Home Page</label>
                                </div>
                                <div class="form-check form-switch pt-2 pb-2">
                                    <input class="form-check-input" type="checkbox" id="isCustomizable" role="switch">
                                    <label class="form-check-label fw-bold ps-2" for="isCustomizable">Customize</label>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Package Categories</label>
                                <div class="d-flex flex-wrap gap-3 mt-2">
                                    <% (packageCategories || []).forEach(cat => { %>
                                        <div class="form-check">
                                            <input class="form-check-input package-category-checkbox" type="checkbox" value="<%= cat.id %>" id="cat_<%= cat.id %>">
                                            <label class="form-check-label" for="cat_<%= cat.id %>">
                                                <%= cat.title %>
                                            </label>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Description</label>
                                <textarea class="form-control" id="description" rows="3"
                                    placeholder="Package description..."></textarea>
                            </div>
                            
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Main Package Image *</label>
                                <div class="d-flex gap-3 align-items-start">
                                    <div id="mainImagePreview" style="width: 240px; aspect-ratio: 16/9; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; background: #f8fafc; display: flex; align-items: center; justify-content: center; position: relative;">
                                        <i class="bi bi-image text-muted opacity-50 fs-2"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <p class="text-muted small mb-3">Upload the primary thumbnail image for this package. (16:9 ratio recommended)</p>
                                        <input type="file" id="mainImageInput" hidden accept="image/*" onchange="uploadMainImage(this)">
                                        <button type="button" class="btn btn-outline-primary btn-sm" id="mainImageUploadBtn" onclick="document.getElementById('mainImageInput').click()">
                                            <i class="bi bi-upload me-1"></i> Upload Main Image
                                        </button>
                                        <input type="hidden" id="fMainImage" value="">
                                        
                                        <div class="mt-3">
                                            <label class="form-label fw-bold small mb-1">Main Image Alt Text</label>
                                            <input type="text" id="fMainImageAlt" class="form-control form-control-sm" placeholder="SEO description">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tf-form-card">
                    <div class="tf-form-header"><i class="bi bi-search text-primary"></i> SEO Settings</div>
                    <div class="tf-form-body">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Meta Title</label>
                                <input type="text" class="form-control" id="metaTitle" maxlength="255" placeholder="SEO page title">
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Meta Description</label>
                                <textarea class="form-control" id="metaDescription" rows="3" placeholder="SEO page description"></textarea>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Meta Keywords</label>
                                <textarea class="form-control" id="metaKeyword" rows="2" placeholder="keyword one, keyword two"></textarea>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Schema JSON-LD</label>
                                <textarea class="form-control font-monospace" id="metaSchema" rows="5" placeholder='{"@context":"https://schema.org"}'></textarea>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Destinations & Daily Itinerary -->
                <div class="tf-form-card">
                    <div class="tf-form-header"><i class="bi bi-calendar-week text-danger"></i> Destinations & Daily
                        Activities</div>
                    <div class="tf-form-body">
                        <div id="destinationsList"></div>
                        <button class="tf-add-row mt-2" id="addDestinationBtn">
                            <i class="bi bi-plus-lg me-1"></i> Add Destination
                        </button>
                    </div>
                </div>

                <div class="tf-form-card">
                    <div class="tf-form-header"><i class="bi bi-images text-warning"></i> Package Gallery</div>
                    <div class="tf-form-body">
                        <div class="gallery-grid">
                            <div class="gallery-upload-card">
                                <i class="bi bi-lock-fill fs-2 mb-2"></i>
                                <span class="small fw-bold text-center px-3">Gallery will be available after saving the package</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Inclusions & Exclusions -->
                <div class="row g-4">
                    <div class="col-6">
                        <div class="tf-form-card">
                            <div class="tf-form-header"><i class="bi bi-check-circle text-success"></i> Inclusions</div>
                            <div class="tf-form-body">
                                <div id="inclusionsList"></div>
                                <div class="input-group mt-2">
                                    <input type="text" class="form-control" id="newInclusion"
                                        placeholder="Enter inclusion">
                                    <button class="btn btn-outline-primary" id="addInclusionBtn">Add</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="tf-form-card">
                            <div class="tf-form-header"><i class="bi bi-x-circle text-danger"></i> Exclusions</div>
                            <div class="tf-form-body">
                                <div id="exclusionsList"></div>
                                <div class="input-group mt-2">
                                    <input type="text" class="form-control" id="newExclusion"
                                        placeholder="Enter exclusion">
                                    <button class="btn btn-outline-primary" id="addExclusionBtn">Add</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const destinationsData = <%- JSON.stringify(destinations).replace(/</g, '\\u003c') %>;
        const categoriesData = <%- JSON.stringify(categories).replace(/</g, '\\u003c') %>;
        const activitiesData = <%- JSON.stringify(activities).replace(/</g, '\\u003c') %>;
        let hotelsData = [];
        let hotelCatalogPage = 0;
        let hotelCatalogHasMore = true;
        let hotelCatalogLoading = false;

        let destinations = [];
        let inclusions = [];
        let exclusions = [];

        // Modal state
        let currentDestIdx = null;
        let currentDayNum = null;
        let editingHotelId = null;

        function showNotification(message, isError = false) {
            const toast = document.getElementById('notificationToast');
            const toastMsg = document.getElementById('toastMessage');
            const icon = toastMsg.querySelector('i');

            if (isError) {
                icon.className = 'bi bi-x-circle-fill text-danger fs-4';
                toastMsg.style.borderLeftColor = '#dc2626';
            } else {
                icon.className = 'bi bi-check-circle-fill text-success fs-4';
                toastMsg.style.borderLeftColor = '#10b981';
            }

            toastMsg.querySelector('span').textContent = message;
            toast.style.display = 'block';

            setTimeout(() => {
                toast.style.display = 'none';
            }, 3000);
        }

        function syncTaxPercent(force = false) {
            const taxSelect = document.getElementById('taxType');
            const taxPercentInput = document.getElementById('taxPercent');
            if (!taxSelect || !taxPercentInput) return;

            const selectedOption = taxSelect.selectedOptions[0];
            if (force || taxPercentInput.value === '') {
                taxPercentInput.value = selectedOption?.dataset.percent || '0';
            }
        }

        function generateId() {
            return Date.now() + '-' + Math.random().toString(36).substr(2, 9);
        }

        function slugify(value) {
            return (value || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
        }

        function updateDayRanges() {
            let currentDay = 1;
            destinations.forEach((dest, idx) => {
                const days = Math.max(parseInt(dest.nights, 10) || 1, 1);
                dest.startDay = currentDay;
                dest.endDay = currentDay + days - 1;
                currentDay = dest.endDay + 1;

                const durationInput = document.getElementById('duration');
                if (durationInput && currentDay - 1 > 0) {
                    durationInput.value = currentDay - 1;
                }
            });
        }

        function renderDestinations() {
            const container = document.getElementById('destinationsList');
            if (!container) return;

            if (destinations.length === 0) {
                container.innerHTML = '<div class="alert alert-info">No destinations added. Click "Add Destination" to start building your itinerary.</div>';
                return;
            }

            let html = '';
            destinations.forEach((dest, idx) => {
                if (!Array.isArray(dest.hotels)) dest.hotels = [];
                html += `
                <div class="tf-row-item" data-dest-idx="${idx}">
                    <div class="tf-row-del" onclick="removeDestination(${idx})"><i class="bi bi-trash3"></i></div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-5">
                            <label class="form-label fw-bold">Destination</label>
                            <select class="form-select dest-select" data-idx="${idx}">
                                <option value="">Select Destination</option>
                                ${destinationsData.map(d => `<option value="${d.id}" ${dest.destinationId == d.id ? 'selected' : ''}>${d.name}</option>`).join('')}
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Days</label>
                            <input type="number" class="form-control nights-input" data-idx="${idx}" value="${dest.nights || 1}" min="1">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Day Range</label>
                            <input type="text" class="form-control bg-light" value="Day ${dest.startDay || 1} - ${dest.endDay || (dest.startDay + dest.nights - 1)}" readonly disabled>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label fw-bold">Daily Activities</label>
                        <div class="day-tabs" id="dayTabs-${idx}"></div>
                        <div id="dayContents-${idx}"></div>
                    </div>
                </div>
            `;
            });
            container.innerHTML = html;

            destinations.forEach((dest, idx) => {
                attachDestinationEvents(idx);
                renderDayTabs(idx);
            });
        }

        function attachDestinationEvents(idx) {
            const destDiv = document.querySelector(`.tf-row-item[data-dest-idx="${idx}"]`);
            if (!destDiv) return;

            const destSelect = destDiv.querySelector('.dest-select');
            const nightsInput = destDiv.querySelector('.nights-input');

            if (destSelect) {
                destSelect.addEventListener('change', (e) => {
                    destinations[idx].destinationId = parseInt(e.target.value);
                    const selectedDest = destinationsData.find(d => d.id == e.target.value);
                    if (selectedDest) {
                        destinations[idx].destinationName = selectedDest.name;
                    }
                    destinations[idx].hotels = [];
                    updateDayRanges();
                    renderDestinations();
                });
            }

            if (nightsInput) {
                nightsInput.addEventListener('change', (e) => {
                    destinations[idx].nights = parseInt(e.target.value) || 1;
                    const days = destinations[idx].nights;
                    destinations[idx].hotels = (destinations[idx].hotels || []).filter(hotel => Number(hotel.dayNumber || 1) <= days);
                    Object.keys(destinations[idx].activities || {}).forEach(day => {
                        if (Number(day) > days) delete destinations[idx].activities[day];
                    });
                    updateDayRanges();
                    renderDestinations();
                });
            }
        }

        function renderDayTabs(destIdx) {
            const dest = destinations[destIdx];
            if (!dest) return;

            const totalDays = Math.max(parseInt(dest.nights, 10) || 1, 1);

            if (!dest.activities) dest.activities = {};
            for (let i = 1; i <= totalDays; i++) {
                if (!dest.activities[i]) dest.activities[i] = [];
                // Ensure every activity has an ID for proper deletion in UI
                dest.activities[i].forEach(act => {
                    if (!act.id) act.id = generateId();
                });
            }

            const tabsContainer = document.getElementById(`dayTabs-${destIdx}`);
            const contentsContainer = document.getElementById(`dayContents-${destIdx}`);

            if (!tabsContainer || !contentsContainer) return;

            let tabsHtml = '';
            let contentsHtml = '';

            for (let i = 1; i <= totalDays; i++) {
                const dayNum = dest.startDay + i - 1;
                tabsHtml += `
                <div class="day-tab-btn ${i === 1 ? 'active' : ''}" onclick="showDay(${destIdx}, ${i})">
                    <div class="d-num">Day ${dayNum}</div>
                    <div class="d-lbl">Day ${i}</div>
                </div>
            `;

                contentsHtml += `
                <div class="tf-day-content ${i === 1 ? 'active' : ''}" id="dayContent-${destIdx}-${i}">
                    <div class="d-flex gap-2 flex-wrap mb-2">
                        <button class="btn btn-sm btn-outline-primary" onclick="openActivityModal(${destIdx}, ${i})">
                            <i class="bi bi-plus"></i> Add Activity
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-success" onclick="openHotelModal(${destIdx}, ${i})">
                            <i class="bi bi-building-add"></i> Add Hotel
                        </button>
                    </div>
                    <div class="tf-hotel-section mb-3" id="hotelsList-${destIdx}-${i}">
                        ${renderHotelsList((dest.hotels || []).filter(hotel => Number(hotel.dayNumber || 1) === i), destIdx, i)}
                    </div>
                    <div id="activitiesList-${destIdx}-${i}">
                        ${renderActivitiesList(dest.activities[i] || [], destIdx, i)}
                    </div>
                </div>
            `;
            }

            tabsContainer.innerHTML = tabsHtml;
            contentsContainer.innerHTML = contentsHtml;
        }

        function renderActivitiesList(activities, destIdx, dayNum) {
            if (!activities || activities.length === 0) {
                return '<div class="text-muted small p-3 text-center">No activities added for this day</div>';
            }

            return activities.map(act => `
            <div class="tf-activity-unit d-flex justify-content-between align-items-start">
                <div class="d-flex gap-3 align-items-start flex-grow-1">
                    ${act.image ? `<img src="${act.image}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid #cbd5e1; flex-shrink: 0;">` : ''}
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <strong>${escapeHtml(act.name)}</strong>
                            <span class="activity-badge">${escapeHtml(getActivityTimeSlot(act))}</span>
                            ${getActivityDuration(act) ? `<span class="hotel-meta-pill"><i class="bi bi-clock"></i> ${escapeHtml(getActivityDuration(act))}</span>` : ''}
                            ${(act.departureCity || act.departureFrom) ? `<span class="hotel-meta-pill"><i class="bi bi-geo-alt"></i> ${escapeHtml(act.departureCity || act.departureFrom)}</span>` : ''}
                        </div>
                        ${act.description ? `<div class="text-muted small mt-1">${sanitizeRichText(act.description)}</div>` : ''}
                    </div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <i class="bi bi-pencil text-primary edit-activity" style="cursor:pointer" onclick="openEditActivityModal(${destIdx}, ${dayNum}, '${act.id}')"></i>
                    <i class="bi bi-trash3 text-danger remove-activity" style="cursor:pointer" onclick="removeActivity(${destIdx}, ${dayNum}, '${act.id}')"></i>
                </div>
            </div>
        `).join('');
        }

        function getHotelCatalogItem(hotelId) {
            return hotelsData.find(hotel => String(hotel.id) === String(hotelId));
        }

        async function loadHotelChunk({ reset = false, selectedHotelId = '' } = {}) {
            if (hotelCatalogLoading || (!reset && !hotelCatalogHasMore)) return;
            if (reset) {
                hotelsData = [];
                hotelCatalogPage = 0;
                hotelCatalogHasMore = true;
            }

            hotelCatalogLoading = true;
            const nextPage = hotelCatalogPage + 1;
            try {
                const params = new URLSearchParams({ page: nextPage, limit: 20 });
                if (nextPage === 1 && selectedHotelId) params.set('selected_id', selectedHotelId);
                const response = await fetch(`/travel/packages/hotel-options?${params.toString()}`);
                const result = await response.json();
                if (!response.ok || !result.success) throw new Error(result.message || 'Unable to load hotels');

                const knownIds = new Set(hotelsData.map(hotel => String(hotel.id)));
                result.hotels.forEach(hotel => {
                    if (!knownIds.has(String(hotel.id))) hotelsData.push(hotel);
                });
                hotelCatalogPage = nextPage;
                hotelCatalogHasMore = Boolean(result.pagination?.hasMore);
            } finally {
                hotelCatalogLoading = false;
            }
        }

        function renderHotelSelectOptions(selectedHotelId = '') {
            const select = document.getElementById('modalHotelSelect');
            if (!select) return;
            select.disabled = false;
            select.dataset.selectedHotelId = selectedHotelId;
            select.innerHTML = `
                <option value="">Select Hotel</option>
                ${hotelsData.map(hotel => `<option value="${hotel.id}" ${String(selectedHotelId) === String(hotel.id) ? 'selected' : ''}>${escapeHtml(hotel.name)}</option>`).join('')}
                ${hotelCatalogHasMore ? '<option value="__load_more__">Load more hotels...</option>' : ''}
            `;
        }

        function formatMoney(value) {
            const amount = parseFloat(value) || 0;
            if (!amount) return 'Price not set';
            return `₹${amount.toLocaleString('en-IN')}`;
        }

        function renderStars(count) {
            const rating = Math.max(0, Math.min(parseInt(count, 10) || 0, 5));
            if (!rating) return '';
            return Array.from({ length: rating }, () => '<i class="bi bi-star-fill"></i>').join('');
        }

        function renderHotelsList(hotels, destIdx, dayNum) {
            if (!hotels || hotels.length === 0) {
                return '<div class="hotel-empty">No hotel added for this day yet.</div>';
            }

            return hotels.map(hotel => `
            <div class="tf-hotel-unit d-flex justify-content-between align-items-start">
                <div class="d-flex gap-3 align-items-start flex-grow-1">
                    ${hotel.image ? `<img src="${hotel.image}" class="hotel-thumb" alt="${escapeHtml(hotel.name)}">` : '<div class="hotel-thumb hotel-icon-thumb"><i class="bi bi-building"></i></div>'}
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <strong>${escapeHtml(hotel.name || 'Selected Hotel')}</strong>
                            ${hotel.starRating ? `<span class="hotel-meta-pill">${renderStars(hotel.starRating)}</span>` : ''}
                            ${hotel.guestRating ? `<span class="hotel-meta-pill"><i class="bi bi-hand-thumbs-up"></i> ${escapeHtml(hotel.guestRating)}</span>` : ''}
                        </div>
                        <div class="text-muted small mt-1">
                            ${escapeHtml(hotel.nights || 1)} night${parseInt(hotel.nights, 10) === 1 ? '' : 's'} ·
                            ${escapeHtml(hotel.rooms || 1)} room${parseInt(hotel.rooms, 10) === 1 ? '' : 's'} ·
                            ${escapeHtml(formatMoney(hotel.pricePerNight))}/night
                        </div>
                        ${hotel.notes ? `<div class="text-muted small mt-1">${escapeHtml(hotel.notes)}</div>` : ''}
                    </div>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <i class="bi bi-pencil text-primary" style="cursor:pointer" onclick="openHotelModal(${destIdx}, ${dayNum}, '${hotel.id}')"></i>
                    <i class="bi bi-trash3 text-danger" style="cursor:pointer" onclick="removeHotel(${destIdx}, '${hotel.id}')"></i>
                </div>
            </div>
        `).join('');
        }

        async function populateHotelSelect(selectedHotelId = '') {
            const select = document.getElementById('modalHotelSelect');
            const help = document.getElementById('modalHotelHelp');
            if (!select) return;
            select.innerHTML = '<option value="">Loading hotels...</option>';
            select.disabled = true;
            if (help) help.textContent = 'Loading all hotels in small chunks.';
            try {
                await loadHotelChunk({ reset: true, selectedHotelId });
                renderHotelSelectOptions(selectedHotelId);
                if (help) help.textContent = hotelCatalogHasMore
                    ? 'All destinations are included. Choose “Load more hotels...” for the next chunk.'
                    : 'Showing hotels from all destinations.';
            } catch (error) {
                select.innerHTML = '<option value="">Unable to load hotels</option>';
                if (help) help.textContent = error.message;
            }
        }

        function updateHotelPreview() {
            const selectedHotelId = document.getElementById('modalHotelSelect')?.value;
            const preview = document.getElementById('modalHotelPreview');
            const hotel = getHotelCatalogItem(selectedHotelId);
            if (!preview) return;

            if (!hotel) {
                preview.innerHTML = `
                    <div class="hotel-thumb hotel-icon-thumb"><i class="bi bi-building"></i></div>
                    <div>
                        <div class="fw-bold">Select a hotel</div>
                        <div class="text-muted small">Price, rating, and room details will appear here.</div>
                    </div>
                `;
                return;
            }

            preview.innerHTML = `
                ${hotel.image_url ? `<img src="${hotel.image_url}" class="hotel-thumb" alt="${escapeHtml(hotel.name)}">` : '<div class="hotel-thumb hotel-icon-thumb"><i class="bi bi-building"></i></div>'}
                <div>
                    <div class="fw-bold">${escapeHtml(hotel.name)}</div>
                    <div class="text-muted small">
                        ${hotel.star_rating ? `${escapeHtml(hotel.star_rating)} star · ` : ''}
                        ${hotel.guest_rating ? `Guest ${escapeHtml(hotel.guest_rating)} · ` : ''}
                        ${escapeHtml(formatMoney(hotel.price_per_night))}/night
                    </div>
                </div>
            `;
        }

        async function openHotelModal(destIdx, dayNum, hotelId = null) {
            const dest = destinations[destIdx];
            if (!dest || !dest.destinationId) {
                showNotification('Please select destination before adding hotel', true);
                return;
            }

            currentDestIdx = destIdx;
            currentDayNum = dayNum;
            editingHotelId = hotelId;
            if (!Array.isArray(dest.hotels)) dest.hotels = [];

            const existingHotel = hotelId ? dest.hotels.find(hotel => String(hotel.id) === String(hotelId)) : null;

            document.getElementById('hotelModal').classList.add('active');
            await populateHotelSelect(existingHotel?.hotelId || '');
            document.getElementById('modalHotelNights').value = existingHotel?.nights || dest.nights || 1;
            document.getElementById('modalHotelRooms').value = existingHotel?.rooms || 1;
            document.getElementById('modalHotelNotes').value = existingHotel?.notes || '';

            document.querySelector('#hotelModal h5').innerHTML = existingHotel
                ? '<i class="bi bi-pencil-square me-2"></i> Edit Hotel'
                : '<i class="bi bi-building-add me-2"></i> Add Hotel';
            document.getElementById('confirmHotelBtn').innerText = existingHotel ? 'Save Changes' : 'Add Hotel';

            updateHotelPreview();
        }

        function addHotelFromModal() {
            const selectedHotelId = document.getElementById('modalHotelSelect')?.value;
            const hotel = getHotelCatalogItem(selectedHotelId);
            if (!hotel) {
                showNotification('Please select a hotel', true);
                return;
            }

            const dest = destinations[currentDestIdx];
            if (!dest) return;
            if (!Array.isArray(dest.hotels)) dest.hotels = [];

            const duplicate = dest.hotels.find(item => Number(item.dayNumber || 1) === Number(currentDayNum) && String(item.hotelId) === String(hotel.id) && String(item.id) !== String(editingHotelId));
            if (duplicate) {
                showNotification('This hotel is already added for this stay', true);
                return;
            }

            const hotelData = {
                id: editingHotelId || generateId(),
                hotelId: hotel.id,
                destinationId: hotel.destination_id,
                name: hotel.name || '',
                image: hotel.image_url || '',
                starRating: parseInt(hotel.star_rating, 10) || 0,
                guestRating: parseFloat(hotel.guest_rating) || 0,
                pricePerNight: parseFloat(hotel.price_per_night) || 0,
                dayNumber: currentDayNum,
                nights: parseInt(document.getElementById('modalHotelNights').value, 10) || 1,
                rooms: parseInt(document.getElementById('modalHotelRooms').value, 10) || 1,
                notes: document.getElementById('modalHotelNotes').value.trim()
            };

            if (editingHotelId) {
                const index = dest.hotels.findIndex(item => String(item.id) === String(editingHotelId));
                if (index !== -1) dest.hotels[index] = hotelData;
                showNotification('Hotel updated successfully!');
            } else {
                dest.hotels.push(hotelData);
                showNotification('Hotel added successfully!');
            }

            renderDestinations();
            document.getElementById('hotelModal').classList.remove('active');
        }

        function removeHotel(destIdx, hotelId) {
            const hotels = destinations[destIdx]?.hotels || [];
            const index = hotels.findIndex(hotel => String(hotel.id) === String(hotelId));
            if (index !== -1) {
                hotels.splice(index, 1);
                renderDestinations();
                showNotification('Hotel removed');
            }
        }

        function showDay(destIdx, dayNum) {
            const dest = destinations[destIdx];
            if (!dest) return;
            const totalDays = Math.max(parseInt(dest.nights, 10) || 1, 1);

            const tabsContainer = document.getElementById(`dayTabs-${destIdx}`);
            if (tabsContainer) {
                const tabs = tabsContainer.querySelectorAll('.day-tab-btn');
                tabs.forEach((tab, idx) => {
                    if (idx + 1 === dayNum) {
                        tab.classList.add('active');
                    } else {
                        tab.classList.remove('active');
                    }
                });
            }

            for (let i = 1; i <= totalDays; i++) {
                const content = document.getElementById(`dayContent-${destIdx}-${i}`);
                if (content) {
                    content.classList.remove('active');
                }
            }
            const activeContent = document.getElementById(`dayContent-${destIdx}-${dayNum}`);
            if (activeContent) {
                activeContent.classList.add('active');
            }
        }

        let editingActivityId = null;

        function formatActivityText(command) {
            document.getElementById('modalDescription').focus();
            document.execCommand(command, false, null);
        }

        function sanitizeRichText(value) {
            const template = document.createElement('template');
            template.innerHTML = String(value || '');
            const allowed = new Set(['B', 'STRONG', 'I', 'EM', 'U', 'UL', 'OL', 'LI', 'P', 'DIV', 'BR']);
            Array.from(template.content.querySelectorAll('*')).forEach(node => {
                if (!allowed.has(node.tagName)) {
                    node.replaceWith(...node.childNodes);
                    return;
                }
                Array.from(node.attributes).forEach(attribute => node.removeAttribute(attribute.name));
            });
            return template.innerHTML.trim();
        }

        function getActivityTimeSlot(activity) {
            const legacySlots = ['Full Day', 'Morning', 'Noon', 'Evening', 'Morning to Noon'];
            return activity.timeSlot || activity.time_slot || (legacySlots.includes(activity.duration) ? activity.duration : 'Full Day');
        }

        function getActivityDuration(activity) {
            return activity.timeSlot || activity.time_slot ? (activity.duration || '') : '';
        }

        function openActivityModal(destIdx, dayNum) {
            currentDestIdx = destIdx;
            currentDayNum = dayNum;
            editingActivityId = null;

            document.getElementById('modalActivityName').value = '';
            document.getElementById('modalTimeSlot').value = 'Full Day';
            document.getElementById('modalActivityDuration').value = '';
            document.getElementById('modalDepartureCity').value = '';
            document.getElementById('modalDescription').innerHTML = '';

            // Reset image preview and hidden input
            document.getElementById('modalActivityImage').value = '';
            document.getElementById('modalActivityImagePreview').innerHTML = '<i class="bi bi-image text-muted opacity-50 fs-4"></i>';
            document.getElementById('modalActivityImageBtn').innerHTML = '<i class="bi bi-upload me-1"></i> Upload Image';

            // Set modal title and button text
            document.querySelector('#activityModal h5').innerHTML = '<i class="bi bi-plus-circle me-2"></i> Add Activity';
            document.getElementById('confirmActivityBtn').innerText = 'Add Activity';

            document.getElementById('activityModal').classList.add('active');
        }

        function openEditActivityModal(destIdx, dayNum, activityId) {
            currentDestIdx = destIdx;
            currentDayNum = dayNum;
            editingActivityId = activityId;

            const act = destinations[destIdx].activities[dayNum].find(a => a.id === activityId);
            if (!act) return;

            document.getElementById('modalActivityName').value = act.name || '';
            document.getElementById('modalTimeSlot').value = getActivityTimeSlot(act);
            document.getElementById('modalActivityDuration').value = getActivityDuration(act);
            document.getElementById('modalDepartureCity').value = act.departureCity || act.departure_city || act.departureFrom || act.departure_from || '';
            document.getElementById('modalDescription').innerHTML = sanitizeRichText(act.description || '');

            // Set image preview and hidden input
            document.getElementById('modalActivityImage').value = act.image || '';
            if (act.image) {
                document.getElementById('modalActivityImagePreview').innerHTML = `<img src="${act.image}" style="width: 100%; height: 100%; object-fit: cover;">`;
                document.getElementById('modalActivityImageBtn').innerHTML = '<i class="bi bi-check2 me-1"></i> Change Image';
            } else {
                document.getElementById('modalActivityImagePreview').innerHTML = '<i class="bi bi-image text-muted opacity-50 fs-4"></i>';
                document.getElementById('modalActivityImageBtn').innerHTML = '<i class="bi bi-upload me-1"></i> Upload Image';
            }

            // Set modal title and button text
            document.querySelector('#activityModal h5').innerHTML = '<i class="bi bi-pencil-square me-2"></i> Edit Activity';
            document.getElementById('confirmActivityBtn').innerText = 'Save Changes';

            document.getElementById('activityModal').classList.add('active');
        }

        async function uploadActivityImage(input) {
            if (!input.files || !input.files[0]) return;

            const formData = new FormData();
            formData.append('activity_image', input.files[0]);

            try {
                const btn = document.getElementById('modalActivityImageBtn');
                const originalHtml = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Uploading...';
                btn.disabled = true;

                const res = await fetch(`/travel/packages/activity-image`, {
                    method: 'POST',
                    body: formData
                });
                const result = await res.json();

                if (result.success) {
                    document.getElementById('modalActivityImage').value = result.imageUrl;
                    document.getElementById('modalActivityImagePreview').innerHTML = `<img src="${result.imageUrl}" style="width: 100%; height: 100%; object-fit: cover;">`;
                    btn.innerHTML = '<i class="bi bi-check2 me-1"></i> Change Image';
                    showNotification('Activity image uploaded successfully!');
                } else {
                    showNotification('Upload failed: ' + result.message, true);
                    btn.innerHTML = originalHtml;
                }
                btn.disabled = false;
            } catch (err) {
                showNotification('Server error uploading image', true);
                document.getElementById('modalActivityImageBtn').disabled = false;
                document.getElementById('modalActivityImageBtn').innerHTML = '<i class="bi bi-upload me-1"></i> Upload Image';
            }
            input.value = '';
        }

        function addActivityFromModal() {
            const name = document.getElementById('modalActivityName').value.trim();
            if (!name) {
                showNotification('Please enter activity name', true);
                return;
            }

            const timeSlot = document.getElementById('modalTimeSlot').value;
            const duration = document.getElementById('modalActivityDuration').value.trim();
            const departureCity = document.getElementById('modalDepartureCity').value.trim();
            const description = sanitizeRichText(document.getElementById('modalDescription').innerHTML);
            const image = document.getElementById('modalActivityImage').value;

            if (editingActivityId) {
                // Find and update existing activity
                const activities = destinations[currentDestIdx].activities[currentDayNum];
                const act = activities.find(a => a.id === editingActivityId);
                if (act) {
                    act.name = name;
                    act.timeSlot = timeSlot;
                    act.duration = duration;
                    act.departureCity = departureCity;
                    delete act.departureFrom;
                    act.description = description;
                    act.image = image;
                }
                showNotification('Activity updated successfully!');
            } else {
                // Add new activity
                const newActivity = {
                    id: generateId(),
                    name: name,
                    timeSlot: timeSlot,
                    duration: duration,
                    departureCity: departureCity,
                    description: description,
                    image: image
                };

                if (!destinations[currentDestIdx].activities[currentDayNum]) {
                    destinations[currentDestIdx].activities[currentDayNum] = [];
                }
                destinations[currentDestIdx].activities[currentDayNum].push(newActivity);
                showNotification('Activity added successfully!');
            }

            const container = document.getElementById(`activitiesList-${currentDestIdx}-${currentDayNum}`);
            if (container) {
                container.innerHTML = renderActivitiesList(destinations[currentDestIdx].activities[currentDayNum], currentDestIdx, currentDayNum);
            }

            document.getElementById('activityModal').classList.remove('active');
        }

        function removeActivity(destIdx, dayNum, activityId) {
            const activities = destinations[destIdx].activities[dayNum];
            const index = activities.findIndex(a => a.id === activityId);
            if (index !== -1) {
                activities.splice(index, 1);
                const container = document.getElementById(`activitiesList-${destIdx}-${dayNum}`);
                if (container) {
                    container.innerHTML = renderActivitiesList(activities, destIdx, dayNum);
                }
                showNotification('Activity removed');
            }
        }

        function removeDestination(idx) {
            destinations.splice(idx, 1);
            updateDayRanges();
            renderDestinations();
            showNotification('Destination removed');
        }

        function escapeHtml(str) {
            if (!str) return '';
            return String(str).replace(/[&<>"']/g, function (m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                if (m === '"') return '&quot;';
                if (m === "'") return '&#39;';
                return m;
            });
        }

        function renderInclusions() {
            const container = document.getElementById('inclusionsList');
            if (!container) return;

            if (inclusions.length === 0) {
                container.innerHTML = '<div class="text-muted">No inclusions added</div>';
                return;
            }

            container.innerHTML = inclusions.map((inc, idx) => `
            <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                <span><i class="bi bi-check-circle-fill text-success me-2"></i>${escapeHtml(inc)}</span>
                <i class="bi bi-trash3 text-danger" style="cursor:pointer" onclick="removeInclusion(${idx})"></i>
            </div>
        `).join('');
        }

        function renderExclusions() {
            const container = document.getElementById('exclusionsList');
            if (!container) return;

            if (exclusions.length === 0) {
                container.innerHTML = '<div class="text-muted">No exclusions added</div>';
                return;
            }

            container.innerHTML = exclusions.map((exc, idx) => `
            <div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
                <span><i class="bi bi-x-circle-fill text-danger me-2"></i>${escapeHtml(exc)}</span>
                <i class="bi bi-trash3 text-danger" style="cursor:pointer" onclick="removeExclusion(${idx})"></i>
            </div>
        `).join('');
        }

        function addInclusion() {
            const input = document.getElementById('newInclusion');
            const text = input.value.trim();
            if (text) {
                inclusions.push(text);
                renderInclusions();
                input.value = '';
                showNotification('Inclusion added');
            }
        }

        function addExclusion() {
            const input = document.getElementById('newExclusion');
            const text = input.value.trim();
            if (text) {
                exclusions.push(text);
                renderExclusions();
                input.value = '';
                showNotification('Exclusion added');
            }
        }

        function removeInclusion(idx) {
            inclusions.splice(idx, 1);
            renderInclusions();
            showNotification('Inclusion removed');
        }

        function removeExclusion(idx) {
            exclusions.splice(idx, 1);
            renderExclusions();
            showNotification('Exclusion removed');
        }

        async function uploadMainImage(input) {
            if (!input.files || !input.files[0]) return;

            const formData = new FormData();
            formData.append('main_image', input.files[0]);

            const btn = document.getElementById('mainImageUploadBtn');
            const originalHtml = btn ? btn.innerHTML : '';

            try {
                if (btn) {
                    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Uploading...';
                    btn.disabled = true;
                }

                const res = await fetch('/travel/packages/main-image', {
                    method: 'POST',
                    body: formData
                });
                const result = await res.json();

                if (result.success) {
                    document.getElementById('fMainImage').value = result.imageUrl;
                    document.getElementById('mainImagePreview').innerHTML = `<img src="${result.imageUrl}" style="width: 100%; height: 100%; object-fit: cover;">`;
                    if (btn) btn.innerHTML = '<i class="bi bi-check2 me-1"></i> Change Main Image';
                    showNotification('Main image uploaded successfully!');
                } else {
                    showNotification('Upload failed: ' + (result.message || 'Unable to upload image'), true);
                    if (btn) btn.innerHTML = originalHtml;
                }
            } catch (err) {
                showNotification('Server error uploading image', true);
                if (btn) btn.innerHTML = originalHtml;
            } finally {
                if (btn) btn.disabled = false;
                input.value = '';
            }
        }

        async function savePackage() {
            const packageName = document.getElementById('packageName').value;
            const slug = document.getElementById('packageSlug')?.value.trim() || '';
            const duration = parseInt(document.getElementById('duration').value);
            const departureCity = document.getElementById('departureCity')?.value.trim() || '';
            const price = parseInt(document.getElementById('price').value) || 0;
            const description = document.getElementById('description').value;
            const showInHomePage = !!document.getElementById('showInHomePage')?.checked;
            const isCustomizable = !!document.getElementById('isCustomizable')?.checked;
            const discountPercentage = parseFloat(document.getElementById('discountPercentage')?.value) || 0;
            const taxType = document.getElementById('taxType')?.value || '';
            const taxPercent = parseFloat(document.getElementById('taxPercent')?.value) || 0;
            const sortOrderValue = document.getElementById('sortOrder')?.value;

            if (!packageName) {
                showNotification('Please enter package name', true);
                return;
            }
            if (destinations.length === 0) {
                showNotification('Please add at least one destination', true);
                return;
            }

            const packageData = {
                name: packageName,
                slug: slug,
                duration: duration,
                departure_city: departureCity,
                price: price,
                discount_percentage: discountPercentage,
                tax_type: taxType,
                tax_percent: taxPercent,
                sort_order: sortOrderValue === '' ? null : parseInt(sortOrderValue, 10),
                travel_type: document.querySelector('input[name="packageTravelType"]:checked')?.value || 'domestic',
                description: description,
                meta_title: document.getElementById('metaTitle')?.value.trim() || null,
                meta_description: document.getElementById('metaDescription')?.value.trim() || null,
                meta_keyword: document.getElementById('metaKeyword')?.value.trim() || null,
                schema: document.getElementById('metaSchema')?.value.trim() || null,
                show_in_home_page: showInHomePage,
                is_customizable: isCustomizable,
                package_categories: Array.from(document.querySelectorAll('.package-category-checkbox:checked')).map(cb => cb.value),
                main_image: document.getElementById('fMainImage').value,
                main_image_alt: document.getElementById('fMainImageAlt').value,
                destinations: destinations.map(dest => ({
                    destinationId: dest.destinationId,
                    nights: dest.nights,
                    activities: dest.activities,
                    hotels: dest.hotels || []
                })),
                inclusions: inclusions,
                exclusions: exclusions
            };

            try {
                const response = await fetch('/travel/packages/save', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(packageData)
                });

                const responseData = await response.json();
                console.log("Server response:", responseData);

                if (responseData.success) {
                    showNotification(responseData.message || 'Package created successfully!');
                    setTimeout(() => {
                        window.location.href = `/travel/packages/${responseData.id}/edit`;
                    }, 1500);
                } else {
                    const errorMsg = responseData.message || 'Something went wrong';
                    showNotification('Error: ' + errorMsg, true);
                }
            } catch (err) {
                console.error("Fetch error details:", err);
                showNotification('Network error: ' + err.message, true);
            }
        }

        // Event Listeners
        document.getElementById('addDestinationBtn')?.addEventListener('click', () => {
            destinations.push({
                id: generateId(),
                destinationId: null,
                destinationName: '',
                nights: 2,
                startDay: 1,
                endDay: 2,
                activities: {},
                hotels: []
            });
            updateDayRanges();
            renderDestinations();
            showNotification('Destination added');
        });

        document.getElementById('addInclusionBtn')?.addEventListener('click', addInclusion);
        document.getElementById('addExclusionBtn')?.addEventListener('click', addExclusion);
        document.getElementById('savePackageBtn')?.addEventListener('click', savePackage);
        document.getElementById('taxType')?.addEventListener('change', () => syncTaxPercent(true));
        document.getElementById('packageName')?.addEventListener('input', (e) => {
            const slugInput = document.getElementById('packageSlug');
            if (slugInput && !slugInput.dataset.touched) slugInput.value = slugify(e.target.value);
        });
        document.getElementById('packageSlug')?.addEventListener('input', (e) => {
            e.target.dataset.touched = 'true';
            e.target.value = slugify(e.target.value);
        });
        document.getElementById('closeModalBtn')?.addEventListener('click', () => {
            document.getElementById('activityModal').classList.remove('active');
        });
        document.getElementById('confirmActivityBtn')?.addEventListener('click', addActivityFromModal);
        document.getElementById('closeHotelModalBtn')?.addEventListener('click', () => {
            document.getElementById('hotelModal').classList.remove('active');
        });
        document.getElementById('confirmHotelBtn')?.addEventListener('click', addHotelFromModal);
        document.getElementById('modalHotelSelect')?.addEventListener('change', async (event) => {
            const select = event.currentTarget;
            if (select.value === '__load_more__') {
                const selectedHotelId = select.dataset.selectedHotelId || '';
                select.disabled = true;
                try {
                    await loadHotelChunk();
                    renderHotelSelectOptions(selectedHotelId);
                } catch (error) {
                    showNotification(error.message, true);
                    renderHotelSelectOptions(selectedHotelId);
                }
                return;
            }
            select.dataset.selectedHotelId = select.value;
            updateHotelPreview();
        });

        document.getElementById('newInclusion')?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') addInclusion();
        });
        document.getElementById('newExclusion')?.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') addExclusion();
        });

        // Initialize
        if (destinations.length === 0) {
            destinations.push({
                id: generateId(),
                destinationId: null,
                destinationName: '',
                nights: 2,
                startDay: 1,
                endDay: 2,
                activities: {},
                hotels: []
            });
            renderDestinations();
        }

        renderInclusions();
        renderExclusions();
        syncTaxPercent();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
