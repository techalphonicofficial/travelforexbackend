<div class="tf-page-header">
  <div>
    <h1 class="tf-page-title">Tour Packages</h1>
    <p class="tf-page-sub">Manage holiday itineraries and routing</p>
  </div>
  <div class="d-flex gap-3">
    <div class="tf-view-toggle">
      <button class="active" id="viewList" onclick="toggleView('list')"><i class="bi bi-list-ul"></i></button>
      <button id="viewGrid" onclick="toggleView('grid')"><i class="bi bi-grid-3x3-gap-fill"></i></button>
    </div>
    <a href="/travel/packages/create" class="btn-add-primary"><i class="bi bi-plus-lg"></i> Create New Package</a>
  </div>
</div>

<!-- FILTERS -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="input-group">
      <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
      <input type="text" class="form-control border-start-0 ps-0" id="searchPkg" placeholder="Search package name..."
        onkeyup="filterData()">
    </div>
  </div>

</div>

<div id="packageListContent"></div>
<div id="pagination" class="mt-4"></div>


<script>
  let ALL_DATA = <%- JSON.stringify(packages).replace(/</g, '\\u003c') %>;
  let filtered = [...ALL_DATA];
  let currentView = 'list';
  let currentPage = 1;
  const itemsPerPage = 8;

  function render() {
    const container = document.getElementById('packageListContent');

    const start = (currentPage - 1) * itemsPerPage;
    const end = start + itemsPerPage;
    const paginated = filtered.slice(start, end);

    if (currentView === 'list') {
      container.innerHTML = `
      <div class="tf-table-card">
        <table class="table align-middle mb-0">
          <thead class="bg-light">
            <tr>
              <th class="ps-3" style="width:90px">Order</th>
              <th class="ps-4">Package Details</th>

              <th>Route (Stay Duration)</th>

              <th class="text-end pe-4">Actions</th>
            </tr>
          </thead>
          <tbody>
            ${paginated.map(p => `
              <tr class="package-sort-row" data-package-id="${p.id}" draggable="true">
                <td class="ps-3">
                  <span class="package-drag-handle d-inline-flex align-items-center gap-2 text-muted" style="cursor:grab" title="Drag to reorder">
                    <i class="bi bi-grip-vertical fs-5"></i>
                    <span class="badge bg-light text-dark border">${p.sort_order ?? '-'}</span>
                  </span>
                </td>
                <td class="ps-4">
                  <div class="d-flex align-items-center gap-3">
                    <div style="width: 50px; aspect-ratio: 1; border-radius: 8px; overflow: hidden; background: #f8fafc; border: 1px solid #eee; flex-shrink: 0;">
                      ${p.main_image ? `<img src="${p.main_image}" alt="${p.main_image_alt || p.name}" style="width: 100%; height: 100%; object-fit: cover;">` : `<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc;"><i class="bi bi-image"></i></div>`}
                    </div>
                    <div>
                      <div class="fw-bold text-dark d-flex align-items-center gap-2">
                        ${p.name}
                        ${p.show_in_home_page ? '<span class="badge" style="background-color:#d1fae5; color:#065f46; font-size:0.65rem; border-radius:12px; padding:2px 6px;">Home Page</span>' : ''}
                      </div>
                      <div class="text-muted small">${p.duration_days} Days / ${Math.max(0, p.duration_days - 1)} Nights • <strong class="text-primary">₹${p.price || 0}</strong></div>
                    </div>
                  </div>
                </td>
                <td><div class="text-muted small" style="max-width:280px">${formatStaysJS(p.destinations)}</div></td>

                <td class="text-end pe-4">
                  <div class="d-flex justify-content-end gap-2">
                    <a href="/travel/packages/${p.id}/edit" class="btn-icon btn-icon-edit"><i class="bi bi-pencil"></i></a>
                    <a href="/travel/packages/${p.id}" class="btn-icon btn-icon-view"><i class="bi bi-eye"></i></a>
                    <a href="/travel/packages/${p.id}/reviews" class="btn-icon btn-icon-view" title="Package reviews"><i class="bi bi-star"></i></a>
                    <button class="btn-icon btn-icon-view" onclick="duplicatePkg('${p.id}')" title="Duplicate package"><i class="bi bi-copy"></i></button>
                    <button class="btn-icon btn-icon-del" onclick="deletePkg('${p.id}')"><i class="bi bi-trash3"></i></button>
                  </div>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
    } else {
      container.innerHTML = `<div class="row g-4">${paginated.map(p => `
      <div class="col-md-3">
        <div class="tf-card h-100 p-0 overflow-hidden">
          <div style="width: 100%; aspect-ratio: 16/9; background: #f8fafc; position: relative; border-bottom: 1px solid #eee;">
            ${p.main_image ? `<img src="${p.main_image}" alt="${p.main_image_alt || p.name}" style="width: 100%; height: 100%; object-fit: cover;">` : `<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc;"><i class="bi bi-image fs-1"></i></div>`}
            <div style="position: absolute; top: 10px; left: 10px;">
              <span class="tf-badge pill-active">${p.duration_days} Days</span>
            </div>
          </div>
          <div class="p-3">
            <div class="d-flex justify-content-between mb-2">
           
          </div>
          <h6 class="fw-bold text-dark mb-1 d-flex justify-content-between align-items-start gap-2">
            <span>${p.name}</span>
            <span class="d-inline-flex gap-2">
              ${p.show_in_home_page ? '<i class="bi bi-house-door-fill text-success" style="font-size: 0.9rem;" title="Shown on Home Page"></i>' : ''}
            </span>
          </h6>
          <div class="text-muted small mb-3">
             <i class="bi bi-geo-alt me-1"></i> ${formatStaysJS(p.destinations)}
          </div>
          <div class="mt-auto d-flex justify-content-between align-items-center">
            <span class="fw-bold text-primary" style="font-size: 1.05rem;">₹${p.price || 0}</span>
            <div class="d-flex gap-1">
              <a href="/travel/packages/${p.id}/edit" class="btn-icon btn-icon-edit btn-sm"><i class="bi bi-pencil"></i></a>
              <a href="/travel/packages/${p.id}/reviews" class="btn-icon btn-icon-view btn-sm" title="Package reviews"><i class="bi bi-star"></i></a>
              <button class="btn-icon btn-icon-view btn-sm" onclick="duplicatePkg('${p.id}')" title="Duplicate package"><i class="bi bi-copy"></i></button>
              <button class="btn-icon btn-icon-del btn-sm" onclick="deletePkg('${p.id}')"><i class="bi bi-trash3"></i></button>
            </div>
          </div>
        </div>
      </div>
    `).join('')}</div>`;
    }
    renderPagination();
    initializeDragAndDrop();
  }

  // JS Helpers for dynamic rendering
  function formatStaysJS(items) {
    if (!items || items.length === 0) return 'Route TBD';
    return items
      .sort((a, b) => (a.order || 0) - (b.order || 0))
      .map(pd => `${pd.destination?.name || 'Unknown'} (${pd.nights || 0}N)`)
      .join(' → ');
  }


  function filterData() {
    const query = document.getElementById('searchPkg').value.toLowerCase();
    filtered = ALL_DATA.filter(p => {
      const mSearch = p.name.toLowerCase().includes(query);
      return mSearch;
    });
    currentPage = 1;
    render();
  }

  function toggleView(v) {
    currentView = v;
    document.getElementById('viewList').classList.toggle('active', v === 'list');
    document.getElementById('viewGrid').classList.toggle('active', v === 'grid');
    render();
  }

  function renderPagination() {
    const totalPages = Math.ceil(filtered.length / itemsPerPage);
    let html = `<nav><ul class="pagination justify-content-center">`;
    for (let i = 1; i <= totalPages; i++) {
      html += `<li class="page-item ${i === currentPage ? 'active' : ''}"><a class="page-link" href="#" onclick="currentPage=${i}; render(); return false;">${i}</a></li>`;
    }
    html += `</ul></nav>`;
    document.getElementById('pagination').innerHTML = totalPages > 1 ? html : '';
  }

  function initializeDragAndDrop() {
    if (currentView !== 'list') return;

    const isFiltering = !!document.getElementById('searchPkg').value.trim();
    const rows = document.querySelectorAll('.package-sort-row');
    let draggedId = null;

    rows.forEach(row => {
      row.draggable = !isFiltering;
      const handle = row.querySelector('.package-drag-handle');
      if (isFiltering && handle) handle.title = 'Clear search to reorder packages';

      row.addEventListener('dragstart', event => {
        if (isFiltering) return event.preventDefault();
        draggedId = Number(row.dataset.packageId);
        row.style.opacity = '0.45';
        event.dataTransfer.effectAllowed = 'move';
      });

      row.addEventListener('dragend', () => {
        row.style.opacity = '';
        rows.forEach(item => item.style.boxShadow = '');
      });

      row.addEventListener('dragover', event => {
        if (!draggedId || Number(row.dataset.packageId) === draggedId) return;
        event.preventDefault();
        row.style.boxShadow = 'inset 0 2px 0 #6366f1';
      });

      row.addEventListener('dragleave', () => { row.style.boxShadow = ''; });

      row.addEventListener('drop', async event => {
        event.preventDefault();
        const targetId = Number(row.dataset.packageId);
        if (!draggedId || draggedId === targetId) return;

        const fromIndex = ALL_DATA.findIndex(item => Number(item.id) === draggedId);
        const targetIndex = ALL_DATA.findIndex(item => Number(item.id) === targetId);
        if (fromIndex < 0 || targetIndex < 0) return;

        const [moved] = ALL_DATA.splice(fromIndex, 1);
        const newTargetIndex = ALL_DATA.findIndex(item => Number(item.id) === targetId);
        ALL_DATA.splice(newTargetIndex, 0, moved);
        ALL_DATA.forEach((item, index) => { item.sort_order = index + 1; });
        filtered = [...ALL_DATA];
        render();

        try {
          const response = await fetch('/travel/packages/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ids: ALL_DATA.map(item => item.id) })
          });
          const result = await response.json();
          if (!response.ok || !result.success) throw new Error(result.message || 'Unable to save order');
        } catch (error) {
          alert('Order save failed: ' + error.message);
          location.reload();
        }
      });
    });
  }

  async function duplicatePkg(id) {
    if (!confirm('Duplicate this package with its itinerary and content?')) return;
    try {
      const response = await fetch(`/travel/packages/${id}/duplicate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const result = await response.json();
      if (!response.ok || !result.success) throw new Error(result.message || 'Unable to duplicate package');
      window.location.href = `/travel/packages/${result.id}/edit`;
    } catch (error) {
      alert('Duplicate failed: ' + error.message);
    }
  }

  async function deletePkg(id) {
    if (confirm('Are you sure you want to delete this package?')) {
      try {
        const res = await fetch(`/api/v1/packages/${id}`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json'
          }
        });
        const data = await res.json();
        if (data.success) {
          location.reload();
        } else {
          alert('Error: ' + (data.message || 'Failed to delete'));
        }
      } catch (err) {
        alert('Network Error: ' + err.message);
      }
    }
  }

  render();
</script>
