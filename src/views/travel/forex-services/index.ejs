<%
const _services = JSON.stringify(forexServices || []);
const _countries = JSON.stringify(countries || []);
%>

<style>
  .design-card {
    background: #fff;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.03);
    margin-bottom: 2rem;
  }
  .table-minimal {
    border-collapse: separate;
    border-spacing: 0 0.5rem;
  }
  .table-minimal thead th {
    border-bottom: 0;
    color: #111827;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: capitalize;
    padding-bottom: 0.5rem;
  }
  .table-minimal tbody td {
    border: none;
    padding: 0.75rem 0.5rem;
    color: #4b5563;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .btn-create {
    background-color: #0ea5e9;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 0.4rem 1rem;
    font-size: 0.85rem;
    font-weight: 500;
  }
  .btn-create:hover { background-color: #0284c7; color: #fff; }
  .filter-input {
    background-color: #f9fafb;
    border: 1px solid #f3f4f6;
    border-radius: 6px;
    font-size: 0.85rem;
    color: #4b5563;
  }
  .filter-input:focus {
    background-color: #fff;
    border-color: #d1d5db;
    box-shadow: none;
  }
  .btn-group-toggle .btn {
    border: 1px solid #e5e7eb;
    background-color: #fff;
    color: #4b5563;
    font-size: 0.82rem;
    padding: 0.35rem 0.75rem;
    font-weight: 500;
  }
  .btn-group-toggle .btn.active {
    background-color: #f3f4f6;
    color: #111827;
    box-shadow: none;
  }
  .custom-checkbox {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1.5px solid #d1d5db;
    appearance: none;
    outline: none;
    cursor: pointer;
    position: relative;
    background-color: #fff;
    transition: all 0.2s;
    margin: 0;
    vertical-align: middle;
  }
  .custom-checkbox:checked {
    background-color: #0ea5e9;
    border-color: #0ea5e9;
  }
  .custom-checkbox:checked::after {
    content: '';
    position: absolute;
    left: 5px;
    top: 2px;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .table-minimal tbody tr td:first-child {
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .table-minimal tbody tr.row-selected td:first-child {
    border-left-color: #0ea5e9;
  }
  .table-minimal tbody tr.row-selected td {
    background-color: #f8fafc;
  }
  .bulk-delete-bar {
    display: none;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.8rem 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .code-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: #eff6ff;
    color: #1d4ed8;
    border-radius: 999px;
    padding: 0.28rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0;
  }
  .exchange-pill {
    background: #f0fdf4;
    color: #15803d;
    border-radius: 999px;
    padding: 0.28rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 700;
  }
</style>

<div class="design-card">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-3">
    <div>
      <h3 class="fw-bold mb-1" style="color: #111827;">Forex Services</h3>
      <p class="text-muted mb-0" style="font-size: 0.85rem;">Country-wise forex code and exchange type records.</p>
    </div>
    <div class="d-flex gap-3 align-items-center">
      <div class="btn-group btn-group-toggle shadow-sm" role="group">
        <button type="button" class="btn active d-flex align-items-center gap-2" id="vList" onclick="setView('list')">
          <i class="bi bi-list-ul"></i> List
        </button>
        <button type="button" class="btn d-flex align-items-center gap-2" id="vCards" onclick="setView('cards')">
          <i class="bi bi-grid-3x3-gap"></i> Cards
        </button>
      </div>
      <button class="btn-create shadow-sm" data-bs-toggle="modal" data-bs-target="#modal" onclick="openCreate()">
        <i class="bi bi-plus-lg me-1"></i> Add Forex Service
      </button>
    </div>
  </div>

  <hr style="border-color: #e5e7eb; margin: 1.25rem -1.5rem;">

  <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4 mt-2">
    <div class="d-flex gap-2 flex-wrap">
      <div class="position-relative" style="width: 260px;">
        <i class="bi bi-search position-absolute text-muted" style="left: 12px; top: 50%; transform: translateY(-50%); font-size: 0.85rem;"></i>
        <input type="text" id="searchInput" class="form-control form-control-sm filter-input ps-5 py-2" placeholder="Search code or type..." oninput="applyFilters()">
      </div>
      <select id="countryFilter" class="form-select form-select-sm filter-input py-2" style="width: 180px;" onchange="applyFilters()">
        <option value="">All Countries</option>
        <% countries.forEach(country => { %>
        <option value="<%= country.id %>"><%= country.name %></option>
        <% }) %>
      </select>
    </div>
    <span class="text-muted fw-bold" id="countLabel" style="font-size: 0.85rem;"></span>
  </div>

  <div id="bulkActionsBar" class="bulk-delete-bar align-items-center justify-content-between">
    <button class="btn btn-danger btn-sm px-3 py-2 d-inline-flex align-items-center gap-2" style="background-color: #ef4444; border:none; border-radius:6px; font-weight:600;" onclick="confirmBulkDelete()">
      <i class="bi bi-trash3"></i> Delete selected
    </button>
    <span id="selectedCountMsg" class="fw-bold" style="color: #4b5563; font-size:0.9rem;">0 records selected</span>
  </div>

  <div id="listView">
    <div class="table-responsive" style="border: none; box-shadow: none; overflow: visible;">
      <table class="table table-minimal w-100">
        <thead>
          <tr>
            <th style="width:30px"><input type="checkbox" class="custom-checkbox" id="selectAllCheckbox" onchange="toggleSelectAll()"></th>
            <th style="width:40px">#</th>
            <th>Country</th>
            <th>Code</th>
            <th>Exchange Type</th>
            <th>Created</th>
            <th style="width:80px;text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="listBody"></tbody>
      </table>
      <div id="listPag"></div>
    </div>
  </div>

  <div id="cardsView" style="display:none">
    <div class="tf-cards" id="cardsBody"></div>
    <div class="tf-pagination mt-3" style="border-radius:16px;background:#fff;box-shadow:0 4px 16px rgba(79,70,229,.07)" id="cardsPag"></div>
  </div>

  <div class="modal fade tf-modal" id="modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:500px">
      <div class="modal-content">
        <div class="modal-header" style="background:linear-gradient(135deg,#0284c7,#22d3ee);color:#fff">
          <h5 class="modal-title fw-bold" id="modalTitle">Add Forex Service</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="fId">
          <div class="mb-3">
            <label class="form-label">Country <span class="text-danger">*</span></label>
            <select class="form-select" id="fCountry">
              <option value="">Select Country</option>
              <% countries.forEach(country => { %>
              <option value="<%= country.id %>"><%= country.name %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">Code <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="fCode" maxlength="20" placeholder="e.g. USD, EUR, AED">
          </div>
          <div class="mb-3">
            <label class="form-label">Exchange Type <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="fExchangeType" maxlength="100" placeholder="e.g. Buy, Sell, Buy & Sell">
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button class="btn-add-primary" onclick="save()"><i class="bi bi-check2 me-1"></i>Save</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade tf-modal" id="delModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
      <div class="modal-content">
        <div class="modal-body text-center p-4">
          <div style="width:60px;height:60px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.7rem;color:#ef4444"><i class="bi bi-trash3"></i></div>
          <h5 class="fw-bold mb-1">Delete Forex Service?</h5>
          <p class="text-muted" id="delMsg" style="font-size:.88rem"></p>
          <div class="d-flex gap-2 justify-content-center mt-3">
            <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-danger px-4 rounded-3 fw-semibold" id="delBtn">Yes, Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
  const ALL = <%- _services %>;
  const COUNTRIES = <%- _countries %>;
  const COUNTRY_MAP = Object.fromEntries(COUNTRIES.map(country => [String(country.id), country.name]));
  const COLORS = ['#0ea5e9','#10b981','#f59e0b','#ec4899','#4f46e5','#06b6d4','#ef4444','#8b5cf6'];
  const PS = 10;
  let view = 'list', page = 1, filtered = [...ALL], delId = null;
  let selectedIds = new Set();

  function escapeHtml(value) {
    return String(value ?? '').replace(/[&<>"']/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
  }

  function applyFilters() {
    const q = document.getElementById('searchInput').value.toLowerCase();
    const country = document.getElementById('countryFilter').value;
    filtered = ALL.filter(record => {
      const countryName = COUNTRY_MAP[String(record.country_id)] || '';
      const haystack = `${record.code || ''} ${record.exchange_type || ''} ${countryName}`.toLowerCase();
      return haystack.includes(q) && (!country || String(record.country_id) === country);
    });
    page = 1;
    render();
  }

  function render() {
    const total = filtered.length;
    const pages = Math.max(1, Math.ceil(total / PS));
    page = Math.min(page, pages);
    const start = (page - 1) * PS;
    const slice = filtered.slice(start, start + PS);
    document.getElementById('countLabel').textContent = `${total} result${total !== 1 ? 's' : ''}`;
    if (view === 'list') renderList(slice, start, total, pages);
    else renderCards(slice, start, total, pages);
    evaluateSelectionState();
    updateBulkActionBar();
  }

  function renderList(slice, start, total, pages) {
    const body = document.getElementById('listBody');
    if (!slice.length) {
      body.innerHTML = emptyRow(7);
      document.getElementById('listPag').innerHTML = '';
      return;
    }

    body.innerHTML = slice.map((record, index) => {
      const color = COLORS[(record.id || index) % COLORS.length];
      const country = COUNTRY_MAP[String(record.country_id)] || '-';
      const date = record.created_at ? new Date(record.created_at).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : '-';
      const checked = selectedIds.has(String(record.id)) ? 'checked' : '';
      const rowClass = checked ? 'row-selected' : '';
      const safeCountry = escapeHtml(country);
      const safeCode = escapeHtml(record.code);
      const safeType = escapeHtml(record.exchange_type);

      return `<tr class="${rowClass}">
        <td><input type="checkbox" class="custom-checkbox row-checkbox" value="${record.id}" onchange="toggleRowSelection(this)" ${checked}></td>
        <td style="color:#6b7280;">${start + index + 1}</td>
        <td><div style="display:flex;align-items:center;gap:.7rem">
          <div class="row-avatar" style="background:${color}18;color:${color}; width:28px; height:28px; font-size:0.8rem;"><i class="bi bi-flag"></i></div>
          <span style="font-weight:600;color:#111827">${safeCountry}</span>
        </div></td>
        <td><span class="code-pill"><i class="bi bi-currency-exchange"></i>${safeCode}</span></td>
        <td><span class="exchange-pill">${safeType}</span></td>
        <td><span style="color:#8888bb;font-size:.82rem">${date}</span></td>
        <td style="text-align:right">
          <button class="btn btn-sm btn-light border me-1 rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="openEdit('${record.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil" style="font-size:0.8rem;color:#4b5563;"></i></button>
          <button class="btn btn-sm btn-light border rounded-circle p-1" style="width:26px;height:26px;line-height:1;" onclick="confirmDel('${record.id}', event)"><i class="bi bi-trash3" style="font-size:0.8rem;color:#ef4444;"></i></button>
        </td>
      </tr>`;
    }).join('');
    document.getElementById('listPag').innerHTML = pagHTML(page, pages, total, start, slice.length);
  }

  function renderCards(slice, start, total, pages) {
    const body = document.getElementById('cardsBody');
    if (!slice.length) {
      body.innerHTML = `<div class="tf-empty" style="grid-column:1/-1">${emptyInner()}</div>`;
      document.getElementById('cardsPag').innerHTML = '';
      return;
    }

    body.innerHTML = slice.map(record => {
      const color = COLORS[(record.id || 0) % COLORS.length];
      const country = escapeHtml(COUNTRY_MAP[String(record.country_id)] || '-');
      const code = escapeHtml(record.code);
      const exchangeType = escapeHtml(record.exchange_type);
      return `<div class="tf-card">
        <div style="display:flex;align-items:center;justify-content:space-between">
          <div class="tf-card-icon" style="background:${color}18;color:${color}"><i class="bi bi-currency-exchange"></i></div>
          <span class="tf-badge" style="background:rgba(14,165,233,.1);color:#0284c7">${code}</span>
        </div>
        <div class="tf-card-name">${country}</div>
        <div class="tf-card-meta">${exchangeType}</div>
        <div class="tf-card-actions">
          <button class="btn-icon btn-icon-edit" style="flex:1;justify-content:center" onclick="openEdit('${record.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil me-1"></i>Edit</button>
          <button class="btn-icon btn-icon-del" onclick="confirmDel('${record.id}')"><i class="bi bi-trash3"></i></button>
        </div>
      </div>`;
    }).join('');
    document.getElementById('cardsPag').innerHTML = pagHTML(page, pages, total, start, slice.length);
  }

  function pagHTML(current, pages, total, start, length) {
    const prev = `<button onclick="goPage(${current - 1})" ${current <= 1 ? 'disabled' : ''}><i class="bi bi-chevron-left"></i></button>`;
    const next = `<button onclick="goPage(${current + 1})" ${current >= pages ? 'disabled' : ''}><i class="bi bi-chevron-right"></i></button>`;
    let numbers = '';
    for (let i = 1; i <= pages; i++) {
      if (pages <= 6 || Math.abs(i - current) <= 1 || i === 1 || i === pages) numbers += `<button class="${i === current ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
      else if (Math.abs(i - current) === 2) numbers += `<button disabled style="border:0;background:none;color:#8888bb">...</button>`;
    }
    return `<div class="tf-page-info">Showing ${start + 1}-${start + length} of ${total}</div><div class="tf-pages">${prev}${numbers}${next}</div>`;
  }

  function emptyRow(cols) {
    return `<tr><td colspan="${cols}"><div class="tf-empty"><div class="tf-empty-icon"><i class="bi bi-currency-exchange"></i></div><p>No forex services found.</p></div></td></tr>`;
  }

  function emptyInner() {
    return `<div class="tf-empty-icon"><i class="bi bi-currency-exchange"></i></div><p>No forex services found.</p>`;
  }

  function goPage(nextPage) {
    page = nextPage;
    render();
  }

  function setView(nextView) {
    view = nextView;
    document.getElementById('listView').style.display = nextView === 'list' ? '' : 'none';
    document.getElementById('cardsView').style.display = nextView === 'cards' ? '' : 'none';
    document.getElementById('vList').classList.toggle('active', nextView === 'list');
    document.getElementById('vCards').classList.toggle('active', nextView === 'cards');
    render();
  }

  function openCreate() {
    document.getElementById('modalTitle').textContent = 'Add Forex Service';
    document.getElementById('fId').value = '';
    document.getElementById('fCountry').value = '';
    document.getElementById('fCode').value = '';
    document.getElementById('fExchangeType').value = '';
  }

  function openEdit(id) {
    const record = ALL.find(item => String(item.id) === String(id));
    if (!record) return;
    document.getElementById('modalTitle').textContent = 'Edit Forex Service';
    document.getElementById('fId').value = record.id;
    document.getElementById('fCountry').value = record.country_id;
    document.getElementById('fCode').value = record.code || '';
    document.getElementById('fExchangeType').value = record.exchange_type || '';
  }

  async function save() {
    const id = document.getElementById('fId').value;
    const country_id = document.getElementById('fCountry').value;
    const code = document.getElementById('fCode').value.trim().toUpperCase();
    const exchange_type = document.getElementById('fExchangeType').value.trim();
    if (!country_id || !code || !exchange_type) return alert('Country, code, and exchange type are required');

    const response = await fetch(id ? `/api/v1/forex-services/${id}` : '/api/v1/forex-services', {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ country_id, code, exchange_type })
    });
    const result = await response.json();
    if (result.success) location.reload();
    else alert(result.message || 'Error');
  }

  function confirmDel(id, event) {
    if (event) event.stopPropagation();
    const record = ALL.find(item => String(item.id) === String(id));
    delId = id;
    document.getElementById('delMsg').textContent = `"${record ? `${record.code} - ${record.exchange_type}` : 'This record'}" will be permanently removed.`;
    document.getElementById('delBtn').onclick = executeSingleDelete;
    new bootstrap.Modal(document.getElementById('delModal')).show();
  }

  async function executeSingleDelete() {
    const response = await fetch(`/api/v1/forex-services/${delId}`, { method: 'DELETE' });
    const result = await response.json();
    if (result.success) location.reload();
    else alert(result.message || 'Error');
  }

  function toggleSelectAll() {
    const mainCheckbox = document.getElementById('selectAllCheckbox');
    const rowCheckboxes = document.querySelectorAll('.row-checkbox');
    const checked = mainCheckbox.checked;
    rowCheckboxes.forEach(checkbox => {
      checkbox.checked = checked;
      const row = checkbox.closest('tr');
      if (checked) {
        row.classList.add('row-selected');
        selectedIds.add(checkbox.value);
      } else {
        row.classList.remove('row-selected');
        selectedIds.delete(checkbox.value);
      }
    });
    updateBulkActionBar();
  }

  function toggleRowSelection(checkbox) {
    const row = checkbox.closest('tr');
    if (checkbox.checked) {
      row.classList.add('row-selected');
      selectedIds.add(checkbox.value);
    } else {
      row.classList.remove('row-selected');
      selectedIds.delete(checkbox.value);
      document.getElementById('selectAllCheckbox').checked = false;
    }
    updateBulkActionBar();
  }

  function evaluateSelectionState() {
    const rowCheckboxes = document.querySelectorAll('.row-checkbox');
    if (!rowCheckboxes.length) {
      document.getElementById('selectAllCheckbox').checked = false;
      return;
    }
    document.getElementById('selectAllCheckbox').checked = Array.from(rowCheckboxes).every(checkbox => checkbox.checked);
  }

  function updateBulkActionBar() {
    const bar = document.getElementById('bulkActionsBar');
    const msg = document.getElementById('selectedCountMsg');
    if (selectedIds.size > 0) {
      bar.style.display = 'flex';
      msg.textContent = `${selectedIds.size} records selected`;
    } else {
      bar.style.display = 'none';
      document.getElementById('selectAllCheckbox').checked = false;
    }
  }

  function confirmBulkDelete() {
    document.getElementById('delMsg').textContent = `Are you sure you want to permanently delete the ${selectedIds.size} selected records?`;
    document.getElementById('delBtn').onclick = executeBulkDelete;
    new bootstrap.Modal(document.getElementById('delModal')).show();
  }

  async function executeBulkDelete() {
    const response = await fetch('/api/v1/forex-services/bulk-delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ ids: Array.from(selectedIds) })
    });
    const result = await response.json();
    if (result.success) location.reload();
    else alert(result.message || 'Error');
  }

  render();
  </script>
</div>
