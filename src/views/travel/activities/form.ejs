<%- contentFor('body') %>

<div class="content-header">
    <div class="container-fluid">
        <div class="row align-items-center mb-4 mt-2">
            <div class="col-sm-6">
                <h1 class="m-0 text-dark" style="font-weight: 800;"><%= title %></h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="/travel/activities" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <form action="/travel/activities/<%= activity ? activity.id : 'save' %>" method="POST">
                    
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Activity Name</label>
                            <input type="text" name="name" class="form-control" value="<%= activity ? activity.name : '' %>" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Destination</label>
                            <select name="destination_id" class="form-control select2" required>
                                <option value="">Select Destination...</option>
                                <% destinations.forEach(d => { %>
                                    <option value="<%= d.id %>" <%= activity && activity.destination_id == d.id ? 'selected' : '' %>><%= d.name %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Source Type</label>
                            <select name="source_type" id="source_type" class="form-control">
                                <option value="manual" <%= activity && activity.source_type === 'manual' ? 'selected' : '' %>>Manual</option>
                                <option value="third_party" <%= activity && activity.source_type === 'third_party' ? 'selected' : '' %>>3rd Party Provider</option>
                            </select>
                        </div>
                        <div class="col-md-8 form-group" id="provider_name_group" style="display: none;">
                            <label>Provider Name</label>
                            <input type="text" name="provider_name" class="form-control" value="<%= activity ? activity.provider_name : '' %>" placeholder="e.g. Viator, GetYourGuide, Klook...">
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Duration (Minutes)</label>
                            <input type="number" name="duration_minutes" class="form-control" value="<%= activity ? activity.duration_minutes : '' %>">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Price (₹)</label>
                            <input type="number" step="0.01" name="price" class="form-control" value="<%= activity ? activity.price : '' %>" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Description</label>
                        <textarea name="description" class="form-control" rows="4"><%= activity ? activity.description : '' %></textarea>
                    </div>

                    <button type="submit" class="btn btn-success mt-3"><i class="fas fa-save mr-2"></i> Save Activity</button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    function toggleProviderField() {
        if ($('#source_type').val() === 'third_party') {
            $('#provider_name_group').show();
        } else {
            $('#provider_name_group').hide();
        }
    }
    
    $(function() {
        $('#source_type').on('change', toggleProviderField);
        toggleProviderField(); // Init
        $('.select2').select2({ theme: 'bootstrap4' });
    });
</script>
