<%
const _mappings = JSON.stringify(mappings).replace(/</g, '\\u003c');
const _destinations = JSON.stringify(destinations).replace(/</g, '\\u003c');
const _continents = JSON.stringify(continents).replace(/</g, '\\u003c');
const _countries = JSON.stringify(countries).replace(/</g, '\\u003c');
const _cities = JSON.stringify(cities).replace(/</g, '\\u003c');
%>

  <!-- HEADER -->
  <div class="tf-page-header">
    <div>
      <p class="tf-page-title"><i class="bi bi-diagram-3 me-2" style="color:#8b5cf6"></i>Destination Mapping</p>
      <p class="tf-page-sub">Connect destinations to their geographic locations</p>
    </div>
    <button class="btn-add-primary"
      style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);box-shadow:0 4px 14px rgba(139,92,246,0.3)"
      data-bs-toggle="modal" data-bs-target="#modal" onclick="openCreate()">
      <i class="bi bi-plus-lg"></i> Add Mapping
    </button>
  </div>

  <!-- STATS -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="tf-stat-card" style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);color:#fff">
        <div class="tf-stat-icon"><i class="bi bi-diagram-3"></i></div>
        <div>
          <div class="tf-stat-num" id="statTotal">
            <%= mappings.length %>
          </div>
          <div class="tf-stat-lbl">Total Mappings</div>
        </div>
      </div>
    </div>
  </div>

  <!-- TOOLBAR -->
  <div class="tf-toolbar">
    <div class="tf-search">
      <i class="bi bi-search tf-si"></i>
      <input type="text" id="searchInput" placeholder="Search destination…" oninput="applyFilters()">
    </div>
    <div class="ms-auto d-flex gap-2 align-items-center">
      <span class="tf-page-info" id="countLabel"></span>
      <button class="view-btn active" id="vList" onclick="setView('list')" title="List"><i
          class="bi bi-list-ul"></i></button>
      <button class="view-btn" id="vCards" onclick="setView('cards')" title="Cards"><i
          class="bi bi-grid-3x3-gap"></i></button>
    </div>
  </div>

  <!-- LIST VIEW -->
  <div id="listView">
    <div class="tf-table-wrap">
      <table class="tf-table">
        <thead>
          <tr>
            <th style="width:48px">#</th>
            <th>Destination</th>
            <th>Continent</th>
            <th>Country</th>
            <th>City / Region</th>
            <th style="width:100px;text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="listBody"></tbody>
      </table>
      <div class="tf-pagination" id="listPag"></div>
    </div>
  </div>

  <!-- CARDS VIEW -->
  <div id="cardsView" style="display:none">
    <div class="tf-cards" id="cardsBody"></div>
    <div class="tf-pagination mt-3"
      style="border-radius:16px;background:#fff;box-shadow:0 4px 16px rgba(139,92,246,.07)" id="cardsPag"></div>
  </div>

  <!-- MODAL -->
  <div class="modal fade tf-modal" id="modal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header" style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);color:#fff">
          <h5 class="modal-title fw-bold" id="modalTitle">Add Mapping</h5>
          <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="fId">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Destination <span class="text-danger">*</span></label>
              <select class="form-select" id="fDest">
                <option value="">Select Destination</option>
                <% destinations.forEach(d=> { %><option value="<%= d.id %>">
                    <%= d.name %>
                  </option>
                  <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Mapping Position <small class="text-muted">(City/Region)</small> <span class="text-danger">*</span></label>
              <div class="position-relative">
                <input type="text" class="form-control" id="citySearch" placeholder="Search city or position..." autocomplete="off">
                <input type="hidden" id="fCity">
                <div id="cityResults" class="list-group position-absolute w-100 mt-1 shadow-lg" style="z-index: 2000; max-height: 250px; overflow-y: auto; display: none;"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
          <button class="btn-add-primary"
            style="background:linear-gradient(135deg,#8b5cf6,#a78bfa);box-shadow:0 4px 14px rgba(139,92,246,0.3)"
            onclick="save()"><i class="bi bi-check2 me-1"></i>Save</button>
        </div>
      </div>
    </div>
  </div>

  <!-- DELETE MODAL -->
  <div class="modal fade tf-modal" id="delModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:380px">
      <div class="modal-content">
        <div class="modal-body text-center p-4">
          <div
            style="width:60px;height:60px;background:#fef2f2;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.7rem;color:#ef4444">
            <i class="bi bi-trash3"></i>
          </div>
          <h5 class="fw-bold mb-1">Delete Mapping?</h5>
          <p class="text-muted" id="delMsg" style="font-size:.88rem"></p>
          <div class="d-flex gap-2 justify-content-center mt-3">
            <button class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Cancel</button>
            <button class="btn btn-danger px-4 rounded-3 fw-semibold" id="delBtn">Yes, Delete</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const ALL = <%- _mappings %>;
    const PS = 10;
    let view = 'list', page = 1, filtered = [...ALL], delId = null;

    function applyFilters() {
      const q = document.getElementById('searchInput').value.toLowerCase();
      filtered = ALL.filter(m => {
        const dName = m.destination?.name?.toLowerCase() || '';
        return dName.includes(q);
      });
      page = 1; render();
    }

    function render() {
      const tot = filtered.length, pages = Math.max(1, Math.ceil(tot / PS));
      page = Math.min(page, pages);
      const s = (page - 1) * PS, slice = filtered.slice(s, s + PS);
      document.getElementById('countLabel').textContent = `${tot} result${tot !== 1 ? 's' : ''}`;
      if (view === 'list') renderList(slice, s, tot, pages);
      else renderCards(slice, s, tot, pages);
    }

    function renderList(slice, s, tot, pages) {
      const body = document.getElementById('listBody');
      if (!slice.length) { body.innerHTML = emptyRow(6); document.getElementById('listPag').innerHTML = ''; return; }
      body.innerHTML = slice.map((m, i) => `<tr>
    <td><span style="color:#8888bb;font-size:0.82rem">${s + i + 1}</span></td>
    <td><span style="font-weight:700;color:#1e1e4a">${m.destination?.name || '—'}</span></td>
    <td>${m.city?.country?.continent?.name || '<span class="text-muted small">Not set</span>'}</td>
    <td>${m.city?.country?.name || '<span class="text-muted small">Not set</span>'}</td>
    <td>${m.city?.name || '<span class="text-muted small">Not set</span>'}</td>
    <td style="text-align:right">
      <button class="btn-icon btn-icon-edit me-1" onclick="openEdit('${m.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil"></i></button>
      <button class="btn-icon btn-icon-del" onclick="confirmDel('${m.id}')"><i class="bi bi-trash3"></i></button>
    </td>
  </tr>`).join('');
      document.getElementById('listPag').innerHTML = pagHTML(page, pages, tot, s, slice.length);
    }

    function renderCards(slice, s, tot, pages) {
      const body = document.getElementById('cardsBody');
      if (!slice.length) { body.innerHTML = `<div class="tf-empty" style="grid-column:1/-1">${emptyInner()}</div>`; document.getElementById('cardsPag').innerHTML = ''; return; }
      body.innerHTML = slice.map(m => `<div class="tf-card">
    <div class="tf-card-icon" style="background:rgba(139,92,246,0.1);color:#8b5cf6"><i class="bi bi-diagram-3"></i></div>
    <div class="tf-card-name">${m.destination?.name || '—'}</div>
    <div class="tf-card-meta">
      <div class="mb-1"><i class="bi bi-globe me-1"></i>${m.city?.country?.continent?.name || '—'}</div>
      <div class="mb-1"><i class="bi bi-flag me-1"></i>${m.city?.country?.name || '—'}</div>
      <div><i class="bi bi-buildings me-1"></i>${m.city?.name || '—'}</div>
    </div>
    <div class="tf-card-actions mt-auto">
      <button class="btn-icon btn-icon-edit" style="flex:1;justify-content:center" onclick="openEdit('${m.id}')" data-bs-toggle="modal" data-bs-target="#modal"><i class="bi bi-pencil me-1"></i>Edit</button>
      <button class="btn-icon btn-icon-del" onclick="confirmDel('${m.id}')"><i class="bi bi-trash3"></i></button>
    </div>
  </div>`).join('');
      document.getElementById('cardsPag').innerHTML = pagHTML(page, pages, tot, s, slice.length);
    }

    function pagHTML(p, pages, tot, s, len) {
      const prev = `<button onclick="goPage(${p - 1})" ${p <= 1 ? 'disabled' : ''}><i class="bi bi-chevron-left"></i></button>`;
      const next = `<button onclick="goPage(${p + 1})" ${p >= pages ? 'disabled' : ''}><i class="bi bi-chevron-right"></i></button>`;
      let nums = '';
      for (let i = 1; i <= pages; i++) {
        if (pages <= 6 || Math.abs(i - p) <= 1 || i === 1 || i === pages) nums += `<button class="${i === p ? 'active' : ''}" onclick="goPage(${i})">${i}</button>`;
        else if (Math.abs(i - p) === 2) nums += `<button disabled style="border:0;background:none;color:#8888bb">…</button>`;
      }
      return `<div class="tf-page-info">Showing ${s + 1}–${s + len} of ${tot}</div><div class="tf-pages">${prev}${nums}${next}</div>`;
    }
    function emptyRow(cols) { return `<tr><td colspan="${cols}"><div class="tf-empty"><div class="tf-empty-icon"><i class="bi bi-diagram-3"></i></div><p>No mappings found.</p></div></td></tr>`; }
    function emptyInner() { return `<div class="tf-empty-icon"><i class="bi bi-diagram-3"></i></div><p>No mappings found.</p>`; }
    function goPage(p) { page = p; render(); }
    function setView(v) {
      view = v;
      document.getElementById('listView').style.display = v === 'list' ? '' : 'none';
      document.getElementById('cardsView').style.display = v === 'cards' ? '' : 'none';
      document.getElementById('vList').classList.toggle('active', v === 'list');
      document.getElementById('vCards').classList.toggle('active', v === 'cards');
      render();
    }

    // Simplified Cascading Logic removed as continent/country selectors are gone.

    // --- ASYNC CITY SEARCH ---
    const citySearch = document.getElementById('citySearch');
    const cityResults = document.getElementById('cityResults');
    const fCity = document.getElementById('fCity');
    let searchTimer;

    citySearch.addEventListener('input', () => {
      clearTimeout(searchTimer);
      const q = citySearch.value.trim();
      if (q.length < 2) { cityResults.style.display = 'none'; return; }
      
      searchTimer = setTimeout(async () => {
        try {
          const res = await fetch(`/travel/api/v1/cities/paginated?page=1&limit=15&search=${encodeURIComponent(q)}`);
          const { success, data } = await res.json();
          if (success && data.rows.length) {
            cityResults.innerHTML = data.rows.map(c => `
              <button type="button" class="list-group-item list-group-item-action py-2" onclick="selectCity('${c.id}', '${c.name.replace(/'/g, "\\'")}', '${c.country?.name || ''}')">
                <div class="fw-bold" style="font-size:0.88rem">${c.name}</div>
                <div class="text-muted small">${c.country?.name || ''} ${c.country?.continent?.name ? '• ' + c.country.continent.name : ''}</div>
              </button>
            `).join('');
            cityResults.style.display = 'block';
          } else {
            cityResults.style.display = 'none';
          }
        } catch (err) { console.error(err); }
      }, 300);
    });

    function selectCity(id, name, country) {
      fCity.value = id;
      citySearch.value = name + (country ? `, ${country}` : '');
      cityResults.style.display = 'none';
    }

    // Close results on click outside
    document.addEventListener('click', (e) => {
      if (!citySearch.contains(e.target) && !cityResults.contains(e.target)) cityResults.style.display = 'none';
    });

    function openCreate() {
      document.getElementById('modalTitle').textContent = 'Add Mapping';
      document.getElementById('fId').value = ''; 
      document.getElementById('fDest').value = '';
      document.getElementById('fCity').value = '';
      document.getElementById('citySearch').value = '';
    }
    
    function openEdit(id) {
      const m = ALL.find(x => x.id == id);
      if (!m) return;
      document.getElementById('modalTitle').textContent = 'Edit Mapping';
      document.getElementById('fId').value = m.id;
      document.getElementById('fDest').value = m.destination_id || '';
      document.getElementById('fCity').value = m.city_id || '';
      
      // Fetch city name for the display
      if (m.city) {
        citySearch.value = m.city.name + (m.city.country ? `, ${m.city.country.name}` : '');
      } else {
        citySearch.value = 'Select City...';
      }
    }
    async function save() {
      const id = document.getElementById('fId').value, destination_id = document.getElementById('fDest').value;
      const city_id = document.getElementById('fCity').value || null;
      if (!destination_id || !city_id) return alert('Destination and City/Region are required');
      const res = await fetch('/travel/mappings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ destination_id, city_id, _id: id || undefined }) });
      location.reload();
    }
    function confirmDel(id) { delId = id; document.getElementById('delMsg').textContent = `This mapping will be permanently removed.`; new bootstrap.Modal(document.getElementById('delModal')).show(); }
    document.getElementById('delBtn').addEventListener('click', async () => {
      await fetch(`/travel/mappings/${delId}`, { method: 'DELETE' }); location.reload();
    });
    render();
  </script>