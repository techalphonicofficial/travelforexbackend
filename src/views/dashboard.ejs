<%
  const dash = locals.dashboardStats || {};
  const vendorRequests = Array.isArray(locals.recentVendorRequests) ? locals.recentVendorRequests : [];
  const packageBookings = Array.isArray(locals.recentPackageBookings) ? locals.recentPackageBookings : [];
  const packageReturnRequests = Array.isArray(locals.recentPackageReturnRequests) ? locals.recentPackageReturnRequests : [];
  const forexRequests = Array.isArray(locals.recentForexConversionRequests) ? locals.recentForexConversionRequests : [];
  const newsletters = Array.isArray(locals.recentNewsletters) ? locals.recentNewsletters : [];
  const inr = (value) => Number(value || 0).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  const fxMoney = (value, code) => {
    const amount = Number(value || 0);
    const currency = String(code || 'INR').toUpperCase();
    try {
      return amount.toLocaleString('en-IN', { style: 'currency', currency, minimumFractionDigits: 2, maximumFractionDigits: 2 });
    } catch (err) {
      return `${currency} ${amount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }
  };
  const fxCustomerLabel = (request) => {
    const customer = request && request.customer ? request.customer : {};
    const user = customer.user || {};
    return user.name || user.email || request.customer_id || 'Customer';
  };
  const vendorOwnerLabel = (request) => {
    const owner = request && request.user ? request.user : {};
    return owner.name || request.legal_name || request.business_name || 'Vendor';
  };
  const compactInr = (value) => {
    const amount = Number(value || 0);
    if (amount >= 10000000) return `₹${(amount / 10000000).toFixed(1)}Cr`;
    if (amount >= 100000) return `₹${(amount / 100000).toFixed(1)}L`;
    if (amount >= 1000) return `₹${(amount / 1000).toFixed(1)}k`;
    return `₹${amount.toFixed(0)}`;
  };
  const forexInrRate = (value) => {
    const amount = Number(value || 0);
    if (!amount) return 'N/A';
    return `₹${amount.toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
  };
  const dashboardDate = (value) => {
    if (!value) return '';
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? '' : date.toLocaleDateString('en-IN');
  };
  const roundMoney = (value) => {
    const amount = Number(value || 0);
    return Number.isFinite(amount) ? Math.round(amount * 100) / 100 : 0;
  };
  const clampPercent = (value) => Math.min(Math.max(roundMoney(value), 0), 100);
  const returnRequestPercent = (rule = {}) => {
    if (rule.return_percentage !== undefined) return clampPercent(rule.return_percentage);
    if (rule.refundable_percentage !== undefined) return clampPercent(rule.refundable_percentage);
    const refundPercent = clampPercent(rule.refund_percentage);
    return refundPercent > 0 ? refundPercent : clampPercent(rule.cancellation_percentage);
  };
  const returnRequestAmount = (request) => {
    const rule = request.cancellation_rule_snapshot || {};
    const booking = request.booking || {};
    const hasRule = rule.return_percentage !== undefined
      || rule.refundable_percentage !== undefined
      || rule.refund_percentage !== undefined
      || rule.cancellation_percentage !== undefined;
    if (request.status === 'pending' && hasRule) {
      const refund = roundMoney(roundMoney(booking.paid_amount) * returnRequestPercent(rule) / 100);
      return roundMoney(refund + roundMoney(booking.remaining_amount));
    }
    const refund = roundMoney(request.requested_refund_amount);
    const cancelRemaining = roundMoney(request.requested_cancel_remaining_amount);
    return roundMoney(refund + cancelRemaining);
  };
%>

