<script>
(function () {
  /* ── Animated Counters ── */
  document.querySelectorAll('.db-stat-val[data-target]').forEach(el => {
    const target = parseInt(el.dataset.target);
    let cur = 0;
    const step = Math.ceil(target / 40);
    const timer = setInterval(() => {
      cur = Math.min(cur + step, target);
      el.textContent = cur;
      if (cur >= target) clearInterval(timer);
    }, 30);
  });

  /* ── Spark Lines (mini) ── */
  const sparkOpts = (color) => ({
    type: 'line',
    data: {
      labels: ['','','','','','',''],
      datasets: [{
        data: Array.from({length:7}, () => Math.floor(Math.random()*60+20)),
        borderColor: color,
        borderWidth: 2,
        fill: false,
        tension: 0.4,
        pointRadius: 0,
      }]
    },
    options: {
      plugins: { legend: { display: false }, tooltip: { enabled: false } },
      scales: { x: { display: false }, y: { display: false } },
      animation: false,
      responsive: true,
      maintainAspectRatio: false,
    }
  });

  new Chart(document.getElementById('spark1'), sparkOpts('#6366f1'));
  new Chart(document.getElementById('spark2'), sparkOpts('#10b981'));
  new Chart(document.getElementById('spark3'), sparkOpts('#f59e0b'));
  new Chart(document.getElementById('spark4'), sparkOpts('#ec4899'));
  new Chart(document.getElementById('spark5'), sparkOpts('#06b6d4'));
  new Chart(document.getElementById('spark6'), sparkOpts('#14b8a6'));
  new Chart(document.getElementById('spark7'), sparkOpts('#8b5cf6'));
  new Chart(document.getElementById('spark8'), sparkOpts('#0f766e'));
  new Chart(document.getElementById('spark9'), sparkOpts('#ef4444'));

  /* ── Revenue Chart ── */
  const revenueCtx = document.getElementById('revenueChart').getContext('2d');
  const revenueGrad = revenueCtx.createLinearGradient(0, 0, 0, 230);
  revenueGrad.addColorStop(0, 'rgba(79,70,229,0.25)');
  revenueGrad.addColorStop(1, 'rgba(79,70,229,0)');

  const bookingGrad = revenueCtx.createLinearGradient(0, 0, 0, 230);
  bookingGrad.addColorStop(0, 'rgba(16,185,129,0.2)');
  bookingGrad.addColorStop(1, 'rgba(16,185,129,0)');

  const labels7d = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
  const revenueData7d = [2800, 3200, 2900, 4100, 3800, 5200, 4600];
  const bookingData7d = [8, 12, 9, 15, 11, 19, 14];

  window.revenueChart = new Chart(revenueCtx, {
    data: {
      labels: labels7d,
      datasets: [
        {
          type: 'line',
          label: 'Revenue ($)',
          data: revenueData7d,
          borderColor: '#4f46e5',
          backgroundColor: revenueGrad,
          borderWidth: 2.5,
          fill: true,
          tension: 0.45,
          pointBackgroundColor: '#4f46e5',
          pointRadius: 4,
          pointHoverRadius: 7,
          yAxisID: 'y',
        },
        {
          type: 'bar',
          label: 'Bookings',
          data: bookingData7d,
          backgroundColor: 'rgba(16,185,129,0.18)',
          borderColor: '#10b981',
          borderWidth: 1.5,
          borderRadius: 6,
          yAxisID: 'y1',
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: {
          position: 'top',
          align: 'end',
          labels: { boxWidth: 12, font: { size: 11 }, color: '#555577' }
        },
        tooltip: {
          backgroundColor: '#1e1b4b',
          titleColor: '#a5b4fc',
          bodyColor: '#e0e7ff',
          padding: 12,
          cornerRadius: 10,
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#8888bb', font: { size: 11 } } },
        y: {
          position: 'left',
          grid: { color: 'rgba(79,70,229,0.06)' },
          ticks: { color: '#8888bb', font: { size: 11 }, callback: v => '$'+v },
        },
        y1: {
          position: 'right',
          grid: { display: false },
          ticks: { color: '#10b981', font: { size: 11 } },
        }
      }
    }
  });

  /* ── Lead Donut Chart ── */
  new Chart(document.getElementById('leadDonutChart'), {
    type: 'doughnut',
    data: {
      labels: ['Organic', 'Referral', 'Social', 'Direct'],
      datasets: [{
        data: [38, 27, 21, 14],
        backgroundColor: ['#4f46e5', '#10b981', '#f59e0b', '#ec4899'],
        borderWidth: 0,
        hoverOffset: 8,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      cutout: '68%',
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1e1b4b',
          titleColor: '#a5b4fc',
          bodyColor: '#e0e7ff',
          padding: 10,
          cornerRadius: 8,
        }
      }
    }
  });

  /* ── Forex Bar Chart ── */
  new Chart(document.getElementById('forexBarChart'), {
    type: 'bar',
    data: {
      labels: ['USD/INR', 'EUR/INR', 'GBP/INR', 'AED/INR', 'AUD/INR', 'SGD/INR'],
      datasets: [{
        label: 'Volume ($)',
        data: [1800, 1200, 980, 650, 420, 350],
        backgroundColor: [
          'rgba(79,70,229,0.75)', 'rgba(16,185,129,0.75)', 'rgba(245,158,11,0.75)',
          'rgba(236,72,153,0.75)', 'rgba(59,130,246,0.75)', 'rgba(139,92,246,0.75)'
        ],
        borderRadius: 8,
        borderWidth: 0,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1e1b4b',
          titleColor: '#a5b4fc',
          bodyColor: '#e0e7ff',
          padding: 10,
          cornerRadius: 8,
          callbacks: { label: ctx => ' $' + ctx.parsed.y }
        }
      },
      scales: {
        x: { grid: { display: false }, ticks: { color: '#8888bb', font: { size: 10 } } },
        y: {
          grid: { color: 'rgba(79,70,229,0.06)' },
          ticks: { color: '#8888bb', font: { size: 11 }, callback: v => '$'+v }
        }
      }
    }
  });

  /* ── Top Destinations Horizontal Bar ── */
  new Chart(document.getElementById('destinationChart'), {
    type: 'bar',
    data: {
      labels: ['Bali', 'Maldives', 'Dubai', 'Paris', 'Thailand', 'Singapore'],
      datasets: [{
        label: 'Bookings',
        data: [22, 18, 15, 12, 10, 8],
        backgroundColor: 'rgba(79,70,229,0.12)',
        borderColor: '#4f46e5',
        borderWidth: 2,
        borderRadius: 8,
        borderSkipped: false,
      }]
    },
    options: {
      indexAxis: 'y',
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1e1b4b',
          titleColor: '#a5b4fc',
          bodyColor: '#e0e7ff',
          padding: 10,
          cornerRadius: 8,
        }
      },
      scales: {
        x: {
          grid: { color: 'rgba(79,70,229,0.06)' },
          ticks: { color: '#8888bb', font: { size: 11 } }
        },
        y: { grid: { display: false }, ticks: { color: '#555577', font: { size: 12, weight: '600' } } }
      }
    }
  });

  /* ── Period Switcher ── */
  window.switchPeriod = function(btn, period) {
    document.querySelectorAll('.db-panel-pill').forEach(b => {
      b.style.background = '#f0f0fa'; b.style.color = '#8888bb';
    });
    btn.style.background = '#4f46e5'; btn.style.color = '#fff';

    const datasets = {
      '7d': { labels: ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'], rev: [2800,3200,2900,4100,3800,5200,4600], bk: [8,12,9,15,11,19,14] },
      '30d': { labels: ['W1','W2','W3','W4'], rev: [12000,16500,14200,18700], bk: [38,52,44,62] },
      '90d': { labels: ['Jan','Feb','Mar'], rev: [45000,52000,61000], bk: [142,168,195] },
    };
    const d = datasets[period];
    window.revenueChart.data.labels = d.labels;
    window.revenueChart.data.datasets[0].data = d.rev;
    window.revenueChart.data.datasets[1].data = d.bk;
    window.revenueChart.update();
  };

})();
</script>
