<div class="mb-4">
    <h2 class="fw-bold mb-1">Change Password: <span class="text-primary"><%= user.name %></span></h2>
    <p class="text-secondary small mb-0">Reset or update the security credentials for this user account.</p>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm border-0 mb-4 p-4">
            <form action="/users/change-password/<%= user.id %>" method="POST" id="changePasswordForm">
                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold text-secondary small">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-secondary-subtle px-3"><i class="bi bi-lock"></i></span>
                        <input type="password" class="form-control p-2 shadow-none border-secondary-subtle" id="password" name="password" placeholder="Min. 8 characters" required minlength="8">
                    </div>
                </div>

                <div class="mb-4">
                    <label for="confirm_password" class="form-label fw-semibold text-secondary small">Confirm New Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-secondary-subtle px-3"><i class="bi bi-shield-check"></i></span>
                        <input type="password" class="form-control p-2 shadow-none border-secondary-subtle" id="confirm_password" name="confirm_password" placeholder="Repeat new password" required minlength="8">
                    </div>
                    <div class="invalid-feedback" id="matchError">
                        Passwords do not match.
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 pt-3 mt-3 border-top">
                    <a href="/users" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4 fw-bold">Update Password</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-12 col-lg-5 ms-lg-auto">
        <div class="card border-0 bg-primary bg-opacity-10 p-4 rounded-4 h-100">
            <h5 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-2"></i> Security Guidelines</h5>
            <ul class="list-unstyled mb-0 small text-secondary-emphasis">
                <li class="mb-2 d-flex align-items-start"><i class="bi bi-check2-circle text-primary me-2 mt-1"></i> Use a mix of uppercase, numbers, and symbols.</li>
                <li class="mb-2 d-flex align-items-start"><i class="bi bi-check2-circle text-primary me-2 mt-1"></i> Minimum length of 8 characters highly recommended.</li>
                <li class="mb-2 d-flex align-items-start"><i class="bi bi-check2-circle text-primary me-2 mt-1"></i> Avoid using common words or names.</li>
                <li class="d-flex align-items-start"><i class="bi bi-check2-circle text-primary me-2 mt-1"></i> Ensure the user receives their new credentials securely.</li>
            </ul>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById('changePasswordForm');
    const pass = document.getElementById('password');
    const confirmPass = document.getElementById('confirm_password');
    const error = document.getElementById('matchError');

    form.addEventListener('submit', (e) => {
        if (pass.value !== confirmPass.value) {
            e.preventDefault();
            confirmPass.classList.add('is-invalid');
            error.style.display = 'block';
        }
    });

    confirmPass.addEventListener('input', () => {
        if (confirmPass.classList.contains('is-invalid')) {
            confirmPass.classList.remove('is-invalid');
            error.style.display = 'none';
        }
    });
</script>
