<!-- HERO / PAGE HEADER -->
<% if (page.feature_image) { %>
<header class="py-5 position-relative overflow-hidden" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('<%= page.feature_image %>') center/cover no-repeat; min-height: 400px; display: flex; align-items: center;">
    <div class="container text-white text-center">
        <h1 class="display-3 fw-bold mb-3"><%= page.title %></h1>
        <p class="lead opacity-75 mx-auto" style="max-width: 700px;"><%= page.description %></p>
    </div>
</header>
<% } else { %>
<header class="py-5 bg-indigo-light">
    <div class="container text-center pt-5">
        <h1 class="display-4 fw-bold text-indigo"><%= page.title %></h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;"><%= page.description %></p>
    </div>
</header>
<% } %>

<% if (page.details && page.details.length > 0) { %>
    <% page.details.forEach(section => { 
        let content = {};
        try {
            content = typeof section.json_data === 'string'
                ? JSON.parse(section.json_data || '{}')
                : (section.json_data || {});
        } catch(e) {}
    %>
        
        <!-- SECTION TYPE: STANDARD -->
        <% if (section.section === 'standard') { %>
            <section class="py-5">
                <div class="container">
                    <% if (section.title) { %><h2 class="text-center mb-4"><%= section.title %></h2><% } %>
                    <div class="prose mx-auto" style="max-width: 800px;">
                        <%- section.description %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: IMAGE + TEXT -->
        <% if (section.section === 'image_text') { %>
            <section class="py-5">
                <div class="container">
                    <div class="row align-items-center g-5 <%= content.side === 'left' ? 'flex-row-reverse' : '' %>">
                        <div class="col-lg-6 text-center">
                            <% if (section.title) { %><h2 class="mb-4 text-center"><%= section.title %></h2><% } %>
                            <div class="text-muted text-center"><%- content.body %></div>
                        </div>
                        <div class="col-lg-6 text-center">
                            <% const isVideo = content.media_url && content.media_url.match(/\.(mp4|webm|ogg|mov|avi)$/i); %>
                            <% if (isVideo) { %>
                                <video src="<%= content.media_url %>" class="img-fluid rounded-4 shadow-lg w-100" controls autoplay muted loop></video>
                            <% } else { %>
                                <img src="<%= content.media_url %>" class="img-fluid rounded-4 shadow-lg" alt="<%= section.title %>">
                            <% } %>
                        </div>

                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: RICH TEXT -->
        <% if (section.section === 'rich_text') { %>
            <section class="py-5">
                <div class="container">
                    <div class="prose mx-auto">
                        <%- content.body %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: CTA BANNER -->
        <% if (section.section === 'cta_banner') { %>
            <section class="py-5">
                <div class="container text-center bg-indigo-light p-5 rounded-5 shadow-sm">
                    <h2 class="display-6 fw-bold mb-4"><%= section.title || content.title %></h2>
                    <a href="<%= content.btn_link %>" class="btn btn-primary btn-lg rounded-pill px-5 shadow"><%= content.btn_text %></a>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: STATS BAR -->
        <% if (section.section === 'stats_bar') { %>
            <section class="py-5 bg-dark text-white">
                <div class="container">
                    <div class="row text-center g-4">
                        <% if (content.stats) { content.stats.forEach(stat => { %>
                            <div class="col-md-3">
                                <div class="display-4 fw-bold text-indigo"><%= stat.value %></div>
                                <div class="text-muted text-uppercase small ls-wide"><%= stat.label %></div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: FAQ ACCORDION -->
        <% if (section.section === 'faq_accordion') { %>
            <section class="py-5">
                <div class="container">
                    <h2 class="text-center mb-5"><%= section.title || "Frequently Asked Questions" %></h2>
                    <div class="accordion accordion-flush mx-auto" style="max-width: 800px;" id="faqAcc-<%= section.id %>">
                        <% if (content.faqs) { content.faqs.forEach((faq, i) => { %>
                            <div class="accordion-item mb-3 border rounded-3 overflow-hidden">
                                <h2 class="accordion-header">
                                    <button class="accordion-button <%= i === 0 ? '' : 'collapsed' %> fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#faq-<%= section.id %>-<%= i %>">
                                        <%= faq.q %>
                                    </button>
                                </h2>
                                <div id="faq-<%= section.id %>-<%= i %>" class="accordion-collapse collapse <%= i === 0 ? 'show' : '' %>" data-bs-parent="#faqAcc-<%= section.id %>">
                                    <div class="accordion-body text-muted">
                                        <%= faq.a %>
                                    </div>
                                </div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: TIMELINE -->
        <% if (section.section === 'timeline') { %>
            <section class="py-5 bg-light">
                <div class="container">
                    <h2 class="text-center mb-5"><%= section.title || content.headline %></h2>
                    <div class="timeline mx-auto" style="max-width: 800px;">
                        <% if (content.items) { content.items.forEach(item => { %>
                            <div class="d-flex gap-4 mb-4">
                                <div class="fw-bold text-indigo fs-4" style="min-width: 80px;"><%= item.year %></div>
                                <div class="border-start ps-4 position-relative">
                                    <div class="position-absolute rounded-circle bg-indigo shadow-sm" style="width: 12px; height: 12px; left: -7px; top: 10px;"></div>
                                    <h4 class="fw-bold"><%= item.title %></h4>
                                    <p class="text-muted"><%= item.desc %></p>
                                </div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: FEATURE GRID -->
        <% if (section.section === 'feature_grid') { %>
            <section class="py-5">
                <div class="container">
                    <h2 class="text-center mb-5"><%= section.title || content.headline %></h2>
                    <div class="row g-4">
                        <% if (content.features) { content.features.forEach(feature => { %>
                            <div class="col-md-4">
                                <div class="p-4 rounded-4 h-100 transition-up shadow-sm border">
                                    <div class="mb-3 text-indigo fs-2"><i class="bi <%= feature.icon %>"></i></div>
                                    <h4 class="fw-bold"><%= feature.title %></h4>
                                    <p class="text-muted mb-0"><%= feature.desc %></p>
                                </div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: TESTIMONIAL GRID -->
        <% if (section.section === 'testimonial_grid') { %>
            <section class="py-5 bg-indigo-light">
                <div class="container">
                    <h2 class="text-center mb-5"><%= section.title || "What Our Clients Say" %></h2>
                    <div class="row g-4">
                        <% if (content.testimonials) { content.testimonials.forEach(testi => { %>
                            <div class="col-md-4">
                                <div class="p-4 bg-white rounded-4 h-100 shadow-sm">
                                    <div class="mb-3 text-warning">
                                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                                    </div>
                                    <h5 class="fw-bold italic mb-3"><%= testi.title %></h5>
                                    <p class="text-muted mb-4">"<%= testi.text %>"</p>
                                    <div class="fw-bold text-indigo">— <%= testi.name %></div>
                                </div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: GALLERY -->
        <% if (section.section === 'gallery') { %>
            <section class="py-5">
                <div class="container">
                    <h2 class="text-center mb-5"><%= section.title || "Gallery" %></h2>
                    <div class="row g-3">
                        <% if (content.images) { content.images.forEach(img => { %>
                            <div class="col-6 col-md-4 col-lg-3">
                                <div class="position-relative overflow-hidden rounded-3 shadow-sm group" style="aspect-ratio: 1/1;">
                                    <img src="<%= img.img %>" class="w-100 h-100 object-fit-cover transition-transform duration-500 group-hover-scale-110" alt="<%= img.lbl %>">
                                    <div class="position-absolute bottom-0 start-0 end-0 p-3 bg-gradient-to-t from-black/70 to-transparent text-white opacity-0 group-hover-opacity-100 transition-opacity">
                                        <small><%= img.lbl %></small>
                                    </div>
                                </div>
                            </div>
                        <% })} %>
                    </div>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: DESTINATION TABS -->
        <% if (section.section === 'destination_tabs') { %>
            <section class="py-5 destination-tabs-section" id="destination-tabs-<%= section.id %>">
                <div class="container">
                    <% if (section.title) { %><h2 class="text-center fw-bold mb-2"><%= section.title %></h2><% } %>
                    <% if (content.heading_content) { %><p class="text-center fs-5 mb-2"><%= content.heading_content %></p><% } %>
                    <% if (content.description) { %><p class="text-center text-muted mb-4"><%= content.description %></p><% } %>

                    <div class="destination-tab-buttons d-flex justify-content-center flex-wrap gap-2 mb-5" role="tablist">
                        <% (content.tabs || []).forEach((tab, tabIndex) => { %>
                            <button type="button" class="destination-tab-btn <%= tabIndex === 0 ? 'active' : '' %>"
                                data-tab-index="<%= tabIndex %>" role="tab"><%= tab.label || tab.title || tab.key %></button>
                        <% }) %>
                    </div>

                    <% (content.tabs || []).forEach((tab, tabIndex) => { %>
                        <div class="destination-tab-panel <%= tabIndex === 0 ? 'active' : '' %>"
                            data-tab-panel="<%= tabIndex %>" role="tabpanel">
                            <div class="destination-card-grid">
                                <% (tab.destinations || tab.items || []).forEach(destination => { %>
                                    <article class="destination-page-card">
                                        <div class="destination-card-media">
                                            <img src="<%= destination.image || destination.img || '/assets/img/placeholder.png' %>"
                                                alt="<%= destination.name || '' %>">
                                            <% if (destination.badge) { %><span class="destination-card-badge"><%= destination.badge %></span><% } %>
                                        </div>
                                        <div class="destination-card-body">
                                            <h3><%= destination.name %></h3>
                                            <a href="<%= destination.cta_link || destination.link || (destination.slug ? '/destination/' + destination.slug : '#') %>">
                                                <%= destination.cta_text || 'Apply Now' %> <span aria-hidden="true">→</span>
                                            </a>
                                        </div>
                                    </article>
                                <% }) %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </section>
        <% } %>

        <!-- SECTION TYPE: EXCLUSIVE OFFERS -->
        <% if (section.section === 'offer_grid') { %>
            <section class="py-5 exclusive-offers-section">
                <div class="container">
                    <% if (section.title) { %><h2 class="text-center fw-bold mb-2"><%= section.title %></h2><% } %>
                    <% if (content.heading_content) { %><p class="text-center fs-5 mb-2"><%= content.heading_content %></p><% } %>
                    <% if (content.description) { %><p class="text-center text-muted mb-5"><%= content.description %></p><% } %>

                    <div class="exclusive-offers-grid">
                        <% (content.offers || []).forEach(offer => { %>
                            <a href="<%= offer.link || '#' %>" class="exclusive-offer-card offer-size-<%= offer.size || 'standard' %>">
                                <img src="<%= offer.image || offer.img || '/assets/img/placeholder.png' %>" alt="<%= offer.title || '' %>">
                                <div class="exclusive-offer-overlay"></div>
                                <div class="exclusive-offer-content">
                                    <% if (offer.type) { %><span class="exclusive-offer-type"><%= offer.type %></span><% } %>
                                    <div class="exclusive-offer-copy">
                                        <h3><%= offer.title %></h3>
                                        <% if (offer.validity || offer.valid_until) { %><p><%= offer.validity || offer.valid_until %></p><% } %>
                                        <% if (offer.code || offer.coupon_code) { %>
                                            <span class="exclusive-offer-code">USE CODE: <strong><%= offer.code || offer.coupon_code %></strong></span>
                                        <% } %>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </section>
        <% } %>

    <% }) %>
<% } %>

<style>
    .transition-up { transition: transform 0.3s; }
    .transition-up:hover { transform: translateY(-5px); }
    .ls-wide { letter-spacing: 0.1em; }
    .italic { font-style: italic; }
    .group:hover .group-hover-scale-110 { transform: scale(1.1); }
    .group:hover .group-hover-opacity-100 { opacity: 1; }
    .transition-transform { transition: transform 0.5s; }
    .transition-opacity { transition: opacity 0.3s; }
    .object-fit-cover { object-fit: cover; }
    .prose p { margin-bottom: 1.5rem; line-height: 1.7; color: var(--text-muted); font-size: 1.1rem; }
    .destination-tabs-section { background: linear-gradient(120deg, #edf8ff 0%, #f3ecff 100%); }
    .destination-tab-btn { border: 0; border-radius: 999px; background: #fff; color: #334155; font-weight: 700; padding: .85rem 1.6rem; box-shadow: 0 4px 14px rgba(15, 23, 42, .06); }
    .destination-tab-btn.active { background: #111; color: #fff; box-shadow: 0 10px 22px rgba(15, 23, 42, .2); }
    .destination-tab-panel { display: none; }
    .destination-tab-panel.active { display: block; }
    .destination-card-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 1.5rem; }
    .destination-page-card { background: #fff; border: 1px solid #d8dee9; border-radius: 20px; overflow: hidden; min-width: 0; }
    .destination-card-media { height: 200px; position: relative; overflow: hidden; }
    .destination-card-media img { width: 100%; height: 100%; object-fit: cover; }
    .destination-card-badge { position: absolute; left: 12px; bottom: 12px; border-radius: 8px; padding: .45rem .7rem; background: #ff3b3b; color: #fff; font-size: .7rem; font-weight: 800; }
    .destination-card-body { padding: 1.15rem 1.4rem 1.3rem; }
    .destination-card-body h3 { font-size: 1.35rem; font-weight: 800; margin-bottom: .9rem; }
    .destination-card-body a { color: #050505; font-weight: 800; text-decoration: none; }
    .exclusive-offers-section { background: linear-gradient(120deg, #eef5ff 0%, #fff0fa 100%); }
    .exclusive-offers-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); grid-auto-rows: 220px; grid-auto-flow: dense; gap: 1.25rem; }
    .exclusive-offer-card { position: relative; display: block; min-width: 0; overflow: hidden; border-radius: 18px; color: #fff; text-decoration: none; box-shadow: 0 10px 28px rgba(15, 23, 42, .13); }
    .exclusive-offer-card:hover { color: #fff; }
    .exclusive-offer-card.offer-size-wide { grid-column: span 2; }
    .exclusive-offer-card.offer-size-featured { grid-column: span 2; grid-row: span 2; }
    .exclusive-offer-card > img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease; }
    .exclusive-offer-card:hover > img { transform: scale(1.04); }
    .exclusive-offer-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0, 0, 0, .05) 5%, rgba(0, 0, 0, .82) 100%); }
    .exclusive-offer-content { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 1.5rem; }
    .exclusive-offer-type { align-self: flex-start; padding: .45rem .7rem; border: 1px solid rgba(255, 255, 255, .65); border-radius: 8px; background: rgba(255, 255, 255, .18); font-size: .72rem; font-weight: 800; letter-spacing: .04em; }
    .exclusive-offer-copy h3 { margin: 0 0 .45rem; font-size: 1.35rem; font-weight: 800; }
    .offer-size-featured .exclusive-offer-copy h3 { font-size: 2rem; }
    .exclusive-offer-copy p { margin: 0 0 .6rem; color: rgba(255, 255, 255, .78); font-size: .8rem; font-weight: 600; }
    .exclusive-offer-code { display: inline-block; border: 1px dashed rgba(255, 255, 255, .75); border-radius: 7px; padding: .45rem .7rem; color: #fff36a; font-size: .78rem; font-weight: 700; }
    @media (max-width: 1199px) { .destination-card-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @media (max-width: 991px) { .exclusive-offers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
    @media (max-width: 767px) { .destination-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; } .exclusive-offers-grid { grid-auto-rows: 210px; } .exclusive-offer-card.offer-size-featured { grid-row: span 1; } }
    @media (max-width: 480px) { .destination-card-grid { grid-template-columns: 1fr; } .exclusive-offers-grid { grid-template-columns: 1fr; } .exclusive-offer-card.offer-size-wide, .exclusive-offer-card.offer-size-featured { grid-column: span 1; } }
</style>

<script>
    document.querySelectorAll('.destination-tabs-section').forEach(section => {
        const buttons = section.querySelectorAll('.destination-tab-btn');
        const panels = section.querySelectorAll('.destination-tab-panel');
        buttons.forEach(button => {
            button.addEventListener('click', () => {
                const index = button.dataset.tabIndex;
                buttons.forEach(item => item.classList.toggle('active', item === button));
                panels.forEach(panel => panel.classList.toggle('active', panel.dataset.tabPanel === index));
            });
        });
    });
</script>
