<header class="py-5 bg-light border-bottom">
    <div class="container text-center pt-5">
        <h1 class="display-4 fw-bold">Our Blog</h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">Stories of craftsmanship, jewelry trends, and the lifestyle of the modern collector.</p>
    </div>
</header>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <% posts.forEach(post => { %>
                <div class="col-md-4">
                    <article class="card h-100 border-0 shadow-sm overflow-hidden transition-up">
                        <% if (post.featured_image) { %>
                            <img src="<%= post.featured_image %>" class="card-img-top" style="height: 240px; object-fit: cover;">
                        <% } %>
                        <div class="card-body p-4">
                            <div class="mb-2">
                                <span class="badge bg-indigo-light text-indigo px-3 rounded-pill small fw-bold">
                                    <%= post.category ? post.category.name : 'General' %>
                                </span>
                            </div>
                            <h3 class="h4 fw-bold mb-3">
                                <a href="/page/blog/<%= post.slug %>" class="text-decoration-none text-dark hover-indigo">
                                    <%= post.title %>
                                </a>
                            </h3>
                            <p class="text-muted small mb-4 line-clamp-3"><%= post.summary %></p>
                            <a href="/page/blog/<%= post.slug %>" class="fw-bold text-indigo text-decoration-none small">
                                Read Article <i class="bi bi-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </article>
                </div>
            <% }) %>
            <% if (posts.length === 0) { %>
                <div class="col-12 text-center py-5">
                    <h3 class="text-muted">No posts found yet.</h3>
                </div>
            <% } %>
        </div>
    </div>
</section>

<style>
    .transition-up { transition: transform 0.3s, box-shadow 0.3s; }
    .transition-up:hover { transform: translateY(-8px); box-shadow: 0 12px 30px rgba(0,0,0,0.1) !important; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .hover-indigo:hover { color: var(--primary) !important; }
</style>
