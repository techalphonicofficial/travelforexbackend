<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Module Management</h2>
        <p class="text-secondary small mb-0">Define organizational modules to group permissions logically.</p>
    </div>
    <a href="/modules/create" class="btn btn-primary d-flex align-items-center gap-2">
        <i class="bi bi-plus-lg"></i> Create New Module
    </a>
</div>

<div class="card shadow-sm border-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-secondary">Module Name</th>
                    <th class="py-3 text-uppercase small fw-bold text-secondary">Created At</th>
                    <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-secondary">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% modules.forEach(module => { %>
                <tr>
                    <td class="ps-4">
                        <div class="d-flex align-items-center">
                            <div class="bg-indigo bg-opacity-10 text-indigo rounded-circle p-2 me-3">
                                <i class="bi bi-box"></i>
                            </div>
                            <span class="fw-semibold text-dark"><%= module.name %></span>
                        </div>
                    </td>
                    <td class="text-secondary small"><%= new Date(module.created_at).toLocaleDateString() %></td>
                    <td class="pe-4 text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a href="/modules/<%= module.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit Module">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <button onclick="deleteModule('<%= module.id %>')" class="btn btn-sm btn-outline-danger" title="Delete Module">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
                <% }) %>
                <% if (modules.length === 0) { %>
                <tr>
                    <td colspan="3" class="text-center py-5 text-secondary">
                        <i class="bi bi-folder2-open fs-1 d-block mb-2 op-30"></i>
                        No modules found. Create one to organize permissions.
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<style>
.bg-indigo { background-color: #6366f1; }
.text-indigo { color: #6366f1; }
</style>

<script>
async function deleteModule(id) {
    if (confirm('Are you sure you want to delete this module? All associated permissions will also be affected.')) {
        try {
            const response = await fetch(`/modules/${id}`, {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await response.json();
            if (data.status === 'success') {
                window.location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An unexpected error occurred.');
        }
    }
}
</script>
