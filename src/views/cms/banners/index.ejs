<div class="tf-page-header">
  <div>
    <h2 class="tf-page-title">Banner Management</h2>
    <p class="tf-page-sub">Manage promotional banners for your website</p>
  </div>
  <a href="/cms/banners/create" class="btn btn-add-primary">
    <i class="bi bi-plus-lg me-2"></i> Add Banner
  </a>
</div>

<div class="tf-table-wrap">
  <table class="tf-table">
    <thead>
      <tr>
        <th>Banner</th>
        <th>Position</th>
        <th>Device</th>
        <th>Status</th>
        <th class="text-end">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% banners.forEach(banner => { %>
        <tr id="row-<%= banner.id %>">
          <td>
            <div class="d-flex align-items-center gap-3">
              <% if (banner.image_path) { %>
                <img src="<%= banner.image_path %>" class="rounded" style="width: 80px; height: 45px; object-fit: cover;">
              <% } else { %>
                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="width: 80px; height: 45px;">
                  <i class="bi bi-image text-muted"></i>
                </div>
              <% } %>
              <div>
                <div class="fw-bold"><%= banner.title || 'Untitled Banner' %></div>
                <div class="small text-muted"><%= banner.subtitle || 'No subtitle' %></div>
              </div>
            </div>
          </td>
          <td>
            <span class="badge bg-light text-dark border"><%= banner.position.toUpperCase() %></span>
          </td>
          <td>
            <span class="badge bg-light text-dark border"><%= banner.device.toUpperCase() %></span>
          </td>
          <td>
            <span class="tf-badge <%= banner.status ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger' %>">
              <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
              <%= banner.status ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td class="text-end">
            <div class="d-flex justify-content-end gap-2">
              <a href="/cms/banners/<%= banner.id %>/edit" class="btn-icon btn-icon-edit" title="Edit">
                <i class="bi bi-pencil"></i>
              </a>
              <button onclick="deleteBanner(<%= banner.id %>)" class="btn-icon btn-icon-del" title="Delete">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
      <% }) %>
      <% if (banners.length === 0) { %>
        <tr>
          <td colspan="5" class="text-center py-5 text-muted">
            <i class="bi bi-collection fs-1 d-block mb-2"></i>
            No banners found. Start by creating one!
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<script>
  async function deleteBanner(id) {
    if (!confirm('Are you sure you want to delete this banner?')) return;
    
    try {
      const res = await fetch(`/cms/banners/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) {
        document.getElementById(`row-${id}`).remove();
      } else {
        alert('Error: ' + data.message);
      }
    } catch (err) {
      alert('Failed to delete banner');
    }
  }
</script>
