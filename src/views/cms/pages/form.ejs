<!-- HEADER -->
<div class="tf-page-header">
  <div class="d-flex align-items-center gap-3">
    <a href="/cms/pages" class="tf-back-btn"><i class="bi bi-chevron-left"></i></a>
    <div>
      <p class="tf-page-title"><i class="bi bi-file-earmark-plus me-2" style="color:#4f46e5"></i>
        <%= page ? 'Edit Page' : 'Create Page' %>
      </p>
      <p class="tf-page-sub">Configure page content, SEO metadata, and dynamic layout sections</p>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="/cms/pages" class="btn btn-light px-4 rounded-3 border">Cancel</a>
    <button type="submit" form="pageForm" class="btn-add-primary px-5"
      style="background:linear-gradient(135deg,#4f46e5,#818cf8);box-shadow:0 4px 14px rgba(79,70,229,0.3)">
      <i class="bi bi-check2-circle"></i> Save Page
    </button>
  </div>
</div>

<form id="pageForm">
  <div class="row g-4">
    <!-- LEFT COLUMN: MAIN CONTENT -->
    <div class="col-lg-8">
      <div class="tf-form-card mb-4">
        <div class="tf-form-header"><i class="bi bi-info-circle text-primary"></i> Basic Information</div>
        <div class="tf-form-body">
          <div class="mb-4">
            <label class="form-label fw-bold">Page Title <span class="text-danger">*</span></label>
            <input type="text" name="title" class="form-control" placeholder="e.g. Home Page" required
              value="<%= page ? page.title : '' %>"
              oninput="if(!document.getElementsByName('slug')[0].value) document.getElementsByName('slug')[0].value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')">
          </div>
          <div class="mb-4">
            <label class="form-label fw-bold">URL Slug <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text bg-light text-muted small">/page/</span>
              <input type="text" name="slug" class="form-control" placeholder="page-slug" required
                value="<%= page ? page.slug : '' %>">
            </div>
          </div>
          <div class="mb-0">
            <label class="form-label fw-bold">General Description</label>
            <textarea name="description" class="form-control" rows="4"
              placeholder="Brief overview of the page content..."><%= page ? page.description : '' %></textarea>
          </div>
        </div>
      </div>

      <!-- DYNAMIC SECTIONS -->
      <div class="tf-form-card">
        <div class="tf-form-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-layers text-indigo"></i> Page Content Blocks</span>
          <button type="button" class="btn btn-sm btn-outline-primary fw-bold rounded-pill px-3" onclick="addSection()">
            <i class="bi bi-plus-lg me-1"></i> Add Block
          </button>
        </div>
        <div class="tf-form-body">
          <div id="sectionsContainer" class="d-flex flex-column gap-4">
            <% if (page && page.details && page.details.length> 0) { %>
              <% page.details.forEach((detail, index)=> { %>
                <div class="section-item p-4 rounded-4 border position-relative" data-index="<%= index %>"
                  style="background:#fcfdff; border-style: dashed !important;">
                  <button type="button" class="btn-icon btn-icon-del position-absolute" style="top:1rem;right:1rem"
                    onclick="removeSection(this)"><i class="bi bi-trash3"></i></button>

                  <% let content={}; try { content = typeof detail.json_data === 'string' ? JSON.parse(detail.json_data) : (detail.json_data || {}); } catch(e) {} %>
                  <div class="row g-3">
                    <div class="col-md-3">
                      <label class="small fw-bold text-muted mb-1 uppercase">Block ID (Key)</label>
                      <input type="text" name="sections[<%= index %>][key]" class="form-control form-control-sm"
                        placeholder="e.g. hero-section" value="<%= detail.key %>">
                    </div>
                    <div class="col-md-3">
                      <label class="small fw-bold text-muted mb-1 uppercase">Block Heading</label>
                      <input type="text" name="sections[<%= index %>][title]" class="form-control form-control-sm"
                        placeholder="Display Title" value="<%= detail.title %>">
                    </div>
                    <div class="col-md-3">
                      <label class="small fw-bold text-muted mb-1 uppercase">Heading Content</label>
                      <input type="text" class="form-control form-control-sm item-heading-content"
                        placeholder="Heading Content" value="<%= content.heading_content || '' %>">
                    </div>
                    <div class="col-md-3">
                      <label class="small fw-bold text-muted mb-1 uppercase">Block Layout</label>
                      <select name="sections[<%= index %>][section]" class="form-select form-select-sm"
                        onchange="toggleSectionType(this)">
                        <option value="standard" <%=detail.section==='standard' ? 'selected' : '' %>>Standard (Text +
                          Desc)</option>
                        <option value="image_text" <%=detail.section==='image_text' ? 'selected' : '' %>>Media + Text
                        </option>
                        <option value="rich_text" <%=detail.section==='rich_text' ? 'selected' : '' %>>Rich Text Block
                        </option>
                        <option value="cta_banner" <%=detail.section==='cta_banner' ? 'selected' : '' %>>CTA Banner
                        </option>
                        <option value="faq_accordion" <%=detail.section==='faq_accordion' ? 'selected' : '' %>>FAQ
                          Accordion</option>
                        <option value="stats_bar" <%=detail.section==='stats_bar' ? 'selected' : '' %>>Stats Bar
                        </option>
                        <option value="timeline" <%=detail.section==='timeline' ? 'selected' : '' %>>Timeline</option>
                        <option value="feature_grid" <%=detail.section==='feature_grid' ? 'selected' : '' %>>Feature
                          Grid</option>
                        <option value="testimonial_grid" <%=detail.section==='testimonial_grid' ? 'selected' : '' %>
                          >Testimonials</option>
                        <option value="gallery" <%=detail.section==='gallery' ? 'selected' : '' %>>Gallery (Photos)
                        </option>
                        <option value="why_choose_us" <%=detail.section==='why_choose_us' ? 'selected' : '' %>>Why Choose Us</option>
                        <option value="story_grid" <%=detail.section==='story_grid' ? 'selected' : '' %>>Story (Text + Stats + Images)</option>
                        <option value="team_grid" <%=detail.section==='team_grid' ? 'selected' : '' %>>Team Grid</option>
                        <option value="tabs_section" <%=detail.section==='tabs_section' ? 'selected' : '' %>>Tabs Content (Image + Rich Text)</option>
                      </select>
                    </div>

                    <div class="col-12 mt-3 content-area">

                        <!-- Standard -->
                        <div class="type-standard section-content"
                          style="display: <%= detail.section === 'standard' ? 'block' : 'none' %>">
                          <textarea name="sections[<%= index %>][description]" class="form-control" rows="3"
                            placeholder="Enter content description here..."><%= detail.description %></textarea>
                        </div>

                        <!-- Media Text (Formerly Image Text) -->
                        <div class="type-image_text section-content"
                          style="display: <%= detail.section === 'image_text' ? 'block' : 'none' %>">
                          <div class="row g-2">
                            <div class="col-md-8">
                                <textarea class="form-control item-body"
                                  placeholder="Body Content"><%= content.body || '' %></textarea>
                                <div class="mt-2">
                                  <label class="small fw-bold text-muted mb-1">Points (Optional)</label>
                                  <div class="image-text-points-list d-flex flex-column gap-2 mb-2">
                                    <% (content.points || []).forEach(pt => { %>
                                      <div class="item-row d-flex gap-2 align-items-center bg-white p-1 rounded border">
                                        <input type="text" class="form-control form-control-sm f1" placeholder="Point Title" value="<%= pt.title %>">
                                        <button type="button" class="btn btn-sm btn-light text-danger border py-0 px-2" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                      </div>
                                    <% }) %>
                                  </div>
                                  <button type="button" class="btn btn-xs btn-outline-secondary" onclick="addItem(<%= index %>, 'image_text_point')">+ Add Point</button>
                                </div>
                            </div>
                            <div class="col-md-4">
                              <div class="media-selector-wrap bg-white border rounded-3 p-2 text-center mb-1">
                                <% const isVideo = content.media_url && content.media_url.match(/\.(mp4|webm|ogg|mov|avi)$/i); %>
                                <img src="<%= !isVideo ? (content.media_url || '/assets/img/placeholder.png') : '' %>"
                                  class="img-preview mb-2 rounded"
                                  style="max-height: 80px; display: <%= content.media_url && !isVideo ? 'block' : 'none' %>; margin: 0 auto;">
                                <video class="video-preview mb-2 rounded" src="<%= isVideo ? content.media_url : '' %>"
                                  style="max-height: 80px; display: <%= isVideo ? 'block' : 'none' %>; margin: 0 auto;" controls autoplay muted loop></video>
                                <div class="placeholder-icon mb-2 text-muted"
                                  style="display: <%= content.media_url ? 'none' : 'block' %>"><i
                                    class="bi bi-camera-video fs-4"></i></div>
                                <input type="text" class="form-control form-control-sm item-img mb-1"
                                  placeholder="Media URL" value="<%= content.media_url || '' %>"
                                  onchange="updatePreview(this)">
                                <button type="button" class="btn btn-xs btn-outline-primary w-100 py-1"
                                  onclick="openMediaLibrary(this)" style="font-size: 0.7rem;">Select Media</button>
                              </div>
                              <select class="form-select form-select-sm item-side">
                                <option value="right" <%=content.side==='right' ? 'selected' : '' %>>Media Right
                                </option>
                                <option value="left" <%=content.side==='left' ? 'selected' : '' %>>Media Left</option>
                                <option value="center" <%=content.side==='center' ? 'selected' : '' %>>Media Center
                                </option>
                              </select>
                            </div>
                          </div>
                        </div>

                        <!-- Rich Text -->
                        <div class="type-rich_text section-content"
                          style="display: <%= detail.section === 'rich_text' ? 'block' : 'none' %>">
                          <textarea class="form-control item-body rich-editor" rows="5"
                            placeholder="HTML / Rich Text Content"><%= content.body || '' %></textarea>
                        </div>

                        <!-- CTA Banner -->
                        <div class="type-cta_banner section-content"
                          style="display: <%= detail.section === 'cta_banner' ? 'block' : 'none' %>">
                          <div class="row g-2">
                            <div class="col-md-6"><input type="text" class="form-control item-btn_text"
                                placeholder="Button Text" value="<%= content.btn_text || '' %>"></div>
                            <div class="col-md-6"><input type="text" class="form-control item-btn_link"
                                placeholder="Button Link" value="<%= content.btn_link || '' %>"></div>
                          </div>
                        </div>

                        <!-- FAQ / Stats / Timeline / Features / Testimonials / Gallery / Team (List Based) -->
                        <div class="type-list-based section-content"
                          style="display: <%= ['faq_accordion', 'stats_bar', 'timeline', 'feature_grid', 'testimonial_grid', 'gallery', 'team_grid'].includes(detail.section) ? 'block' : 'none' %>">
                          <div class="mb-3">
                            <label class="small fw-bold text-muted mb-1">Block Description (Optional)</label>
                            <textarea class="form-control form-control-sm item-block-desc" rows="2" placeholder="Brief text under heading..."><%= content.block_desc || '' %></textarea>
                          </div>
                          <div class="items-list d-flex flex-column gap-2 mb-3">
                            <% const listKey={ 'faq_accordion' : 'faqs' , 'stats_bar' : 'stats' , 'timeline' : 'items'
                              , 'feature_grid' : 'features' , 'testimonial_grid' : 'testimonials' , 'gallery' : 'images' , 'team_grid': 'team'
                              }[detail.section] || 'items' ; const items=Array.isArray(content[listKey]) ?
                              content[listKey] : []; items.forEach((item, i)=> { %>
                              <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                <% if (detail.section==='faq_accordion' ) { %>
                                  <input type="text" class="form-control form-control-sm f1" placeholder="Question"
                                    value="<%= item.q %>">
                                  <input type="text" class="form-control form-control-sm f2" placeholder="Answer"
                                    value="<%= item.a %>">
                                  <% } else if (detail.section==='stats_bar' ) { %>
                                    <div class="d-flex flex-column gap-2 flex-grow-1">
                                      <input type="text" class="form-control form-control-sm f1" placeholder="Value"
                                        value="<%= item.value %>">
                                      <textarea class="form-control form-control-sm f2 rich-editor" placeholder="Label"><%= item.label %></textarea>
                                    </div>
                                    <% } else if (detail.section==='timeline' ) { %>
                                      <input type="text" class="form-control form-control-sm f1" placeholder="Year"
                                        value="<%= item.year %>" style="width:100px">
                                      <input type="text" class="form-control form-control-sm f2" placeholder="Title"
                                        value="<%= item.title %>">
                                      <input type="text" class="form-control form-control-sm f3" placeholder="Desc"
                                        value="<%= item.desc %>">
                                      <% } else if (detail.section==='feature_grid' ) { %>
                                        <input type="text" class="form-control form-control-sm f1"
                                          placeholder="Icon Class" value="<%= item.icon %>">
                                        <input type="text" class="form-control form-control-sm f2" placeholder="Title"
                                          value="<%= item.title %>">
                                        <input type="text" class="form-control form-control-sm f3" placeholder="Desc"
                                          value="<%= item.desc %>">
                                        <% } else if (detail.section==='testimonial_grid' ) { %>
                                          <input type="text" class="form-control form-control-sm f1" placeholder="Name"
                                            value="<%= item.name %>">
                                          <input type="text" class="form-control form-control-sm f2" placeholder="Title"
                                            value="<%= item.title %>">
                                          <input type="text" class="form-control form-control-sm f3" placeholder="Text"
                                            value="<%= item.text %>">
                                          <% } else if (detail.section==='gallery' ) { %>
                                            <input type="text" class="form-control form-control-sm f1"
                                              placeholder="Image URL" value="<%= item.img %>">
                                            <input type="text" class="form-control form-control-sm f2"
                                              placeholder="Label" value="<%= item.lbl %>">
                                          <% } else if (detail.section==='team_grid' ) { %>
                                            <div class="d-flex flex-column flex-grow-1 gap-2 align-items-start">
                                              <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                                                <img src="<%= item.img || '/assets/img/placeholder.png' %>" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: <%= item.img ? 'block' : 'none' %>;">
                                                <input type="text" class="form-control form-control-sm f1" placeholder="Image URL" value="<%= item.img %>" onchange="updatePreview(this)">
                                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                                              </div>
                                              <div class="row g-2 w-100 m-0">
                                                <div class="col-md-6 p-0 pe-1"><input type="text" class="form-control form-control-sm f2" placeholder="Name" value="<%= item.name %>"></div>
                                                <div class="col-md-6 p-0 ps-1"><input type="text" class="form-control form-control-sm f3" placeholder="Role/Designation" value="<%= item.role %>"></div>
                                              </div>
                                              <textarea class="form-control form-control-sm f4" placeholder="Short Bio" rows="2"><%= item.bio %></textarea>
                                            </div>
                                          <% } %>
                                              <button type="button" class="btn btn-sm btn-light text-danger border"
                                                onclick="this.parentElement.remove()"><i
                                                  class="bi bi-x-lg"></i></button>
                              </div>
                              <% }); %>
                          </div>
                          <button type="button" class="btn btn-sm btn-light border fw-bold text-primary"
                            onclick="addItem(<%= index %>)">
                            <i class="bi bi-plus-lg me-1"></i>Add Item
                          </button>
                        </div>

                        <!-- Why Choose Us (Complex) -->
                        <div class="type-why_choose_us section-content"
                          style="display: <%= detail.section === 'why_choose_us' ? 'block' : 'none' %>">
                          <div class="row g-3">
                            <!-- Stats List -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">1. Stats (Numbers)</label>
                              <div class="stats-list d-flex flex-column gap-2 mb-2">
                                <% (content.stats || []).forEach(st => { %>
                                  <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                    <input type="text" class="form-control form-control-sm f1" placeholder="Value (e.g. 3400+)" value="<%= st.value %>">
                                    <input type="text" class="form-control form-control-sm f2" placeholder="Label" value="<%= st.label %>">
                                    <button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                  </div>
                                <% }) %>
                              </div>
                              <button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(<%= index %>, 'stat')">+ Add Stat</button>
                            </div>
                            <!-- Features List -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">2. Features (Points)</label>
                              <div class="features-list d-flex flex-column gap-2 mb-2">
                                <% (content.features || []).forEach(ft => { %>
                                  <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                    <input type="text" class="form-control form-control-sm f1" placeholder="Title" value="<%= ft.title %>">
                                    <input type="text" class="form-control form-control-sm f2" placeholder="Description" value="<%= ft.desc %>">
                                    <button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                  </div>
                                <% }) %>
                              </div>
                              <button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(<%= index %>, 'feature')">+ Add Feature</button>
                            </div>
                            <!-- Gallery List -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">3. Gallery Images</label>
                              <div class="gallery-list d-flex flex-column gap-2 mb-2">
                                <% (content.gallery || []).forEach(gl => { %>
                                  <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                    <div class="d-flex flex-column flex-grow-1">
                                      <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                                        <img src="<%= gl.img || '/assets/img/placeholder.png' %>" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: <%= gl.img ? 'block' : 'none' %>;">
                                        <input type="text" class="form-control form-control-sm f1" placeholder="Image URL" value="<%= gl.img %>" onchange="updatePreview(this)">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                                      </div>
                                      <input type="text" class="form-control form-control-sm f2" placeholder="Label" value="<%= gl.lbl %>">
                                    </div>
                                    <button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                  </div>
                                <% }) %>
                              </div>
                              <button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(<%= index %>, 'gallery')">+ Add Image</button>
                            </div>
                          </div>
                        </div>

                        <!-- Story Grid (Text + Stats + Images) -->
                        <div class="type-story_grid section-content"
                          style="display: <%= detail.section === 'story_grid' ? 'block' : 'none' %>">
                          <div class="row g-3">
                            <!-- Story Description -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">1. Story Description</label>
                              <textarea class="form-control item-story-desc rich-editor" rows="4" placeholder="Detailed story text goes here..."><%= content.story_desc || '' %></textarea>
                            </div>
                            <!-- Stats List -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">2. Labels / Stats (Array)</label>
                              <div class="story-stats-list d-flex flex-column gap-2 mb-2">
                                <% (content.stats || []).forEach(st => { %>
                                  <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                    <input type="text" class="form-control form-control-sm f1" placeholder="Label/Value (e.g. 50K+)" value="<%= st.value %>">
                                    <input type="text" class="form-control form-control-sm f2" placeholder="Description (e.g. Happy Travelers)" value="<%= st.desc %>">
                                    <button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                  </div>
                                <% }) %>
                              </div>
                              <button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(<%= index %>, 'story_stat')">+ Add Label</button>
                            </div>
                            <!-- Gallery List with Alt -->
                            <div class="col-12">
                              <label class="small fw-bold text-indigo mb-2 d-block">3. Images (Array)</label>
                              <div class="story-gallery-list d-flex flex-column gap-2 mb-2">
                                <% (content.gallery || []).forEach(gl => { %>
                                  <div class="item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border">
                                    <div class="d-flex flex-column flex-grow-1">
                                      <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                                        <img src="<%= gl.img || '/assets/img/placeholder.png' %>" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: <%= gl.img ? 'block' : 'none' %>;">
                                        <input type="text" class="form-control form-control-sm f1" placeholder="Image URL" value="<%= gl.img %>" onchange="updatePreview(this)">
                                        <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                                      </div>
                                      <input type="text" class="form-control form-control-sm f2" placeholder="Image Alt Text" value="<%= gl.alt %>">
                                    </div>
                                    <button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>
                                  </div>
                                <% }) %>
                              </div>
                              <button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(<%= index %>, 'story_gallery')">+ Add Image</button>
                            </div>
                          </div>
                        </div>

                        <!-- Tabs Section -->
                        <div class="type-tabs_section section-content"
                          style="display: <%= detail.section === 'tabs_section' ? 'block' : 'none' %>">
                          <div class="mb-3">
                            <label class="small fw-bold text-muted mb-1">Block Description (Optional)</label>
                            <textarea class="form-control form-control-sm item-block-desc" rows="2" placeholder="Brief text under heading..."><%= content.block_desc || '' %></textarea>
                          </div>
                          <div class="tabs-list d-flex flex-column gap-2 mb-3">
                            <% (content.tabs || []).forEach((tab, i) => { %>
                              <div class="item-row d-flex flex-column gap-2 bg-white p-3 rounded-3 border shadow-sm">
                                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                                  <span class="fw-bold text-primary small"><i class="bi bi-window-stack me-1"></i> Tab Item</span>
                                  <button type="button" class="btn btn-sm btn-light text-danger border py-0 px-2" onclick="this.closest('.item-row').remove()"><i class="bi bi-x-lg"></i></button>
                                </div>
                                <div class="row g-3">
                                  <div class="col-md-4">
                                    <label class="small fw-bold text-muted">Tab Title / Key</label>
                                    <input type="text" class="form-control form-control-sm f1 mb-2" placeholder="e.g. Inside Cabin" value="<%= tab.title %>">
                                    <label class="small fw-bold text-muted">Badge (Optional)</label>
                                    <input type="text" class="form-control form-control-sm f2 mb-2" placeholder="e.g. BEST VALUE" value="<%= tab.badge %>">
                                    <label class="small fw-bold text-muted">Tab Image</label>
                                    <div class="media-selector-wrap border rounded p-2 text-center bg-light">
                                      <img src="<%= tab.img || '/assets/img/placeholder.png' %>" class="img-preview rounded shadow-sm" style="width:100%; height:80px; object-fit:cover; display:<%= tab.img ? 'block' : 'none' %>;">
                                      <input type="text" class="form-control form-control-sm f3 mt-2" placeholder="Image URL" value="<%= tab.img %>" onchange="updatePreview(this)">
                                      <button type="button" class="btn btn-sm btn-outline-primary mt-1 w-100" onclick="openMediaLibrary(this)"><i class="bi bi-image me-1"></i> Select</button>
                                    </div>
                                  </div>
                                  <div class="col-md-8">
                                    <label class="small fw-bold text-muted">Tab Content (Rich Text)</label>
                                    <textarea class="form-control f4 rich-editor" placeholder="Tab Content (Rich Text)"><%= tab.content %></textarea>
                                  </div>
                                </div>
                              </div>
                            <% }) %>
                          </div>
                          <button type="button" class="btn btn-sm btn-light border fw-bold text-primary" onclick="addItem(<%= index %>, 'tabs_section')"><i class="bi bi-plus-lg me-1"></i> Add Tab</button>
                        </div>

                        <input type="hidden" name="sections[<%= index %>][json_data]"
                          value='<%= detail.json_data || "{}" %>' class="json-data-input">
                    </div>
                  </div>
                </div>
                <% }) %>
                  <% } %>
          </div>

          <% if (!page || !page.details || page.details.length===0) { %>
            <div id="noSectionsMsg" class="text-center py-5 rounded-4 bg-light border-dashed">
              <i class="bi bi-box-seam fs-1 text-muted opacity-25"></i>
              <p class="mt-2 text-muted">No content blocks added. Build your page by adding sections.</p>
            </div>
            <% } %>
        </div>
      </div>
    </div>

    <!-- RIGHT COLUMN: MEDIA & SEO -->
    <div class="col-lg-4">
      <div class="tf-form-card mb-4">
        <div class="tf-form-header"><i class="bi bi-image text-warning"></i> Feature Image</div>
        <div class="tf-form-body">
          <div class="mb-3">
            <div class="image-upload-wrap p-3 border-dashed rounded-4 text-center bg-light" style="cursor:pointer"
              onclick="document.getElementById('featureImageInput').click()">
              <input type="file" name="feature_image" id="featureImageInput" class="d-none" accept="image/*">
              <div id="imagePreviewContainer" style="display: <%= page && page.feature_image ? 'block' : 'none' %>;">
                <img id="imagePreview" src="<%= page ? page.feature_image : '#' %>"
                  class="img-fluid rounded-3 mb-2 shadow-sm" style="max-height: 200px;">
                <p class="small text-primary fw-bold mb-0">Click to change</p>
              </div>
              <div id="uploadPlaceholder" style="display: <%= page && page.feature_image ? 'none' : 'block' %>;">
                <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                <p class="small text-muted mb-0">Page cover image</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="tf-form-card">
        <div class="tf-form-header"><i class="bi bi-search text-success"></i> SEO Metadata</div>
        <div class="tf-form-body">
          <div class="mb-3">
            <label class="form-label small fw-bold">Meta Title</label>
            <input type="text" name="meta_title" class="form-control" value="<%= page ? page.meta_title : '' %>">
          </div>
          <div class="mb-3">
            <label class="form-label small fw-bold">Meta Keywords</label>
            <textarea name="keyword" class="form-control" rows="2"><%= page ? page.keyword : '' %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-bold">Meta Description</label>
            <textarea name="meta_description" class="form-control"
              rows="3"><%= page ? page.meta_description : '' %></textarea>
          </div>
          <div class="mb-0">
            <label class="form-label small fw-bold">JSON-LD Schema</label>
            <textarea name="schema" class="form-control font-monospace" style="font-size:0.75rem"
              rows="4"><%= page ? page.schema : '' %></textarea>
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

<script>
  // Update media preview from URL input
  function updatePreview(input) {
    const wrap = input.closest('.media-selector-wrap') || input.parentElement;
    const img = wrap.querySelector('.img-preview');
    const vid = wrap.querySelector('.video-preview');
    const placeholder = wrap.querySelector('.placeholder-icon');
    if (input.value) {
      const isVideo = input.value.match(/\.(mp4|webm|ogg|mov|avi)$/i);
      if (isVideo) {
        if (img) img.style.display = 'none';
        if (vid) {
          vid.src = input.value;
          vid.style.display = 'block';
        }
      } else {
        if (vid) vid.style.display = 'none';
        if (img) {
          img.src = input.value;
          img.style.display = 'block';
        }
      }
      if (placeholder) placeholder.style.display = 'none';
    } else {
      if (img) img.style.display = 'none';
      if (vid) vid.style.display = 'none';
      if (placeholder) placeholder.style.display = 'block';
    }
  }

  let currentMediaPage = 1;
  let hasMoreMedia = true;
  let isMediaLoading = false;

  async function loadMediaLibrary(reset = false) {
    if (reset) {
        currentMediaPage = 1;
        hasMoreMedia = true;
        document.getElementById('mediaGrid').innerHTML = '';
    }
    if (!hasMoreMedia || isMediaLoading) return;
    
    isMediaLoading = true;
    const container = document.getElementById('mediaGrid');
    
    const loadingIndicator = document.createElement('div');
    loadingIndicator.className = 'text-center py-5 w-100 media-loading-indicator';
    loadingIndicator.innerHTML = '<div class="spinner-border text-primary"></div>';
    container.appendChild(loadingIndicator);

    try {
      const res = await fetch(`/cms/media/all?page=${currentMediaPage}&limit=16`);
      const result = await res.json();
      
      const loader = container.querySelector('.media-loading-indicator');
      if (loader) loader.remove();

      if (result.success) {
        const html = result.data.map(m => {
          const isVideo = m.url && m.url.match(/\.(mp4|webm|ogg|mov|avi)$/i);
          return `
          <div class="col-md-3 col-6 mb-3">
            <div class="media-item border rounded-3 p-1 position-relative" style="cursor:pointer" onclick="selectMedia('${m.url}')">
              ${isVideo 
                ? `<video src="${m.url}" style="height:100px; width:100%; object-fit:cover; background:#000;" class="rounded-2" muted></video><div style="position:absolute; top:5px; right:5px; background:rgba(0,0,0,0.5); color:#fff; border-radius:4px; padding:2px 5px; font-size:10px;"><i class="bi bi-camera-video"></i></div>` 
                : `<img src="${m.url}" class="img-fluid rounded-2" style="height:100px; width:100%; object-fit:cover;">`}
              <div class="media-info small text-truncate mt-1 px-1">${m.label || 'Unnamed'}</div>
            </div>
          </div>
        `}).join('');
        container.insertAdjacentHTML('beforeend', html);
        
        hasMoreMedia = result.hasMore;
        if (hasMoreMedia) {
            const loadMoreBtn = document.createElement('div');
            loadMoreBtn.className = 'col-12 text-center mt-3 mb-3 media-load-more-container';
            loadMoreBtn.innerHTML = '<button type="button" class="btn btn-outline-primary btn-sm px-4 rounded-pill" onclick="loadMoreMedia()">Load More</button>';
            container.appendChild(loadMoreBtn);
        }
      }
    } catch (e) {
      const loader = container.querySelector('.media-loading-indicator');
      if (loader) loader.remove();
      container.insertAdjacentHTML('beforeend', '<div class="alert alert-danger w-100">Failed to load media</div>');
    }
    isMediaLoading = false;
  }

  function loadMoreMedia() {
    const btnContainer = document.querySelector('.media-load-more-container');
    if (btnContainer) btnContainer.remove();
    currentMediaPage++;
    loadMediaLibrary();
  }

  function openMediaLibrary(btn) {
    activeMediaTarget = btn.closest('.media-selector-wrap') || btn.parentElement;
    const modal = new bootstrap.Modal(document.getElementById('mediaLibraryModal'));
    loadMediaLibrary(true);
    modal.show();
  }

  function selectMedia(url) {
    const input = activeMediaTarget.querySelector('input[type="text"]');
    input.value = url;
    updatePreview(input);
    bootstrap.Modal.getInstance(document.getElementById('mediaLibraryModal')).hide();
  }

  async function uploadFromModal(input) {
    if (!input.files || !input.files[0]) return;
    const formData = new FormData();
    formData.append('media', input.files[0]);
    formData.append('entity_type', 'page');

    try {
      const res = await fetch('/cms/media/upload', { method: 'POST', body: formData });
      const result = await res.json();
      if (result.success) {
        loadMediaLibrary(true); // Refresh grid from page 1
      } else {
        alert('Upload failed: ' + result.message);
      }
    } catch (e) {
      alert('Error uploading file');
    }
  }

  // Image preview logic for feature image
  document.getElementById('featureImageInput').addEventListener('change', function (e) {
    const container = document.getElementById('imagePreviewContainer');
    const placeholder = document.getElementById('uploadPlaceholder');
    const preview = document.getElementById('imagePreview');
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onload = e => { preview.src = e.target.result; container.style.display = 'block'; placeholder.style.display = 'none'; }
      reader.readAsDataURL(file);
    }
  });

  let sectionCount = <%= page && page.details ? page.details.length : 0 %>;

  function toggleSectionType(select) {
    const parent = select.closest('.section-item');
    const type = select.value;
    const contentArea = parent.querySelector('.content-area');

    // Hide all
    contentArea.querySelectorAll('.section-content').forEach(el => el.style.display = 'none');

    // Show selected
    if (['faq_accordion', 'stats_bar', 'timeline', 'feature_grid', 'testimonial_grid', 'gallery', 'team_grid'].includes(type)) {
      contentArea.querySelector('.type-list-based').style.display = 'block';
    } else if (type === 'why_choose_us') {
      contentArea.querySelector('.type-why_choose_us').style.display = 'block';
    } else if (type === 'story_grid') {
      contentArea.querySelector('.type-story_grid').style.display = 'block';
    } else {
      const target = contentArea.querySelector(`.type-${type}`);
      if (target) target.style.display = 'block';
    }
  }

  function addItem(index, subType) {
    const section = document.querySelector(`.section-item[data-index="${index}"]`);
    const type = section.querySelector('select[name*="[section]"]').value;
    let list = section.querySelector('.items-list');
    
    if (type === 'why_choose_us') {
      const listMap = { 'stat': 'stats-list', 'feature': 'features-list', 'gallery': 'gallery-list' };
      list = section.querySelector(`.${listMap[subType]}`);
    } else if (type === 'story_grid') {
      const listMap = { 'story_stat': 'story-stats-list', 'story_gallery': 'story-gallery-list' };
      list = section.querySelector(`.${listMap[subType]}`);
    } else if (type === 'image_text') {
      list = section.querySelector('.image-text-points-list');
    } else if (type === 'tabs_section') {
      list = section.querySelector('.tabs-list');
    }

    let html = '';
    const rowClass = "item-row d-flex gap-2 align-items-center bg-white p-2 rounded-3 border shadow-sm";
    const delBtn = '<button type="button" class="btn btn-sm btn-light text-danger border" onclick="this.parentElement.remove()"><i class="bi bi-x-lg"></i></button>';

    if (type === 'image_text' && subType === 'image_text_point') {
        html = `<div class="${rowClass} p-1"><input type="text" class="form-control form-control-sm f1" placeholder="Point Title">${delBtn}</div>`;
    } else if (type === 'why_choose_us') {
      if (subType === 'stat') html = `<div class="${rowClass}"><input type="text" class="form-control form-control-sm f1" placeholder="Value"><input type="text" class="form-control form-control-sm f2" placeholder="Label">${delBtn}</div>`;
      if (subType === 'feature') html = `<div class="${rowClass}"><input type="text" class="form-control form-control-sm f1" placeholder="Title"><input type="text" class="form-control form-control-sm f2" placeholder="Desc">${delBtn}</div>`;
      if (subType === 'gallery') html = `<div class="${rowClass}">
                <div class="d-flex flex-column flex-grow-1">
                  <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                    <img src="/assets/img/placeholder.png" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;">
                    <video class="video-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;" muted></video>
                    <input type="text" class="form-control form-control-sm f1" placeholder="Media URL" onchange="updatePreview(this)">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                  </div>
                  <input type="text" class="form-control form-control-sm f2" placeholder="Label">
                </div>
                ${delBtn}
              </div>`;
    } else if (type === 'story_grid') {
      if (subType === 'story_stat') html = `<div class="${rowClass}"><input type="text" class="form-control form-control-sm f1" placeholder="Label/Value (e.g. 50K+)"><input type="text" class="form-control form-control-sm f2" placeholder="Description (e.g. Happy Travelers)">${delBtn}</div>`;
      if (subType === 'story_gallery') html = `<div class="${rowClass}">
                <div class="d-flex flex-column flex-grow-1">
                  <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                    <img src="/assets/img/placeholder.png" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;">
                    <video class="video-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;" muted></video>
                    <input type="text" class="form-control form-control-sm f1" placeholder="Media URL" onchange="updatePreview(this)">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                  </div>
                  <input type="text" class="form-control form-control-sm f2" placeholder="Image Alt Text">
                </div>
                ${delBtn}
              </div>`;
    } else if (type === 'faq_accordion') {
      html = `<div class="${rowClass}"><input type="text" class="form-control form-control-sm f1" placeholder="Question"><input type="text" class="form-control form-control-sm f2" placeholder="Answer">${delBtn}</div>`;
    } else if (type === 'stats_bar') {
      html = `<div class="${rowClass} align-items-start">
                <div class="d-flex flex-column gap-2 flex-grow-1">
                  <input type="text" class="form-control form-control-sm f1" placeholder="Value">
                  <textarea class="form-control form-control-sm f2 rich-editor" placeholder="Label"></textarea>
                </div>
                ${delBtn}
              </div>`;
    } else if (type === 'timeline' || type === 'feature_grid' || type === 'testimonial_grid') {
      const p1 = type === 'timeline' ? 'Year' : (type === 'feature_grid' ? 'Icon Class' : 'Name');
      const p2 = 'Title';
      const p3 = type === 'timeline' ? 'Desc' : (type === 'feature_grid' ? 'Desc' : 'Text');
      html = `<div class="${rowClass}"><input type="text" class="form-control form-control-sm f1" placeholder="${p1}" style="width:100px"><input type="text" class="form-control form-control-sm f2" placeholder="${p2}"><input type="text" class="form-control form-control-sm f3" placeholder="${p3}">${delBtn}</div>`;
    } else if (type === 'gallery') {
      html = `<div class="${rowClass}">
                <div class="d-flex flex-column flex-grow-1">
                  <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                    <img src="/assets/img/placeholder.png" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;">
                    <video class="video-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;" muted></video>
                    <input type="text" class="form-control form-control-sm f1" placeholder="Media URL" onchange="updatePreview(this)">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                  </div>
                  <input type="text" class="form-control form-control-sm f2" placeholder="Label">
                </div>
                ${delBtn}
              </div>`;
    } else if (type === 'team_grid') {
      html = `<div class="${rowClass} align-items-start">
                <div class="d-flex flex-column flex-grow-1 gap-2">
                  <div class="d-flex gap-2 align-items-center mb-1 media-selector-wrap">
                    <img src="/assets/img/placeholder.png" class="img-preview rounded" style="width: 40px; height: 40px; object-fit: cover; display: none;">
                    <input type="text" class="form-control form-control-sm f1" placeholder="Image URL" onchange="updatePreview(this)">
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="openMediaLibrary(this)"><i class="bi bi-folder2-open"></i></button>
                  </div>
                  <div class="row g-2 w-100 m-0">
                    <div class="col-md-6 p-0 pe-1"><input type="text" class="form-control form-control-sm f2" placeholder="Name"></div>
                    <div class="col-md-6 p-0 ps-1"><input type="text" class="form-control form-control-sm f3" placeholder="Role/Designation"></div>
                  </div>
                  <textarea class="form-control form-control-sm f4" placeholder="Short Bio" rows="2"></textarea>
                </div>
                ${delBtn}
              </div>`;
    } else if (type === 'tabs_section') {
      html = `<div class="item-row d-flex flex-column gap-2 bg-white p-3 rounded-3 border shadow-sm">
                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                  <span class="fw-bold text-primary small"><i class="bi bi-window-stack me-1"></i> Tab Item</span>
                  <button type="button" class="btn btn-sm btn-light text-danger border py-0 px-2" onclick="this.closest('.item-row').remove()"><i class="bi bi-x-lg"></i></button>
                </div>
                <div class="row g-3">
                  <div class="col-md-4">
                    <label class="small fw-bold text-muted">Tab Title / Key</label>
                    <input type="text" class="form-control form-control-sm f1 mb-2" placeholder="e.g. Inside Cabin">
                    <label class="small fw-bold text-muted">Badge (Optional)</label>
                    <input type="text" class="form-control form-control-sm f2 mb-2" placeholder="e.g. BEST VALUE">
                    <label class="small fw-bold text-muted">Tab Image</label>
                    <div class="media-selector-wrap border rounded p-2 text-center bg-light">
                      <img src="/assets/img/placeholder.png" class="img-preview rounded shadow-sm" style="width:100%; height:80px; object-fit:cover; display:none;">
                      <input type="text" class="form-control form-control-sm f3 mt-2" placeholder="Image URL" onchange="updatePreview(this)">
                      <button type="button" class="btn btn-sm btn-outline-primary mt-1 w-100" onclick="openMediaLibrary(this)"><i class="bi bi-image me-1"></i> Select</button>
                    </div>
                  </div>
                  <div class="col-md-8">
                    <label class="small fw-bold text-muted">Tab Content (Rich Text)</label>
                    <textarea class="form-control f4 rich-editor" placeholder="Tab Content (Rich Text)"></textarea>
                  </div>
                </div>
              </div>`;
    }
    list.insertAdjacentHTML('beforeend', html);
    
    // Initialize CKEditor on newly added rich-editors in the item row
    setTimeout(() => {
        if (list.lastElementChild) {
            list.lastElementChild.querySelectorAll('.rich-editor').forEach(textarea => {
                ClassicEditor.create(textarea).then(editor => {
                    textarea.ckeditorInstance = editor;
                }).catch(err => console.error(err));
            });
        }
    }, 100);
  }

  function addSection() {
    const msg = document.getElementById('noSectionsMsg');
    if (msg) msg.remove();
    const container = document.getElementById('sectionsContainer');
    const html = `
      <div class="section-item p-4 rounded-4 border position-relative" data-index="${sectionCount}" style="background:#fcfdff; border-style: dashed !important;">
        <button type="button" class="btn-icon btn-icon-del position-absolute" style="top:1rem;right:1rem" onclick="removeSection(this)"><i class="bi bi-trash3"></i></button>
        <div class="row g-3">
          <div class="col-md-3"><label class="small fw-bold text-muted mb-1 uppercase">Block ID (Key)</label><input type="text" name="sections[${sectionCount}][key]" class="form-control form-control-sm" placeholder="e.g. hero-section"></div>
          <div class="col-md-3"><label class="small fw-bold text-muted mb-1 uppercase">Block Heading</label><input type="text" name="sections[${sectionCount}][title]" class="form-control form-control-sm" placeholder="Display Title"></div>
          <div class="col-md-3"><label class="small fw-bold text-muted mb-1 uppercase">Heading Content</label><input type="text" class="form-control form-control-sm item-heading-content" placeholder="Heading Content"></div>
          <div class="col-md-3"><label class="small fw-bold text-muted mb-1 uppercase">Block Layout</label>
            <select name="sections[${sectionCount}][section]" class="form-select form-select-sm" onchange="toggleSectionType(this)">
              <option value="standard">Standard</option>
              <option value="image_text">Media + Text</option>
              <option value="rich_text">Rich Text</option>
              <option value="cta_banner">CTA Banner</option>
              <option value="faq_accordion">FAQ Accordion</option>
              <option value="stats_bar">Stats Bar</option>
              <option value="timeline">Timeline</option>
              <option value="feature_grid">Feature Grid</option>
              <option value="testimonial_grid">Testimonials</option>
              <option value="gallery">Gallery</option>
              <option value="why_choose_us">Why Choose Us</option>
              <option value="story_grid">Story (Text + Stats + Images)</option>
              <option value="team_grid">Team Grid</option>
              <option value="tabs_section">Tabs Content (Image + Rich Text)</option>
            </select>
          </div>
          <div class="col-12 mt-3 content-area">
            <div class="type-standard section-content"><textarea name="sections[${sectionCount}][description]" class="form-control" rows="3" placeholder="Description"></textarea></div>
            <div class="type-image_text section-content" style="display:none">
              <div class="row g-2">
                <div class="col-md-8">
                  <textarea class="form-control item-body" placeholder="Body Content"></textarea>
                  <div class="mt-2">
                    <label class="small fw-bold text-muted mb-1">Points (Optional)</label>
                    <div class="image-text-points-list d-flex flex-column gap-2 mb-2"></div>
                    <button type="button" class="btn btn-xs btn-outline-secondary" onclick="addItem(${sectionCount}, 'image_text_point')">+ Add Point</button>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="media-selector-wrap bg-white border rounded-3 p-2 text-center mb-1">
                    <img src="/assets/img/placeholder.png" class="img-preview mb-2 rounded" style="max-height: 80px; display: none; margin: 0 auto;">
                    <video class="video-preview mb-2 rounded" style="max-height: 80px; display: none; margin: 0 auto;" controls autoplay muted></video>
                    <div class="placeholder-icon mb-2 text-muted"><i class="bi bi-camera-video fs-4"></i></div>
                    <input type="text" class="form-control form-control-sm item-img mb-1" placeholder="Media URL" onchange="updatePreview(this)">
                    <button type="button" class="btn btn-xs btn-outline-primary w-100 py-1" onclick="openMediaLibrary(this)" style="font-size: 0.7rem;">Select Media</button>
                  </div>
                  <select class="form-select form-select-sm item-side"><option value="right">Media Right</option><option value="left">Media Left</option><option value="center">Media Center</option></select>
                </div>
              </div>
            </div>
            <div class="type-rich_text section-content" style="display:none"><textarea class="form-control item-body rich-editor" rows="5" placeholder="Rich Text"></textarea></div>
            <div class="type-cta_banner section-content" style="display:none"><div class="row g-2"><div class="col-md-6"><input type="text" class="form-control item-btn_text" placeholder="Btn Text"></div><div class="col-md-6"><input type="text" class="form-control item-btn_link" placeholder="Btn Link"></div></div></div>
            <div class="type-list-based section-content" style="display:none">
              <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Block Description (Optional)</label>
                <textarea class="form-control form-control-sm item-block-desc" rows="2" placeholder="Brief text under heading..."></textarea>
              </div>
              <div class="items-list d-flex flex-column gap-2 mb-3"></div>
              <button type="button" class="btn btn-sm btn-light border fw-bold text-primary" onclick="addItem(${sectionCount})">+ Add Item</button>
            </div>
            <div class="type-why_choose_us section-content" style="display:none">
              <div class="row g-3">
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">1. Stats</label><div class="stats-list d-flex flex-column gap-2 mb-2"></div><button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(${sectionCount}, 'stat')">+ Add Stat</button></div>
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">2. Features</label><div class="features-list d-flex flex-column gap-2 mb-2"></div><button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(${sectionCount}, 'feature')">+ Add Feature</button></div>
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">3. Gallery</label><div class="gallery-list d-flex flex-column gap-2 mb-2"></div><button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(${sectionCount}, 'gallery')">+ Add Image</button></div>
              </div>
            </div>
            <div class="type-story_grid section-content" style="display:none">
              <div class="row g-3">
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">1. Story Description</label><textarea class="form-control item-story-desc rich-editor" rows="4" placeholder="Detailed story text..."></textarea></div>
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">2. Labels / Stats</label><div class="story-stats-list d-flex flex-column gap-2 mb-2"></div><button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(${sectionCount}, 'story_stat')">+ Add Label</button></div>
                <div class="col-12"><label class="small fw-bold text-indigo mb-2 d-block">3. Images</label><div class="story-gallery-list d-flex flex-column gap-2 mb-2"></div><button type="button" class="btn btn-xs btn-outline-indigo" onclick="addItem(${sectionCount}, 'story_gallery')">+ Add Image</button></div>
              </div>
            </div>
            <div class="type-tabs_section section-content" style="display:none">
              <div class="mb-3">
                <label class="small fw-bold text-muted mb-1">Block Description (Optional)</label>
                <textarea class="form-control form-control-sm item-block-desc" rows="2" placeholder="Brief text under heading..."></textarea>
              </div>
              <div class="tabs-list d-flex flex-column gap-2 mb-3"></div>
              <button type="button" class="btn btn-sm btn-light border fw-bold text-primary" onclick="addItem(${sectionCount}, 'tabs_section')"><i class="bi bi-plus-lg me-1"></i> Add Tab</button>
            </div>
            <input type="hidden" name="sections[${sectionCount}][json_data]" value="{}" class="json-data-input">
          </div>
        </div>
      </div>`;
    container.insertAdjacentHTML('beforeend', html);
    
    // Initialize CKEditor on newly added rich-editors
    setTimeout(() => {
        const newSection = document.querySelector(`.section-item[data-index="${sectionCount}"]`);
        if (newSection) {
            newSection.querySelectorAll('.rich-editor').forEach(textarea => {
                ClassicEditor.create(textarea).then(editor => {
                    textarea.ckeditorInstance = editor;
                }).catch(err => console.error(err));
            });
        }
        sectionCount++;
    }, 100);
  }

  function removeSection(btn) {
    btn.closest('.section-item').remove();
    if (!document.querySelector('.section-item')) {
      document.getElementById('sectionsContainer').innerHTML = '<div id="noSectionsMsg" class="text-center py-5 rounded-4 bg-light border-dashed"><i class="bi bi-box-seam fs-1 text-muted opacity-25"></i><p class="mt-2 text-muted">No blocks added.</p></div>';
    }
  }

  document.getElementById('pageForm').addEventListener('submit', async e => {
    e.preventDefault();
    
    // Update all textarea values from CKEditor instances before saving
    document.querySelectorAll('.rich-editor').forEach(textarea => {
        if (textarea.ckeditorInstance) {
            textarea.value = textarea.ckeditorInstance.getData();
        }
    });

    document.querySelectorAll('.section-item').forEach(section => {
      const idx = section.getAttribute('data-index');
      const type = section.querySelector('select[name*="[section]"]').value;
      const headingContent = section.querySelector('.item-heading-content') ? section.querySelector('.item-heading-content').value : '';
      let data = { heading_content: headingContent };

      if (type === 'image_text') {
        const points = Array.from(section.querySelectorAll('.image-text-points-list .item-row')).map(r => ({ title: r.querySelector('.f1').value }));
        data = { ...data, body: section.querySelector('.type-image_text .item-body').value, media_url: section.querySelector('.item-img').value, side: section.querySelector('.item-side').value, points };
      } else if (type === 'rich_text') {
        data = { ...data, body: section.querySelector('.type-rich_text .item-body').value };
      } else if (type === 'cta_banner') {
        data = { ...data, btn_text: section.querySelector('.item-btn_text').value, btn_link: section.querySelector('.item-btn_link').value };
      } else if (type === 'why_choose_us') {
        const stats = Array.from(section.querySelectorAll('.stats-list .item-row')).map(r => ({ value: r.querySelector('.f1').value, label: r.querySelector('.f2').value }));
        const features = Array.from(section.querySelectorAll('.features-list .item-row')).map(r => ({ title: r.querySelector('.f1').value, desc: r.querySelector('.f2').value }));
        const gallery = Array.from(section.querySelectorAll('.gallery-list .item-row')).map(r => ({ img: r.querySelector('.f1').value, lbl: r.querySelector('.f2').value }));
        data = { ...data, stats, features, gallery };
      } else if (type === 'story_grid') {
        const story_desc = section.querySelector('.item-story-desc') ? section.querySelector('.item-story-desc').value : '';
        const stats = Array.from(section.querySelectorAll('.story-stats-list .item-row')).map(r => ({ value: r.querySelector('.f1').value, desc: r.querySelector('.f2').value }));
        const gallery = Array.from(section.querySelectorAll('.story-gallery-list .item-row')).map(r => ({ img: r.querySelector('.f1').value, alt: r.querySelector('.f2').value }));
        data = { ...data, story_desc, stats, gallery };
      } else if (type === 'tabs_section') {
        const blockDesc = section.querySelector('.type-tabs_section .item-block-desc') ? section.querySelector('.type-tabs_section .item-block-desc').value : '';
        if (blockDesc) data.block_desc = blockDesc;
        const tabs = Array.from(section.querySelectorAll('.tabs-list .item-row')).map(r => ({
          title: r.querySelector('.f1').value,
          badge: r.querySelector('.f2').value,
          img: r.querySelector('.f3').value,
          content: r.querySelector('.f4').value
        }));
        data = { ...data, tabs };
      } else if (['faq_accordion', 'stats_bar', 'timeline', 'feature_grid', 'testimonial_grid', 'gallery', 'team_grid'].includes(type)) {
        const rows = section.querySelectorAll('.type-list-based .items-list .item-row');
        const listKey = { 'faq_accordion': 'faqs', 'stats_bar': 'stats', 'timeline': 'items', 'feature_grid': 'features', 'testimonial_grid': 'testimonials', 'gallery': 'images', 'team_grid': 'team' }[type];
        
        // Capture block description if present
        const blockDesc = section.querySelector('.type-list-based .item-block-desc') ? section.querySelector('.type-list-based .item-block-desc').value : '';
        if (blockDesc) data.block_desc = blockDesc;

        data[listKey] = Array.from(rows).map(row => {
          const f1 = row.querySelector('.f1') ? row.querySelector('.f1').value : null;
          const f2 = row.querySelector('.f2') ? row.querySelector('.f2').value : null;
          const f3 = row.querySelector('.f3') ? row.querySelector('.f3').value : null;
          const f4 = row.querySelector('.f4') ? row.querySelector('.f4').value : null;
          
          if (type === 'faq_accordion') return { q: f1, a: f2 };
          if (type === 'stats_bar') return { value: f1, label: f2 };
          if (type === 'timeline') return { year: f1, title: f2, desc: f3 };
          if (type === 'feature_grid') return { icon: f1, title: f2, desc: f3 };
          if (type === 'testimonial_grid') return { name: f1, title: f2, text: f3 };
          if (type === 'gallery') return { img: f1, lbl: f2 };
          if (type === 'team_grid') return { img: f1, name: f2, role: f3, bio: f4 };
        });
      }
      section.querySelector('.json-data-input').value = JSON.stringify(data);
    });

    const formData = new FormData(e.target);
    const isUpdate = '<%= page ? "true" : "false" %>' === 'true';
    const url = isUpdate ? `/cms/pages/<%= page ? page.id : "" %>/update` : '/cms/pages/save';
    const res = await fetch(url, { method: 'POST', body: formData });
    const result = await res.json();
    if (result.success) window.location.href = '/cms/pages'; else alert(result.message);
  });
</script>

<script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.rich-editor').forEach(textarea => {
            ClassicEditor.create(textarea).then(editor => {
                // Store instance on the element for easy access on submit
                textarea.ckeditorInstance = editor;
            }).catch(error => console.error(error));
        });
    });
</script>

<style>
  .ck-editor__editable_inline {
    min-height: 150px;
  }
</style>

