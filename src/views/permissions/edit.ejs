<div class="mb-4">
    <h2 class="fw-bold mb-1">Edit Permission: <span class="text-primary"><%= permission.name %></span></h2>
    <p class="text-secondary small mb-0">Modify permission name and group association.</p>
</div>

<div class="card shadow-sm border-0 mb-4 p-4 max-w-lg">
    <form action="/permissions/<%= permission.id %>?_method=PUT" method="POST">
        <div class="mb-3">
            <label for="name" class="form-label fw-semibold text-secondary small">Permission Name</label>
            <input type="text" class="form-control p-2 shadow-none border-secondary-subtle" id="name" name="name" value="<%= permission.name %>" required>
        </div>

        <div class="mb-3">
            <label for="module_id" class="form-label fw-semibold text-secondary small">Associate Module</label>
            <select class="form-select p-2 shadow-none border-secondary-subtle" id="module_id" name="module_id" required>
                <% modules.forEach(module => { %>
                <option value="<%= module.id %>" <%= permission.module_id === module.id ? 'selected' : '' %>><%= module.name %></option>
                <% }) %>
            </select>
        </div>

        <div class="d-flex justify-content-end gap-3 pt-3 mt-4 border-top">
            <a href="/permissions" class="btn btn-light px-4">Cancel</a>
            <button type="submit" class="btn btn-primary px-4 fw-bold">Update Permission</button>
        </div>
    </form>
</div>

<style>
.max-w-lg { max-width: 600px; }
</style>
