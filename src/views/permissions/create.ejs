<div class="mb-4">
    <h2 class="fw-bold mb-1">Create New Permission</h2>
    <p class="text-secondary small mb-0">Define a granular permission and associate it with a functional module.</p>
</div>

<div class="card shadow-sm border-0 mb-4 p-4 max-w-lg">
    <form action="/permissions" method="POST">
        <div class="mb-3">
            <label for="name" class="form-label fw-semibold text-secondary small">Permission Name</label>
            <input type="text" class="form-control p-2 shadow-none border-secondary-subtle" id="name" name="name" placeholder="e.g. view_reports, edit_users" required>
        </div>

        <div class="mb-3">
            <label for="module_id" class="form-label fw-semibold text-secondary small">Associate Module</label>
            <select class="form-select p-2 shadow-none border-secondary-subtle" id="module_id" name="module_id" required>
                <option value="" disabled selected>Select a module</option>
                <% modules.forEach(module => { %>
                <option value="<%= module.id %>"><%= module.name %></option>
                <% }) %>
            </select>
        </div>

        <div class="d-flex justify-content-end gap-3 pt-3 mt-4 border-top">
            <a href="/permissions" class="btn btn-light px-4">Cancel</a>
            <button type="submit" class="btn btn-primary px-4 fw-bold">Create Permission</button>
        </div>
    </form>
</div>

<style>
.max-w-lg { max-width: 600px; }
</style>
