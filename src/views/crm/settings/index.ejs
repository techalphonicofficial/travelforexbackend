<div class="tf-page-header">
  <div>
    <h1 class="tf-page-title">CRM Settings</h1>
    <p class="tf-page-sub">Global configuration for lead management</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="tf-form-card shadow-sm border-0">
      <div class="tf-form-header"><i class="bi bi-gear-wide-connected text-primary"></i> Automations & Defaults</div>
      <div class="tf-form-body">
        <form id="crmSettingsForm">
          <div class="mb-4">
            <label class="form-label fw-bold">Default Pipeline for New Leads</label>
            <p class="text-muted small">This pipeline will be pre-selected when creating a new lead manually.</p>
            <select class="form-select" name="crm_default_pipeline_id">
              <option value="">-- No Default (Manual Selection) --</option>
              <% pipelines.forEach(p=> { %>
                <option value="<%= p.id %>" <%=p.id==defaultPipelineId ? 'selected' : '' %>><%= p.name %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-bold">Default Assignee for New Leads</label>
            <p class="text-muted small">New leads (including those from API) will be automatically assigned to this
              user.</p>
            <select class="form-select" name="crm_default_assignee_id">
              <option value="">-- No Default (Unassigned) --</option>
              <% users.forEach(u=> { %>
                <option value="<%= u.id %>" <%=u.id==defaultAssigneeId ? 'selected' : '' %>><%= u.name %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="mb-4 opacity-50 pe-none">
            <label class="form-label fw-bold">Auto-Assignment Rule</label>
            <p class="text-muted small">Automatically assign new leads using Round Robin [COMING SOON]</p>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="assignment_type" id="assignManual" value="manual"
                checked>
              <label class="form-check-label" for="assignManual">Manual</label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="assignment_type" id="assignRR" value="round_robin">
              <label class="form-check-label" for="assignRR">Round Robin</label>
            </div>
          </div>

          <div class="mt-4 pt-3 border-top">
            <button type="button" class="btn btn-primary px-5 rounded-pill fw-bold" id="saveCrmSettingsBtn">
              Save CRM Settings
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="tf-form-card shadow-sm border-0 h-100">
      <div class="tf-form-header"><i class="bi bi-info-circle text-info"></i> Help & Usage</div>
      <div class="tf-form-body">
        <div class="d-flex flex-column gap-3">
          <div class="p-3 bg-light rounded-3">
            <h6 class="fw-bold"><i class="bi bi-diagram-3 me-2"></i> Pipelines</h6>
            <p class="small text-muted mb-0">Use the Pipelines section to define your sales funnel. Each stage can have
              a unique color for the Kanban board.</p>
          </div>
          <div class="p-3 bg-light rounded-3">
            <h6 class="fw-bold"><i class="bi bi-ui-checks me-2"></i> Custom Fields</h6>
            <p class="small text-muted mb-0">The Form Builder allows you to capture specific data (like travel dates or
              budget) on a per-pipeline basis.</p>
          </div>
          <div class="p-3 bg-light rounded-3">
            <h6 class="fw-bold"><i class="bi bi-calendar-event me-2"></i> Follow-ups</h6>
            <p class="small text-muted mb-0">Never miss a lead! Schedule calls and set reminders directly from the lead
              detail view.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('saveCrmSettingsBtn').addEventListener('click', async () => {
    const btn = document.getElementById('saveCrmSettingsBtn');
    const form = document.getElementById('crmSettingsForm');
    const formData = new FormData(form);
    const body = {};
    formData.forEach((value, key) => body[key] = value);

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Saving...';

    try {
      const res = await fetch('/crm/settings/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      const data = await res.json();
      if (data.success) {
        alert('CRM Settings updated successfully');
        location.reload();
      } else {
        alert('Error: ' + data.message);
      }
    } catch (err) {
      alert('Network error');
    } finally {
      btn.disabled = false;
      btn.innerHTML = 'Save CRM Settings';
    }
  });
</script>