<div class="tf-page-header">
  <div class="d-flex align-items-center gap-3">
    <a href="/crm/pipelines" class="tf-back-btn"><i class="bi bi-chevron-left"></i></a>
    <div>
      <h1 class="tf-page-title"><%= title %></h1>
      <p class="tf-page-sub">Configure your pipeline and its sales stages</p>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="/crm/pipelines" class="btn btn-light px-4 rounded-3 border">Cancel</a>
    <button class="btn-save" id="savePipelineBtn">
      <i class="bi bi-check2-circle me-1"></i> Save Pipeline
    </button>
  </div>
</div>

<form id="pipelineForm">
  <input type="hidden" name="id" value="<%= pipeline ? pipeline.id : '' %>">
  <div class="row g-4">
    <div class="col-md-5">
      <div class="tf-form-card">
        <div class="tf-form-header"><i class="bi bi-info-circle text-primary"></i> Basic Info</div>
        <div class="tf-form-body">
          <div class="mb-3">
            <label class="form-label fw-bold">Pipeline Name</label>
            <input type="text" class="form-control" name="name" value="<%= pipeline ? pipeline.name : '' %>" required placeholder="e.g., International Tours">
          </div>
          <div class="mb-3">
            <label class="form-label fw-bold">Description</label>
            <textarea class="form-control" name="description" rows="3" placeholder="Describe the purpose of this pipeline..."><%= pipeline ? pipeline.description : '' %></textarea>
          </div>
          <div class="form-check form-switch mt-4">
            <input class="form-check-input" type="checkbox" name="is_active" id="is_active" <%= !pipeline || pipeline.is_active ? 'checked' : '' %>>
            <label class="form-check-label fw-bold" for="is_active">Active Pipeline</label>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-7">
      <div class="tf-form-card">
        <div class="tf-form-header d-flex justify-content-between align-items-center">
          <span><i class="bi bi-layers text-success"></i> Pipeline Stages</span>
          <button type="button" class="btn btn-sm btn-primary rounded-pill px-3" onclick="addStage()">
            <i class="bi bi-plus-lg me-1"></i> Add Stage
          </button>
        </div>
        <div class="tf-form-body">
          <div id="stagesContainer" class="d-flex flex-column gap-3">
            <% if (pipeline && pipeline.stages && pipeline.stages.length > 0) { %>
              <% pipeline.stages.sort((a,b) => a.order - b.order).forEach((stage, index) => { %>
                <div class="stage-row card border-0 shadow-sm p-3 bg-light" data-id="<%= stage.id %>">
                  <div class="row g-2 align-items-center">
                    <div class="col-auto">
                      <div class="drag-handle cursor-move text-muted"><i class="bi bi-grip-vertical"></i></div>
                    </div>
                    <div class="col">
                      <input type="text" class="form-control form-control-sm stage-name" value="<%= stage.name %>" placeholder="Stage Name">
                    </div>
                    <div class="col-auto">
                      <input type="color" class="form-control form-control-sm form-control-color border-0 p-0" value="<%= stage.color %>" title="Stage Color">
                    </div>
                    <div class="col-auto">
                      <button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeStage(this, <%= stage.id %>)">
                        <i class="bi bi-trash3"></i>
                      </button>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } else if (!pipeline) { %>
              <!-- Default stages for new pipeline -->
              <div class="stage-row card border-0 shadow-sm p-3 bg-light">
                <div class="row g-2 align-items-center">
                  <div class="col-auto"><div class="drag-handle text-muted"><i class="bi bi-grip-vertical"></i></div></div>
                  <div class="col"><input type="text" class="form-control form-control-sm stage-name" value="New" placeholder="Stage Name"></div>
                  <div class="col-auto"><input type="color" class="form-control form-control-sm form-control-color border-0 p-0" value="#4f46e5"></div>
                  <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeStage(this)"><i class="bi bi-trash3"></i></button></div>
                </div>
              </div>
              <div class="stage-row card border-0 shadow-sm p-3 bg-light">
                <div class="row g-2 align-items-center">
                  <div class="col-auto"><div class="drag-handle text-muted"><i class="bi bi-grip-vertical"></i></div></div>
                  <div class="col"><input type="text" class="form-control form-control-sm stage-name" value="Contacted" placeholder="Stage Name"></div>
                  <div class="col-auto"><input type="color" class="form-control form-control-sm form-control-color border-0 p-0" value="#f59e0b"></div>
                  <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeStage(this)"><i class="bi bi-trash3"></i></button></div>
                </div>
              </div>
            <% } %>
          </div>
          <div class="mt-3 text-center text-muted small">
            <i class="bi bi-info-circle me-1"></i> Stages will be displayed in the order shown above.
          </div>
        </div>
      </div>
    </div>
  </div>
</form>

<style>
  .cursor-move { cursor: move; }
  .form-control-color { width: 38px; height: 31px; border-radius: 8px !important; }
  .tf-back-btn {
    width: 40px; height: 40px; background: #f0f0fa; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: #4f46e5; text-decoration: none; transition: all 0.2s;
  }
  .btn-save {
    background: linear-gradient(135deg, #4f46e5, #818cf8); border: none;
    padding: 0.6rem 2rem; border-radius: 12px; color: white; font-weight: 600;
  }
</style>

<script>
function addStage() {
  const container = document.getElementById('stagesContainer');
  const div = document.createElement('div');
  div.className = 'stage-row card border-0 shadow-sm p-3 bg-light animate__animated animate__fadeInUp';
  div.innerHTML = `
    <div class="row g-2 align-items-center">
      <div class="col-auto"><div class="drag-handle text-muted"><i class="bi bi-grip-vertical"></i></div></div>
      <div class="col"><input type="text" class="form-control form-control-sm stage-name" placeholder="Stage Name"></div>
      <div class="col-auto"><input type="color" class="form-control form-control-sm form-control-color border-0 p-0" value="#4f46e5"></div>
      <div class="col-auto"><button type="button" class="btn btn-sm btn-outline-danger border-0" onclick="removeStage(this)"><i class="bi bi-trash3"></i></button></div>
    </div>
  `;
  container.appendChild(div);
}

async function removeStage(btn, id) {
  if (id) {
    if (!confirm('Are you sure? Removing an existing stage might affect leads already in this stage.')) return;
    try {
      const res = await fetch(`/crm/pipelines/stage/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (!data.success) { alert('Error: ' + data.message); return; }
    } catch (err) { alert('Network error'); return; }
  }
  btn.closest('.stage-row').remove();
}

document.getElementById('savePipelineBtn').addEventListener('click', async () => {
  const btn = document.getElementById('savePipelineBtn');
  const form = document.getElementById('pipelineForm');
  const stages = [];
  
  document.querySelectorAll('.stage-row').forEach(row => {
    stages.push({
      id: row.dataset.id || null,
      name: row.querySelector('.stage-name').value,
      color: row.querySelector('input[type="color"]').value
    });
  });

  if (stages.length === 0) {
    alert('Please add at least one stage to the pipeline.');
    return;
  }

  const formData = new FormData(form);
  const body = {
    id: formData.get('id'),
    name: formData.get('name'),
    description: formData.get('description'),
    is_active: formData.get('is_active'),
    stages: JSON.stringify(stages)
  };

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Saving...';

  try {
    const res = await fetch('/crm/pipelines/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const data = await res.json();
    if (data.success) {
      window.location.href = '/crm/pipelines';
    } else {
      alert('Error: ' + data.message);
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Save Pipeline';
    }
  } catch (err) {
    alert('Network error');
    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-check2-circle me-1"></i> Save Pipeline';
  }
});
</script>
