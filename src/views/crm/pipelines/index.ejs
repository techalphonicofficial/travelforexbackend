<div class="tf-page-header">
  <div>
    <h1 class="tf-page-title">CRM Pipelines</h1>
    <p class="tf-page-sub">Manage your sales pipelines and stages</p>
  </div>
  <a href="/crm/pipelines/create" class="btn-add-primary"><i class="bi bi-plus-lg"></i> Create Pipeline</a>
</div>

<div class="row g-4">
  <% if (pipelines.length === 0) { %>
    <div class="col-12">
      <div class="tf-card text-center py-5">
        <i class="bi bi-diagram-3 fs-1 text-muted opacity-25 mb-3"></i>
        <p class="text-muted">No pipelines created yet.</p>
        <a href="/crm/pipelines/create" class="btn btn-primary btn-sm">Create your first pipeline</a>
      </div>
    </div>
  <% } else { %>
    <% pipelines.forEach(pipeline => { %>
      <div class="col-md-6 col-lg-4">
        <div class="tf-card h-100">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h5 class="tf-card-name mb-1"><%= pipeline.name %></h5>
              <p class="tf-card-meta mb-0"><%= pipeline.description || 'No description' %></p>
            </div>
            <div class="tf-badge <%= pipeline.is_active ? 'pill-active' : 'pill-inactive' %>">
              <%= pipeline.is_active ? 'Active' : 'Inactive' %>
            </div>
          </div>
          
          <div class="pipeline-stages-preview mb-4">
            <label class="form-label small fw-bold text-uppercase text-muted mb-2">Stages</label>
            <div class="d-flex flex-wrap gap-2">
              <% if (pipeline.stages && pipeline.stages.length > 0) { %>
                <% pipeline.stages.sort((a,b) => a.order - b.order).forEach(stage => { %>
                  <span class="badge" style="background-color: <%= stage.color %>15; color: <%= stage.color %>; border: 1px solid <%= stage.color %>30; font-size: 0.75rem;">
                    <%= stage.name %>
                  </span>
                <% }) %>
              <% } else { %>
                <span class="text-muted small italic">No stages defined</span>
              <% } %>
            </div>
          </div>

          <div class="tf-card-actions mt-auto pt-3 border-top">
            <a href="/crm/pipelines/<%= pipeline.id %>/edit" class="btn btn-sm btn-light border flex-grow-1 fw-bold">
              <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <a href="/crm/form-builder?pipeline_id=<%= pipeline.id %>" class="btn btn-sm btn-light border flex-grow-1 fw-bold" title="Form Builder">
              <i class="bi bi-ui-checks me-1"></i> Form
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>

<script>
async function deletePipeline(id) {
  if (confirm('Are you sure you want to delete this pipeline? All related leads and fields will be affected.')) {
    try {
      const res = await fetch(`/crm/pipelines/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
      else alert('Error: ' + data.message);
    } catch (err) { alert('Network error'); }
  }
}
</script>
