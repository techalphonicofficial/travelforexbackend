<div class="tf-page-header">
  <div>
    <h1 class="tf-page-title">CRM Follow-ups</h1>
    <p class="tf-page-sub">Track your tasks and scheduled customer interactions</p>
  </div>
</div>

<div class="row g-4">
  <!-- Status Stats -->
  <div class="col-md-3">
    <div class="tf-stat-card shadow-sm border-0 mb-3" style="background: linear-gradient(135deg, #4f46e5, #818cf8); color: white;">
      <div class="tf-stat-icon"><i class="bi bi-calendar-check"></i></div>
      <div>
        <div class="tf-stat-num"><%= todayFollowUps.length %></div>
        <div class="tf-stat-lbl">Due Today</div>
      </div>
    </div>
    
    <div class="tf-stat-card shadow-sm border-0" style="background: #fff; color: #1e1e4a;">
      <div class="tf-stat-icon" style="background: rgba(79, 70, 229, 0.1); color: #4f46e5;"><i class="bi bi-clock-history"></i></div>
      <div>
        <div class="tf-stat-num text-primary"><%= followUps.filter(f => f.status === 'pending').length %></div>
        <div class="tf-stat-lbl">Total Pending</div>
      </div>
    </div>
  </div>

  <div class="col-md-9">
    <!-- Today's Follow-ups -->
    <div class="tf-form-card mb-4 border-start border-danger border-4">
      <div class="tf-form-header px-4 d-flex justify-content-between align-items-center">
        <span class="text-danger fw-800"><i class="bi bi-exclamation-circle-fill me-1"></i> Due Today</span>
      </div>
      <div class="tf-form-body p-0">
        <% if (todayFollowUps.length === 0) { %>
          <div class="text-center py-4 text-muted small">No follow-ups due today. You're all caught up!</div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table align-middle mb-0">
              <tbody class="border-top-0">
                <% todayFollowUps.forEach(fw => { %>
                  <tr>
                    <td class="ps-4" style="width: 50px;">
                      <div class="icon-sq-sm bg-danger text-white"><i class="bi <%= fw.follow_up_type === 'call' ? 'bi-telephone' : (fw.follow_up_type === 'email' ? 'bi-envelope' : 'bi-chat-dots') %>"></i></div>
                    </td>
                    <td>
                      <div class="fw-bold"><%= fw.lead ? fw.lead.name : 'Unknown Lead' %></div>
                      <div class="small text-muted"><%= fw.lead ? fw.lead.phone : '' %></div>
                    </td>
                    <td><span class="badge bg-light text-dark fw-bold"><%= fw.follow_up_time || 'Anytime' %></span></td>
                    <td class="small"><%= fw.notes %></td>
                    <td class="text-end pe-4">
                      <div class="d-flex justify-content-end gap-2">
                        <a href="/crm/leads/<%= fw.lead_id %>" class="btn btn-sm btn-light border px-3">View Lead</a>
                        <button class="btn btn-sm btn-success px-3" onclick="updateFollowUpStatus(<%= fw.id %>, 'done')">Complete</button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

    <!-- All Pending Follow-ups -->
    <div class="tf-form-card shadow-sm border-0">
      <div class="tf-form-header px-4">Remaining Activities</div>
      <div class="tf-form-body">
        <% if (followUps.filter(f => f.status === 'pending').length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-check2-all fs-1 text-muted opacity-25"></i>
            <p class="text-muted">No pending activities found.</p>
          </div>
        <% } else { %>
          <table class="tf-table">
            <thead>
              <tr>
                <th>Date / Time</th>
                <th>Lead</th>
                <th>Type</th>
                <th>Notes</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% followUps.filter(f => f.status === 'pending').forEach(fw => { %>
                <tr>
                  <td>
                    <div class="fw-bold"><%= new Date(fw.follow_up_date).toLocaleDateString() %></div>
                    <div class="small text-muted"><%= fw.follow_up_time || '' %></div>
                  </td>
                  <td>
                    <a href="/crm/leads/<%= fw.lead_id %>" class="text-decoration-none fw-bold text-dark"><%= fw.lead ? fw.lead.name : 'Unknown' %></a>
                  </td>
                  <td>
                    <span class="text-capitalize small fw-bold">
                      <i class="bi bi-<%= fw.follow_up_type === 'call' ? 'telephone' : (fw.follow_up_type === 'email' ? 'envelope' : 'chat-dots') %> me-1"></i>
                      <%= fw.follow_up_type %>
                    </span>
                  </td>
                  <td class="small opacity-75"><%= fw.notes %></td>
                  <td class="text-end">
                    <div class="d-flex justify-content-end gap-1">
                      <button class="btn-icon btn-icon-edit text-success" onclick="updateFollowUpStatus(<%= fw.id %>, 'done')" title="Done"><i class="bi bi-check-lg"></i></button>
                      <button class="btn-icon btn-icon-del" onclick="deleteFollowUp(<%= fw.id %>)"><i class="bi bi-trash3"></i></button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>
</div>

<style>
  .icon-sq-sm { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 0.9rem; }
  .btn-soft-danger { background: #fef2f2; color: #ef4444; border: 1px solid #fee2e2; }
  .btn-soft-danger:hover { background: #fee2e2; }
</style>

<script>
  async function updateFollowUpStatus(id, status) {
    try {
      const res = await fetch(`/crm/follow-ups/${id}/status`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status })
      });
      const data = await res.json();
      if (data.success) location.reload();
    } catch (err) { alert('Network error'); }
  }

  async function deleteFollowUp(id) {
    if (confirm('Delete this follow-up?')) {
      const res = await fetch(`/crm/follow-ups/${id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.success) location.reload();
    }
  }
</script>
